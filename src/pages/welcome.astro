---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { ensureCommunitySchema } from '../lib/community-schema';

const db = getDB();
let user: any = null;
const cookie = Astro.cookies.get('dsn_user')?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

let intros: any[] = [];
let myIntro: any = null;
if (db) {
  await ensureCommunitySchema(db);
  const r = await db.prepare('SELECT * FROM member_intros ORDER BY id DESC LIMIT 60').all();
  intros = (r.results || []) as any[];
  if (user?.email) {
    myIntro = intros.find((i: any) => (i.member_email || '').toLowerCase() === user.email.toLowerCase());
  }
}

function timeAgo(iso: string): string {
  if (!iso) return '';
  const ms = Date.now() - new Date((iso || '').includes('Z') ? iso : iso + 'Z').getTime();
  if (Number.isNaN(ms) || ms < 0) return '';
  const s = Math.floor(ms / 1000);
  if (s < 60) return 'just now';
  const m = Math.floor(s / 60);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  const d = Math.floor(h / 24);
  return d < 30 ? `${d}d ago` : new Date(iso).toLocaleDateString();
}
---
<Base title="👋 New here" description="Quick introductions from new Denver Social members.">
<div class="wel-wrap">
  <header class="wel-head">
    <div class="wel-emoji">👋</div>
    <h1>New here</h1>
    <p>Quick hellos from people who just joined. Drop your own to say hi.</p>
  </header>

  {user ? (
    myIntro ? (
      <div class="wel-yours">
        <span class="wel-yours-tag">Your intro</span>
        <p>"{myIntro.body}"</p>
        <button class="wel-edit-btn" id="wel-edit">Edit</button>
      </div>
    ) : (
      <form id="wel-form" class="wel-composer">
        <label class="wel-label">Say hi 👋</label>
        <textarea name="body" rows={3} maxlength="500" placeholder="Hey, I'm Sarah. New to Denver from PDX, hike a lot, looking for board game friends." class="wel-input" required></textarea>
        <div class="wel-foot">
          <span class="wel-hint">Anyone signed in can see this. Keep it brief.</span>
          <button type="submit" class="wel-post-btn">Post intro</button>
        </div>
      </form>
    )
  ) : (
    <div class="wel-signed-out">
      <a href="/login?next=/welcome" class="btn-cta">Sign in to drop a hi</a>
    </div>
  )}

  {intros.length === 0 ? (
    <div class="wel-empty">Nobody's introduced themselves yet. Be first?</div>
  ) : (
    <div class="wel-feed">
      {intros.map((i: any) => {
        const isMine = user?.email && (i.member_email || '').toLowerCase() === user.email.toLowerCase();
        const initial = (i.member_name || '?')[0]?.toUpperCase();
        return (
          <article class="wel-card">
            <div class="wel-avatar">{initial}</div>
            <div class="wel-body">
              <div class="wel-meta">
                <strong>{i.member_name || 'Member'}</strong>
                {i.neighborhood && <span class="wel-loc">📍 {i.neighborhood}</span>}
                <span class="wel-time">{timeAgo(i.created_at)}</span>
              </div>
              <p>{i.body}</p>
              {isMine && <button class="wel-mod-btn" data-delete-intro={i.id}>×</button>}
            </div>
          </article>
        );
      })}
    </div>
  )}
</div>

<style>
  .wel-wrap { max-width: 680px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .wel-head { text-align: center; margin-bottom: 28px; }
  .wel-emoji { font-size: 52px; margin-bottom: 10px; }
  .wel-head h1 { font-family: var(--font-display); font-size: clamp(28px, 5vw, 38px); font-weight: 900; letter-spacing: -0.025em; }
  .wel-head p { font-size: 15px; color: var(--text-sec); margin-top: 6px; }

  .wel-composer, .wel-yours, .wel-signed-out {
    background: var(--bg); border: 1px solid var(--border); border-radius: 16px;
    padding: 20px; margin-bottom: 24px;
  }
  .wel-yours { background: linear-gradient(160deg, var(--accent-dim), transparent); border-color: var(--accent); }
  .wel-yours-tag { font-size: 11px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.06em; display: block; margin-bottom: 6px; }
  .wel-yours p { font-size: 15px; line-height: 1.55; font-style: italic; color: var(--text); }
  .wel-edit-btn { background: none; border: none; color: var(--text-sec); font-size: 13px; cursor: pointer; margin-top: 8px; font-weight: 600; padding: 0; }
  .wel-edit-btn:hover { color: var(--text); }
  .wel-signed-out { text-align: center; }

  .wel-label { display: block; font-family: var(--font-display); font-size: 12px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .wel-input {
    width: 100%; padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;
    font-size: 15px; font-family: var(--font); color: var(--text); background: var(--bg);
    resize: vertical; line-height: 1.5;
  }
  .wel-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .wel-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; gap: 10px; flex-wrap: wrap; }
  .wel-hint { font-size: 12px; color: var(--text-faint); }
  .wel-post-btn { padding: 10px 18px; border-radius: 999px; border: none; background: var(--cta-bg); color: #fff; font-family: var(--font-display); font-weight: 700; font-size: 13px; cursor: pointer; }

  .wel-feed { display: flex; flex-direction: column; gap: 10px; }
  .wel-card {
    display: flex; gap: 12px; padding: 14px 16px;
    background: var(--bg); border: 1px solid var(--border); border-radius: 14px;
  }
  .wel-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, var(--sunset), var(--pink));
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 800; font-size: 16px; flex-shrink: 0;
  }
  .wel-body { flex: 1; min-width: 0; position: relative; }
  .wel-meta { display: flex; gap: 8px; align-items: baseline; margin-bottom: 4px; flex-wrap: wrap; }
  .wel-meta strong { font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--text); }
  .wel-loc { font-size: 12px; color: var(--text-sec); }
  .wel-time { font-size: 11px; color: var(--text-faint); }
  .wel-body p { font-size: 14px; line-height: 1.55; color: var(--text); white-space: pre-wrap; word-wrap: break-word; }
  .wel-mod-btn { position: absolute; top: 0; right: 0; background: none; border: none; color: var(--text-faint); cursor: pointer; font-size: 18px; line-height: 1; padding: 4px 8px; }
  .wel-mod-btn:hover { color: #DC2626; }

  .wel-empty { padding: 48px 20px; text-align: center; color: var(--text-faint); background: var(--surface); border: 1px dashed var(--border); border-radius: 14px; }
</style>

<script is:inline>
  const form = document.getElementById('wel-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const res = await fetch('/api/community', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'create_intro', body: fd.get('body') }),
      });
      const d = await res.json();
      if (d.ok) location.reload();
      else alert('Failed: ' + d.error);
    });
  }
  const editBtn = document.getElementById('wel-edit');
  editBtn?.addEventListener('click', async () => {
    if (!confirm('Replace your current intro?')) return;
    const text = prompt('New intro:');
    if (text == null || text.trim() === '') return;
    const res = await fetch('/api/community', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'create_intro', body: text }),
    });
    const d = await res.json();
    if (d.ok) location.reload();
    else alert('Failed: ' + d.error);
  });
  document.querySelectorAll('[data-delete-intro]').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete your intro?')) return;
      const id = parseInt(btn.getAttribute('data-delete-intro'));
      const res = await fetch('/api/community', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete_intro', id }),
      });
      const d = await res.json();
      if (d.ok) location.reload();
      else alert('Failed: ' + d.error);
    });
  });
</script>
</Base>
