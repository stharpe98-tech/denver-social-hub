---
import Base from '../../layouts/Base.astro';

// Mock — preview only. Real version reads from D1 profiles table.
const jimmy = {
  slug: 'jimmy',
  display_name: 'Jimmy Reyes',
  headline: 'Realtor — Denver, Wash Park & Cherry Creek',
  accent: '#7C3AED',
  photo: '👨🏽‍💼',
  bio: 'Born and raised in Denver. 8 years selling homes in the south-central neighborhoods. I host a monthly first-time-buyer meetup at Stem Ciders — open to anyone curious about the market.',
  offers: [
    { icon: '🏠', label: 'Free 30-min buyer consult' },
    { icon: '📊', label: 'Custom neighborhood reports' },
    { icon: '🍻', label: 'Monthly buyer meetups (free, open)' },
  ],
  links: [
    { label: 'Instagram', url: '#', icon: '📷' },
    { label: 'Website', url: '#', icon: '🌐' },
  ],
  contact_email: 'jimmy@example.com',
  contact_phone: '720-555-0192',
  groups: [
    { name: 'Wash Park Buyers Club', members: 47 },
    { name: 'First-Time Buyer Meetup', members: 112 },
  ],
  posts: [
    { kind: 'offer', title: 'Free homebuyer Q&A this Thursday 7pm', body: 'Stem Ciders, RiNo. No pitch — bring questions.', when: '2d ago' },
    { kind: 'offer', title: 'Looking for a contractor referral?', body: 'I keep a vetted list. Reach out.', when: '1w ago' },
  ],
};

const sarah = {
  slug: 'sarah',
  display_name: 'Sarah Kline',
  headline: 'Yoga teacher & dog walker — Highlands',
  accent: '#10B981',
  photo: '🧘🏻‍♀️',
  bio: 'Vinyasa & restorative yoga in living rooms and backyards across NW Denver. Also walk a handful of dogs Mon/Wed/Fri. Big into trail runs at Sloan\'s.',
  offers: [
    { icon: '🧘', label: 'In-home yoga (1-on-1 or small group)' },
    { icon: '🐕', label: 'Dog walks — Highlands & Sunnyside' },
    { icon: '🏃', label: 'Free Sunday morning trail group' },
  ],
  links: [
    { label: 'Instagram', url: '#', icon: '📷' },
  ],
  contact_email: 'sarah.kline@example.com',
  contact_phone: '',
  groups: [
    { name: 'NW Denver Trail Runners', members: 28 },
  ],
  posts: [
    { kind: 'offer', title: 'Trail run Sunday 8am — Sloan\'s Lake', body: 'Easy 4-miler, coffee after at Sloan\'s Tap.', when: '3d ago' },
  ],
};

function Profile(p: any) {
  return p;
}
---
<Base title="Personal pages — preview">
  <div class="wrap">
    <div class="banner">📦 PREVIEW — mock data. Showing two profiles + the claim flow + the editor.</div>

    <section>
      <h2 class="section-h">1. Jimmy's page <span class="muted">(/u/jimmy)</span></h2>
      <p class="section-sub">Realtor vibe — same template, his content & accent color.</p>

      {(() => { const u = jimmy; return (
      <div class="profile" style={`--profile-accent: ${u.accent}`}>
        <header class="prof-hero">
          <div class="prof-avatar">{u.photo}</div>
          <div class="prof-id">
            <h1 class="prof-name">{u.display_name}</h1>
            <p class="prof-headline">{u.headline}</p>
          </div>
        </header>
        <p class="prof-bio">{u.bio}</p>

        <div class="prof-offers">
          <h3 class="prof-h3">What I offer</h3>
          <ul>
            {u.offers.map((o: any) => <li><span>{o.icon}</span>{o.label}</li>)}
          </ul>
        </div>

        <div class="prof-links">
          {u.links.map((l: any) => <a href={l.url} class="prof-link">{l.icon} {l.label}</a>)}
        </div>

        <div class="prof-contact">
          <button class="prof-cta">📬 Get in touch with {u.display_name.split(' ')[0]}</button>
          <div class="prof-cta-hint">Email + phone revealed on click</div>
        </div>

        <div class="prof-groups">
          <h3 class="prof-h3">Jimmy's groups</h3>
          {u.groups.map((g: any) => (
            <a href="#" class="prof-group-row">
              <span class="prof-group-name">{g.name}</span>
              <span class="prof-group-meta">{g.members} members →</span>
            </a>
          ))}
        </div>

        <div class="prof-posts">
          <h3 class="prof-h3">Recent posts</h3>
          {u.posts.map((p: any) => (
            <a href="#" class="prof-post">
              <div class="prof-post-top">
                <span class={`chip chip-${p.kind}`}>{p.kind === 'offer' ? '🤝 Offer' : '🙏 Need'}</span>
                <span class="prof-post-when">{p.when}</span>
              </div>
              <div class="prof-post-title">{p.title}</div>
              <div class="prof-post-body">{p.body}</div>
            </a>
          ))}
        </div>

        <footer class="prof-foot">
          <a href="#" class="prof-share">🔗 Share this page</a>
          <a href="#" class="prof-report">🚩 Report</a>
        </footer>
      </div>
      ); })()}
    </section>

    <section>
      <h2 class="section-h">2. Sarah's page <span class="muted">(/u/sarah)</span></h2>
      <p class="section-sub">Same template, completely different person. Green accent, different content, no groups list because she only has one. Phone hidden because she didn't add one.</p>

      {(() => { const u = sarah; return (
      <div class="profile" style={`--profile-accent: ${u.accent}`}>
        <header class="prof-hero">
          <div class="prof-avatar">{u.photo}</div>
          <div class="prof-id">
            <h1 class="prof-name">{u.display_name}</h1>
            <p class="prof-headline">{u.headline}</p>
          </div>
        </header>
        <p class="prof-bio">{u.bio}</p>

        <div class="prof-offers">
          <h3 class="prof-h3">What I offer</h3>
          <ul>
            {u.offers.map((o: any) => <li><span>{o.icon}</span>{o.label}</li>)}
          </ul>
        </div>

        <div class="prof-links">
          {u.links.map((l: any) => <a href={l.url} class="prof-link">{l.icon} {l.label}</a>)}
        </div>

        <div class="prof-contact">
          <button class="prof-cta">📬 Get in touch with Sarah</button>
          <div class="prof-cta-hint">Email revealed on click (no phone shared)</div>
        </div>

        <div class="prof-groups">
          <h3 class="prof-h3">Sarah's groups</h3>
          {u.groups.map((g: any) => (
            <a href="#" class="prof-group-row">
              <span class="prof-group-name">{g.name}</span>
              <span class="prof-group-meta">{g.members} members →</span>
            </a>
          ))}
        </div>

        <div class="prof-posts">
          <h3 class="prof-h3">Recent posts</h3>
          {u.posts.map((p: any) => (
            <a href="#" class="prof-post">
              <div class="prof-post-top">
                <span class={`chip chip-${p.kind}`}>{p.kind === 'offer' ? '🤝 Offer' : '🙏 Need'}</span>
                <span class="prof-post-when">{p.when}</span>
              </div>
              <div class="prof-post-title">{p.title}</div>
              <div class="prof-post-body">{p.body}</div>
            </a>
          ))}
        </div>

        <footer class="prof-foot">
          <a href="#" class="prof-share">🔗 Share this page</a>
          <a href="#" class="prof-report">🚩 Report</a>
        </footer>
      </div>
      ); })()}
    </section>

    <section>
      <h2 class="section-h">3. The claim flow <span class="muted">(/u/new)</span></h2>
      <p class="section-sub">Open self-serve. Pick a slug, enter your email, get a 6-digit code, and you're in the editor for that page.</p>
      <div class="claim-box">
        <h3 class="claim-h">Get your own page on Denver Social</h3>
        <p class="claim-sub">Free. Takes 2 minutes.</p>
        <div class="claim-field">
          <label>Pick your URL</label>
          <div class="slug-row"><span class="slug-prefix">denversocialhub.com/u/</span><input type="text" placeholder="jimmy" value="jimmy"/></div>
          <div class="slug-check">✓ available</div>
        </div>
        <div class="claim-field">
          <label>Your email <span class="opt">(we'll send a code, won't show publicly)</span></label>
          <input type="email" placeholder="you@example.com"/>
        </div>
        <button class="claim-cta">Send me a code →</button>
        <div class="claim-foot">By claiming a page you agree to keep it real — no spam, no impersonation. Page reviewed if reported.</div>
      </div>
    </section>

    <section>
      <h2 class="section-h">4. The editor <span class="muted">(/u/jimmy/edit)</span></h2>
      <p class="section-sub">After verifying their email, Jimmy lands here. Same fields as the public page — inline edits, autosaves.</p>
      <div class="editor">
        <div class="editor-toolbar">
          <span class="editor-status">● Saved · 2s ago</span>
          <a href="#" class="editor-preview">👁 Preview public page</a>
          <a href="#" class="editor-out">Sign out of editor</a>
        </div>
        <div class="editor-field"><label>Display name</label><input type="text" value="Jimmy Reyes"/></div>
        <div class="editor-field"><label>Headline</label><input type="text" value="Realtor — Denver, Wash Park & Cherry Creek"/></div>
        <div class="editor-field"><label>Bio</label><textarea rows="3">Born and raised in Denver. 8 years selling homes…</textarea></div>
        <div class="editor-field"><label>Accent color</label>
          <div class="color-row">
            <span class="swatch swatch-purple swatch-active"></span>
            <span class="swatch swatch-blue"></span>
            <span class="swatch swatch-green"></span>
            <span class="swatch swatch-orange"></span>
            <span class="swatch swatch-pink"></span>
          </div>
        </div>
        <div class="editor-field"><label>Photo / avatar emoji</label><input type="text" value="👨🏽‍💼"/></div>
        <div class="editor-field two">
          <div><label>Email shown after Reveal</label><input value="jimmy@example.com"/></div>
          <div><label>Phone shown after Reveal</label><input value="720-555-0192"/></div>
        </div>
        <div class="editor-section">
          <label>What you offer</label>
          <div class="editor-offer"><input value="🏠 Free 30-min buyer consult"/><button class="x">×</button></div>
          <div class="editor-offer"><input value="📊 Custom neighborhood reports"/><button class="x">×</button></div>
          <button class="add">+ Add an offer</button>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-h">5. Admin moderation queue <span class="muted">(/admin/pages)</span></h2>
      <p class="section-sub">You see every page, who claimed it, when, and any reports. One click to take a page offline.</p>
      <div class="mod-table">
        <div class="mod-row mod-head"><div>Slug</div><div>Name</div><div>Email</div><div>Reports</div><div>Action</div></div>
        <div class="mod-row"><div>/u/jimmy</div><div>Jimmy Reyes</div><div>jimmy@example.com</div><div>0</div><div><button class="mini">View</button><button class="mini mini-danger">Take offline</button></div></div>
        <div class="mod-row"><div>/u/sarah</div><div>Sarah Kline</div><div>sarah.kline@example.com</div><div>0</div><div><button class="mini">View</button><button class="mini mini-danger">Take offline</button></div></div>
        <div class="mod-row mod-flagged"><div>/u/cashapp4u</div><div>(no name)</div><div>spammer@example.com</div><div>3 🚩</div><div><button class="mini">View</button><button class="mini mini-danger">Take offline</button></div></div>
      </div>
    </section>
  </div>
</Base>

<style>
  .wrap { max-width: 760px; margin: 0 auto; padding: var(--space-5) var(--space-4) var(--space-8); }
  .banner { background: #FEF3C7; border: 1px solid #FCD34D; color: #92400E; padding: var(--space-2) var(--space-3); border-radius: 10px; font-size: 13px; margin-bottom: var(--space-5); text-align: center; }
  section { margin-bottom: var(--space-7); }
  .section-h { font-family: var(--font-display, sans-serif); font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 4px; }
  .section-h .muted { font-family: var(--mono, monospace); font-size: 13px; color: var(--text-faint); font-weight: 400; margin-left: 6px; }
  .section-sub { font-size: 14px; color: var(--text-sec); margin-bottom: var(--space-3); line-height: 1.5; }

  /* Profile */
  .profile { background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-lg, 20px); overflow: hidden; }
  .prof-hero { display: flex; gap: 16px; align-items: center; padding: var(--space-4) var(--space-5); background: color-mix(in srgb, var(--profile-accent) 8%, #fff); border-bottom: 1px solid var(--border); }
  .prof-avatar { width: 72px; height: 72px; border-radius: 50%; background: #fff; border: 3px solid var(--profile-accent); display: flex; align-items: center; justify-content: center; font-size: 36px; flex-shrink: 0; }
  .prof-name { font-family: var(--font-display, sans-serif); font-size: 24px; font-weight: 800; color: var(--text); margin-bottom: 2px; line-height: 1.1; }
  .prof-headline { font-size: 14px; color: var(--text-sec); }
  .prof-bio { padding: var(--space-3) var(--space-5); font-size: 15px; color: var(--text); line-height: 1.55; }
  .prof-h3 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-faint); margin-bottom: 8px; }
  .prof-offers { padding: var(--space-3) var(--space-5); border-top: 1px solid var(--border); }
  .prof-offers ul { list-style: none; padding: 0; margin: 0; }
  .prof-offers li { display: flex; gap: 10px; align-items: center; padding: 6px 0; font-size: 14px; color: var(--text); }
  .prof-offers li span { font-size: 18px; width: 24px; }
  .prof-links { padding: 0 var(--space-5) var(--space-3); display: flex; gap: 8px; flex-wrap: wrap; }
  .prof-link { padding: 6px 12px; border-radius: 999px; background: var(--surface, #F8F9FB); border: 1px solid var(--border); font-size: 13px; color: var(--text); text-decoration: none; }
  .prof-contact { padding: 0 var(--space-5) var(--space-3); }
  .prof-cta { width: 100%; padding: 13px; border-radius: 999px; border: none; background: var(--profile-accent); color: #fff; font-weight: 700; font-size: 15px; cursor: pointer; }
  .prof-cta-hint { font-size: 12px; color: var(--text-faint); text-align: center; margin-top: 6px; }
  .prof-groups, .prof-posts { padding: var(--space-3) var(--space-5); border-top: 1px solid var(--border); }
  .prof-group-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--surface, #F8F9FB); text-decoration: none; color: inherit; font-size: 14px; }
  .prof-group-name { font-weight: 600; color: var(--text); }
  .prof-group-meta { font-size: 12px; color: var(--text-faint); }
  .prof-post { display: block; padding: 10px 0; border-bottom: 1px solid var(--surface, #F8F9FB); text-decoration: none; color: inherit; }
  .prof-post-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .prof-post-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
  .prof-post-body { font-size: 13px; color: var(--text-sec); }
  .prof-post-when { font-size: 11px; color: var(--text-faint); }
  .prof-foot { padding: var(--space-3) var(--space-5); border-top: 1px solid var(--border); display: flex; justify-content: space-between; font-size: 12px; }
  .prof-share { color: var(--text-sec); text-decoration: none; }
  .prof-report { color: var(--text-faint); text-decoration: none; }
  .chip { display: inline-flex; padding: 2px 8px; border-radius: 999px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .chip-offer { background: #F0FDF4; color: #047857; }
  .chip-need { background: #EEF2FF; color: #4338CA; }

  /* Claim flow */
  .claim-box { background: var(--surface, #F8F9FB); border: 1.5px solid var(--border); border-radius: var(--radius-lg, 20px); padding: var(--space-5); max-width: 480px; margin: 0 auto; }
  .claim-h { font-family: var(--font-display, sans-serif); font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 4px; }
  .claim-sub { text-align: center; font-size: 14px; color: var(--text-sec); margin-bottom: var(--space-4); }
  .claim-field { margin-bottom: var(--space-3); }
  .claim-field label { display: block; font-size: 12px; font-weight: 600; color: var(--text-sec); margin-bottom: 6px; }
  .claim-field label .opt { font-weight: 400; color: var(--text-faint); }
  .slug-row { display: flex; align-items: stretch; border: 1.5px solid var(--border); border-radius: 10px; overflow: hidden; background: #fff; }
  .slug-prefix { padding: 10px 12px; background: var(--surface, #F8F9FB); color: var(--text-faint); font-size: 13px; font-family: monospace; border-right: 1px solid var(--border); }
  .slug-row input { flex: 1; border: none; padding: 10px 12px; font-size: 14px; outline: none; font-family: monospace; }
  .claim-field input[type=email] { width: 100%; padding: 10px 12px; border-radius: 10px; border: 1.5px solid var(--border); font-size: 14px; background: #fff; }
  .slug-check { font-size: 12px; color: #047857; margin-top: 6px; }
  .claim-cta { width: 100%; padding: 14px; border-radius: 999px; border: none; background: var(--accent); color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: var(--space-2); }
  .claim-foot { font-size: 11px; color: var(--text-faint); text-align: center; margin-top: var(--space-3); line-height: 1.5; }

  /* Editor */
  .editor { background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-lg, 20px); padding: var(--space-4); }
  .editor-toolbar { display: flex; gap: 16px; padding-bottom: var(--space-3); margin-bottom: var(--space-3); border-bottom: 1px solid var(--border); align-items: center; font-size: 12px; }
  .editor-status { color: #047857; }
  .editor-preview { margin-left: auto; color: var(--accent); text-decoration: none; }
  .editor-out { color: var(--text-faint); text-decoration: none; }
  .editor-field { margin-bottom: var(--space-3); }
  .editor-field.two { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
  .editor-field label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-faint); margin-bottom: 4px; }
  .editor-field input, .editor-field textarea { width: 100%; padding: 9px 12px; border-radius: 10px; border: 1.5px solid var(--border); font-size: 14px; background: var(--surface, #F8F9FB); font-family: inherit; }
  .color-row { display: flex; gap: 8px; }
  .swatch { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 3px solid transparent; }
  .swatch-purple { background: #7C3AED; } .swatch-blue { background: #3B82F6; } .swatch-green { background: #10B981; } .swatch-orange { background: #F59E0B; } .swatch-pink { background: #EC4899; }
  .swatch-active { border-color: var(--text); }
  .editor-section { margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px dashed var(--border); }
  .editor-section > label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-faint); margin-bottom: 8px; }
  .editor-offer { display: flex; gap: 8px; margin-bottom: 6px; }
  .editor-offer input { flex: 1; padding: 8px 12px; border-radius: 8px; border: 1.5px solid var(--border); font-size: 14px; }
  .x { width: 32px; border-radius: 8px; border: 1px solid var(--border); background: #fff; cursor: pointer; color: var(--text-faint); }
  .add { background: none; border: 1px dashed var(--border); padding: 8px; width: 100%; border-radius: 8px; color: var(--text-sec); font-size: 13px; cursor: pointer; }

  /* Admin */
  .mod-table { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; font-size: 13px; }
  .mod-row { display: grid; grid-template-columns: 110px 1fr 1.3fr 80px 200px; gap: 12px; padding: 10px 14px; border-bottom: 1px solid var(--border); align-items: center; }
  .mod-row:last-child { border-bottom: none; }
  .mod-head { background: var(--surface, #F8F9FB); font-weight: 700; font-size: 11px; text-transform: uppercase; color: var(--text-faint); letter-spacing: 0.5px; }
  .mod-flagged { background: #FEF2F2; }
  .mini { padding: 4px 8px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg); font-size: 11px; cursor: pointer; margin-right: 4px; }
  .mini-danger { color: #DC2626; border-color: #FECACA; }

  @media (max-width: 600px) {
    .mod-row { grid-template-columns: 1fr 1fr; }
    .mod-row > div:nth-child(3), .mod-row > div:nth-child(5) { display: none; }
    .editor-field.two { grid-template-columns: 1fr; }
  }
</style>
