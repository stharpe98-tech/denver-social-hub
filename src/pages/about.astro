---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getContent } from '../lib/content';

const db = getDB();
let totalMembers = 0;
try {
  if (db) {
    const mc = await db.prepare("SELECT COUNT(*) as cnt FROM members").first();
    totalMembers = mc?.cnt || 0;
  }
} catch {}

const faqs = [
  { q: "Is this actually free?", a: "Yep. No fees, no premium tier, no upsell." },
  { q: "I don't know anyone — is that weird?", a: "Most people show up solo. Groups are capped at 6–12 so you actually meet everyone." },
  { q: "Is it safe? What about creeps?", a: "Locations stay hidden until you RSVP, every event has a host, and we remove anyone who makes others uncomfortable. More on our /help#safety page." },
  { q: "How much does an event cost?", a: "Some are free (hikes, park hangs, coffee). Dinners run $20–35 a head. Price is always shown upfront." },
  { q: "Can I post my own event?", a: "Yes — hit \"Plan an event\" from /events. You don't need permission to have a good idea." },
  { q: "What if I RSVP and can't make it?", a: "Just cancel so someone else can grab the spot. Life happens — don't ghost repeatedly." },
];
const content = await getContent();
---
<Base title="About">
<div class="ab">

  <!-- HERO -->
  <header class="ab-hero">
    <span class="ab-eyebrow">About Denver Social</span>
    <h1 set:html={content.about_title}></h1>
    <p class="ab-lede">{content.about_subtitle}</p>
  </header>

  <!-- STATS — inline, no card -->
  <div class="ab-stats">
    <div><strong>{totalMembers || '88'}+</strong><span>members</span></div>
    <div class="ab-stats-dot"></div>
    <div><strong>6–12</strong><span>per event</span></div>
    <div class="ab-stats-dot"></div>
    <div><strong>Free</strong><span>to join</span></div>
  </div>

  <!-- FOUNDER LETTER -->
  <section class="ab-card">
    <header class="ab-letter-head">
      <div class="ab-letter-avatar">S</div>
      <div>
        <strong>Seth</strong>
        <span>the guy who texts everyone "are you coming?"</span>
      </div>
    </header>
    <div class="ab-letter">
      <p>I moved to Denver and had zero friends here. Bars were too loud, meetup groups had 400 people standing around awkwardly, and Bumble BFF felt like a job interview. All I wanted was a few people to grab dinner with on a Tuesday.</p>
      <p>So I booked a table for 8 in RiNo and posted it. Strangers showed up. People kept asking "when's the next one?" — so we kept going. Bowling, hikes, pottery, game nights. There's 80+ of us now and it still feels small because every event is capped at 12.</p>
      <p>The only rules: don't be a creep, show up if you say you will, don't pitch crypto at dinner. That's it.</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section>
    <h2 class="ab-h2">It's not <em>complicated.</em></h2>
    <div class="ab-steps">
      <div class="ab-step">
        <div class="ab-step-num">1</div>
        <div>
          <strong>Make a profile</strong>
          <p>About 60 seconds. Sign in with Discord, tell us your neighborhood and what sounds fun. No credit card, no personality quiz.</p>
        </div>
      </div>
      <div class="ab-step">
        <div class="ab-step-num">2</div>
        <div>
          <strong>Find something that sounds fun</strong>
          <p>Pottery on Saturday, dinner in LoHi, bowling and cheap beer. Hit RSVP. Worst case: you eat good food with strangers.</p>
        </div>
      </div>
      <div class="ab-step">
        <div class="ab-step-num">3</div>
        <div>
          <strong>Actually show up</strong>
          <p>You walk in, there's 8 people at a table, and within 20 minutes you're laughing about something dumb. No icebreakers, no name tags.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <h2 class="ab-h2">Totally fair <em>questions.</em></h2>
    <div class="ab-faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CLOSER -->
  <section class="ab-closer">
    <span class="ab-closer-emoji">👋</span>
    <h2>Alright — you in?</h2>
    <p>The Discord is where everything happens: new events, random plans, voice hangs, people just being goofy between meetups. Come lurk, or say hi.</p>
    <div class="ab-closer-btns">
      <a href="https://discord.gg/S8SFNkdSgK" class="btn-cta" target="_blank" rel="noopener">Join the Discord →</a>
      <a href="/contact" class="btn-sec">Contact us</a>
    </div>
  </section>

</div>

<style>
  .ab { max-width: 700px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }

  /* Hero */
  .ab-hero { margin-bottom: 28px; }
  .ab-eyebrow {
    display: inline-block; font-family: var(--font-display);
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-dim);
    padding: 6px 14px; border-radius: 999px; margin-bottom: 16px;
  }
  .ab-hero h1 {
    font-family: var(--font-display); font-size: clamp(30px, 5vw, 42px);
    font-weight: 900; letter-spacing: -0.025em; line-height: 1.1;
    color: var(--text); margin-bottom: 14px;
  }
  .ab-hero h1 em { font-style: normal; color: var(--accent); }
  .ab-lede { font-size: 17px; color: var(--text-sec); line-height: 1.55; max-width: 540px; }

  /* Inline stats — no boxed pill, just clean numbers */
  .ab-stats {
    display: flex; align-items: center; gap: clamp(14px, 4vw, 28px);
    padding: 18px 0; margin-bottom: 28px;
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    flex-wrap: wrap; justify-content: center;
  }
  .ab-stats > div { text-align: center; }
  .ab-stats strong {
    display: block; font-family: var(--font-display);
    font-size: 26px; font-weight: 900; color: var(--accent); line-height: 1;
  }
  .ab-stats span { display: block; font-size: 12px; color: var(--text-sec); margin-top: 4px; text-transform: lowercase; }
  .ab-stats-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--border-hover); }

  /* Unified card */
  .ab-card {
    padding: 24px clamp(20px, 4vw, 28px); margin-bottom: 32px;
    background: var(--bg); border: 1px solid var(--border); border-radius: 18px;
  }

  /* Founder letter */
  .ab-letter-head { display: flex; align-items: center; gap: 14px; padding-bottom: 16px; margin-bottom: 16px; border-bottom: 1px solid var(--border); }
  .ab-letter-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: linear-gradient(135deg, var(--sunset), var(--pink));
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 17px; font-weight: 800; flex-shrink: 0;
  }
  .ab-letter-head strong { display: block; font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text); }
  .ab-letter-head span { font-size: 12px; color: var(--text-faint); }
  .ab-letter p { font-size: 15px; line-height: 1.65; color: var(--text-sec); margin-bottom: 10px; }
  .ab-letter p:last-child { margin-bottom: 0; }

  /* Section heading — same treatment for every section */
  .ab-h2 {
    font-family: var(--font-display); font-size: clamp(24px, 4vw, 32px);
    font-weight: 900; letter-spacing: -0.02em; color: var(--text);
    margin: 40px 0 20px;
  }
  .ab-h2 em { font-style: normal; color: var(--accent); }

  /* How it works */
  .ab-steps { display: flex; flex-direction: column; gap: 10px; }
  .ab-step {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 16px 18px; background: var(--bg);
    border: 1px solid var(--border); border-radius: 14px;
  }
  .ab-step-num {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    background: var(--accent-dim); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 14px; font-weight: 800;
  }
  .ab-step > div:last-child strong { display: block; font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
  .ab-step p { font-size: 14px; line-height: 1.55; color: var(--text-sec); margin: 0; }

  /* FAQ — same shell as steps */
  .ab-faq { display: flex; flex-direction: column; gap: 8px; }
  .ab-faq details {
    background: var(--bg); border: 1px solid var(--border); border-radius: 14px;
    overflow: hidden;
  }
  .ab-faq summary {
    padding: 14px 18px; font-family: var(--font-display); font-size: 14px;
    font-weight: 700; color: var(--text); cursor: pointer;
    list-style: none; display: flex; align-items: center; justify-content: space-between;
  }
  .ab-faq summary::-webkit-details-marker { display: none; }
  .ab-faq summary::after { content: '+'; color: var(--text-faint); font-size: 18px; flex-shrink: 0; }
  .ab-faq details[open] summary::after { content: '−'; color: var(--accent); }
  .ab-faq summary:hover { background: var(--surface); }
  .ab-faq p { padding: 0 18px 14px; font-size: 14px; line-height: 1.6; color: var(--text-sec); margin: 0; }

  /* Closer */
  .ab-closer {
    margin-top: 40px; padding: 36px clamp(20px, 4vw, 36px); border-radius: 20px;
    background: linear-gradient(135deg, var(--sunset-dim), var(--pink-dim));
    border: 1px solid rgba(249,115,22,0.18); text-align: center;
  }
  .ab-closer-emoji { font-size: 40px; display: block; margin-bottom: 8px; }
  .ab-closer h2 { font-family: var(--font-display); font-size: 26px; font-weight: 900; letter-spacing: -0.02em; color: var(--text); margin-bottom: 10px; }
  .ab-closer p { font-size: 15px; line-height: 1.55; color: var(--text-sec); max-width: 440px; margin: 0 auto 20px; }
  .ab-closer-btns { display: inline-flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
</style>
</Base>
