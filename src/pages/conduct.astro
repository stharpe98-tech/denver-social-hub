---
import Base from '../layouts/Base.astro';
---
<Base title="Code of Conduct">
  <div style="max-width:600px;margin:0 auto;padding:24px 20px">
    <h1 style="font-size:28px;color:#fff;margin-bottom:8px">Code of Conduct</h1>
    <p style="font-size:14px;color:#6b7a8e;margin-bottom:28px;line-height:1.7">
      Denver Social exists to help people connect. We take that seriously. Here's how we handle things when they go sideways.
    </p>

    <!-- Instant removal -->
    <div style="background:rgba(248,113,113,.06);border:1px solid rgba(248,113,113,.2);border-radius:16px;padding:20px 24px;margin-bottom:16px">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
        <span style="font-size:20px">🚫</span>
        <h3 style="font-size:16px;color:#f87171;font-weight:700">Instant removal — no warning</h3>
      </div>
      <p style="font-size:13px;color:#6b7a8e;margin-bottom:10px">These are zero-tolerance. No second chances, no exceptions.</p>
      <div style="display:flex;flex-direction:column;gap:8px">
        {[
          "Sexual harassment or assault of any kind",
          "Threatening or intimidating behavior",
          "Sharing someone's private location outside the group",
          "Showing up clearly intoxicated and causing problems",
          "Any behavior that makes someone feel unsafe",
        ].map(item => (
          <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:#9ca3af">
            <span style="color:#f87171;flex-shrink:0;margin-top:1px">✕</span>
            {item}
          </div>
        ))}
      </div>
    </div>

    <!-- Warning first -->
    <div style="background:rgba(251,191,36,.06);border:1px solid rgba(251,191,36,.2);border-radius:16px;padding:20px 24px;margin-bottom:16px">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
        <span style="font-size:20px">⚠️</span>
        <h3 style="font-size:16px;color:#fbbf24;font-weight:700">Warning first, then removal</h3>
      </div>
      <p style="font-size:13px;color:#6b7a8e;margin-bottom:10px">You'll get a heads up. Keep it up and you're out.</p>
      <div style="display:flex;flex-direction:column;gap:8px">
        {[
          "No-showing 3+ times without notice — 4th strike is removal",
          "Soliciting, MLM pitches, or using events to sell things",
          "Being consistently rude or dismissive to members",
          "Repeatedly showing up late without a heads up",
        ].map(item => (
          <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:#9ca3af">
            <span style="color:#fbbf24;flex-shrink:0;margin-top:1px">!</span>
            {item}
          </div>
        ))}
      </div>
    </div>

    <!-- Gentle reminder -->
    <div style="background:rgba(96,165,250,.06);border:1px solid rgba(96,165,250,.2);border-radius:16px;padding:20px 24px;margin-bottom:28px">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
        <span style="font-size:20px">💬</span>
        <h3 style="font-size:16px;color:#60a5fa;font-weight:700">Just a friendly reminder</h3>
      </div>
      <p style="font-size:13px;color:#6b7a8e;margin-bottom:10px">Not a violation — we get it, life happens.</p>
      <div style="display:flex;flex-direction:column;gap:8px">
        {[
          "First no-show ever — things come up",
          "Running a little late once in a while",
          "Being a little awkward at first — we all are",
        ].map(item => (
          <div style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:#9ca3af">
            <span style="color:#60a5fa;flex-shrink:0;margin-top:1px">→</span>
            {item}
          </div>
        ))}
      </div>
    </div>

    <!-- The basics -->
    <div class="card" style="margin-bottom:16px">
      <h3 style="font-size:16px;color:#fff;margin-bottom:14px">The basics</h3>
      <div style="display:flex;flex-direction:column;gap:10px;font-size:13px;color:#6b7a8e;line-height:1.7">
        <p><b style="color:#e8ecf4">Be respectful.</b> Treat everyone the way you'd want to be treated at a friend's dinner table.</p>
        <p><b style="color:#e8ecf4">Keep locations private.</b> Addresses are only shared with RSVPed members. Don't post them publicly.</p>
        <p><b style="color:#e8ecf4">No soliciting.</b> This isn't a networking event or MLM opportunity.</p>
      </div>
    </div>

    <!-- Reporting -->
    <div class="card">
      <h3 style="font-size:16px;color:#fff;margin-bottom:10px">Reporting something</h3>
      <p style="font-size:13px;color:#6b7a8e;line-height:1.7;margin-bottom:14px">
        If something happens — or you're not sure if it crosses a line — reach out. All reports are handled privately and taken seriously.
      </p>
      <a href="https://discord.gg/S8SFNkdSgK" style="display:inline-block;padding:10px 20px;background:#5865F2;color:#fff;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;margin-right:10px">Message Seth on Discord</a>
      <a href="mailto:stharpe98@gmail.com" style="display:inline-block;padding:10px 20px;background:rgba(255,255,255,.06);color:#e8ecf4;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,.08)">Email Seth</a>
    </div>
  </div>
</Base>
