---
import { getDB } from '../../../lib/db';
import { requireApprovedOrg } from '../../../lib/admin-auth';
const gate = await requireApprovedOrg(Astro);
if (gate instanceof Response) return gate;
const db = getDB();
let pending: any[] = [];
let approved: any[] = [];
let webhookUrl = '';
try {
  if (db) {
    const all = await db.prepare(`SELECT p.*, COUNT(DISTINCT r.id) as signups FROM potlucks p LEFT JOIN potluck_rsvp r ON r.potluck_id=p.id GROUP BY p.id ORDER BY p.id DESC`).all();
    const rows = all?.results ?? [];
    pending = rows.filter((p:any) => p.status === 'pending');
    approved = rows.filter((p:any) => p.status !== 'pending');
    const cfg = await db.prepare(`SELECT value FROM config WHERE key='webhook_url'`).first() as any;
    webhookUrl = cfg?.value ?? '';
  }
} catch(e) {}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Potluck Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #f7f5f2; color: #1c1917; font-family: 'DM Sans', sans-serif; min-height: 100vh; }
    body { padding-bottom: 40px; -webkit-overflow-scrolling: touch; }
    .mh { background: #fff8f0; border-bottom: 1px solid #e4ddd4; padding: 28px 20px; }
    .mh-in { max-width: 700px; margin: 0 auto; }
    .mh-back { color: #8a7a70; font-size: 13px; text-decoration: none; margin-bottom: 10px; display: inline-flex; align-items: center; gap: 4px; }
    .mh h1 { font-family: 'Playfair Display', serif; font-size: clamp(20px,5vw,28px); color: #1c1917; }
    .mp { max-width: 700px; margin: 0 auto; padding: 20px 16px; }
    .ms { margin-bottom: 28px; }
    .ms-label { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #8a7a70; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #ffffff; }
    .settings-card { background: #ffffff; border: 1px solid #e4ddd4; border-radius: 12px; padding: 18px; }
    .settings-row { display: flex; gap: 10px; }
    .settings-row input { flex: 1; padding: 11px 13px; background: #f7f5f2; border: 1.5px solid #e4ddd4; border-radius: 9px; color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; min-width: 0; }
    .settings-row input:focus { border-color: #f77f00; }
    .settings-row input::placeholder { color: #a09890; }
    .settings-hint { font-size: 12px; color: #a09890; margin-top: 8px; line-height: 1.6; }
    .pending-card { background: #ffffff; border: 1px solid #fcd5a0; border-radius: 12px; padding: 16px; margin-bottom: 10px; }
    .pending-title { font-family: 'Playfair Display', serif; font-size: 18px; color: #1c1917; margin-bottom: 4px; }
    .pending-meta { font-size: 13px; color: #8a7a70; margin-bottom: 14px; line-height: 1.7; }
    .pending-actions { display: flex; gap: 8px; }
    .btn-approve { background: linear-gradient(135deg,#065f46,#16a34a); color: #1c1917; border: none; padding: 10px 20px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; flex: 1; }
    .btn-reject { background: #1a0000; border: 1px solid #7f1d1d; color: #f87171; padding: 10px 20px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 14px; cursor: pointer; flex: 1; }
    .approved-card { background: #ffffff; border: 1px solid #e4ddd4; border-radius: 10px; padding: 14px 16px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; text-decoration: none; gap: 12px; -webkit-tap-highlight-color: transparent; }
    .approved-card:active { border-color: #f77f00; }
    .approved-title { font-size: 15px; color: #1c1917; font-weight: 500; }
    .approved-meta { font-size: 12px; color: #a09890; margin-top: 2px; }
    .approved-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .approved-signups { font-size: 12px; color: #8a7a70; }
    .abadge { padding: 3px 10px; border-radius: 100px; font-size: 11px; font-weight: 600; }
    .ab-up { background: rgba(247,127,0,0.15); border: 1px solid rgba(247,127,0,0.3); color: #92400e; }
    .ab-past { background: #1a1a1a; border: 1px solid #2a2a2a; color: #a09890; }
    .create-btn { background: linear-gradient(135deg,#c2410c,#f77f00); color: #1c1917; border: none; padding: 12px 24px; border-radius: 10px; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600; cursor: pointer; width: 100%; margin-bottom: 12px; }
    .create-form { background: #ffffff; border: 1px solid #e4ddd4; border-radius: 12px; padding: 18px; display: none; }
    .cf-field { margin-bottom: 12px; }
    .cf-field label { display: block; font-size: 11px; color: #8a7a70; margin-bottom: 5px; font-weight: 600; text-transform: uppercase; }
    .cf-input { width: 100%; padding: 11px 13px; background: #f7f5f2; border: 1.5px solid #e4ddd4; border-radius: 9px; color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; -webkit-appearance: none; }
    .cf-input:focus { border-color: #f77f00; }
    .cf-input::placeholder { color: #a09890; }
    .cf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media(max-width:400px) { .cf-grid { grid-template-columns: 1fr; } }
    .save-btn { background: linear-gradient(135deg,#c2410c,#f77f00); color: #1c1917; border: none; padding: 12px 24px; border-radius: 9px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; margin-top: 4px; }
    .empty { text-align: center; padding: 28px; color: #a09890; font-style: italic; font-size: 13px; }
    .toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #0d2e1a; border: 1px solid #166534; color: #4ade80; padding: 10px 20px; border-radius: 8px; font-size: 13px; display: none; z-index: 999; white-space: nowrap; }
  </style>
</head>
<body>
  <div class="mh">
    <div class="mh-in">
      <a href="/potlucks" class="mh-back">← Potlucks</a>
      <h1>⚙ Potluck Admin</h1>
    </div>
  </div>

  <div class="mp">
    <div class="ms">
      <div class="ms-label">⚡ Zapier Webhook</div>
      <div class="settings-card">
        <div class="settings-row">
          <input type="text" id="webhook-input" value={webhookUrl} placeholder="https://hooks.zapier.com/hooks/catch/…"/>
          <button class="save-btn" id="save-webhook" style="padding:11px 18px;font-size:14px">Save</button>
        </div>
        <div class="settings-hint">Every sign-up fires to this URL → Google Sheets. In Zapier: Webhooks (Catch Hook) → Google Sheets (Create Row).</div>
      </div>
    </div>

    <div class="ms">
      <div class="ms-label">📧 Email Confirmations (Resend)</div>
      <div class="settings-card">
        <div class="cf-field" style="margin-bottom:10px"><label>Resend API Key</label><input type="text" id="resend-key" class="cf-input" placeholder="re_xxxxxxxxxxxxxxx" value=""/></div>
        <div class="cf-field" style="margin-bottom:10px"><label>Your Site URL</label><input type="text" id="site-url" class="cf-input" placeholder="https://denversocialhub.com" value=""/></div>
        <div class="cf-field" style="margin-bottom:12px"><label>From Email</label><input type="text" id="from-email" class="cf-input" placeholder="Denver Social &lt;noreply@denversocialhub.com&gt;" value=""/></div>
        <button class="save-btn" id="save-email-cfg">Save</button>
        <div class="settings-hint" style="margin-top:8px">Get a free API key at resend.com. Sends confirmation + reminder emails automatically when people sign up.</div>
      </div>
    </div>

    <div class="ms">
      <div class="ms-label">📞 Contact & Payments</div>
      <div class="settings-card">
        <div class="cf-field" style="margin-bottom:10px"><label>Organizer Email (gets notified per sign-up)</label><input type="text" id="cfg-organizer-email" class="cf-input" placeholder="you@example.com"/></div>
        <div class="cf-field" style="margin-bottom:10px"><label>Contact Phone (shown after sign-up)</label><input type="text" id="cfg-contact-phone" class="cf-input" placeholder="(720) 555-1234"/></div>
        <div class="cf-field" style="margin-bottom:10px"><label>Discord Handle</label><input type="text" id="cfg-contact-discord" class="cf-input" placeholder="@yourhandle"/></div>
        <div class="cf-field" style="margin-bottom:10px"><label>Discord Invite URL</label><input type="text" id="cfg-contact-discord-url" class="cf-input" placeholder="https://discord.gg/…"/></div>
        <div class="cf-field" style="margin-bottom:10px"><label>Venmo Handle</label><input type="text" id="cfg-venmo" class="cf-input" placeholder="@yourvenmo"/></div>
        <div class="cf-field" style="margin-bottom:10px"><label>Stripe Payment Link (optional)</label><input type="text" id="cfg-stripe" class="cf-input" placeholder="https://buy.stripe.com/…"/></div>
        <div class="cf-field" style="margin-bottom:12px"><label>Cash App Handle (optional)</label><input type="text" id="cfg-cashapp" class="cf-input" placeholder="$yourcashtag"/></div>
        <button class="save-btn" id="save-contact-cfg">Save</button>
        <div class="settings-hint" style="margin-top:8px">Phone, Discord, Venmo, etc. show up on the post-signup confirmation card — never in the public HTML.</div>
      </div>
    </div>

    <div class="ms">
      <div class="ms-label">🛡 Bot Protection (Cloudflare Turnstile)</div>
      <div class="settings-card">
        <div class="cf-field" style="margin-bottom:10px"><label>Turnstile Secret Key</label><input type="text" id="cfg-turnstile-secret" class="cf-input" placeholder="0x4AAAAAAA…"/></div>
        <button class="save-btn" id="save-turnstile-cfg">Save</button>
        <div class="settings-hint" style="margin-top:8px">Get this from dash.cloudflare.com → Turnstile. The site key is already wired in code.</div>
      </div>
    </div>

    <div class="ms">
      <div class="ms-label">⏳ Pending ({pending.length})</div>
      {pending.length === 0
        ? <div class="empty">No pending submissions</div>
        : pending.map((p:any) => (
          <div class="pending-card">
            <div class="pending-title">{p.title}</div>
            <div class="pending-meta">
              {p.date_label && <span>📅 {p.date_label}{p.time_label ? ` · ${p.time_label}` : ''}<br/></span>}
              {p.location && <span>📍 {p.location}{p.location_detail ? ` · ${p.location_detail}` : ''}<br/></span>}
              {p.description && <span style="font-style:italic">{p.description}</span>}
            </div>
            <div class="pending-actions">
              <button class="btn-approve" data-id={p.id}>✓ Approve</button>
              <button class="btn-reject" data-id={p.id}>✕ Reject</button>
            </div>
          </div>
        ))
      }
    </div>

    <div class="ms">
      <div class="ms-label">➕ Create New</div>
      <button class="create-btn" id="toggle-create">+ New Potluck</button>
      <div class="create-form" id="create-form">
        <div class="cf-field"><label>Title *</label><input type="text" id="c-title" class="cf-input" placeholder="Summer Kickoff Potluck"/></div>
        <div class="cf-field"><label>Cover Photo URL <span style="font-weight:400;color:#a09890">(optional — paste any image link)</span></label><input type="text" id="c-cover" class="cf-input" placeholder="https://images.unsplash.com/…"/></div>
        <div class="cf-field"><label>Description</label><input type="text" id="c-desc" class="cf-input" placeholder="What's the vibe?"/></div>
        <div class="cf-grid">
          <div class="cf-field"><label>Date</label><input type="text" id="c-date" class="cf-input" placeholder="May 30th"/></div>
          <div class="cf-field"><label>Event Date (for reminders)</label><input type="date" id="c-event-date" class="cf-input"/></div>
          <div class="cf-field"><label>Time</label><input type="text" id="c-time" class="cf-input" placeholder="12pm–4pm"/></div>
          <div class="cf-field"><label>Location</label><input type="text" id="c-loc" class="cf-input" placeholder="Cheeseman Park"/></div>
          <div class="cf-field"><label>Detail</label><input type="text" id="c-locdetail" class="cf-input" placeholder="West side"/></div>
        </div>
        <div class="cf-field" style="margin-bottom:12px">
          <label>Template</label>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button type="button" class="tmpl-btn active" data-t="warm" style="padding:8px 14px;border-radius:8px;border:2px solid #f77f00;background:rgba(247,127,0,0.1);color:#c2410c;font-family:inherit;font-size:13px;cursor:pointer">🌞 Warm</button>
            <button type="button" class="tmpl-btn" data-t="dark" style="padding:8px 14px;border-radius:8px;border:2px solid #e4ddd4;background:#fff;color:#57524c;font-family:inherit;font-size:13px;cursor:pointer">🌙 Dark</button>
            <button type="button" class="tmpl-btn" data-t="clean" style="padding:8px 14px;border-radius:8px;border:2px solid #e4ddd4;background:#fff;color:#57524c;font-family:inherit;font-size:13px;cursor:pointer">✨ Clean</button>
            <button type="button" class="tmpl-btn" data-t="festive" style="padding:8px 14px;border-radius:8px;border:2px solid #e4ddd4;background:#fff;color:#57524c;font-family:inherit;font-size:13px;cursor:pointer">🎉 Festive</button>
          </div>
          <input type="hidden" id="c-template" value="warm"/>
        </div>
        <button class="save-btn" id="create-submit">Create & Publish</button>
      </div>
    </div>

    <div class="ms">
      <div class="ms-label">All Potlucks ({approved.length})</div>
      {approved.length === 0
        ? <div class="empty">None yet</div>
        : approved.map((p:any) => (
          <a href={`/potlucks/manage/${p.id}`} class="approved-card">
            <div>
              <div class="approved-title">{p.title}</div>
              <div class="approved-meta">{p.date_label} · {p.location}</div>
              {p.template && p.template !== 'warm' && <span style="font-size:11px;background:var(--accent-dim,rgba(247,127,0,0.1));color:#c2410c;padding:2px 8px;border-radius:6px;margin-top:2px;display:inline-block">{p.template}</span>}
              {p.locked ? <span style="font-size:11px;background:#fef2f2;color:#dc2626;padding:2px 8px;border-radius:6px;margin-top:2px;display:inline-block">🔒 locked</span> : ''}
            </div>
            <div class="approved-right">
              <div class="approved-signups">{p.signups || 0} signups</div>
              <span class={p.status === 'upcoming' ? 'abadge ab-up' : 'abadge ab-past'}>{p.status}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline>
    function showToast(msg) {
      var t = document.getElementById('toast');
      t.textContent = msg;
      t.style.display = 'block';
      setTimeout(function() { t.style.display = 'none'; }, 2500);
    }

    document.getElementById('save-webhook').addEventListener('click', async function() {
      var url = document.getElementById('webhook-input').value.trim();
      var res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'set_config',key:'webhook_url',value:url}) });
      var data = await res.json();
      if (data.ok) showToast('Webhook saved ✓');
    });

    document.querySelectorAll('.btn-approve').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'approve',id:parseInt(btn.dataset.id)}) });
        var data = await res.json();
        if (data.ok) { showToast('Approved ✓'); setTimeout(function(){ location.reload(); }, 800); }
      });
    });

    document.querySelectorAll('.btn-reject').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        if (!confirm('Reject this?')) return;
        var res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'reject',id:parseInt(btn.dataset.id)}) });
        var data = await res.json();
        if (data.ok) { showToast('Rejected'); setTimeout(function(){ location.reload(); }, 800); }
      });
    });

    document.getElementById('toggle-create').addEventListener('click', function() {
      var f = document.getElementById('create-form');
      f.style.display = f.style.display === 'block' ? 'none' : 'block';
    });

    // Load existing config
    fetch('/api/potlucks?type=config').then(function(r){ return r.json(); }).then(function(cfg){
      var setVal = function(id, val) { var el = document.getElementById(id); if (el && val) el.value = val; };
      setVal('resend-key', cfg.resend_api_key);
      setVal('site-url', cfg.site_url);
      setVal('from-email', cfg.from_email);
      setVal('cfg-organizer-email', cfg.organizer_email);
      setVal('cfg-contact-phone', cfg.contact_phone);
      setVal('cfg-contact-discord', cfg.contact_discord);
      setVal('cfg-contact-discord-url', cfg.contact_discord_url);
      setVal('cfg-venmo', cfg.venmo_handle);
      setVal('cfg-stripe', cfg.stripe_link);
      setVal('cfg-cashapp', cfg.cashapp_handle);
      setVal('cfg-turnstile-secret', cfg.turnstile_secret_key);
    }).catch(function(){});

    function saveCfg(key, value) {
      return fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'set_config',key:key,value:value}) });
    }
    document.getElementById('save-contact-cfg').addEventListener('click', async function() {
      await Promise.all([
        saveCfg('organizer_email', document.getElementById('cfg-organizer-email').value.trim()),
        saveCfg('contact_phone', document.getElementById('cfg-contact-phone').value.trim()),
        saveCfg('contact_discord', document.getElementById('cfg-contact-discord').value.trim()),
        saveCfg('contact_discord_url', document.getElementById('cfg-contact-discord-url').value.trim()),
        saveCfg('venmo_handle', document.getElementById('cfg-venmo').value.trim()),
        saveCfg('stripe_link', document.getElementById('cfg-stripe').value.trim()),
        saveCfg('cashapp_handle', document.getElementById('cfg-cashapp').value.trim()),
      ]);
      showToast('Contact info saved ✓');
    });
    document.getElementById('save-turnstile-cfg').addEventListener('click', async function() {
      await saveCfg('turnstile_secret_key', document.getElementById('cfg-turnstile-secret').value.trim());
      showToast('Turnstile saved ✓');
    });

    document.getElementById('save-email-cfg').addEventListener('click', async function() {
      var key = document.getElementById('resend-key').value.trim();
      var url = document.getElementById('site-url').value.trim();
      var from = document.getElementById('from-email').value.trim();
      await Promise.all([
        fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'set_config',key:'resend_api_key',value:key}) }),
        fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'set_config',key:'site_url',value:url}) }),
        fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'set_config',key:'from_email',value:from}) }),
      ]);
      showToast('Email settings saved ✓');
    });

    // Template picker
    document.querySelectorAll('.tmpl-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tmpl-btn').forEach(function(b) {
          b.style.borderColor='#e4ddd4'; b.style.background='#fff'; b.style.color='#57524c';
        });
        btn.style.borderColor='#f77f00'; btn.style.background='rgba(247,127,0,0.1)'; btn.style.color='#c2410c';
        document.getElementById('c-template').value = btn.dataset.t;
      });
    });

    document.getElementById('create-submit').addEventListener('click', async function() {
      var title = document.getElementById('c-title').value.trim();
      if (!title) return;
      var tmplInput = document.getElementById('c-template'); var body = { action:'create', title: title, description:'', date_label: document.getElementById('c-date').value, event_date: document.getElementById('c-event-date').value || null, time_label: document.getElementById('c-time').value, location: document.getElementById('c-loc').value, location_detail: document.getElementById('c-locdetail').value, cover_photo: document.getElementById('c-cover').value.trim() || null, status:'upcoming', template: tmplInput ? tmplInput.value : 'warm' };
      var res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      var data = await res.json();
      if (data.ok) window.location.href = '/potlucks/manage/' + data.id;
    });
  </script>
</body>
</html>
