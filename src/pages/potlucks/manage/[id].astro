---
import { getDB } from '../../../lib/db';
import { requireApprovedOrg } from '../../../lib/admin-auth';
import { ensurePotluckSchema } from '../../../lib/potluck-schema';
const gate = await requireApprovedOrg(Astro);
if (gate instanceof Response) return gate;
const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
let signups: any[] = [];
let slots: any[] = [];
try {
  if (db && id) {
    await ensurePotluckSchema(db);
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
    const s = await db.prepare(`SELECT * FROM potluck_rsvp WHERE potluck_id=? ORDER BY created_at DESC`).bind(id).all();
    signups = s?.results ?? [];
    const sl = await db.prepare(`SELECT * FROM potluck_slots WHERE potluck_id=? ORDER BY sort_order ASC, id ASC`).bind(id).all();
    slots = sl?.results ?? [];
  }
} catch(e) { console.error(e); }
if (!potluck) return Astro.redirect('/potlucks');
const attending = signups.filter((s:any) => s.rsvp === 'yes');
const notComing = signups.filter((s:any) => s.rsvp !== 'yes');
const guestTotal = attending.reduce((sum:number, s:any) => sum + (parseInt(s.guest_count)||1), 0);
const utensilPeople = attending.filter((s:any) => s.utensils);
const earlyPeople = attending.filter((s:any) => s.early_arrive);
const seatingPeople = attending.filter((s:any) => s.seating);
const dishMap: Record<string,string[]> = {};
attending.forEach((s:any) => {
  if (s.dish) {
    const k = s.dish.toLowerCase();
    if (!dishMap[k]) dishMap[k] = [];
    dishMap[k].push(s.name);
  }
});
const dishEntries = Object.entries(dishMap);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Manage · {potluck.title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#0f0f0f;color:#f0ebe3;font-family:'DM Sans',sans-serif;min-height:100vh;padding-bottom:40px}
    .hero{background:#1a0a00;border-bottom:1px solid #2a1a08;padding:32px 24px}
    .hero-inner{max-width:800px;margin:0 auto}
    .back{color:#6b5040;font-size:13px;text-decoration:none;margin-bottom:12px;display:inline-flex;align-items:center;gap:4px}
    .hero h1{font-family:'Playfair Display',serif;font-size:clamp(22px,5vw,32px);color:#fff;margin-bottom:4px}
    .hero p{font-size:13px;color:#6b5040}
    .hero-actions{margin-top:14px;display:flex;gap:8px;flex-wrap:wrap}
    .page{max-width:800px;margin:0 auto;padding:24px 16px}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:28px}
    .stat-card{background:#1a1108;border:1px solid #2a1a08;border-radius:12px;padding:16px;text-align:center}
    .stat-num{font-size:28px;font-weight:700;color:#f5c842;margin-bottom:4px}
    .stat-label{font-size:11px;color:#6b5040;text-transform:uppercase;letter-spacing:0.5px}
    .sec{margin-bottom:28px}
    .sec-label{font-size:10px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#6b5040;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #1a1108}
    .dish-grid{display:flex;flex-wrap:wrap;gap:8px}
    .dish-item{background:#1a1108;border:1px solid #2a1a08;border-radius:10px;padding:8px 14px}
    .dish-name{color:#f0ebe3;font-weight:500;font-size:13px;margin-bottom:2px}
    .dish-who{color:#4a3020;font-size:11px}
    .dish-item.full .dish-name{color:#f87171}
    .table{width:100%;border-collapse:collapse;font-size:13px}
    .table th{text-align:left;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#4a3020;padding:8px 10px;border-bottom:1px solid #2a1a08}
    .table td{padding:10px;border-bottom:1px solid #1a1108;color:#b09070;vertical-align:top}
    .table td:first-child{color:#f0ebe3;font-weight:500}
    .helper-row{display:flex;flex-wrap:wrap;gap:8px}
    .helper-chip{background:#1a1108;border:1px solid #2a1a08;border-radius:8px;padding:5px 12px;font-size:12px;color:#b09070}
    .del-btn{background:none;border:none;color:#4a3020;cursor:pointer;font-size:12px;padding:2px 6px;border-radius:4px}
    .del-btn:hover{background:#2e0d0d;color:#f87171}
    .btn-orange{background:linear-gradient(135deg,#c2410c,#f77f00);color:#fff;border:none;padding:8px 18px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer}
    .btn-ghost{background:transparent;color:#c4956a;border:1.5px solid #2a1a08;padding:8px 18px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer}
    .edit-panel{background:#1a1108;border:1px solid #2a1a08;border-radius:12px;padding:20px;margin-top:14px}
    .field{margin-bottom:12px}
    .field label{display:block;font-size:11px;color:#6b5040;margin-bottom:4px}
    input[type=text]{width:100%;padding:8px 10px;background:#0f0f0f;border:1px solid #2a1a08;border-radius:7px;color:#f0ebe3;font-family:'DM Sans',sans-serif;font-size:13px;outline:none}
    .empty{text-align:center;padding:32px;color:#4a3020;font-style:italic;font-size:13px}
    .hidden{display:none!important}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  </style>
</head>
<body>
  <div class="hero">
    <div class="hero-inner">
      <a href={`/potlucks/${id}`} class="back">← Back to event</a>
      <h1>⚙ Manage · {potluck.title}</h1>
      <p>{potluck.date_label} · {potluck.location}</p>
      <div class="hero-actions">
        <button class="btn-orange" onclick="document.getElementById('edit-panel').classList.toggle('hidden')">✏️ Edit details</button>
        <button class="btn-ghost" onclick="markPast()">Mark as Past</button>
      </div>
      <div class="edit-panel hidden" id="edit-panel">
        <div class="grid2">
          <div class="field"><label>Title</label><input type="text" id="e-title" value={potluck.title}/></div>
          <div class="field"><label>Date</label><input type="text" id="e-date" value={potluck.date_label ?? ''}/></div>
          <div class="field"><label>Event Date (for reminders)</label><input type="date" id="e-event-date" value={potluck.event_date ?? ''}/></div>
          <div class="field"><label>Time</label><input type="text" id="e-time" value={potluck.time_label ?? ''}/></div>
          <div class="field"><label>Location</label><input type="text" id="e-loc" value={potluck.location ?? ''}/></div>
          <div class="field" style="grid-column:1/-1"><label>Cover Photo URL</label><input type="text" id="e-cover" value={potluck.cover_photo ?? ''} placeholder="https://images.unsplash.com/…"/></div>
        </div>
        <button class="btn-orange" onclick="saveEdit()" style="margin-top:4px">Save</button>
      </div>
    </div>
  </div>

  <div class="page">
    <div class="sec">
      <div class="sec-label">Sign-up Items ({slots.length})</div>
      <div class="slot-grid-wrap">
        <table class="slot-table">
          <thead><tr><th style="width:120px">Time</th><th>Item</th><th style="width:100px">Category</th><th style="width:60px">Max</th><th style="width:80px"></th></tr></thead>
          <tbody>
            {slots.map((s:any) => (
              <tr data-slot-id={s.id}>
                <td><input type="text" class="sl-time" value={s.slot_time ?? ''} placeholder="—"/></td>
                <td><input type="text" class="sl-suggestion" value={s.suggestion ?? ''}/></td>
                <td><input type="text" class="sl-category" value={s.category ?? ''}/></td>
                <td><input type="number" class="sl-max" value={s.max_claims ?? 1} min="1"/></td>
                <td style="text-align:right"><button class="sl-save">Save</button> <button class="sl-del">✕</button></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div style="margin-top:14px;background:#fff8ec;border:1.5px dashed #fcd5a0;border-radius:10px;padding:14px">
        <div style="font-size:12px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Add new item</div>
        <div style="display:grid;grid-template-columns:120px 1fr 100px 60px auto;gap:6px;align-items:center">
          <input type="text" id="new-time" placeholder="Time (opt)" style="padding:8px;border:1px solid #e4ddd4;border-radius:6px;font-family:inherit;font-size:13px"/>
          <input type="text" id="new-suggestion" placeholder="Item (e.g. Chips & dip)" style="padding:8px;border:1px solid #e4ddd4;border-radius:6px;font-family:inherit;font-size:13px"/>
          <input type="text" id="new-category" placeholder="Category" value="Items" style="padding:8px;border:1px solid #e4ddd4;border-radius:6px;font-family:inherit;font-size:13px"/>
          <input type="number" id="new-max" value="1" min="1" style="padding:8px;border:1px solid #e4ddd4;border-radius:6px;font-family:inherit;font-size:13px"/>
          <button id="add-slot" class="btn-orange" style="white-space:nowrap">+ Add</button>
        </div>
      </div>
    </div>
    <style is:inline>
      .slot-grid-wrap{overflow-x:auto;background:#fff;border:1px solid #e4ddd4;border-radius:12px}
      .slot-table{width:100%;border-collapse:collapse;font-size:13px}
      .slot-table th{text-align:left;padding:10px 12px;font-size:11px;font-weight:700;color:#a09890;text-transform:uppercase;letter-spacing:0.5px;background:#f7f5f2;border-bottom:1px solid #e4ddd4}
      .slot-table td{padding:6px 8px;border-bottom:1px solid #f0ede8;vertical-align:middle}
      .slot-table input{width:100%;padding:7px 9px;border:1px solid transparent;border-radius:6px;font-family:inherit;font-size:13px;background:transparent}
      .slot-table input:focus{border-color:#f77f00;background:#fffaf2;outline:none}
      .slot-table .sl-save,.slot-table .sl-del{padding:6px 10px;border-radius:6px;border:1px solid #e4ddd4;background:#fff;font-size:12px;font-family:inherit;cursor:pointer}
      .slot-table .sl-save{color:#c2410c;border-color:#fcd5a0}
      .slot-table .sl-del{color:#a09890}
    </style>

    <div class="stats-grid">
      <div class="stat-card"><div class="stat-num">{guestTotal}</div><div class="stat-label">People Total</div></div>
      <div class="stat-card"><div class="stat-num">{attending.length}</div><div class="stat-label">Sign-ups</div></div>
      <div class="stat-card"><div class="stat-num">{dishEntries.length}</div><div class="stat-label">Dishes</div></div>
      <div class="stat-card"><div class="stat-num">{utensilPeople.length}</div><div class="stat-label">Utensils</div></div>
      <div class="stat-card"><div class="stat-num">{earlyPeople.length}</div><div class="stat-label">Early Help</div></div>
      <div class="stat-card"><div class="stat-num">{seatingPeople.length}</div><div class="stat-label">Seating</div></div>
    </div>

    {dishEntries.length > 0 && (
      <div class="sec">
        <div class="sec-label">Dishes</div>
        <div class="dish-grid">
          {dishEntries.map(([dish, names]) => (
            <div class={names.length >= 2 ? 'dish-item full' : 'dish-item'}>
              <div class="dish-name">{dish}{names.length >= 2 ? ' ⚠ FULL' : ''}</div>
              <div class="dish-who">{names.join(', ')}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    {(utensilPeople.length > 0 || earlyPeople.length > 0 || seatingPeople.length > 0) && (
      <div class="sec">
        <div class="sec-label">Helpers</div>
        {utensilPeople.length > 0 && <div style="margin-bottom:8px"><span style="font-size:12px;color:#6b5040;margin-right:8px">🥄 Utensils:</span><span class="helper-row">{utensilPeople.map((s:any)=><span class="helper-chip">{s.name}</span>)}</span></div>}
        {earlyPeople.length > 0 && <div style="margin-bottom:8px"><span style="font-size:12px;color:#6b5040;margin-right:8px">⏰ Early:</span><span class="helper-row">{earlyPeople.map((s:any)=><span class="helper-chip">{s.name}</span>)}</span></div>}
        {seatingPeople.length > 0 && <div><span style="font-size:12px;color:#6b5040;margin-right:8px">🪑 Seating:</span><span class="helper-row">{seatingPeople.map((s:any)=><span class="helper-chip">{s.name}</span>)}</span></div>}
      </div>
    )}

    <div class="sec">
      <div class="sec-label">All Sign-ups ({attending.length})</div>
      {attending.length === 0
        ? <div class="empty">No sign-ups yet</div>
        : (
          <table class="table">
            <thead><tr><th>Name</th><th>Dish</th><th>👥</th><th>From</th><th>Dietary</th><th></th></tr></thead>
            <tbody>
              {attending.map((s:any) => (
                <tr>
                  <td>{s.name}{s.handle ? <span style="color:#4a3020;display:block;font-size:11px">{s.handle}</span> : null}</td>
                  <td>{s.dish || '—'}{s.dish_category ? <span style="color:#4a3020;display:block;font-size:11px">{s.dish_category}</span> : null}</td>
                  <td>{s.guest_count || 1}</td>
                  <td style="font-size:11px;color:#6b5040">{s.platforms || '—'}</td>
                  <td style="font-size:12px;color:#4a3020">{s.dietary || '—'}</td>
                  <td><button class="del-btn" onclick={`deleteRsvp(${s.id})`}>✕</button></td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      }
    </div>

    {notComing.length > 0 && (
      <div class="sec">
        <div class="sec-label">Can't Make It ({notComing.length})</div>
        <div class="helper-row">
          {notComing.map((s:any) => <span class="helper-chip">{s.name}</span>)}
        </div>
      </div>
    )}
  </div>

  <script define:vars={{ id, potluck }}>
    async function deleteRsvp(rsvpId) {
      if (!confirm('Remove this sign-up?')) return;
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'delete_rsvp',id:rsvpId}) });
      const data = await res.json();
      if (data.ok) location.reload();
    }
    async function saveEdit() {
      const body = { action:'update', id: parseInt(id), title: document.getElementById('e-title').value, date_label: document.getElementById('e-date').value, event_date: document.getElementById('e-event-date').value || null, time_label: document.getElementById('e-time').value, location: document.getElementById('e-loc').value, cover_photo: document.getElementById('e-cover').value.trim() || null, description: potluck.description || '', location_detail: potluck.location_detail || '', status: potluck.status };
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    }
    async function markPast() {
      if (!confirm('Mark this potluck as past?')) return;
      const body = { action:'update', id: parseInt(id), title: potluck.title, description: potluck.description || '', date_label: potluck.date_label || '', event_date: potluck.event_date || null, time_label: potluck.time_label || '', location: potluck.location || '', location_detail: potluck.location_detail || '', cover_photo: potluck.cover_photo || null, status: 'past' };
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    }

    document.querySelectorAll('.slot-table tr[data-slot-id]').forEach(function(row) {
      const slotId = parseInt(row.getAttribute('data-slot-id'));
      row.querySelector('.sl-save').addEventListener('click', async function() {
        const body = {
          action: 'update', id: slotId,
          slot_time: row.querySelector('.sl-time').value.trim(),
          suggestion: row.querySelector('.sl-suggestion').value.trim(),
          category: row.querySelector('.sl-category').value.trim(),
          max_claims: parseInt(row.querySelector('.sl-max').value) || 1,
        };
        const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
        const data = await res.json();
        if (data.ok) row.style.background = '#f0fdf4';
      });
      row.querySelector('.sl-del').addEventListener('click', async function() {
        if (!confirm('Delete this item?')) return;
        const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ action:'delete', id: slotId }) });
        const data = await res.json();
        if (data.ok) row.remove();
      });
    });

    document.getElementById('add-slot').addEventListener('click', async function() {
      const suggestion = document.getElementById('new-suggestion').value.trim();
      if (!suggestion) { document.getElementById('new-suggestion').focus(); return; }
      const body = {
        action: 'add', potluck_id: parseInt(id),
        slot_time: document.getElementById('new-time').value.trim(),
        suggestion: suggestion,
        category: document.getElementById('new-category').value.trim() || 'Items',
        max_claims: parseInt(document.getElementById('new-max').value) || 1,
      };
      const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    });
  </script>
</body>
</html>
