---
import { getDB } from '../../../lib/db';
import { requireApprovedOrg } from '../../../lib/admin-auth';
import { ensurePotluckSchema } from '../../../lib/potluck-schema';
const gate = await requireApprovedOrg(Astro);
if (gate instanceof Response) return gate;
const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
let signups: any[] = [];
let slots: any[] = [];
try {
  if (db && id) {
    await ensurePotluckSchema(db);
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
    const s = await db.prepare(`SELECT * FROM potluck_rsvp WHERE potluck_id=? ORDER BY created_at DESC`).bind(id).all();
    signups = s?.results ?? [];
    const sl = await db.prepare(`SELECT * FROM potluck_slots WHERE potluck_id=? ORDER BY sort_order ASC, id ASC`).bind(id).all();
    slots = sl?.results ?? [];
  }
} catch(e) { console.error(e); }
if (!potluck) return Astro.redirect('/potlucks');
const attending = signups.filter((s:any) => s.rsvp === 'yes');
const notComing = signups.filter((s:any) => s.rsvp !== 'yes');
const guestTotal = attending.reduce((sum:number, s:any) => sum + (parseInt(s.guest_count)||1), 0);
const utensilPeople = attending.filter((s:any) => s.utensils);
const earlyPeople = attending.filter((s:any) => s.early_arrive);
const seatingPeople = attending.filter((s:any) => s.seating);
const dishMap: Record<string,string[]> = {};
attending.forEach((s:any) => {
  if (s.dish) {
    const k = s.dish.toLowerCase();
    if (!dishMap[k]) dishMap[k] = [];
    dishMap[k].push(s.name);
  }
});
const dishEntries = Object.entries(dishMap);

// Group slots by category
const catMap: Record<string, any[]> = {};
slots.forEach((s: any) => {
  const cat = s.category || 'Items';
  if (!catMap[cat]) catMap[cat] = [];
  catMap[cat].push(s);
});
const catEntries = Object.entries(catMap);
const catEmoji: Record<string,string> = { 'Salads':'🥗', 'Mains':'🍖', 'Sides':'🥘', 'Snacks':'🧀', 'Desserts':'🍰', 'Drinks':'🥤', 'Setup':'🛠', 'Items':'📦' };
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Manage · {potluck.title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--accent:#2D5F3F;--accent-light:#e8f5e9;--bg:#FAFAF8;--card:#FFFFFF;--border:#E8E4DE;--text:#1a1a1a;--muted:#7a746c;--danger:#dc2626;--danger-bg:#fef2f2}
    body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;min-height:100vh;padding-bottom:60px}

    /* Top bar */
    .top-bar{background:var(--card);border-bottom:1px solid var(--border);padding:16px 24px;position:sticky;top:0;z-index:50}
    .top-inner{max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .top-left{display:flex;align-items:center;gap:12px}
    .back-link{color:var(--muted);text-decoration:none;font-size:13px;display:flex;align-items:center;gap:4px;padding:6px 12px;border-radius:8px;border:1px solid var(--border);transition:all 0.15s}
    .back-link:hover{background:var(--bg);color:var(--text)}
    .top-title{font-family:'Cormorant Garamond',sans-serif;font-size:18px;font-weight:700;color:var(--text)}
    .top-actions{display:flex;gap:8px}

    /* Buttons */
    .btn{padding:8px 16px;border-radius:8px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;border:none;transition:all 0.15s;display:inline-flex;align-items:center;gap:6px}
    .btn-primary{background:var(--accent);color:#fff}
    .btn-primary:hover{background:#234a30}
    .btn-outline{background:transparent;color:var(--muted);border:1px solid var(--border)}
    .btn-outline:hover{background:var(--bg);color:var(--text)}
    .btn-danger{background:transparent;color:var(--danger);border:1px solid #fca5a5}
    .btn-danger:hover{background:var(--danger-bg)}
    .btn-sm{padding:5px 10px;font-size:12px;border-radius:6px}

    /* Page container */
    .page{max-width:900px;margin:0 auto;padding:24px 16px}

    /* Stat cards */
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:28px}
    .stat{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px 16px;text-align:center}
    .stat-num{font-family:'Cormorant Garamond',sans-serif;font-size:32px;font-weight:700;color:var(--accent);line-height:1}
    .stat-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-top:6px}

    /* Section */
    .section{margin-bottom:28px}
    .section-head{font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:8px}
    .section-count{background:var(--accent-light);color:var(--accent);font-size:11px;font-weight:600;padding:2px 8px;border-radius:10px}

    /* Sign-up items table */
    .items-wrap{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .cat-header{background:var(--bg);padding:10px 16px;font-size:12px;font-weight:600;color:var(--muted);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px}
    .cat-header:not(:first-child){border-top:1px solid var(--border)}
    .item-row{display:grid;grid-template-columns:100px 1fr 100px 50px 70px;align-items:center;padding:6px 16px;border-bottom:1px solid #f5f3f0;gap:4px}
    .item-row:last-child{border-bottom:none}
    .item-row input{width:100%;padding:7px 10px;border:1px solid transparent;border-radius:6px;font-family:inherit;font-size:13px;background:transparent;color:var(--text)}
    .item-row input:focus{border-color:var(--accent);background:#f8fdf9;outline:none}
    .item-row input[type=number]{width:50px;text-align:center}
    .item-actions{display:flex;gap:4px;justify-content:flex-end}

    /* Category badge */
    .cat-badge{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--accent-light);color:var(--accent)}

    /* Add new */
    .add-strip{background:var(--card);border:1.5px dashed var(--border);border-radius:12px;padding:16px;margin-top:14px}
    .add-strip-title{font-size:12px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px}
    .add-grid{display:grid;grid-template-columns:100px 1fr 100px 50px auto;gap:8px;align-items:center}
    .add-grid input{padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:13px;background:var(--card)}
    .add-grid input:focus{border-color:var(--accent);outline:none}

    /* Bulk import */
    .bulk-details{margin-top:14px;background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .bulk-details summary{padding:12px 16px;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted);list-style:none;display:flex;align-items:center;gap:6px}
    .bulk-details summary::before{content:'▸';font-size:11px;transition:transform 0.15s}
    .bulk-details[open] summary::before{transform:rotate(90deg)}
    .bulk-details summary:hover{background:var(--bg)}
    .bulk-inner{padding:0 16px 16px}
    .bulk-help{font-size:12px;color:var(--muted);margin-bottom:10px;line-height:1.5}
    .bulk-inner textarea{width:100%;padding:10px;border:1px solid var(--border);border-radius:8px;font-family:'JetBrains Mono',monospace;font-size:13px;resize:vertical;min-height:100px}
    .bulk-inner textarea:focus{border-color:var(--accent);outline:none}
    .bulk-footer{display:flex;gap:8px;align-items:center;margin-top:10px}
    .bulk-footer input{flex:1;padding:8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:13px}

    /* Guest list table */
    .guest-table{width:100%;border-collapse:collapse;font-size:13px}
    .guest-table th{text-align:left;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--muted);padding:10px 12px;background:var(--bg);border-bottom:1px solid var(--border)}
    .guest-table td{padding:10px 12px;border-bottom:1px solid #f5f3f0;vertical-align:top}
    .guest-table td:first-child{font-weight:500;color:var(--text)}
    .guest-table tr:last-child td{border-bottom:none}
    .guest-sub{display:block;font-size:11px;color:var(--muted);font-weight:400;margin-top:2px}
    .guest-wrap{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}

    /* Dish chips */
    .dish-grid{display:flex;flex-wrap:wrap;gap:8px}
    .dish-chip{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:8px 14px}
    .dish-name{font-size:13px;font-weight:500;color:var(--text)}
    .dish-who{font-size:11px;color:var(--muted);margin-top:2px}
    .dish-chip.full{border-color:#fca5a5;background:var(--danger-bg)}
    .dish-chip.full .dish-name{color:var(--danger)}

    /* Helper chips */
    .helper-row{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px}
    .helper-chip{background:var(--accent-light);color:var(--accent);padding:4px 12px;border-radius:8px;font-size:12px;font-weight:500}
    .helper-section{margin-bottom:10px;display:flex;align-items:center;flex-wrap:wrap;gap:8px}
    .helper-label{font-size:12px;color:var(--muted);min-width:80px}

    /* Edit panel */
    .edit-panel{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;margin-top:20px}
    .edit-panel.hidden{display:none!important}
    .edit-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .field label{display:block;font-size:11px;font-weight:500;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px}
    .field input{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-family:inherit;font-size:13px;background:var(--card);color:var(--text)}
    .field input:focus{border-color:var(--accent);outline:none}
    .field-full{grid-column:1/-1}

    /* Empty state */
    .empty{text-align:center;padding:40px;color:var(--muted);font-style:italic;font-size:14px}

    /* Can't make it */
    .decline-list{display:flex;flex-wrap:wrap;gap:6px}
    .decline-chip{background:#f5f3f0;color:var(--muted);padding:4px 12px;border-radius:8px;font-size:12px}

    @media(max-width:640px){
      .add-grid{grid-template-columns:1fr 1fr;gap:6px}
      .add-grid input:first-child{grid-column:1/-1}
      .item-row{grid-template-columns:1fr 50px 60px;padding:8px 12px}
      .item-row .sl-time{display:none}
      .item-row .sl-category{display:none}
      .edit-grid{grid-template-columns:1fr}
      .top-title{font-size:15px}
      .stats{grid-template-columns:repeat(3,1fr)}
    }
  </style>
</head>
<body>
  <div class="top-bar">
    <div class="top-inner">
      <div class="top-left">
        <a href={`/potlucks/${id}`} class="back-link">← Back</a>
        <span class="top-title">{potluck.title}</span>
      </div>
      <div class="top-actions">
        <button class="btn btn-primary" onclick="document.getElementById('edit-panel').classList.toggle('hidden')">Edit details</button>
        <button class="btn btn-outline" onclick="duplicatePotluck()">Duplicate</button>
        <button class="btn btn-outline" onclick="markPast()">Mark as Past</button>
      </div>
    </div>
  </div>

  <div class="page">
    <!-- Edit Panel (hidden by default) -->
    <div class="edit-panel hidden" id="edit-panel">
      <div style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:14px">Edit Event Details</div>
      <div class="edit-grid">
        <div class="field"><label>Title</label><input type="text" id="e-title" value={potluck.title}/></div>
        <div class="field"><label>Date</label><input type="text" id="e-date" value={potluck.date_label ?? ''}/></div>
        <div class="field"><label>Event Date (for reminders)</label><input type="date" id="e-event-date" value={potluck.event_date ?? ''}/></div>
        <div class="field"><label>Time</label><input type="text" id="e-time" value={potluck.time_label ?? ''}/></div>
        <div class="field"><label>Location</label><input type="text" id="e-loc" value={potluck.location ?? ''}/></div>
        <div class="field field-full"><label>Cover Photo URL</label><input type="text" id="e-cover" value={potluck.cover_photo ?? ''} placeholder="https://images.unsplash.com/…"/></div>
      </div>
      <button class="btn btn-primary" onclick="saveEdit()" style="margin-top:12px">Save changes</button>
    </div>

    <!-- Stats -->
    <div class="stats">
      <div class="stat"><div class="stat-num">{guestTotal}</div><div class="stat-label">People</div></div>
      <div class="stat"><div class="stat-num">{attending.length}</div><div class="stat-label">Sign-ups</div></div>
      <div class="stat"><div class="stat-num">{slots.length}</div><div class="stat-label">Items</div></div>
      <div class="stat"><div class="stat-num">{utensilPeople.length}</div><div class="stat-label">Utensils</div></div>
      <div class="stat"><div class="stat-num">{earlyPeople.length}</div><div class="stat-label">Early Help</div></div>
      <div class="stat"><div class="stat-num">{seatingPeople.length}</div><div class="stat-label">Seating</div></div>
    </div>

    <!-- Sign-up Items -->
    <div class="section">
      <div class="section-head">Sign-up Items <span class="section-count">{slots.length}</span></div>
      <div class="items-wrap">
        {catEntries.map(([cat, items]) => (
          <Fragment>
            <div class="cat-header">{catEmoji[cat] || '📦'} {cat} <span style="color:var(--accent);font-size:11px">({items.length})</span></div>
            {items.map((s: any) => (
              <div class="item-row" data-slot-id={s.id}>
                <input type="text" class="sl-time" value={s.slot_time ?? ''} placeholder="Time"/>
                <input type="text" class="sl-suggestion" value={s.suggestion ?? ''}/>
                <input type="text" class="sl-category" value={s.category ?? ''}/>
                <input type="number" class="sl-max" value={s.max_claims ?? 1} min="1"/>
                <div class="item-actions">
                  <button class="btn btn-sm btn-outline sl-save">Save</button>
                  <button class="btn btn-sm btn-danger sl-del">✕</button>
                </div>
              </div>
            ))}
          </Fragment>
        ))}
        {slots.length === 0 && <div class="empty">No items yet — add some below</div>}
      </div>

      <!-- Add new item -->
      <div class="add-strip">
        <div class="add-strip-title">+ Add Item</div>
        <div class="add-grid">
          <input type="text" id="new-time" placeholder="Time"/>
          <input type="text" id="new-suggestion" placeholder="Item name (e.g. Chips & dip)"/>
          <input type="text" id="new-category" placeholder="Category" value="Items"/>
          <input type="number" id="new-max" value="1" min="1"/>
          <button id="add-slot" class="btn btn-primary">Add</button>
        </div>
      </div>

      <!-- Bulk import -->
      <details class="bulk-details">
        <summary>Bulk import (paste a list)</summary>
        <div class="bulk-inner">
          <div class="bulk-help">
            One item per line. Use <code style="background:var(--bg);padding:1px 5px;border-radius:4px;font-size:11px">Time | Item | Category | Max</code> for full control.
          </div>
          <textarea id="bulk-text" rows="5" placeholder={`Chips & dip\nMain dish\nDessert`}></textarea>
          <div class="bulk-footer">
            <input type="text" id="bulk-default-cat" placeholder="Default category" value="Items"/>
            <button id="bulk-add" class="btn btn-primary">Import all</button>
          </div>
        </div>
      </details>
    </div>

    <!-- Dishes brought -->
    {dishEntries.length > 0 && (
      <div class="section">
        <div class="section-head">Dishes <span class="section-count">{dishEntries.length}</span></div>
        <div class="dish-grid">
          {dishEntries.map(([dish, names]) => (
            <div class={names.length >= 2 ? 'dish-chip full' : 'dish-chip'}>
              <div class="dish-name">{dish}{names.length >= 2 ? ' (full)' : ''}</div>
              <div class="dish-who">{names.join(', ')}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Helpers -->
    {(utensilPeople.length > 0 || earlyPeople.length > 0 || seatingPeople.length > 0) && (
      <div class="section">
        <div class="section-head">Helpers</div>
        {utensilPeople.length > 0 && (
          <div class="helper-section">
            <span class="helper-label">🥄 Utensils</span>
            <div class="helper-row">{utensilPeople.map((s:any)=><span class="helper-chip">{s.name}</span>)}</div>
          </div>
        )}
        {earlyPeople.length > 0 && (
          <div class="helper-section">
            <span class="helper-label">⏰ Early</span>
            <div class="helper-row">{earlyPeople.map((s:any)=><span class="helper-chip">{s.name}</span>)}</div>
          </div>
        )}
        {seatingPeople.length > 0 && (
          <div class="helper-section">
            <span class="helper-label">🪑 Seating</span>
            <div class="helper-row">{seatingPeople.map((s:any)=><span class="helper-chip">{s.name}</span>)}</div>
          </div>
        )}
      </div>
    )}

    <!-- Guest List -->
    <div class="section">
      <div class="section-head">Guest List <span class="section-count">{attending.length}</span></div>
      {attending.length === 0
        ? <div class="empty">No sign-ups yet</div>
        : (
          <div class="guest-wrap">
            <table class="guest-table">
              <thead><tr><th>Name</th><th>Bringing</th><th>Guests</th><th>From</th><th>Dietary</th><th></th></tr></thead>
              <tbody>
                {attending.map((s:any) => (
                  <tr>
                    <td>{s.name}{s.handle ? <span class="guest-sub">{s.handle}</span> : null}</td>
                    <td>{s.dish || '—'}{s.dish_category ? <span class="guest-sub">{s.dish_category}</span> : null}</td>
                    <td>{s.guest_count || 1}</td>
                    <td style="font-size:12px;color:var(--muted)">{s.platforms || '—'}</td>
                    <td style="font-size:12px;color:var(--muted)">{s.dietary || '—'}</td>
                    <td><button class="btn btn-sm btn-danger" onclick={`deleteRsvp(${s.id})`}>✕</button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </div>

    <!-- Can't Make It -->
    {notComing.length > 0 && (
      <div class="section">
        <div class="section-head">Can't Make It <span class="section-count">{notComing.length}</span></div>
        <div class="decline-list">
          {notComing.map((s:any) => <span class="decline-chip">{s.name}</span>)}
        </div>
      </div>
    )}
  </div>

  <script define:vars={{ id, potluck }}>
    async function deleteRsvp(rsvpId) {
      if (!confirm('Remove this sign-up?')) return;
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({action:'delete_rsvp',id:rsvpId}) });
      const data = await res.json();
      if (data.ok) location.reload();
    }
    window.deleteRsvp = deleteRsvp;

    async function saveEdit() {
      const body = { action:'update', id: parseInt(id), title: document.getElementById('e-title').value, date_label: document.getElementById('e-date').value, event_date: document.getElementById('e-event-date').value || null, time_label: document.getElementById('e-time').value, location: document.getElementById('e-loc').value, cover_photo: document.getElementById('e-cover').value.trim() || null, description: potluck.description || '', location_detail: potluck.location_detail || '', status: potluck.status };
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    }
    window.saveEdit = saveEdit;

    async function duplicatePotluck() {
      const newTitle = prompt('Title for the copy?', (potluck.title || '') + ' (Copy)');
      if (!newTitle) return;
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ action:'duplicate', id: parseInt(id), new_title: newTitle }) });
      const data = await res.json();
      if (data.ok) window.location.href = '/potlucks/manage/' + data.id;
      else alert('Could not duplicate: ' + (data.error || 'unknown'));
    }
    window.duplicatePotluck = duplicatePotluck;

    async function markPast() {
      if (!confirm('Mark this potluck as past?')) return;
      const body = { action:'update', id: parseInt(id), title: potluck.title, description: potluck.description || '', date_label: potluck.date_label || '', event_date: potluck.event_date || null, time_label: potluck.time_label || '', location: potluck.location || '', location_detail: potluck.location_detail || '', cover_photo: potluck.cover_photo || null, status: 'past' };
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    }
    window.markPast = markPast;

    // Slot inline save/delete
    document.querySelectorAll('.item-row[data-slot-id]').forEach(function(row) {
      const slotId = parseInt(row.getAttribute('data-slot-id'));
      row.querySelector('.sl-save').addEventListener('click', async function() {
        const body = {
          action: 'update', id: slotId,
          slot_time: row.querySelector('.sl-time').value.trim(),
          suggestion: row.querySelector('.sl-suggestion').value.trim(),
          category: row.querySelector('.sl-category').value.trim(),
          max_claims: parseInt(row.querySelector('.sl-max').value) || 1,
        };
        const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
        const data = await res.json();
        if (data.ok) { row.style.background = '#f0fdf4'; setTimeout(() => row.style.background = '', 1500); }
      });
      row.querySelector('.sl-del').addEventListener('click', async function() {
        if (!confirm('Delete this item?')) return;
        const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ action:'delete', id: slotId }) });
        const data = await res.json();
        if (data.ok) row.remove();
      });
    });

    // Bulk import
    document.getElementById('bulk-add').addEventListener('click', async function() {
      const text = document.getElementById('bulk-text').value;
      if (!text.trim()) return;
      const body = {
        action: 'bulk_add', potluck_id: parseInt(id),
        text: text,
        default_category: document.getElementById('bulk-default-cat').value.trim() || 'Items',
      };
      const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    });

    // Add single item
    document.getElementById('add-slot').addEventListener('click', async function() {
      const suggestion = document.getElementById('new-suggestion').value.trim();
      if (!suggestion) { document.getElementById('new-suggestion').focus(); return; }
      const body = {
        action: 'add', potluck_id: parseInt(id),
        slot_time: document.getElementById('new-time').value.trim(),
        suggestion: suggestion,
        category: document.getElementById('new-category').value.trim() || 'Items',
        max_claims: parseInt(document.getElementById('new-max').value) || 1,
      };
      const res = await fetch('/api/potluck-slots', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) location.reload();
    });
  </script>
</body>
</html>
