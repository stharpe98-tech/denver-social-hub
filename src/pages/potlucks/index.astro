---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';
const db = getDB();
let potlucks: any[] = [];
try {
  if (db) {
    const { results } = await db.prepare(`
      SELECT p.*, COUNT(DISTINCT CASE WHEN r.rsvp='yes' THEN r.id END) as attendee_count,
        COUNT(DISTINCT CASE WHEN r.rsvp='yes' AND r.dish!='' THEN LOWER(r.dish) END) as dish_count
      FROM potlucks p LEFT JOIN potluck_rsvp r ON r.potluck_id=p.id
      WHERE p.status != 'pending' GROUP BY p.id ORDER BY p.id DESC
    `).all();
    potlucks = results ?? [];
  }
} catch(e) { console.error(e); }
const upcoming = potlucks.filter((p:any) => p.status === 'upcoming');
const past = potlucks.filter((p:any) => p.status !== 'upcoming');
---
<Base title="Potlucks" description="Community potlucks across Denver — bring a dish, meet your neighbors.">

  <section class="hub-hero">
    <div class="hub-glow"></div>
    <div class="hub-hi">
      <span class="hub-eyebrow">Community · No ads · No fees</span>
      <h1>🍽 Potlucks</h1>
      <p>Bring a dish, meet your neighbors, eat well.</p>
    </div>
  </section>

  <div class="hub-page">
    {upcoming.length > 0 ? (
      <div style="margin-bottom:var(--space-7)">
        <div class="hub-sec"><span class="tag tag-blue">Upcoming</span></div>
        <div class="hub-list">
          {upcoming.map((p:any) => (
            <a href={`/potlucks/${p.id}`} class="hub-card">
              <div class="hub-card-top">
                <div class="hub-card-main">
                  <div class="hub-card-title">{p.title}</div>
                  <div class="hub-card-meta">
                    {p.date_label && <div>📅 {p.date_label}{p.time_label ? ` · ${p.time_label}` : ''}</div>}
                    {p.location && <div>📍 {p.location}{p.location_detail ? ` · ${p.location_detail}` : ''}</div>}
                  </div>
                </div>
                <span class="tag tag-green">Open</span>
              </div>
              <div class="hub-stats">
                <div class="hub-stat">👥 <strong>{p.attendee_count || 0}</strong> signed up</div>
                <div class="hub-stat">🍽 <strong>{p.dish_count || 0}</strong> dishes claimed</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="hub-empty">No upcoming potlucks — suggest one below!</div>
    )}

    {past.length > 0 && (
      <div style="margin-bottom:var(--space-7)">
        <div class="hub-sec"><span class="tag tag-blue" style="background:var(--surface);color:var(--text-faint)">Past</span></div>
        <div class="hub-list">
          {past.map((p:any) => (
            <a href={`/potlucks/${p.id}`} class="hub-card hub-card-past">
              <div class="hub-card-top">
                <div class="hub-card-main">
                  <div class="hub-card-title">{p.title}</div>
                  <div class="hub-card-meta">{p.date_label} · {p.location}</div>
                </div>
                <span class="tag" style="background:var(--surface);color:var(--text-faint)">Past</span>
              </div>
              <div class="hub-stats">
                <div class="hub-stat">👥 <strong>{p.attendee_count || 0}</strong> attended</div>
                <div class="hub-stat">🍽 <strong>{p.dish_count || 0}</strong> dishes</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="hub-suggest">
      <div class="hub-suggest-head">
        <h2>Got an idea for a potluck?</h2>
        <p>Submit it — if approved it'll show up here.</p>
      </div>

      <div class="hub-field"><label>Title *</label><input type="text" id="s-title" class="input" placeholder="e.g. Fall Harvest Potluck"/></div>
      <div class="hub-field"><label>Description</label><textarea id="s-desc" class="input" style="resize:vertical;min-height:84px" placeholder="What's the vibe?"></textarea></div>
      <div class="hub-row2">
        <div class="hub-field"><label>Date</label><input type="text" id="s-date" class="input" placeholder="Oct 18th"/></div>
        <div class="hub-field"><label>Time</label><input type="text" id="s-time" class="input" placeholder="1pm–5pm"/></div>
        <div class="hub-field"><label>Location</label><input type="text" id="s-loc" class="input" placeholder="City Park"/></div>
        <div class="hub-field"><label>Detail</label><input type="text" id="s-locdetail" class="input" placeholder="Near the pavilion"/></div>
      </div>
      <button class="btn-cta" id="suggest-btn" style="width:100%;margin-top:var(--space-2)">Submit idea →</button>
      <div class="hub-success" id="suggest-ok">✅ Submitted! We'll review it and post it if approved.</div>
    </div>
  </div>

  <style>
    .hub-hero { position: relative; overflow: hidden; padding: var(--space-7) var(--space-5) var(--space-6); background: linear-gradient(135deg, #FFFFFF 0%, #E0F2FE 50%, #D1FAE5 100%); border-bottom: 1px solid var(--border); }
    .hub-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(14,165,233,0.10), transparent 70%); pointer-events: none; }
    .hub-hi { position: relative; max-width: 720px; margin: 0 auto; text-align: center; z-index: 1; }
    .hub-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); padding: 5px 12px; background: var(--accent-dim); border-radius: 999px; margin-bottom: var(--space-3); }
    .hub-hero h1 { font-family: var(--font-display); font-size: clamp(32px, 6vw, 48px); color: var(--text); margin-bottom: 8px; font-weight: 800; letter-spacing: -0.02em; }
    .hub-hero p { font-size: 16px; color: var(--text-sec); }

    .hub-page { max-width: 720px; margin: 0 auto; padding: var(--space-6) var(--space-5); }

    .hub-sec { margin-bottom: var(--space-3); }

    .hub-list { display: flex; flex-direction: column; gap: var(--space-3); }
    .hub-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4); box-shadow: var(--card-shadow); text-decoration: none; display: block; transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s; -webkit-tap-highlight-color: transparent; }
    .hub-card:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-lg); border-color: var(--border-hover); }
    .hub-card-past:hover { transform: none; }
    .hub-card-past .hub-card-title { color: var(--text-sec); }
    .hub-card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--space-3); margin-bottom: var(--space-3); }
    .hub-card-main { min-width: 0; flex: 1; }
    .hub-card-title { font-family: var(--font-display); font-size: 19px; font-weight: 700; color: var(--text); margin-bottom: 6px; letter-spacing: -0.01em; }
    .hub-card-meta { font-size: 13px; color: var(--text-sec); line-height: 1.6; }
    .hub-stats { display: flex; gap: var(--space-4); flex-wrap: wrap; padding-top: var(--space-3); border-top: 1px solid var(--border); }
    .hub-stat { font-size: 13px; color: var(--text-sec); }
    .hub-stat strong { color: var(--text); font-weight: 700; }

    .hub-empty { text-align: center; padding: var(--space-6); color: var(--text-faint); font-size: 14px; background: var(--surface); border: 1px dashed var(--border); border-radius: var(--radius); margin-bottom: var(--space-7); }

    .hub-suggest { padding-top: var(--space-6); border-top: 1px solid var(--border); }
    .hub-suggest-head h2 { font-family: var(--font-display); font-size: 24px; font-weight: 700; margin-bottom: 4px; letter-spacing: -0.01em; }
    .hub-suggest-head p { color: var(--text-sec); font-size: 14px; margin-bottom: var(--space-4); }

    .hub-field { margin-bottom: var(--space-3); }
    .hub-field label { display: block; font-size: 11px; font-weight: 700; color: var(--text-sec); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .hub-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2); }
    @media(max-width: 460px) { .hub-row2 { grid-template-columns: 1fr; } }

    .hub-success { background: var(--tag-bg2); border: 1px solid var(--mint); border-radius: 10px; padding: 12px 16px; color: var(--tag-text2); font-size: 14px; margin-top: var(--space-3); display: none; font-weight: 500; }
  </style>

  <script is:inline>
    document.getElementById('suggest-btn').addEventListener('click', async function() {
      var title = document.getElementById('s-title').value.trim();
      if (!title) { document.getElementById('s-title').style.borderColor = 'var(--red)'; return; }
      var body = {
        action: 'suggest',
        title: title,
        description: document.getElementById('s-desc').value,
        date_label: document.getElementById('s-date').value,
        time_label: document.getElementById('s-time').value,
        location: document.getElementById('s-loc').value,
        location_detail: document.getElementById('s-locdetail').value
      };
      var res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      var data = await res.json();
      if (data.ok) {
        document.getElementById('suggest-ok').style.display = 'block';
        ['s-title','s-desc','s-date','s-time','s-loc','s-locdetail'].forEach(function(id) { document.getElementById(id).value = ''; });
      }
    });
  </script>
</Base>
