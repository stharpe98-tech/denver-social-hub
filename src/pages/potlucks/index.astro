---
import { getDB } from '../../lib/db';
const db = getDB();
let potlucks: any[] = [];
try {
  if (db) {
    const { results } = await db.prepare(`
      SELECT p.*,
        COUNT(DISTINCT CASE WHEN r.rsvp='yes' THEN r.id END) as attendee_count,
        COUNT(DISTINCT CASE WHEN r.rsvp='yes' AND r.dish!='' THEN LOWER(r.dish) END) as dish_count
      FROM potlucks p LEFT JOIN potluck_rsvp r ON r.potluck_id=p.id
      WHERE p.status != 'pending'
      GROUP BY p.id ORDER BY p.id DESC
    `).all();
    potlucks = results ?? [];
  }
} catch(e) { console.error(e); }
const upcoming = potlucks.filter((p:any) => p.status === 'upcoming');
const past = potlucks.filter((p:any) => p.status !== 'upcoming');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Potlucks · Denver Social Community</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#0f0f0f;color:#f0ebe3;font-family:'DM Sans',sans-serif;min-height:100vh;padding-bottom:80px}
    .hero{background:linear-gradient(160deg,#1a0a00,#2d1200,#1a0a00);border-bottom:1px solid #2a1a08;padding:40px 24px 32px;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,#f77f0022,transparent 70%);pointer-events:none}
    .hero-inner{max-width:640px;margin:0 auto;position:relative;z-index:1}
    .hero h1{font-family:'Playfair Display',serif;font-size:clamp(28px,6vw,40px);color:#fff;margin-bottom:6px}
    .hero p{font-size:14px;color:#c4956a;font-style:italic;margin-bottom:16px}
    .page{max-width:640px;margin:0 auto;padding:28px 16px}
    .sec-label{font-size:10px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#6b5040;margin-bottom:14px;display:flex;align-items:center;gap:8px}
    .sec-label::after{content:'';flex:1;height:1px;background:#1a1a0a}
    .card{background:#1a1108;border:1px solid #2a1a08;border-radius:16px;padding:20px;margin-bottom:12px;text-decoration:none;display:block;transition:border-color 0.15s}
    .card:hover{border-color:#f77f00}
    .card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
    .card-title{font-family:'Playfair Display',serif;font-size:20px;color:#fff;margin-bottom:4px}
    .card-meta{font-size:13px;color:#6b5040;line-height:1.7}
    .status{padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600}
    .s-upcoming{background:rgba(247,127,0,0.15);border:1px solid rgba(247,127,0,0.3);color:#f5c842}
    .s-past{background:#1a1a1a;border:1px solid #2a2a2a;color:#4a3020}
    .card-stats{display:flex;gap:16px}
    .stat{font-size:13px;color:#6b5040}
    .stat strong{color:#c4956a}
    .empty{text-align:center;padding:40px;color:#4a3020;font-style:italic;font-size:14px}
    /* Suggest form */
    .suggest-section{margin-top:40px;padding-top:32px;border-top:1px solid #1a1a0a}
    .suggest-title{font-family:'Playfair Display',serif;font-size:20px;color:#c4956a;margin-bottom:6px}
    .suggest-sub{font-size:13px;color:#4a3020;margin-bottom:20px;font-style:italic}
    .field{margin-bottom:14px}
    .field label{display:block;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:#6b5040;margin-bottom:5px}
    input[type=text],textarea{width:100%;padding:11px 13px;background:#1a1108;border:1.5px solid #2a1a08;border-radius:9px;color:#f0ebe3;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color 0.15s}
    input::placeholder,textarea::placeholder{color:#4a3020}
    input:focus,textarea:focus{border-color:#f77f00}
    textarea{resize:vertical;min-height:64px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .submit-btn{background:linear-gradient(135deg,#c2410c,#f77f00);color:#fff;border:none;padding:13px 28px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;cursor:pointer;margin-top:4px;transition:all 0.15s;box-shadow:0 4px 16px rgba(247,127,0,0.2)}
    .submit-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(247,127,0,0.3)}
    .success-msg{background:#0d2e1a;border:1px solid #166534;border-radius:10px;padding:14px 18px;color:#4ade80;font-size:14px;margin-top:12px;display:none}
    .bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#0f0f0f;border-top:1px solid #1a1a1a;display:flex;justify-content:space-around;padding:8px 0 max(8px,env(safe-area-inset-bottom));z-index:100}
    .nav-item{display:flex;flex-direction:column;align-items:center;gap:2px;text-decoration:none;color:#4a3020;font-size:10px;font-weight:500;padding:4px 12px}
    .nav-item.active,.nav-item:hover{color:#f77f00}
    .nav-icon{font-size:20px}
  </style>
</head>
<body>
  <div class="hero">
    <div class="hero-inner">
      <h1>🍽 Potlucks</h1>
      <p>Community food events — show up, eat well, meet people</p>
    </div>
  </div>

  <div class="page">
    {upcoming.length > 0 ? (
      <div style="margin-bottom:32px">
        <div class="sec-label">Upcoming</div>
        {upcoming.map((p:any) => (
          <a href={`/potlucks/${p.id}`} class="card">
            <div class="card-top">
              <div>
                <div class="card-title">{p.title}</div>
                <div class="card-meta">
                  {p.date_label && <span>📅 {p.date_label}{p.time_label ? ` · ${p.time_label}` : ''}</span>}<br/>
                  {p.location && <span>📍 {p.location}{p.location_detail ? ` · ${p.location_detail}` : ''}</span>}
                </div>
              </div>
              <span class="status s-upcoming">Upcoming</span>
            </div>
            <div class="card-stats">
              <div class="stat">👥 <strong>{p.attendee_count || 0}</strong> signed up</div>
              <div class="stat">🍽 <strong>{p.dish_count || 0}</strong> dishes claimed</div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty">No upcoming potlucks right now — suggest one below!</div>
    )}

    {past.length > 0 && (
      <div style="margin-bottom:32px">
        <div class="sec-label">Past Events</div>
        {past.map((p:any) => (
          <a href={`/potlucks/${p.id}`} class="card">
            <div class="card-top">
              <div>
                <div class="card-title" style="color:#6b5040">{p.title}</div>
                <div class="card-meta">{p.date_label} · {p.location}</div>
              </div>
              <span class="status s-past">Past</span>
            </div>
            <div class="card-stats">
              <div class="stat">👥 <strong>{p.attendee_count || 0}</strong> attended</div>
              <div class="stat">🍽 <strong>{p.dish_count || 0}</strong> dishes</div>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- Suggest a potluck -->
    <div class="suggest-section">
      <div class="suggest-title">Got an idea for a potluck?</div>
      <div class="suggest-sub">Submit it and we'll review it. If approved it'll show up here.</div>
      <div class="field"><label>Title <span style="color:#f77f00">*</span></label><input type="text" id="s-title" placeholder="e.g. Fall Harvest Potluck"/></div>
      <div class="field"><label>Description</label><textarea id="s-desc" placeholder="What's the vibe? Any theme?"></textarea></div>
      <div class="grid2">
        <div class="field"><label>Proposed Date</label><input type="text" id="s-date" placeholder="e.g. October 18th"/></div>
        <div class="field"><label>Time</label><input type="text" id="s-time" placeholder="e.g. 1pm–5pm"/></div>
        <div class="field"><label>Location</label><input type="text" id="s-loc" placeholder="e.g. City Park"/></div>
        <div class="field"><label>Location Detail</label><input type="text" id="s-locdetail" placeholder="e.g. Near the pavilion"/></div>
      </div>
      <button class="submit-btn" onclick="suggestPotluck()">Submit idea →</button>
      <div class="success-msg" id="suggest-success">✅ Submitted! We'll review it and get it posted if approved.</div>
    </div>
  </div>

  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="nav-icon">🏠</span>Home</a>
    <a href="/events" class="nav-item"><span class="nav-icon">📅</span>Events</a>
    <a href="/potlucks" class="nav-item active"><span class="nav-icon">🍽</span>Potlucks</a>
    <a href="/recs" class="nav-item"><span class="nav-icon">⭐</span>Recs</a>
  </nav>

  <script>
    async function suggestPotluck() {
      const title = document.getElementById('s-title').value.trim();
      if (!title) { document.getElementById('s-title').style.borderColor = '#f87171'; return; }
      const body = { action:'suggest', title, description: document.getElementById('s-desc').value, date_label: document.getElementById('s-date').value, time_label: document.getElementById('s-time').value, location: document.getElementById('s-loc').value, location_detail: document.getElementById('s-locdetail').value };
      const res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (data.ok) {
        document.getElementById('suggest-success').style.display = 'block';
        ['s-title','s-date','s-time','s-loc','s-locdetail'].forEach(id => (document.getElementById(id) as HTMLInputElement).value = '');
        (document.getElementById('s-desc') as HTMLTextAreaElement).value = '';
      }
    }
  </script>
</body>
</html>
