---
import { getDB } from '../../lib/db';
const db = getDB();
let potlucks: any[] = [];
try {
  if (db) {
    const { results } = await db.prepare(`
      SELECT p.*, COUNT(DISTINCT CASE WHEN r.rsvp='yes' THEN r.id END) as attendee_count,
        COUNT(DISTINCT CASE WHEN r.rsvp='yes' AND r.dish!='' THEN LOWER(r.dish) END) as dish_count
      FROM potlucks p LEFT JOIN potluck_rsvp r ON r.potluck_id=p.id
      WHERE p.status != 'pending' GROUP BY p.id ORDER BY p.id DESC
    `).all();
    potlucks = results ?? [];
  }
} catch(e) { console.error(e); }
const upcoming = potlucks.filter((p:any) => p.status === 'upcoming');
const past = potlucks.filter((p:any) => p.status !== 'upcoming');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Potlucks · Denver Social Community</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #f7f5f2; color: #1c1917; font-family: 'DM Sans', sans-serif; min-height: 100vh; }
    body { padding-bottom: 90px; -webkit-overflow-scrolling: touch; }

    .hub-hero { background: linear-gradient(160deg,#fff8f0,#fef3e0,#fff8f0); border-bottom: 1px solid #e4ddd4; padding: 40px 20px 32px; position: relative; overflow: hidden; }
    .hub-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%,#f77f0022,transparent 70%); pointer-events: none; }
    .hub-hi { max-width: 600px; margin: 0 auto; position: relative; z-index: 1; }
    .hub-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(28px,7vw,40px); color: #1c1917; margin-bottom: 6px; }
    .hub-hero p { font-size: 14px; color: #8a6a40; font-style: italic; }

    .hub-page { max-width: 600px; margin: 0 auto; padding: 24px 16px; }

    .hub-sec { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #8a7a70; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
    .hub-sec::after { content: ''; flex: 1; height: 1px; background: #1a1a0a; }

    .hub-card { background: #ffffff; border: 1px solid #e4ddd4; border-radius: 16px; padding: 18px; margin-bottom: 12px; text-decoration: none; display: block; transition: border-color 0.15s; -webkit-tap-highlight-color: transparent; }
    .hub-card:active { border-color: #f77f00; }
    .hub-card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
    .hub-card-title { font-family: 'Playfair Display', serif; font-size: 18px; color: #1c1917; margin-bottom: 4px; }
    .hub-card-meta { font-size: 13px; color: #8a7a70; line-height: 1.7; }
    .hub-status { padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 600; flex-shrink: 0; }
    .hub-s-up { background: rgba(247,127,0,0.15); border: 1px solid rgba(247,127,0,0.3); color: #92400e; }
    .hub-s-past { background: #1a1a1a; border: 1px solid #2a2a2a; color: #a09890; }
    .hub-stats { display: flex; gap: 16px; flex-wrap: wrap; }
    .hub-stat { font-size: 13px; color: #8a7a70; }
    .hub-stat strong { color: #8a6a40; }

    .hub-empty { text-align: center; padding: 32px 16px; color: #a09890; font-style: italic; font-size: 14px; }

    .hub-suggest { margin-top: 36px; padding-top: 28px; border-top: 1px solid #1a1a0a; }
    .hub-suggest-title { font-family: 'Playfair Display', serif; font-size: 20px; color: #8a6a40; margin-bottom: 6px; }
    .hub-suggest-sub { font-size: 13px; color: #a09890; margin-bottom: 20px; font-style: italic; }

    .hub-field { margin-bottom: 14px; }
    .hub-field label { display: block; font-size: 12px; font-weight: 600; color: #8a7a70; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; }
    .hub-input { width: 100%; padding: 12px 14px; background: #ffffff; border: 1.5px solid #e4ddd4; border-radius: 10px; color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 15px; outline: none; transition: border-color 0.15s; -webkit-appearance: none; }
    .hub-input:focus { border-color: #f77f00; }
    .hub-input::placeholder { color: #a09890; }
    .hub-textarea { width: 100%; padding: 12px 14px; background: #ffffff; border: 1.5px solid #e4ddd4; border-radius: 10px; color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 15px; outline: none; resize: vertical; min-height: 72px; -webkit-appearance: none; }
    .hub-textarea:focus { border-color: #f77f00; }
    .hub-textarea::placeholder { color: #a09890; }

    .hub-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media(max-width: 400px) { .hub-row2 { grid-template-columns: 1fr; } }

    .hub-submit { width: 100%; padding: 15px; border-radius: 12px; border: none; background: linear-gradient(135deg,#c2410c,#f77f00); color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 600; cursor: pointer; margin-top: 4px; box-shadow: 0 4px 16px rgba(247,127,0,0.2); -webkit-tap-highlight-color: transparent; }
    .hub-success { background: #0d2e1a; border: 1px solid #166534; border-radius: 10px; padding: 14px 18px; color: #4ade80; font-size: 14px; margin-top: 12px; display: none; }

    .hub-nav { position: fixed; bottom: 0; left: 0; right: 0; background: #f7f5f2; border-top: 1px solid #1a1a1a; display: flex; justify-content: space-around; padding: 8px 0 max(8px, env(safe-area-inset-bottom)); z-index: 100; }
    .hub-nav a { display: flex; flex-direction: column; align-items: center; gap: 2px; text-decoration: none; color: #a09890; font-size: 10px; font-weight: 500; padding: 4px 12px; -webkit-tap-highlight-color: transparent; }
    .hub-nav a.active { color: #f77f00; }
    .hub-nav-icon { font-size: 20px; }
  </style>
</head>
<body>
  <div class="hub-hero">
    <div class="hub-hi">
      <h1>🍽 Potlucks</h1>
      <p>Community food events — show up, eat well, meet people</p>
    </div>
  </div>

  <div class="hub-page">
    {upcoming.length > 0 ? (
      <div style="margin-bottom:32px">
        <div class="hub-sec">Upcoming</div>
        {upcoming.map((p:any) => (
          <a href={`/potlucks/${p.id}`} class="hub-card">
            <div class="hub-card-top">
              <div>
                <div class="hub-card-title">{p.title}</div>
                <div class="hub-card-meta">
                  {p.date_label && <span>📅 {p.date_label}{p.time_label ? ` · ${p.time_label}` : ''}<br/></span>}
                  {p.location && <span>📍 {p.location}{p.location_detail ? ` · ${p.location_detail}` : ''}</span>}
                </div>
              </div>
              <span class="hub-status hub-s-up">Upcoming</span>
            </div>
            <div class="hub-stats">
              <div class="hub-stat">👥 <strong>{p.attendee_count || 0}</strong> signed up</div>
              <div class="hub-stat">🍽 <strong>{p.dish_count || 0}</strong> dishes claimed</div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="hub-empty">No upcoming potlucks — suggest one below!</div>
    )}

    {past.length > 0 && (
      <div style="margin-bottom:32px">
        <div class="hub-sec">Past</div>
        {past.map((p:any) => (
          <a href={`/potlucks/${p.id}`} class="hub-card">
            <div class="hub-card-top">
              <div>
                <div class="hub-card-title" style="color:#8a7a70">{p.title}</div>
                <div class="hub-card-meta">{p.date_label} · {p.location}</div>
              </div>
              <span class="hub-status hub-s-past">Past</span>
            </div>
            <div class="hub-stats">
              <div class="hub-stat">👥 <strong>{p.attendee_count || 0}</strong> attended</div>
              <div class="hub-stat">🍽 <strong>{p.dish_count || 0}</strong> dishes</div>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="hub-suggest">
      <div class="hub-suggest-title">Got an idea for a potluck?</div>
      <div class="hub-suggest-sub">Submit it — if approved it'll show up here.</div>

      <div class="hub-field"><label>Title *</label><input type="text" id="s-title" class="hub-input" placeholder="e.g. Fall Harvest Potluck"/></div>
      <div class="hub-field"><label>Description</label><textarea id="s-desc" class="hub-textarea" placeholder="What's the vibe?"></textarea></div>
      <div class="hub-row2">
        <div class="hub-field"><label>Date</label><input type="text" id="s-date" class="hub-input" placeholder="Oct 18th"/></div>
        <div class="hub-field"><label>Time</label><input type="text" id="s-time" class="hub-input" placeholder="1pm–5pm"/></div>
        <div class="hub-field"><label>Location</label><input type="text" id="s-loc" class="hub-input" placeholder="City Park"/></div>
        <div class="hub-field"><label>Detail</label><input type="text" id="s-locdetail" class="hub-input" placeholder="Near the pavilion"/></div>
      </div>
      <button class="hub-submit" id="suggest-btn">Submit idea →</button>
      <div class="hub-success" id="suggest-ok">✅ Submitted! We'll review it and post it if approved.</div>
    </div>
  </div>

  <nav class="hub-nav">
    <a href="/"><span class="hub-nav-icon">🏠</span>Home</a>
    <a href="/events"><span class="hub-nav-icon">📅</span>Events</a>
    <a href="/potlucks" class="active"><span class="hub-nav-icon">🍽</span>Potlucks</a>
    <a href="/recs"><span class="hub-nav-icon">⭐</span>Recs</a>
  </nav>

  <script is:inline>
    document.getElementById('suggest-btn').addEventListener('click', async function() {
      var title = document.getElementById('s-title').value.trim();
      if (!title) { document.getElementById('s-title').style.borderColor = '#f87171'; return; }
      var body = {
        action: 'suggest',
        title: title,
        description: document.getElementById('s-desc').value,
        date_label: document.getElementById('s-date').value,
        time_label: document.getElementById('s-time').value,
        location: document.getElementById('s-loc').value,
        location_detail: document.getElementById('s-locdetail').value
      };
      var res = await fetch('/api/potlucks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      var data = await res.json();
      if (data.ok) {
        document.getElementById('suggest-ok').style.display = 'block';
        ['s-title','s-date','s-time','s-loc','s-locdetail'].forEach(function(id) { document.getElementById(id).value = ''; });
        document.getElementById('s-desc').value = '';
      }
    });
  </script>
</body>
</html>
