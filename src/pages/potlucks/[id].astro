---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
let slots: any[] = [];
let signups: any[] = [];

try {
  if (db && id) {
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
    if (potluck?.locked) return Astro.redirect('/potlucks');

    // Slots with claim counts (aggregated)
    const s = await db.prepare(`
      SELECT ps.id, ps.suggestion, ps.category, ps.sort_order, ps.max_claims,
        COUNT(pr.id) as claim_count,
        GROUP_CONCAT(pr.name, ', ') as claimed_names
      FROM potluck_slots ps
      LEFT JOIN potluck_rsvp pr ON LOWER(pr.dish)=LOWER(ps.suggestion)
        AND pr.potluck_id=ps.potluck_id AND pr.rsvp='yes'
      WHERE ps.potluck_id=?
      GROUP BY ps.id
      ORDER BY ps.sort_order ASC
    `).bind(id).all();
    slots = s?.results ?? [];

    // All sign-ups
    const r = await db.prepare(
      `SELECT name, dish, dish_category, guest_count FROM potluck_rsvp WHERE potluck_id=? AND rsvp='yes' ORDER BY created_at ASC`
    ).bind(id).all();
    signups = r?.results ?? [];
  }
} catch (e) { console.error(e); }
if (!potluck) return Astro.redirect('/potlucks');

const guestTotal = signups.reduce((sum: number, s: any) => sum + (parseInt(s.guest_count) || 1), 0);
const totalSlots = slots.reduce((sum: number, s: any) => sum + (s.max_claims < 900 ? s.max_claims : 1), 0);
const totalClaimed = slots.reduce((sum: number, s: any) => sum + s.claim_count, 0);

// Group slots by category
const slotGroupKeys: string[] = [];
const slotGroups: Record<string, any[]> = {};
for (const s of slots) {
  const cat = s.category || 'Other';
  if (!slotGroups[cat]) { slotGroups[cat] = []; slotGroupKeys.push(cat); }
  slotGroups[cat].push(s);
}
---
<Base title={potluck.title} description={potluck.description ?? `Sign up for ${potluck.title}`}>

<style>
  /* ── Layout ─────────────────────────────────────────── */
  .pk { max-width: 620px; margin: 0 auto; padding: 0 var(--space-4) var(--space-8); }

  /* ── Hero ────────────────────────────────────────────── */
  .pk-hero {
    text-align: center;
    padding: var(--space-6) var(--space-4) var(--space-5);
    background: linear-gradient(160deg, #F0F9FF 0%, #ECFDF5 50%, #FEF3C7 100%);
    border-bottom: 1px solid var(--border);
  }
  .pk-emoji { font-size: 56px; margin-bottom: var(--space-2); }
  .pk-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 6vw, 38px);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-2);
    line-height: 1.15;
  }
  .pk-meta {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: var(--space-2);
    font-size: 14px; color: var(--text-sec);
    margin-bottom: var(--space-3);
  }
  .pk-meta span {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 999px; padding: 5px 12px;
  }
  .pk-desc {
    font-size: 15px; color: var(--text-sec); line-height: 1.6;
    max-width: 480px; margin: 0 auto;
  }
  .pk-desc-detail { margin-top: 6px; font-size: 13px; }

  /* ── Stats strip ────────────────────────────────────── */
  .pk-stats {
    display: flex; justify-content: center; gap: var(--space-5);
    padding: var(--space-4) var(--space-4) 0;
    max-width: 620px; margin: 0 auto;
  }
  .pk-stat { text-align: center; }
  .pk-stat-num {
    font-family: var(--font-display); font-size: 28px; font-weight: 800;
    color: var(--accent);
  }
  .pk-stat-label { font-size: 12px; color: var(--text-sec); margin-top: 2px; }

  /* ── RSVP card ──────────────────────────────────────── */
  .pk-rsvp {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .pk-rsvp.success {
    border-color: var(--green);
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
  }
  .pk-step-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1.5px; color: var(--accent); margin-bottom: var(--space-2);
  }
  .pk-step-title {
    font-family: var(--font-display); font-size: 20px; font-weight: 700;
    color: var(--text); margin-bottom: var(--space-3);
  }

  /* Fields */
  .pk-fields { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-bottom: var(--space-3); }
  @media (max-width: 500px) { .pk-fields { grid-template-columns: 1fr; } }
  .pk-field label {
    display: block; font-size: 12px; font-weight: 600;
    color: var(--text-sec); margin-bottom: 4px;
  }
  .pk-field label .opt { font-weight: 400; color: var(--text-faint); }
  .pk-input, .pk-select {
    width: 100%; padding: 11px 14px;
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: 10px; font-size: 15px; color: var(--text);
    font-family: var(--font); outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .pk-input:focus, .pk-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .pk-input.invalid { border-color: #EF4444; }

  .pk-guests {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: var(--space-3);
  }
  .pk-guests-label { font-size: 13px; color: var(--text-sec); font-weight: 600; }
  .pk-guests button {
    width: 34px; height: 34px; border-radius: 8px;
    border: 1.5px solid var(--border); background: var(--bg);
    color: var(--text-sec); font-size: 18px; font-weight: 600;
    cursor: pointer; font-family: inherit;
    transition: border-color 0.15s;
  }
  .pk-guests button:hover { border-color: var(--accent); color: var(--accent); }
  .pk-guests .count { font-weight: 700; font-size: 16px; min-width: 24px; text-align: center; color: var(--text); }
  .pk-guests .note { font-size: 13px; color: var(--text-faint); }

  /* CTA */
  .pk-cta {
    width: 100%; padding: 14px;
    border-radius: var(--radius-pill);
    border: none; cursor: pointer;
    background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font-display); font-size: 17px; font-weight: 700;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.3);
    transition: box-shadow 0.2s, transform 0.15s;
  }
  .pk-cta:hover { box-shadow: 0 6px 20px rgba(14, 165, 233, 0.4); transform: translateY(-1px); }
  .pk-cta:active { transform: scale(0.98); }
  .pk-cta:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  /* Step 2 — Slot Picker */
  #step2 { display: none; }
  .pk-pick-intro { font-size: 14px; color: var(--text-sec); margin-bottom: var(--space-3); line-height: 1.5; }

  .pk-slot-cat {
    font-size: 11px; font-weight: 700; color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 1.2px;
    margin-top: var(--space-3); margin-bottom: var(--space-2);
  }
  .pk-slot-cat:first-child { margin-top: 0; }
  .pk-slot-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 14px; margin-bottom: 6px;
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: 10px; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .pk-slot-item:hover { border-color: var(--accent); background: var(--bg); }
  .pk-slot-item.selected { border-color: var(--green); background: rgba(16, 185, 129, 0.06); }
  .pk-slot-item.full { opacity: 0.45; cursor: default; }
  .pk-slot-item.full:hover { border-color: var(--border); background: var(--surface); }
  .pk-slot-item input[type="radio"] {
    width: 18px; height: 18px; accent-color: var(--green);
    cursor: pointer; flex-shrink: 0;
  }
  .pk-slot-item.full input[type="radio"] { cursor: default; }
  .pk-slot-item .name { flex: 1; font-size: 14px; color: var(--text); font-weight: 500; }
  .pk-slot-item .progress {
    font-size: 12px; color: var(--text-faint); font-weight: 600;
    white-space: nowrap;
  }
  .pk-slot-item .progress.has-claims { color: var(--green); }
  .pk-slot-item .badge {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.5px; padding: 2px 8px; border-radius: 999px;
  }
  .pk-slot-item .badge.open { color: var(--accent); background: var(--accent-dim); }
  .pk-slot-item .badge.full { color: var(--text-faint); background: var(--surface-hover); }

  .pk-step2-btns { display: flex; gap: var(--space-2); margin-top: var(--space-4); }
  .pk-skip {
    flex: 1; padding: 12px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--border);
    background: var(--bg); color: var(--text-sec);
    font-family: var(--font); font-size: 14px; font-weight: 600;
    cursor: pointer; transition: border-color 0.15s;
  }
  .pk-skip:hover { border-color: var(--text-sec); color: var(--text); }
  .pk-save {
    flex: 2; padding: 12px;
    border-radius: var(--radius-pill);
    border: none; cursor: pointer;
    background: var(--green); color: #fff;
    font-family: var(--font-display); font-size: 15px; font-weight: 700;
    transition: box-shadow 0.2s, transform 0.15s;
  }
  .pk-save:hover { box-shadow: 0 4px 14px rgba(16, 185, 129, 0.35); transform: translateY(-1px); }
  .pk-save:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  .pk-error { font-size: 13px; color: #EF4444; margin-top: var(--space-2); display: none; }
  .pk-error.show { display: block; }

  /* ── Section headings ──────────────────────────────── */
  .pk-section-title {
    font-family: var(--font-display); font-size: 18px; font-weight: 700;
    color: var(--text); margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--surface);
  }

  /* ── Sign-up sheet (view) ──────────────────────────── */
  .pk-sheet-cat {
    font-size: 11px; font-weight: 700; color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-top: var(--space-3); margin-bottom: var(--space-2);
    display: flex; align-items: center; gap: 8px;
  }
  .pk-sheet-cat::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .pk-sheet-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; margin-bottom: 6px;
    border-radius: 10px;
  }
  .pk-sheet-item.open {
    background: var(--surface); border: 1.5px dashed var(--border);
  }
  .pk-sheet-item.taken {
    background: rgba(16, 185, 129, 0.04);
    border: 1px solid rgba(16, 185, 129, 0.12);
  }
  .pk-sheet-name { flex: 1; font-size: 14px; font-weight: 500; color: var(--text); }
  .pk-sheet-who { font-size: 13px; color: var(--green); font-weight: 600; }
  .pk-sheet-badge {
    font-size: 11px; font-weight: 700; color: var(--accent);
    background: var(--accent-dim); border-radius: 999px;
    padding: 2px 10px;
  }
  .pk-sheet-progress {
    font-size: 11px; color: var(--text-faint); font-weight: 600;
  }

  /* ── Who's coming ───────────────────────────────────── */
  .pk-guest {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--surface-hover);
  }
  .pk-guest:last-child { border-bottom: none; }
  .pk-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--green));
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; flex-shrink: 0;
  }
  .pk-guest-name { font-size: 14px; font-weight: 600; color: var(--text); }
  .pk-guest-dish { font-size: 12px; color: var(--text-sec); }
  .pk-guest-plus { margin-left: auto; font-size: 12px; color: var(--accent); font-weight: 600; }
  .pk-empty { padding: var(--space-5); text-align: center; color: var(--text-faint); font-style: italic; }

  /* ── Manage RSVP section ───────────────────────────── */
  .pk-manage {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: var(--space-4);
    margin-bottom: var(--space-5);
  }
  .pk-manage-title {
    font-family: var(--font-display); font-size: 16px; font-weight: 700;
    color: var(--text); margin-bottom: var(--space-2);
  }
  .pk-manage-sub { font-size: 13px; color: var(--text-sec); margin-bottom: var(--space-3); line-height: 1.5; }
  .pk-manage-fields { display: flex; gap: var(--space-2); margin-bottom: var(--space-2); }
  @media (max-width: 500px) { .pk-manage-fields { flex-direction: column; } }
  .pk-manage-fields .pk-input { flex: 1; padding: 10px 12px; font-size: 14px; }
  .pk-manage-btn {
    padding: 10px 20px; border-radius: var(--radius-pill);
    border: 1.5px solid var(--accent); background: var(--bg);
    color: var(--accent); font-family: var(--font); font-size: 13px;
    font-weight: 600; cursor: pointer; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .pk-manage-btn:hover { background: var(--accent); color: #fff; }
  .pk-manage-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .pk-manage-err { font-size: 12px; color: #EF4444; margin-top: var(--space-1); display: none; }
  .pk-manage-err.show { display: block; }

  /* ── Actions row ────────────────────────────────────── */
  .pk-actions {
    display: flex; gap: var(--space-3); justify-content: center;
    margin-bottom: var(--space-5); flex-wrap: wrap;
  }
  .pk-action-btn {
    background: none; border: none; color: var(--text-sec);
    font-size: 13px; cursor: pointer; padding: 0;
    font-family: inherit; display: inline-flex;
    align-items: center; gap: 4px;
    text-decoration: none;
  }
  .pk-action-btn:hover { color: var(--text); }

  /* ── Toast ──────────────────────────────────────────── */
  .pk-toast {
    position: fixed; bottom: 24px; left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--green); color: #fff;
    padding: 12px 24px; border-radius: 999px;
    font-size: 14px; font-weight: 600;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    z-index: 1000; opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .pk-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

  /* ── Confirmation overlay ───────────────────────────── */
  .pk-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(15,23,42,0.55); z-index: 1000;
    align-items: center; justify-content: center; padding: 20px;
  }
  .pk-overlay.show { display: flex; }
  .pk-overlay-card {
    background: var(--bg); border-radius: var(--radius-lg);
    max-width: 440px; width: 100%; padding: var(--space-5);
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    text-align: center;
  }
  .pk-overlay-emoji { font-size: 48px; margin-bottom: var(--space-2); }
  .pk-overlay h2 {
    font-family: var(--font-display); font-size: 24px;
    font-weight: 800; margin-bottom: 4px;
  }
  .pk-overlay-sub { color: var(--text-sec); font-size: 14px; margin-bottom: var(--space-4); }
  .pk-overlay-block {
    background: var(--surface); border-radius: 12px;
    padding: 14px 16px; margin-bottom: 10px; text-align: left;
  }
  .pk-overlay-block-label {
    font-size: 11px; font-weight: 700; color: var(--text-sec);
    text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;
  }
  .pk-overlay-block.pay { background: #FEF3C7; }
  .pk-overlay-block.pay .pk-overlay-block-label { color: #92400E; }
  .pk-overlay-rows { font-size: 14px; color: var(--text); line-height: 1.7; }
  .pk-overlay-rows a { color: var(--accent); font-weight: 600; }
  .pk-overlay-ok {
    width: 100%; padding: 13px; border-radius: var(--radius-pill);
    border: none; background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font-display); font-size: 15px; font-weight: 700;
    cursor: pointer; margin-top: var(--space-3);
  }
</style>

<!-- ── HERO ────────────────────────────────────────────── -->
<section class="pk-hero">
  <div class="pk-emoji">🍽️</div>
  <h1 class="pk-title">{potluck.title}</h1>
  <div class="pk-meta">
    {potluck.date_label && <span>📅 {potluck.date_label}{potluck.time_label ? ` · ${potluck.time_label}` : ''}</span>}
    {potluck.location && <span>📍 {potluck.location}</span>}
  </div>
  {potluck.description && <p class="pk-desc">{potluck.description}</p>}
  {potluck.location_detail && <p class="pk-desc pk-desc-detail">{potluck.location_detail}</p>}
</section>

<!-- ── STATS ──────────────────────────────────────────── -->
<div class="pk-stats">
  <div class="pk-stat">
    <div class="pk-stat-num">{guestTotal}</div>
    <div class="pk-stat-label">{guestTotal === 1 ? 'person' : 'people'} coming</div>
  </div>
  <div class="pk-stat">
    <div class="pk-stat-num">{totalClaimed}/{slots.length}</div>
    <div class="pk-stat-label">items claimed</div>
  </div>
</div>

<div class="pk">
  <!-- ── ACTIONS ────────────────────────────────────────── -->
  <div class="pk-actions" style="margin-top:var(--space-4)">
    <button class="pk-action-btn" id="copy-link">🔗 Copy link</button>
    <a href={`/potlucks/${id}/poster`} class="pk-action-btn">🖼 Poster</a>
    <a href={`/potlucks/manage/${id}`} class="pk-action-btn">⚙️ Manage</a>
  </div>

  <!-- ── RSVP CARD ──────────────────────────────────────── -->
  <div class="pk-rsvp" id="rsvp-card">

    <!-- STEP 1: Quick sign-up -->
    <div id="step1">
      <div class="pk-step-label">Step 1</div>
      <div class="pk-step-title">Count me in! 🎉</div>

      <div class="pk-fields">
        <div class="pk-field">
          <label>First name *</label>
          <input type="text" class="pk-input" id="f-first" placeholder="Jamie" autocomplete="given-name"/>
        </div>
        <div class="pk-field">
          <label>Last name <span class="opt">(optional)</span></label>
          <input type="text" class="pk-input" id="f-last" placeholder="Doe" autocomplete="family-name"/>
        </div>
        <div class="pk-field">
          <label>Email <span class="opt">(for reminders)</span></label>
          <input type="email" class="pk-input" id="f-email" placeholder="you@example.com" autocomplete="email"/>
        </div>
        <div class="pk-field">
          <label>Phone <span class="opt">(for SMS)</span></label>
          <input type="tel" class="pk-input" id="f-phone" placeholder="(720) 555-1234" autocomplete="tel"/>
        </div>
      </div>

      <div class="pk-guests">
        <span class="pk-guests-label">How many?</span>
        <button type="button" id="g-minus">−</button>
        <span class="count" id="g-count">1</span>
        <button type="button" id="g-plus">+</button>
        <span class="note" id="g-note">just me</span>
      </div>

      <button class="pk-cta" id="step1-btn">I'm in! 🎉</button>
      <div class="pk-error" id="step1-err"></div>
    </div>

    <!-- STEP 2: Pick what to bring (SignUpGenius-style) -->
    <div id="step2">
      <div class="pk-step-label">Step 2</div>
      <div class="pk-step-title">What would you like to bring? 🥘</div>
      <p class="pk-pick-intro">Pick an item from the list below, or skip if you're just coming to hang out!</p>

      <div id="slot-picker">
        {slotGroupKeys.map((cat) => {
          const items = slotGroups[cat];
          return (
            <>
              <div class="pk-slot-cat">{cat}</div>
              {items.map((item: any) => {
                const isFull = item.max_claims < 900 && item.claim_count >= item.max_claims;
                const spotsLeft = item.max_claims < 900 ? item.max_claims - item.claim_count : null;
                return (
                  <label class={`pk-slot-item ${isFull ? 'full' : ''}`}>
                    <input type="radio" name="slot-pick" value={item.suggestion}
                      data-category={item.category} disabled={isFull} />
                    <span class="name">{item.suggestion}</span>
                    {isFull ? (
                      <span class="badge full">Full</span>
                    ) : item.claim_count > 0 ? (
                      <span class={`progress has-claims`}>
                        {spotsLeft !== null ? `${spotsLeft} spot${spotsLeft !== 1 ? 's' : ''} left` : 'Open'}
                      </span>
                    ) : (
                      <span class="badge open">Needed</span>
                    )}
                  </label>
                );
              })}
            </>
          );
        })}
      </div>

      <div class="pk-step2-btns">
        <button class="pk-skip" id="skip-btn">Just showing up</button>
        <button class="pk-save" id="save-btn">Sign up with this item 🎉</button>
      </div>
      <div class="pk-error" id="step2-err"></div>
    </div>
  </div>

  <!-- ── MANAGE YOUR RSVP ──────────────────────────────── -->
  <div class="pk-manage" id="manage-section">
    <div class="pk-manage-title">Already signed up?</div>
    <div class="pk-manage-sub">Enter your name or email to edit or cancel your sign-up.</div>
    <div class="pk-manage-fields">
      <input type="text" class="pk-input" id="m-lookup" placeholder="Your name or email" autocomplete="off"/>
      <button class="pk-manage-btn" id="m-lookup-btn">Find my RSVP</button>
    </div>
    <div class="pk-manage-err" id="m-lookup-err"></div>
  </div>

  <!-- ── SIGN-UP SHEET ───────────────────────────────── -->
  <div class="pk-section-title">
    Sign-up sheet ({totalClaimed}/{slots.length} items claimed)
  </div>
  {slotGroupKeys.map((cat) => {
    const items = slotGroups[cat];
    return (
      <>
        <div class="pk-sheet-cat"><span>{cat}</span></div>
        {items.map((item: any) => {
          const isFull = item.max_claims < 900 && item.claim_count >= item.max_claims;
          return item.claim_count > 0 ? (
            <div class="pk-sheet-item taken">
              <span style="font-size:16px">✅</span>
              <span class="pk-sheet-name">{item.suggestion}</span>
              <span class="pk-sheet-who">{item.claimed_names}</span>
              {item.max_claims < 900 && item.claim_count < item.max_claims && (
                <span class="pk-sheet-progress">{item.max_claims - item.claim_count} more needed</span>
              )}
            </div>
          ) : (
            <div class="pk-sheet-item open">
              <span style="font-size:16px">⬜</span>
              <span class="pk-sheet-name">{item.suggestion}</span>
              <span class="pk-sheet-badge">Needed</span>
            </div>
          );
        })}
      </>
    );
  })}

  <!-- ── WHO'S COMING ─────────────────────────────────── -->
  <div class="pk-section-title" style="margin-top:var(--space-6)">Who's coming ({guestTotal})</div>
  {signups.length === 0 ? (
    <div class="pk-empty">Nobody's signed up yet — be the first!</div>
  ) : signups.filter((s: any) => parseInt(s.guest_count) > 0).map((s: any) => (
    <div class="pk-guest">
      <div class="pk-avatar">{(s.name || '?').split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase()}</div>
      <div>
        <div class="pk-guest-name">{s.name}</div>
        <div class="pk-guest-dish">{s.dish || 'Just showing up 🎉'}</div>
      </div>
      {s.guest_count > 1 && <div class="pk-guest-plus">+{s.guest_count - 1}</div>}
    </div>
  ))}
</div>

<!-- Toast -->
<div class="pk-toast" id="toast"></div>

<!-- Confirmation overlay -->
<div class="pk-overlay" id="confirm-overlay">
  <div class="pk-overlay-card">
    <div class="pk-overlay-emoji">🎉</div>
    <h2 id="confirm-title">You're in!</h2>
    <div class="pk-overlay-sub">Confirmation email is on the way.</div>
    <div class="pk-overlay-block" id="confirm-contact" style="display:none">
      <div class="pk-overlay-block-label">Stay in touch</div>
      <div class="pk-overlay-rows" id="confirm-contact-rows"></div>
    </div>
    <div class="pk-overlay-block pay" id="confirm-pay" style="display:none">
      <div class="pk-overlay-block-label">Want to chip in?</div>
      <div class="pk-overlay-rows" id="confirm-pay-rows"></div>
    </div>
    <button class="pk-overlay-ok" id="confirm-ok">Got it ✨</button>
  </div>
</div>

<script is:inline define:vars={{ potluckId: id }}>
(function () {
  var guestCount = 1;

  function $(id) { return document.getElementById(id); }
  function val(id) { var el = $(id); return el ? el.value.trim() : ''; }
  function guestNote(n) { return n === 1 ? 'just me' : '+ ' + (n - 1) + (n === 2 ? ' guest' : ' guests'); }
  function escHtml(s) {
    return String(s || '').replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  // ── Guest counter ────────────────────────────────────
  $('g-minus').addEventListener('click', function () {
    guestCount = Math.max(1, guestCount - 1);
    $('g-count').textContent = guestCount;
    $('g-note').textContent = guestNote(guestCount);
  });
  $('g-plus').addEventListener('click', function () {
    guestCount = Math.min(20, guestCount + 1);
    $('g-count').textContent = guestCount;
    $('g-note').textContent = guestNote(guestCount);
  });

  // ── Step 1 → Step 2 ─────────────────────────────────
  $('step1-btn').addEventListener('click', function () {
    var first = val('f-first');
    if (!first) {
      $('f-first').classList.add('invalid');
      $('f-first').focus();
      return;
    }
    $('f-first').classList.remove('invalid');
    $('step1').style.display = 'none';
    $('step2').style.display = 'block';
    $('rsvp-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // ── Highlight selected slot ──────────────────────────
  var slotRadios = document.querySelectorAll('#slot-picker input[type="radio"]');
  slotRadios.forEach(function (radio) {
    radio.addEventListener('change', function () {
      document.querySelectorAll('.pk-slot-item').forEach(function (el) {
        el.classList.remove('selected');
      });
      if (radio.checked) {
        radio.closest('.pk-slot-item').classList.add('selected');
      }
    });
  });

  // ── Skip → submit with no dish ──────────────────────
  $('skip-btn').addEventListener('click', function () {
    submitRsvp('', '');
  });

  // ── Save pick → submit with chosen slot ─────────────
  $('save-btn').addEventListener('click', function () {
    var selected = document.querySelector('#slot-picker input[type="radio"]:checked');
    if (!selected) {
      $('step2-err').textContent = 'Pick an item from the list, or tap "Just showing up".';
      $('step2-err').classList.add('show');
      return;
    }
    $('step2-err').classList.remove('show');
    submitRsvp(selected.value, selected.getAttribute('data-category') || '');
  });

  // ── Submit to API ────────────────────────────────────
  function submitRsvp(dish, dishCategory) {
    var btn = $('save-btn');
    var errId = 'step2-err';
    var origText = btn.textContent;
    btn.disabled = true;
    $('skip-btn').disabled = true;
    btn.textContent = 'Saving…';

    var first = val('f-first');
    var last = val('f-last');
    var name = last ? first + ' ' + last : first;

    fetch('/api/potluck', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        potluckId: String(potluckId),
        name: name,
        email: val('f-email'),
        phone: val('f-phone'),
        handle: '', platforms: '',
        rsvp: 'yes',
        guestCount: String(guestCount),
        dish: dish,
        dishCategory: dishCategory,
        dietary: '', notes: '',
        utensils: false, earlyArrive: false, seating: false,
        _gotcha: '', _turnstile: '',
      }),
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      if (!data.ok) {
        $(errId).textContent = data.error === 'slot_full'
          ? 'Someone just claimed that — try another!'
          : 'Something went wrong — try again.';
        $(errId).classList.add('show');
        btn.disabled = false;
        $('skip-btn').disabled = false;
        btn.textContent = origText;
        return;
      }
      showConfirm(first, data.contact || {});
    })
    .catch(function () {
      $(errId).textContent = 'Network problem — try again.';
      $(errId).classList.add('show');
      btn.disabled = false;
      $('skip-btn').disabled = false;
      btn.textContent = origText;
    });
  }

  // ── Confirmation overlay ─────────────────────────────
  function showConfirm(firstName, contact) {
    $('confirm-title').textContent = "You're in, " + firstName + '!';

    var ccRows = [];
    if (contact.phone) ccRows.push('<div>📞 ' + escHtml(contact.phone) + '</div>');
    if (contact.discord_url) {
      ccRows.push('<div>💬 <a href="' + escHtml(contact.discord_url) + '" target="_blank" rel="noopener">Join Discord</a>' + (contact.discord ? ' · ' + escHtml(contact.discord) : '') + '</div>');
    } else if (contact.discord) {
      ccRows.push('<div>💬 ' + escHtml(contact.discord) + '</div>');
    }
    if (ccRows.length) {
      $('confirm-contact-rows').innerHTML = ccRows.join('');
      $('confirm-contact').style.display = 'block';
    }

    var payRows = [];
    if (contact.venmo) payRows.push('<div>💸 Venmo: <a href="https://venmo.com/' + escHtml(String(contact.venmo).replace(/^@/, '')) + '" target="_blank" rel="noopener">' + escHtml(contact.venmo) + '</a></div>');
    if (contact.cashapp_handle) payRows.push('<div>💵 Cash App: <a href="https://cash.app/' + escHtml(String(contact.cashapp_handle).replace(/^\$/, '$')) + '" target="_blank" rel="noopener">' + escHtml(contact.cashapp_handle) + '</a></div>');
    if (contact.stripe_link) payRows.push('<div>💳 <a href="' + escHtml(contact.stripe_link) + '" target="_blank" rel="noopener">Pay with card</a></div>');
    if (payRows.length) {
      $('confirm-pay-rows').innerHTML = payRows.join('');
      $('confirm-pay').style.display = 'block';
    }

    $('rsvp-card').classList.add('success');
    $('confirm-overlay').classList.add('show');
  }

  $('confirm-ok').addEventListener('click', function () {
    $('confirm-overlay').classList.remove('show');
    location.reload();
  });

  // ── Copy link ────────────────────────────────────────
  $('copy-link').addEventListener('click', function () {
    navigator.clipboard.writeText(location.href).then(function () {
      var t = $('toast');
      t.textContent = 'Link copied ✓';
      t.classList.add('show');
      setTimeout(function () { t.classList.remove('show'); }, 2000);
    }).catch(function () {});
  });

  // ── RSVP lookup ──────────────────────────────────────
  $('m-lookup-btn').addEventListener('click', function () {
    var input = val('m-lookup');
    if (!input) {
      $('m-lookup-err').textContent = 'Enter your name or email.';
      $('m-lookup-err').classList.add('show');
      return;
    }
    $('m-lookup-err').classList.remove('show');
    var btn = $('m-lookup-btn');
    btn.disabled = true;
    btn.textContent = 'Looking up…';

    var isEmail = input.indexOf('@') > -1;
    var body = { potluckId: String(potluckId) };
    if (isEmail) body.email = input;
    else body.name = input;

    fetch('/api/potluck-lookup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      btn.disabled = false;
      btn.textContent = 'Find my RSVP';
      if (data.ok && data.token) {
        window.location.href = '/potlucks/edit?token=' + data.token;
      } else {
        $('m-lookup-err').textContent = data.error || 'Not found. Check your name or email.';
        $('m-lookup-err').classList.add('show');
      }
    })
    .catch(function () {
      btn.disabled = false;
      btn.textContent = 'Find my RSVP';
      $('m-lookup-err').textContent = 'Network problem — try again.';
      $('m-lookup-err').classList.add('show');
    });
  });
})();
</script>
</Base>
