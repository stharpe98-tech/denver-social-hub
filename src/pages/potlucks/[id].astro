---
import { getDB } from '../../lib/db';
const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
let slots: any[] = [];
let signups: any[] = [];
try {
  if (db && id) {
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
    const slotsRes = await db.prepare(`
      SELECT s.id, s.category, s.suggestion, s.max_claims, s.sort_order,
        COUNT(r.id) as claimed
      FROM potluck_slots s
      LEFT JOIN potluck_rsvp r ON LOWER(r.dish)=LOWER(s.suggestion)
        AND r.potluck_id=s.potluck_id AND r.rsvp='yes'
      WHERE s.potluck_id=?
      GROUP BY s.id ORDER BY s.sort_order ASC
    `).bind(id).all();
    slots = slotsRes?.results ?? [];
    const s = await db.prepare(`SELECT name, dish, guest_count FROM potluck_rsvp WHERE potluck_id=? AND rsvp='yes' ORDER BY created_at ASC`).bind(id).all();
    signups = s?.results ?? [];
  }
} catch(e) { console.error(e); }
if (!potluck) return Astro.redirect('/potlucks');

const categories: Record<string, any[]> = {};
slots.forEach((s: any) => {
  if (!categories[s.category]) categories[s.category] = [];
  categories[s.category].push(s);
});
const catEntries = Object.entries(categories);
const totalGuests = signups.reduce((sum: number, s: any) => sum + (parseInt(s.guest_count) || 1), 0);
