---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';
const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
let slots: any[] = [];
let signups: any[] = [];
try {
  if (db && id) {
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
    if (potluck?.locked) return Astro.redirect('/potlucks');
    const s = await db.prepare(`
      SELECT ps.id, ps.suggestion, ps.category, ps.sort_order, ps.max_claims, ps.slot_time,
        pr.name as claimed_by, pr.id as rsvp_id
      FROM potluck_slots ps
      LEFT JOIN potluck_rsvp pr ON LOWER(pr.dish)=LOWER(ps.suggestion)
        AND pr.potluck_id=ps.potluck_id AND pr.rsvp='yes'
      WHERE ps.potluck_id=?
      ORDER BY ps.sort_order ASC
    `).bind(id).all();
    slots = s?.results ?? [];
    const r = await db.prepare(`SELECT name, dish, guest_count FROM potluck_rsvp WHERE potluck_id=? AND rsvp='yes' ORDER BY created_at ASC`).bind(id).all();
    signups = r?.results ?? [];
  }
} catch(e) { console.error(e); }
if (!potluck) return Astro.redirect('/potlucks');

const claimed = slots.filter((s:any) => s.claimed_by).length;
const total = slots.length;
const pct = total > 0 ? Math.round((claimed/total)*100) : 0;
const attending = signups.length;
const colors = ['#0EA5E9','#7c3aed','#0ea5e9','#16a34a','#ec4899','#f59e0b','#0284C7'];

// Group slots by category
const cats: Record<string, any[]> = {};
slots.forEach((s:any) => {
  if (!cats[s.category]) cats[s.category] = [];
  cats[s.category].push(s);
});
---
<Base title={potluck.title} description={potluck.description ?? `Sign up for ${potluck.title}`}>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<style is:inline>

    /* Hero */
    .hero { position: relative; overflow: hidden; }
    .hero-img { width: 100%; height: 200px; object-fit: cover; display: block; }
    .hero-img-placeholder { width: 100%; height: 200px; background: linear-gradient(135deg,#F0F9FF,#E0F2FE); }
    .hero-body { background: #fff; border-bottom: 1px solid #e4ddd4; padding: 20px; }
    .hero-inner { max-width: 600px; margin: 0 auto; }
    .back { font-size: 13px; color: #a09890; text-decoration: none; margin-bottom: 12px; display: inline-flex; align-items: center; gap: 4px; }
    .event-title { font-family: 'Playfair Display', serif; font-size: clamp(22px,5vw,30px); color: #1c1917; margin-bottom: 10px; line-height: 1.2; }
    .event-meta { font-size: 14px; color: #57524c; line-height: 2; margin-bottom: 14px; }
    .event-meta span { display: inline-flex; align-items: center; gap: 6px; }

    /* Progress */
    .progress-wrap { margin-bottom: 14px; }
    .progress-top { display: flex; justify-content: space-between; font-size: 13px; color: #57524c; margin-bottom: 6px; }
    .progress-top strong { color: #0EA5E9; }
    .progress-bar { height: 8px; background: #f0ede8; border-radius: 4px; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #0284C7, #0EA5E9); border-radius: 4px; transition: width 0.4s; }

    /* Attendee avatars */
    .avatars { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: #fff; border: 2px solid #f7f5f2; flex-shrink: 0; }
    .avatar-more { background: #e4ddd4; color: #8a7a70; font-size: 11px; font-weight: 600; }
    .avatars-text { font-size: 13px; color: #8a7a70; }

    /* Share row */
    .share-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
    .share-btn { display: inline-flex; align-items: center; gap: 5px; padding: 6px 12px; border-radius: 8px; border: 1px solid #e4ddd4; background: #f7f5f2; color: #57524c; font-size: 12px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; text-decoration: none; -webkit-tap-highlight-color: transparent; }

    /* Page */
    .page { max-width: 600px; margin: 0 auto; padding: 20px 16px; }

    /* View toggle */
    .view-toggle { display: inline-flex; background: #fff; border: 1px solid #e4ddd4; border-radius: 10px; padding: 3px; margin-bottom: 16px; }
    .vt-btn { background: transparent; border: none; padding: 7px 18px; font-size: 13px; font-weight: 600; color: #a09890; border-radius: 7px; cursor: pointer; font-family: 'DM Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
    .vt-btn.active { background: linear-gradient(135deg, #0284C7, #0EA5E9); color: #fff; }

    /* Grid view */
    .grid-wrap { background: #fff; border: 1.5px solid #e4ddd4; border-radius: 14px; overflow-x: auto; }
    .signup-grid { width: 100%; border-collapse: collapse; font-size: 14px; }
    .signup-grid th { text-align: left; padding: 12px 14px; font-size: 11px; font-weight: 700; color: #8a7a70; text-transform: uppercase; letter-spacing: 1px; background: #f7f5f2; border-bottom: 1.5px solid #e4ddd4; }
    .signup-grid td { padding: 14px; border-bottom: 1px solid #f0ede8; vertical-align: middle; }
    .signup-grid tr:last-child td { border-bottom: none; }
    .g-time { font-weight: 600; color: #57524c; white-space: nowrap; }
    .g-item { color: #1c1917; font-weight: 500; }
    .g-cat { font-size: 11px; color: #a09890; font-weight: 400; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }
    .g-prog { font-size: 13px; color: #6b5040; }
    .g-action { text-align: right; }
    .g-signup-btn { padding: 8px 16px; border-radius: 8px; border: none; background: linear-gradient(135deg, #0284C7, #0EA5E9); color: #fff; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; white-space: nowrap; }
    .g-signup-btn:hover { opacity: 0.9; }
    .g-claimed { font-size: 13px; color: #16a34a; font-weight: 600; white-space: nowrap; }
    .g-empty { text-align: center; color: #a09890; padding: 30px; font-style: italic; }

    /* Category dropdowns */
    .cat-block { margin-bottom: 12px; background: #fff; border: 1.5px solid #e4ddd4; border-radius: 14px; overflow: hidden; }
    .cat-block[open] { border-color: #7DD3FC; }
    .cat-title { font-size: 13px; font-weight: 700; color: #57524c; text-transform: uppercase; letter-spacing: 1px; padding: 16px 18px; display: flex; align-items: center; gap: 12px; cursor: pointer; list-style: none; -webkit-tap-highlight-color: transparent; user-select: none; }
    .cat-title::-webkit-details-marker { display: none; }
    .cat-title:hover { background: #fffaf2; }
    .cat-block[open] .cat-title { border-bottom: 1px solid #f0ede8; background: #fffaf2; }
    .cat-label { flex: 1; }
    .cat-count { font-size: 11px; font-weight: 600; color: #a09890; letter-spacing: 0.5px; text-transform: none; }
    .cat-chev { font-size: 16px; color: #a09890; transition: transform 0.2s; flex-shrink: 0; }
    .cat-block[open] .cat-chev { transform: rotate(180deg); }
    .cat-body { padding: 14px 14px 6px; }

    /* Item rows */
    .item { background: #fff; border: 1.5px solid #e4ddd4; border-radius: 12px; padding: 14px 16px; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; transition: all 0.15s; -webkit-tap-highlight-color: transparent; }
    .item[data-id]:active { background: #F0F9FF; border-color: #0EA5E9; }
    .item.claimed { border-color: #86efac; background: #f0fdf4; cursor: default; }
    .item-name { flex: 1; font-size: 15px; font-weight: 500; color: #1c1917; }
    .item.claimed .item-name { color: #15803d; }
    .item-who { font-size: 13px; color: #16a34a; font-weight: 600; display: flex; align-items: center; gap: 5px; }
    .item-who::before { content: '✓'; font-size: 14px; }
    .claim-btn { flex-shrink: 0; padding: 8px 16px; border-radius: 8px; border: none; background: linear-gradient(135deg,#0284C7,#0EA5E9); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; cursor: pointer; -webkit-tap-highlight-color: transparent; white-space: nowrap; }
    .claim-btn:active { opacity: 0.85; transform: scale(0.97); }

    /* Inline claim form */
    .claim-form { display: none; background: #F0F9FF; border: 1.5px solid #0EA5E9; border-radius: 12px; padding: 16px; margin-bottom: 8px; }
    .claim-form.open { display: block; }
    .claim-form-title { font-size: 14px; font-weight: 600; color: #0284C7; margin-bottom: 12px; }
    .claim-input { width: 100%; padding: 11px 13px; background: #fff; border: 1.5px solid #e4ddd4; border-radius: 9px; color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 15px; outline: none; margin-bottom: 10px; -webkit-appearance: none; }
    .claim-input:focus { border-color: #0EA5E9; }
    .claim-input::placeholder { color: #c0b8b0; }
    .claim-row { display: flex; gap: 8px; align-items: center; }
    .claim-submit { flex: 1; padding: 12px; border-radius: 9px; border: none; background: linear-gradient(135deg,#0284C7,#0EA5E9); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600; cursor: pointer; }
    .claim-cancel { padding: 12px 16px; border-radius: 9px; border: 1.5px solid #e4ddd4; background: transparent; color: #8a7a70; font-family: 'DM Sans', sans-serif; font-size: 14px; cursor: pointer; }
    .claim-guest-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .g-btn { width: 38px; height: 38px; border-radius: 8px; border: 1.5px solid #e4ddd4; background: #fff; font-size: 18px; font-weight: 600; color: #57524c; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .g-count { flex: 1; text-align: center; font-size: 20px; font-weight: 700; color: #1c1917; }
    .g-note { font-size: 12px; color: #a09890; white-space: nowrap; }
    .claim-email { width: 100%; padding: 11px 13px; background: #fff; border: 1.5px solid #e4ddd4; border-radius: 9px; color: #1c1917; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; margin-bottom: 10px; -webkit-appearance: none; }
    .claim-email:focus { border-color: #0EA5E9; }
    .claim-email::placeholder { color: #c0b8b0; }
    .claim-hint { font-size: 11px; color: #a09890; margin-bottom: 10px; line-height: 1.5; }

    /* Custom dish */
    .custom-block { background: #fff; border: 1.5px dashed #e4ddd4; border-radius: 12px; padding: 14px 16px; margin-top: 8px; display: flex; align-items: center; gap: 12px; cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .custom-block:active { background: #F0F9FF; border-color: #0EA5E9; }
    .custom-icon { font-size: 22px; flex-shrink: 0; }
    .custom-text { font-size: 14px; color: #8a7a70; }
    .custom-text strong { color: #1c1917; display: block; }

    /* Success toast */
    .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: #15803d; color: #fff; padding: 12px 24px; border-radius: 100px; font-size: 14px; font-weight: 600; display: none; z-index: 999; box-shadow: 0 4px 20px rgba(0,0,0,0.2); white-space: nowrap; }
    .toast.show { display: block; animation: slideup 0.2s ease; }
    @keyframes slideup { from { transform: translateX(-50%) translateY(12px); opacity:0; } to { transform: translateX(-50%) translateY(0); opacity:1; } }

    /* Tabs */
    .tabs { display: flex; border-bottom: 1px solid #e4ddd4; margin-bottom: 20px; }
    .tab { flex: 1; padding: 11px; font-size: 13px; font-weight: 600; color: #a09890; cursor: pointer; border: none; border-bottom: 2px solid transparent; background: none; font-family: 'DM Sans', sans-serif; }
    .tab.active { color: #0EA5E9; border-bottom-color: #0EA5E9; }
    .panel { display: none; } .panel.active { display: block; }

    /* Who's coming */
    .coming-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid #f0ede8; }
    .coming-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: #fff; flex-shrink: 0; }
    .coming-name { font-size: 15px; font-weight: 500; color: #1c1917; }
    .coming-dish { font-size: 13px; color: #8a7a70; margin-top: 1px; }
    .coming-guests { font-size: 12px; color: #0284C7; font-weight: 500; margin-left: auto; flex-shrink: 0; }

    .empty { text-align: center; padding: 40px; color: #a09890; font-style: italic; font-size: 14px; }
    .hidden { display: none !important; }
</style>

  <!-- HERO -->
  <div class="hero">
    {potluck.cover_photo
      ? <img src={potluck.cover_photo} alt={potluck.title} class="hero-img"/>
      : <div class="hero-img-placeholder"></div>
    }
    <div class="hero-body">
      <div class="hero-inner">
        <a href="/potlucks" class="back">← Potlucks</a>
        <h1 class="event-title">{potluck.title}</h1>
        <div class="event-meta">
          {potluck.date_label && <span>📅 {potluck.date_label}{potluck.time_label ? ` · ${potluck.time_label}` : ''}</span>}
          {potluck.location && <span style="margin-left:8px">📍 {potluck.location}{potluck.location_detail ? ` — ${potluck.location_detail}` : ''}</span>}
        </div>

        {/* Progress */}
        <div class="progress-wrap">
          <div class="progress-top">
            <span><strong>{claimed}</strong> of {total} items claimed</span>
            <span>{attending} {attending === 1 ? 'person' : 'people'} coming</span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" style={`width:${pct}%`}></div>
          </div>
        </div>

        {/* Avatars */}
        {signups.length > 0 && (
          <div class="avatars">
            {signups.slice(0,6).map((s:any, i:number) => (
              <div class="avatar" style={`background:${colors[i%7]}`} title={s.name}>
                {(s.name||'?').split(' ').map((w:string)=>w[0]).join('').slice(0,2).toUpperCase()}
              </div>
            ))}
            {signups.length > 6 && <div class="avatar avatar-more">+{signups.length - 6}</div>}
            <span class="avatars-text">
              {signups.length === 1 ? `${signups[0].name} is coming` :
               `${signups[0].name} and ${signups.length - 1} other${signups.length > 2 ? 's' : ''} are coming`}
            </span>
          </div>
        )}

        <div style="display:flex;gap:10px;align-items:center;margin-top:10px">
          <button id="copy-btn" style="background:none;border:none;font-size:13px;color:#a09890;cursor:pointer;padding:0;font-family:inherit;display:flex;align-items:center;gap:4px">🔗 Copy link</button>
          <span style="color:#e4ddd4">·</span>
          <a href={`/potlucks/${id}/poster`} style="font-size:13px;color:#a09890;text-decoration:none">🖼 Poster</a>
        </div>
      </div>
    </div>
  </div>

  <div class="page">
    <div class="tabs">
      <button class="tab active" id="tab-list">Sign Up</button>
      <button class="tab" id="tab-coming">Who's Coming ({signups.length})</button>
    </div>

    <div class="view-toggle" id="view-toggle">
      <button class="vt-btn active" data-view="cards">Cards</button>
      <button class="vt-btn" data-view="grid">Grid</button>
    </div>

    <!-- SIGN UP GRID (table view) -->
    <div class="panel" id="panel-grid">
      <div class="grid-wrap">
        <table class="signup-grid">
          <thead>
            <tr>
              <th style="width:130px">Time</th>
              <th>Item</th>
              <th style="width:110px">Progress</th>
              <th style="width:120px"></th>
            </tr>
          </thead>
          <tbody>
            {slots.map((s:any) => {
              const filled = s.claimed_by ? 1 : 0;
              const max = s.max_claims || 1;
              return (
                <tr>
                  <td class="g-time">{s.slot_time || '—'}</td>
                  <td class="g-item">{s.suggestion}{s.category && <div class="g-cat">{s.category}</div>}</td>
                  <td class="g-prog">{filled} of {max} filled</td>
                  <td class="g-action">
                    {s.claimed_by
                      ? <span class="g-claimed">✓ {s.claimed_by}</span>
                      : <button class="g-signup-btn" data-id={s.id} data-dish={s.suggestion}>Sign up</button>
                    }
                  </td>
                </tr>
              );
            })}
            {slots.length === 0 && (
              <tr><td colspan="4" class="g-empty">No items yet — check back soon!</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- SIGN UP LIST -->
    <div class="panel active" id="panel-list">

      {Object.entries(cats).map(([cat, items]) => {
        const catTotal = items.length;
        const catClaimed = items.filter((i:any) => i.claimed_by).length;
        return (
          <details class="cat-block">
            <summary class="cat-title">
              <span class="cat-label">{cat}</span>
              <span class="cat-count">{catClaimed} of {catTotal} claimed</span>
              <span class="cat-chev">⌄</span>
            </summary>
            <div class="cat-body">
              {items.map((item:any) => item.claimed_by ? (
                <div class="item claimed">
                  <div class="item-name">{item.suggestion}</div>
                  <div class="item-who">{item.claimed_by}</div>
                </div>
              ) : (
                <div>
                  <div class="item" id={`item-${item.id}`} data-id={item.id} data-dish={item.suggestion} style="cursor:pointer">
                    <div class="item-name">{item.suggestion}</div>
                    <span style="font-size:20px;color:#e4ddd4;flex-shrink:0">›</span>
                  </div>
                  <div class="claim-form" id={`form-${item.id}`}>
                    <div class="claim-form-title">🙌 Bringing {item.suggestion}!</div>
                    <input type="text" class="claim-input" id={`name-${item.id}`} placeholder="Your name *"/>
                    <div class="claim-guest-row">
                      <button type="button" class="g-btn" data-item={item.id} data-dir="-1">−</button>
                      <div class="g-count" id={`gc-${item.id}`}>1</div>
                      <button type="button" class="g-btn" data-item={item.id} data-dir="1">+</button>
                      <div class="g-note" id={`gn-${item.id}`}>just me</div>
                    </div>
                    <input type="email" class="claim-email" id={`email-${item.id}`} placeholder="Email (optional — for a reminder)"/>
                    <div class="claim-hint">🧊 No fridge on site — bring cold dishes in a cooler!</div>
                    <div class="claim-row">
                      <button class="claim-submit" data-id={item.id} data-dish={item.suggestion}>Claim it! 🎉</button>
                      <button class="claim-cancel" data-id={item.id}>Cancel</button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </details>
        );
      })}

      <!-- Bring something else -->
      <details class="cat-block">
        <summary class="cat-title">
          <span class="cat-label">Something else?</span>
          <span class="cat-chev">⌄</span>
        </summary>
        <div class="cat-body">
        <div class="custom-block" id="custom-toggle" style="cursor:pointer">
          <span class="custom-icon">✏️</span>
          <div class="custom-text">
            <strong>Bringing something else?</strong>
            Tap to add it
          </div>
          <span style="font-size:20px;color:#e4ddd4;margin-left:auto">›</span>
        </div>
        <div class="claim-form hidden" id="custom-form">
          <div class="claim-form-title">✏️ What are you bringing?</div>
          <input type="text" class="claim-input" id="custom-dish" placeholder="e.g. Cornbread, fruit punch…" autocomplete="off"/>
          <input type="text" class="claim-input" id="custom-name" placeholder="Your name *"/>
          <div class="claim-guest-row">
            <button type="button" class="g-btn" id="custom-minus">−</button>
            <div class="g-count" id="custom-gc">1</div>
            <button type="button" class="g-btn" id="custom-plus">+</button>
            <div class="g-note" id="custom-gn">just me</div>
          </div>
          <input type="email" class="claim-email" id="custom-email" placeholder="Email (optional — for a reminder)"/>
          <div class="claim-hint">🧊 No fridge on site — bring cold dishes in a cooler!</div>
          <div class="claim-row">
            <button class="claim-submit" id="custom-submit">I'm bringing it! 🎉</button>
            <button class="claim-cancel" id="custom-cancel">Cancel</button>
          </div>
        </div>
        </div>
      </details>

    </div>

    <!-- WHO'S COMING -->
    <div class="panel" id="panel-coming">
      {signups.length === 0
        ? <div class="empty">Nobody's signed up yet — be the first! 🙌</div>
        : signups.map((s:any, i:number) => (
          <div class="coming-row">
            <div class="coming-avatar" style={`background:${colors[i%7]}`}>
              {(s.name||'?').split(' ').map((w:string)=>w[0]).join('').slice(0,2).toUpperCase()}
            </div>
            <div>
              <div class="coming-name">{s.name}</div>
              <div class="coming-dish">{s.dish || 'Showing up 🎉'}</div>
            </div>
            {s.guest_count > 1 && <div class="coming-guests">+{s.guest_count - 1}</div>}
          </div>
        ))
      }
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <div id="confirm-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;padding:20px">
    <div style="background:#fff;border-radius:18px;max-width:440px;width:100%;padding:28px 26px;box-shadow:0 20px 60px rgba(0,0,0,0.25);font-family:'DM Sans',sans-serif">
      <div style="font-size:36px;text-align:center;margin-bottom:6px">🎉</div>
      <div id="confirm-title" style="font-size:22px;font-weight:700;text-align:center;margin-bottom:6px;color:#1c1917">You're in!</div>
      <div id="confirm-sub" style="font-size:14px;text-align:center;color:#57524c;margin-bottom:20px">Confirmation email is on the way.</div>
      <div id="confirm-contact" style="background:#f7f5f2;border-radius:12px;padding:16px 18px;margin-bottom:14px;display:none">
        <div style="font-size:11px;font-weight:700;color:#a09890;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px">Stay in touch</div>
        <div id="cc-rows" style="font-size:14px;color:#1c1917;line-height:1.9"></div>
      </div>
      <div id="confirm-pay" style="background:#F0F9FF;border:1.5px solid #7DD3FC;border-radius:12px;padding:14px 18px;margin-bottom:18px;display:none">
        <div style="font-size:11px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Want to chip in?</div>
        <div id="cp-rows" style="font-size:14px;line-height:1.8"></div>
      </div>
      <button id="confirm-ok" style="width:100%;padding:13px;background:linear-gradient(135deg,#0284C7,#0EA5E9);color:#fff;font-size:15px;font-weight:600;border:none;border-radius:10px;cursor:pointer;font-family:inherit">Got it</button>
    </div>
  </div>

  <script define:vars={{ potluckId: id }}>
    var guestCounts = {};

    // Tabs
    var currentSignupView = 'cards'; // remembers grid vs cards across tab switches
    function showSignupView(v) {
      currentSignupView = v;
      document.querySelectorAll('.vt-btn').forEach(function(b) { b.classList.toggle('active', b.dataset.view === v); });
      document.getElementById('panel-list').classList.toggle('active', v === 'cards');
      document.getElementById('panel-grid').classList.toggle('active', v === 'grid');
    }
    document.getElementById('tab-list').addEventListener('click', function() {
      document.getElementById('tab-list').classList.add('active');
      document.getElementById('tab-coming').classList.remove('active');
      document.getElementById('panel-coming').classList.remove('active');
      document.getElementById('view-toggle').style.display = '';
      showSignupView(currentSignupView);
    });
    document.getElementById('tab-coming').addEventListener('click', function() {
      document.getElementById('tab-coming').classList.add('active');
      document.getElementById('tab-list').classList.remove('active');
      document.getElementById('panel-coming').classList.add('active');
      document.getElementById('panel-list').classList.remove('active');
      document.getElementById('panel-grid').classList.remove('active');
      document.getElementById('view-toggle').style.display = 'none';
    });
    document.querySelectorAll('.vt-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { showSignupView(btn.dataset.view); });
    });

    // Grid → cards: clicking "Sign up" in the grid switches to cards view
    // and opens that item's claim form so the existing inline form logic
    // is the only place a sign-up actually happens.
    document.querySelectorAll('.g-signup-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var itemId = btn.dataset.id;
        showSignupView('cards');
        // expand the parent <details> if collapsed, then open the item's form
        var item = document.getElementById('item-' + itemId);
        if (item) {
          var details = item.closest('details');
          if (details) details.open = true;
          setTimeout(function() {
            item.click();
            item.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 30);
        }
      });
    });

    // Share
    var url = window.location.href;
    document.getElementById('copy-btn').addEventListener('click', function() {
      navigator.clipboard.writeText(url).then(function() {
        showToast('Link copied! 🔗');
      });
    });
    document.getElementById('share-fb').href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);

    // Tappable item rows — open inline form
    document.querySelectorAll('.item[data-id]').forEach(function(row) {
      row.addEventListener('click', function() {
        var id = row.dataset.id;
        // Close any other open forms
        document.querySelectorAll('.claim-form').forEach(function(f) { f.classList.remove('open'); f.classList.add('hidden'); });
        var form = document.getElementById('form-' + id);
        if (form) {
          form.classList.add('open'); form.classList.remove('hidden');
          document.getElementById('name-' + id).focus();
          form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    });

    // Cancel buttons
    document.querySelectorAll('.claim-cancel').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.dataset.id;
        if (id) { var f = document.getElementById('form-' + id); if (f) { f.classList.remove('open'); f.classList.add('hidden'); } }
        else { document.getElementById('custom-form').classList.remove('open'); document.getElementById('custom-form').classList.add('hidden'); }
      });
    });

    // Guest count buttons
    document.querySelectorAll('.g-btn[data-item]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var itemId = btn.dataset.item;
        if (!guestCounts[itemId]) guestCounts[itemId] = 1;
        guestCounts[itemId] = Math.max(1, Math.min(10, guestCounts[itemId] + parseInt(btn.dataset.dir)));
        document.getElementById('gc-' + itemId).textContent = String(guestCounts[itemId]);
        document.getElementById('gn-' + itemId).textContent = guestCounts[itemId] === 1 ? 'just me' : 'me + ' + (guestCounts[itemId]-1) + ' other' + (guestCounts[itemId]>2?'s':'');
      });
    });

    // Custom dish toggle
    var customCount = 1;
    document.getElementById('custom-toggle').addEventListener('click', function() {
      var f = document.getElementById('custom-form');
      f.classList.toggle('hidden');
      if (!f.classList.contains('hidden')) document.getElementById('custom-dish').focus();
    });
    document.getElementById('custom-minus').addEventListener('click', function() {
      customCount = Math.max(1, customCount-1);
      document.getElementById('custom-gc').textContent = String(customCount);
      document.getElementById('custom-gn').textContent = customCount===1?'just me':'me + '+(customCount-1)+' other'+(customCount>2?'s':'');
    });
    document.getElementById('custom-plus').addEventListener('click', function() {
      customCount = Math.min(10, customCount+1);
      document.getElementById('custom-gc').textContent = String(customCount);
      document.getElementById('custom-gn').textContent = customCount===1?'just me':'me + '+(customCount-1)+' other'+(customCount>2?'s':'');
    });
    document.getElementById('custom-cancel').addEventListener('click', function() {
      document.getElementById('custom-form').classList.add('hidden');
    });

    // Submit claim
    document.querySelectorAll('.claim-submit').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var itemId = btn.dataset.id;
        var dish = btn.dataset.dish;
        var name, guests, email;

        if (itemId) {
          name = document.getElementById('name-' + itemId).value.trim();
          guests = guestCounts[itemId] || 1;
          email = document.getElementById('email-' + itemId).value.trim();
        } else {
          // custom
          dish = document.getElementById('custom-dish').value.trim();
          name = document.getElementById('custom-name').value.trim();
          guests = customCount;
          email = document.getElementById('custom-email').value.trim();
          if (!dish) { document.getElementById('custom-dish').focus(); return; }
        }

        if (!name) {
          var nameField = itemId ? document.getElementById('name-' + itemId) : document.getElementById('custom-name');
          nameField.style.borderColor = '#0EA5E9';
          nameField.focus();
          return;
        }

        btn.disabled = true; btn.textContent = 'Saving…';

        try {
          var res = await fetch('/api/potluck', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              potluckId: String(potluckId), name, email, handle: '',
              platforms: '', rsvp: 'yes', guestCount: String(guests),
              dish: dish, dishCategory: '', dietary: '',
              utensils: false, earlyArrive: false, seating: false,
              _gotcha: '', _turnstile: ''
            })
          });
          var data = await res.json();
          if (data.ok) {
            showConfirmation(name.split(' ')[0], data.contact || {});
          } else {
            btn.disabled = false; btn.textContent = itemId ? 'Claim it! 🎉' : 'I\'m bringing it! 🎉';
            showToast('Something went wrong — try again');
          }
        } catch(e) {
          btn.disabled = false; btn.textContent = itemId ? 'Claim it! 🎉' : 'I\'m bringing it! 🎉';
        }
      });
    });

    function showToast(msg) {
      var t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(function() { t.classList.remove('show'); }, 2500);
    }

    function escHtml(s) { return String(s||'').replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }

    function showConfirmation(firstName, contact) {
      document.getElementById('confirm-title').textContent = "You're in, " + firstName + "!";
      var ccRows = [];
      if (contact.phone) ccRows.push('<div>📞 ' + escHtml(contact.phone) + '</div>');
      if (contact.discord_url) ccRows.push('<div>💬 <a href="' + escHtml(contact.discord_url) + '" target="_blank" rel="noopener" style="color:#0284C7;text-decoration:none;font-weight:600">Join Discord</a>' + (contact.discord ? ' · ' + escHtml(contact.discord) : '') + '</div>');
      else if (contact.discord) ccRows.push('<div>💬 ' + escHtml(contact.discord) + '</div>');
      if (ccRows.length > 0) {
        document.getElementById('cc-rows').innerHTML = ccRows.join('');
        document.getElementById('confirm-contact').style.display = 'block';
      }
      var cpRows = [];
      if (contact.venmo) cpRows.push('<div>💸 Venmo: <a href="https://venmo.com/' + escHtml(String(contact.venmo).replace(/^@/, '')) + '" target="_blank" rel="noopener" style="color:#0284C7;text-decoration:none;font-weight:600">' + escHtml(contact.venmo) + '</a></div>');
      if (contact.cashapp_handle) cpRows.push('<div>💵 Cash App: <a href="https://cash.app/' + escHtml(String(contact.cashapp_handle).replace(/^\$/, '$')) + '" target="_blank" rel="noopener" style="color:#0284C7;text-decoration:none;font-weight:600">' + escHtml(contact.cashapp_handle) + '</a></div>');
      if (contact.stripe_link) cpRows.push('<div>💳 <a href="' + escHtml(contact.stripe_link) + '" target="_blank" rel="noopener" style="color:#0284C7;text-decoration:none;font-weight:600">Pay with card</a></div>');
      if (cpRows.length > 0) {
        document.getElementById('cp-rows').innerHTML = cpRows.join('');
        document.getElementById('confirm-pay').style.display = 'block';
      }
      var overlay = document.getElementById('confirm-overlay');
      overlay.style.display = 'flex';
    }

    document.getElementById('confirm-ok').addEventListener('click', function() {
      document.getElementById('confirm-overlay').style.display = 'none';
      location.reload();
    });
  </script>
</Base>
