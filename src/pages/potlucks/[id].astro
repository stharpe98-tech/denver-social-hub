---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
let slots: any[] = [];
let signups: any[] = [];

try {
  if (db && id) {
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
    if (potluck?.locked) return Astro.redirect('/potlucks');
    const s = await db.prepare(`
      SELECT ps.id, ps.suggestion, ps.category, ps.sort_order, ps.max_claims, ps.slot_time,
        pr.name as claimed_by, pr.id as rsvp_id
      FROM potluck_slots ps
      LEFT JOIN potluck_rsvp pr ON LOWER(pr.dish)=LOWER(ps.suggestion)
        AND pr.potluck_id=ps.potluck_id AND pr.rsvp='yes'
      WHERE ps.potluck_id=?
      ORDER BY ps.sort_order ASC
    `).bind(id).all();
    slots = s?.results ?? [];
    const r = await db.prepare(
      `SELECT name, dish, guest_count FROM potluck_rsvp WHERE potluck_id=? AND rsvp='yes' ORDER BY created_at ASC`
    ).bind(id).all();
    signups = r?.results ?? [];
  }
} catch (e) { console.error(e); }
if (!potluck) return Astro.redirect('/potlucks');

const claimed = slots.filter((s: any) => s.claimed_by).length;
const total = slots.length;
const pct = total > 0 ? Math.round((claimed / total) * 100) : 0;
const guestTotal = signups.reduce((sum: number, s: any) => sum + (parseInt(s.guest_count) || 1), 0);

// Group slots by category, preserving sort order. Categories appear in
// the order their first item appears.
const groupedKeys: string[] = [];
const grouped: Record<string, any[]> = {};
for (const s of slots) {
  const cat = s.category || 'Items';
  if (!grouped[cat]) { grouped[cat] = []; groupedKeys.push(cat); }
  grouped[cat].push(s);
}
---
<Base title={potluck.title} description={potluck.description ?? `Sign up for ${potluck.title}`}>

<style>
  .pot-hero { background: var(--bg); border-bottom: 1px solid var(--border); }
  .pot-hero-img { width: 100%; height: 220px; object-fit: cover; display: block; }
  .pot-hero-img-placeholder { width: 100%; height: 140px; background: linear-gradient(135deg, #F0F9FF, #E0F2FE, #D1FAE5); }
  .pot-hero-body { max-width: 720px; margin: 0 auto; padding: var(--space-5) var(--space-4); }
  .pot-back { font-size: 13px; color: var(--text-sec); display: inline-flex; align-items: center; gap: 4px; margin-bottom: var(--space-3); }
  .pot-back:hover { color: var(--text); }
  .pot-title { font-family: var(--font-display); font-size: clamp(26px, 5vw, 36px); font-weight: 800; color: var(--text); margin-bottom: 6px; letter-spacing: -0.02em; }
  .pot-meta { display: flex; gap: var(--space-3); flex-wrap: wrap; font-size: 14px; color: var(--text-sec); margin-bottom: var(--space-3); }
  .pot-meta span { display: inline-flex; align-items: center; gap: 4px; }
  .pot-desc { font-size: 14px; color: var(--text-sec); line-height: 1.6; margin-top: var(--space-2); }

  .pot-prog { padding: var(--space-3) 0; }
  .pot-prog-top { display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: var(--text-sec); margin-bottom: 6px; }
  .pot-prog-top strong { color: var(--accent); font-weight: 700; }
  .pot-prog-bar { height: 6px; background: var(--surface); border-radius: 3px; overflow: hidden; }
  .pot-prog-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 3px; transition: width 0.4s; }

  .pot-actions { display: flex; gap: var(--space-3); align-items: center; flex-wrap: wrap; margin-top: var(--space-3); }
  .pot-link-btn { background: none; border: none; color: var(--text-sec); font-size: 13px; cursor: pointer; padding: 0; font-family: inherit; display: inline-flex; align-items: center; gap: 4px; }
  .pot-link-btn:hover { color: var(--text); }

  .pot-page { max-width: 720px; margin: 0 auto; padding: var(--space-5) var(--space-4) var(--space-8); }

  .pot-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: var(--space-4); }
  .pot-tab { flex: 1; padding: 12px; border: none; background: none; font-family: inherit; font-size: 14px; font-weight: 600; color: var(--text-faint); cursor: pointer; border-bottom: 2px solid transparent; transition: color 0.15s, border-color 0.15s; -webkit-tap-highlight-color: transparent; }
  .pot-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .pot-panel { display: none; }
  .pot-panel.active { display: block; }

  .pot-cat { margin-bottom: var(--space-5); }
  .pot-cat-title { font-size: 11px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: var(--space-2); display: flex; align-items: center; gap: 8px; }
  .pot-cat-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .pot-cat-count { font-weight: 500; font-size: 11px; color: var(--text-faint); text-transform: none; letter-spacing: 0; }

  .pot-item {
    background: var(--bg); border: 1.5px solid var(--border);
    border-radius: var(--radius); padding: 14px 16px;
    margin-bottom: 8px;
    display: flex; align-items: center; gap: 12px;
    transition: border-color 0.15s, background 0.15s;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .pot-item:hover { border-color: var(--accent); background: var(--surface); }
  .pot-item:active { transform: scale(0.99); }
  .pot-item.claimed { background: var(--tag-bg2); border-color: #6EE7B7; cursor: default; }
  .pot-item.claimed:hover { transform: none; background: var(--tag-bg2); }
  .pot-item-name { flex: 1; font-size: 15px; font-weight: 500; color: var(--text); }
  .pot-item-who { font-size: 13px; color: var(--tag-text2); font-weight: 600; }
  .pot-item-arrow { font-size: 20px; color: var(--text-faint); flex-shrink: 0; }

  /* Sign-up form (the centerpiece). Renders inline below the tapped item. */
  .pot-form {
    display: none;
    background: linear-gradient(135deg, #F0F9FF, #ECFDF5);
    border: 1.5px solid var(--accent);
    border-radius: var(--radius);
    padding: var(--space-4);
    margin-bottom: var(--space-3);
  }
  .pot-form.open { display: block; }
  .pot-form-title { font-family: var(--font-display); font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: var(--space-3); }
  .pot-form-title span { color: var(--accent); }

  .pot-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-2); margin-bottom: var(--space-3); }
  @media(min-width: 640px) { .pot-grid { grid-template-columns: 1fr 1fr; gap: var(--space-3) var(--space-4); } }

  .pot-field { display: flex; flex-direction: column; }
  .pot-field label { font-size: 11px; font-weight: 700; color: var(--text-sec); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .pot-field label .opt { font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-faint); }
  .pot-input, .pot-textarea {
    width: 100%; padding: 11px 13px;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; font-size: 15px; color: var(--text);
    font-family: var(--font); outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    -webkit-appearance: none;
  }
  .pot-input:focus, .pot-textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .pot-input.invalid { border-color: var(--red); }
  .pot-textarea { resize: vertical; min-height: 60px; line-height: 1.45; }

  .pot-guests { display: flex; align-items: center; gap: 8px; }
  .pot-guests button { width: 36px; height: 36px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg); color: var(--text-sec); font-size: 18px; font-weight: 600; cursor: pointer; font-family: inherit; }
  .pot-guests button:hover { border-color: var(--accent); color: var(--accent); }
  .pot-guests .pot-count { min-width: 28px; text-align: center; font-weight: 700; color: var(--text); }
  .pot-guests .pot-note { font-size: 13px; color: var(--text-faint); }

  .pot-helpers { display: flex; flex-direction: column; gap: 6px; }
  .pot-check { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text); background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 9px 12px; cursor: pointer; transition: border-color 0.15s; }
  .pot-check:hover { border-color: var(--accent); }
  .pot-check input { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; }

  .pot-hint { font-size: 12px; color: var(--text-sec); margin: var(--space-2) 0 var(--space-3); padding: 8px 12px; background: var(--bg); border-radius: 8px; border-left: 3px solid var(--accent); }

  .pot-form-row { display: flex; gap: 8px; }
  .pot-submit {
    flex: 1; padding: 13px; border-radius: 12px; border: none;
    background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font); font-size: 15px; font-weight: 600;
    cursor: pointer; box-shadow: 0 1px 3px rgba(14,165,233,0.25);
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .pot-submit:hover { box-shadow: 0 6px 18px rgba(14,165,233,0.35); transform: translateY(-1px); }
  .pot-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .pot-cancel {
    padding: 13px 18px; border-radius: 12px; border: 1px solid var(--border);
    background: var(--bg); color: var(--text-sec); cursor: pointer;
    font-family: var(--font); font-size: 14px;
  }
  .pot-cancel:hover { border-color: var(--border-hover); color: var(--text); }

  .pot-error { font-size: 13px; color: var(--red); margin-top: 6px; display: none; }
  .pot-error.show { display: block; }

  /* Custom dish CTA */
  .pot-custom-cta {
    width: 100%; padding: 16px;
    background: var(--bg); border: 1.5px dashed var(--border);
    border-radius: var(--radius); cursor: pointer;
    font-family: var(--font); font-size: 14px; color: var(--text-sec);
    text-align: left;
    display: flex; align-items: center; gap: 12px;
    transition: all 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .pot-custom-cta:hover { border-color: var(--accent); color: var(--text); }
  .pot-custom-cta-icon { font-size: 20px; }
  .pot-custom-cta strong { display: block; color: var(--text); font-weight: 600; margin-bottom: 2px; }

  /* Who's coming */
  .pot-coming-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--surface-hover); }
  .pot-coming-row:last-child { border-bottom: none; }
  .pot-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0; }
  .pot-coming-name { font-size: 14px; font-weight: 600; color: var(--text); }
  .pot-coming-dish { font-size: 12px; color: var(--text-sec); }
  .pot-coming-plus { margin-left: auto; font-size: 12px; color: var(--accent); font-weight: 600; }
  .pot-empty { padding: var(--space-5); text-align: center; color: var(--text-faint); font-style: italic; }

  /* Toast + confirmation modal */
  .pot-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--mint); color: #fff; padding: 12px 22px; border-radius: 999px; font-size: 14px; font-weight: 600; box-shadow: 0 4px 20px rgba(0,0,0,0.2); display: none; z-index: 1000; }
  .pot-toast.show { display: block; }

  .pot-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.55); align-items: center; justify-content: center; padding: 20px; z-index: 1000; }
  .pot-overlay.show { display: flex; }
  .pot-overlay-card { background: var(--bg); border-radius: var(--radius-lg); max-width: 460px; width: 100%; padding: var(--space-5); box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
  .pot-overlay h2 { font-family: var(--font-display); font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 4px; }
  .pot-overlay-sub { text-align: center; color: var(--text-sec); font-size: 14px; margin-bottom: var(--space-4); }
  .pot-overlay-card .pot-block { background: var(--surface); border-radius: 12px; padding: 14px 16px; margin-bottom: 10px; }
  .pot-overlay-card .pot-block-label { font-size: 11px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
  .pot-overlay-card .pot-block.pay { background: var(--tag-bg3); }
  .pot-overlay-card .pot-block.pay .pot-block-label { color: var(--tag-text3); }
  .pot-overlay-rows { font-size: 14px; color: var(--text); line-height: 1.7; }
  .pot-overlay-rows a { color: var(--accent); font-weight: 600; }
  .pot-overlay-ok { width: 100%; padding: 13px; border-radius: 12px; border: none; background: var(--cta-bg); color: var(--cta-text); font-family: var(--font); font-size: 15px; font-weight: 600; cursor: pointer; }
</style>

<section class="pot-hero">
  {potluck.cover_photo
    ? <img src={potluck.cover_photo} alt={potluck.title} class="pot-hero-img" loading="eager"/>
    : <div class="pot-hero-img-placeholder"></div>}
  <div class="pot-hero-body">
    <a href="/potlucks" class="pot-back">← All potlucks</a>
    <h1 class="pot-title">{potluck.title}</h1>
    <div class="pot-meta">
      {potluck.date_label && <span>📅 {potluck.date_label}{potluck.time_label ? ` · ${potluck.time_label}` : ''}</span>}
      {potluck.location && <span>📍 {potluck.location}{potluck.location_detail ? ` — ${potluck.location_detail}` : ''}</span>}
    </div>
    {potluck.description && <p class="pot-desc">{potluck.description}</p>}

    <div class="pot-prog">
      <div class="pot-prog-top">
        <span><strong>{claimed}</strong> of {total} items claimed</span>
        <span>{guestTotal} {guestTotal === 1 ? 'person' : 'people'} coming</span>
      </div>
      <div class="pot-prog-bar"><div class="pot-prog-fill" style={`width:${pct}%`}></div></div>
    </div>

    <div class="pot-actions">
      <button class="pot-link-btn" id="copy-link">🔗 Copy link</button>
      <a href={`/potlucks/${id}/poster`} class="pot-link-btn">🖼 Poster</a>
    </div>
  </div>
</section>

<div class="pot-page">
  <div class="pot-tabs">
    <button class="pot-tab active" data-tab="signup">Sign up</button>
    <button class="pot-tab" data-tab="coming">Who's coming ({signups.length})</button>
  </div>

  <!-- SIGN UP TAB -->
  <div class="pot-panel active" id="panel-signup">
    {groupedKeys.length === 0 ? (
      <div class="pot-empty">No items listed yet — check back soon.</div>
    ) : groupedKeys.map((cat) => {
      const items = grouped[cat];
      const catClaimed = items.filter((i:any) => i.claimed_by).length;
      return (
        <div class="pot-cat">
          <div class="pot-cat-title">
            <span>{cat}</span>
            <span class="pot-cat-count">{catClaimed} of {items.length} claimed</span>
          </div>
          {items.map((item:any) => item.claimed_by ? (
            <div class="pot-item claimed">
              <div class="pot-item-name">{item.suggestion}</div>
              <div class="pot-item-who">✓ {item.claimed_by}</div>
            </div>
          ) : (
            <div>
              <div class="pot-item" data-id={item.id} data-dish={item.suggestion}>
                <div class="pot-item-name">{item.suggestion}</div>
                <span class="pot-item-arrow">›</span>
              </div>
              <div class="pot-form" id={`form-${item.id}`}>
                <div class="pot-form-title">Bringing <span>{item.suggestion}</span></div>
                <div class="pot-grid">
                  <div class="pot-field">
                    <label>First name <span class="opt">*</span></label>
                    <input type="text" class="pot-input" id={`first-${item.id}`} placeholder="Jamie" autocomplete="given-name"/>
                  </div>
                  <div class="pot-field">
                    <label>Last name <span class="opt">(optional)</span></label>
                    <input type="text" class="pot-input" id={`last-${item.id}`} placeholder="Doe" autocomplete="family-name"/>
                  </div>
                  <div class="pot-field">
                    <label>Email <span class="opt">(for a reminder)</span></label>
                    <input type="email" class="pot-input" id={`email-${item.id}`} placeholder="you@example.com" autocomplete="email"/>
                  </div>
                  <div class="pot-field">
                    <label>Phone <span class="opt">(for SMS)</span></label>
                    <input type="tel" class="pot-input" id={`phone-${item.id}`} placeholder="(720) 555-1234" autocomplete="tel"/>
                  </div>
                  <div class="pot-field">
                    <label>How many coming?</label>
                    <div class="pot-guests">
                      <button type="button" data-id={item.id} data-dir="-1">−</button>
                      <span class="pot-count" id={`gc-${item.id}`}>1</span>
                      <button type="button" data-id={item.id} data-dir="1">+</button>
                      <span class="pot-note" id={`gn-${item.id}`}>just me</span>
                    </div>
                  </div>
                  <div class="pot-field">
                    <label>How can you help?</label>
                    <div class="pot-helpers">
                      <label class="pot-check"><input type="checkbox" id={`utensils-${item.id}`}/> 🥄 Utensils / plates</label>
                      <label class="pot-check"><input type="checkbox" id={`early-${item.id}`}/> ⏰ Arrive early</label>
                      <label class="pot-check"><input type="checkbox" id={`seating-${item.id}`}/> 🪑 Chairs / blanket</label>
                    </div>
                  </div>
                  <div class="pot-field" style="grid-column:1/-1">
                    <label>Dietary / allergies <span class="opt">(optional)</span></label>
                    <textarea class="pot-textarea" id={`dietary-${item.id}`} placeholder="vegan, nut allergy, gluten-free…"></textarea>
                  </div>
                  <div class="pot-field" style="grid-column:1/-1">
                    <label>Notes for the organizer <span class="opt">(optional)</span></label>
                    <textarea class="pot-textarea" id={`notes-${item.id}`} placeholder="Anything else we should know?"></textarea>
                  </div>
                </div>
                <div class="pot-hint">🧊 No fridge on site — bring cold dishes in a cooler!</div>
                <div class="pot-form-row">
                  <button class="pot-submit" data-id={item.id} data-dish={item.suggestion}>Claim it! 🎉</button>
                  <button class="pot-cancel" data-id={item.id}>Cancel</button>
                </div>
                <div class="pot-error" id={`err-${item.id}`}></div>
              </div>
            </div>
          ))}
        </div>
      );
    })}

    <!-- Custom dish -->
    <div class="pot-cat">
      <div class="pot-cat-title"><span>Bringing something else?</span></div>
      <button type="button" class="pot-custom-cta" id="custom-toggle">
        <span class="pot-custom-cta-icon">✏️</span>
        <div>
          <strong>Add your own dish</strong>
          <span>Doesn't see what you want to bring? Add it here.</span>
        </div>
      </button>
      <div class="pot-form" id="form-custom">
        <div class="pot-form-title">What are you <span>bringing?</span></div>
        <div class="pot-grid">
          <div class="pot-field" style="grid-column:1/-1">
            <label>What are you bringing? <span class="opt">*</span></label>
            <input type="text" class="pot-input" id="custom-dish" placeholder="e.g. Cornbread, fruit punch…"/>
          </div>
          <div class="pot-field">
            <label>First name <span class="opt">*</span></label>
            <input type="text" class="pot-input" id="custom-first" placeholder="Jamie" autocomplete="given-name"/>
          </div>
          <div class="pot-field">
            <label>Last name <span class="opt">(optional)</span></label>
            <input type="text" class="pot-input" id="custom-last" placeholder="Doe" autocomplete="family-name"/>
          </div>
          <div class="pot-field">
            <label>Email <span class="opt">(for a reminder)</span></label>
            <input type="email" class="pot-input" id="custom-email" placeholder="you@example.com" autocomplete="email"/>
          </div>
          <div class="pot-field">
            <label>Phone <span class="opt">(for SMS)</span></label>
            <input type="tel" class="pot-input" id="custom-phone" placeholder="(720) 555-1234" autocomplete="tel"/>
          </div>
          <div class="pot-field">
            <label>How many coming?</label>
            <div class="pot-guests">
              <button type="button" id="custom-minus">−</button>
              <span class="pot-count" id="custom-count">1</span>
              <button type="button" id="custom-plus">+</button>
              <span class="pot-note" id="custom-note">just me</span>
            </div>
          </div>
          <div class="pot-field">
            <label>How can you help?</label>
            <div class="pot-helpers">
              <label class="pot-check"><input type="checkbox" id="custom-utensils"/> 🥄 Utensils / plates</label>
              <label class="pot-check"><input type="checkbox" id="custom-early"/> ⏰ Arrive early</label>
              <label class="pot-check"><input type="checkbox" id="custom-seating"/> 🪑 Chairs / blanket</label>
            </div>
          </div>
          <div class="pot-field" style="grid-column:1/-1">
            <label>Dietary / allergies <span class="opt">(optional)</span></label>
            <textarea class="pot-textarea" id="custom-dietary" placeholder="vegan, nut allergy, gluten-free…"></textarea>
          </div>
          <div class="pot-field" style="grid-column:1/-1">
            <label>Notes for the organizer <span class="opt">(optional)</span></label>
            <textarea class="pot-textarea" id="custom-notes" placeholder="Anything else we should know?"></textarea>
          </div>
        </div>
        <div class="pot-hint">🧊 No fridge on site — bring cold dishes in a cooler!</div>
        <div class="pot-form-row">
          <button class="pot-submit" id="custom-submit">I'm bringing it! 🎉</button>
          <button class="pot-cancel" id="custom-cancel">Cancel</button>
        </div>
        <div class="pot-error" id="err-custom"></div>
      </div>
    </div>
  </div>

  <!-- WHO'S COMING TAB -->
  <div class="pot-panel" id="panel-coming">
    {signups.length === 0 ? (
      <div class="pot-empty">Nobody's signed up yet — be the first!</div>
    ) : signups.map((s: any) => (
      <div class="pot-coming-row">
        <div class="pot-avatar">{(s.name || '?').split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase()}</div>
        <div>
          <div class="pot-coming-name">{s.name}</div>
          <div class="pot-coming-dish">{s.dish || 'Just showing up 🎉'}</div>
        </div>
        {s.guest_count > 1 && <div class="pot-coming-plus">+{s.guest_count - 1}</div>}
      </div>
    ))}
  </div>
</div>

<div class="pot-toast" id="toast"></div>

<div class="pot-overlay" id="confirm-overlay">
  <div class="pot-overlay-card">
    <div style="font-size:40px;text-align:center;margin-bottom:8px">🎉</div>
    <h2 id="confirm-title">You're in!</h2>
    <div class="pot-overlay-sub">Confirmation email is on the way.</div>
    <div class="pot-block" id="confirm-contact" style="display:none">
      <div class="pot-block-label">Stay in touch</div>
      <div class="pot-overlay-rows" id="confirm-contact-rows"></div>
    </div>
    <div class="pot-block pay" id="confirm-pay" style="display:none">
      <div class="pot-block-label">Want to chip in?</div>
      <div class="pot-overlay-rows" id="confirm-pay-rows"></div>
    </div>
    <button class="pot-overlay-ok" id="confirm-ok">Got it</button>
  </div>
</div>

<script is:inline define:vars={{ potluckId: id }}>
  (function () {
    var guestCounts = {};
    var customCount = 1;

    function val(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
    function checked(id) { var el = document.getElementById(id); return !!(el && el.checked); }

    function closeAllForms() {
      document.querySelectorAll('.pot-form').forEach(function (f) { f.classList.remove('open'); });
    }

    // ── Tabs ─────────────────────────────────────────────────────────
    document.querySelectorAll('.pot-tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var t = tab.dataset.tab;
        document.querySelectorAll('.pot-tab').forEach(function (x) { x.classList.toggle('active', x.dataset.tab === t); });
        document.getElementById('panel-signup').classList.toggle('active', t === 'signup');
        document.getElementById('panel-coming').classList.toggle('active', t === 'coming');
      });
    });

    // ── Item rows: tap to open inline form ──────────────────────────
    document.querySelectorAll('.pot-item[data-id]').forEach(function (row) {
      row.addEventListener('click', function () {
        var id = row.dataset.id;
        closeAllForms();
        var form = document.getElementById('form-' + id);
        if (!form) return;
        form.classList.add('open');
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(function () {
          var first = document.getElementById('first-' + id);
          if (first) first.focus();
        }, 250);
      });
    });

    // ── Cancel buttons ──────────────────────────────────────────────
    document.querySelectorAll('.pot-cancel').forEach(function (btn) {
      btn.addEventListener('click', function () { closeAllForms(); });
    });

    // ── Custom dish toggle ──────────────────────────────────────────
    document.getElementById('custom-toggle').addEventListener('click', function () {
      closeAllForms();
      var form = document.getElementById('form-custom');
      form.classList.add('open');
      form.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(function () {
        var dish = document.getElementById('custom-dish');
        if (dish) dish.focus();
      }, 250);
    });

    // ── Guest counters ──────────────────────────────────────────────
    function guestNote(n) { return n === 1 ? 'just me' : '+ ' + (n - 1) + (n === 2 ? ' guest' : ' guests'); }

    document.querySelectorAll('.pot-guests button[data-id]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.dataset.id;
        var dir = parseInt(btn.dataset.dir);
        var cur = guestCounts[id] || 1;
        var next = Math.max(1, Math.min(20, cur + dir));
        guestCounts[id] = next;
        document.getElementById('gc-' + id).textContent = next;
        document.getElementById('gn-' + id).textContent = guestNote(next);
      });
    });

    document.getElementById('custom-minus').addEventListener('click', function () {
      customCount = Math.max(1, customCount - 1);
      document.getElementById('custom-count').textContent = customCount;
      document.getElementById('custom-note').textContent = guestNote(customCount);
    });
    document.getElementById('custom-plus').addEventListener('click', function () {
      customCount = Math.min(20, customCount + 1);
      document.getElementById('custom-count').textContent = customCount;
      document.getElementById('custom-note').textContent = guestNote(customCount);
    });

    // ── Submit ──────────────────────────────────────────────────────
    function showErr(id, msg) {
      var el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg; el.classList.add('show');
    }
    function clearErr(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.textContent = ''; el.classList.remove('show');
    }

    function escHtml(s) {
      return String(s || '').replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function showConfirm(firstName, contact) {
      document.getElementById('confirm-title').textContent = "You're in, " + firstName + '!';
      var ccRows = [];
      if (contact.phone) ccRows.push('<div>📞 ' + escHtml(contact.phone) + '</div>');
      if (contact.discord_url) {
        ccRows.push('<div>💬 <a href="' + escHtml(contact.discord_url) + '" target="_blank" rel="noopener">Join Discord</a>' + (contact.discord ? ' · ' + escHtml(contact.discord) : '') + '</div>');
      } else if (contact.discord) {
        ccRows.push('<div>💬 ' + escHtml(contact.discord) + '</div>');
      }
      if (ccRows.length) {
        document.getElementById('confirm-contact-rows').innerHTML = ccRows.join('');
        document.getElementById('confirm-contact').style.display = 'block';
      }

      var payRows = [];
      if (contact.venmo) payRows.push('<div>💸 Venmo: <a href="https://venmo.com/' + escHtml(String(contact.venmo).replace(/^@/, '')) + '" target="_blank" rel="noopener">' + escHtml(contact.venmo) + '</a></div>');
      if (contact.cashapp_handle) payRows.push('<div>💵 Cash App: <a href="https://cash.app/' + escHtml(String(contact.cashapp_handle).replace(/^\$/, '$')) + '" target="_blank" rel="noopener">' + escHtml(contact.cashapp_handle) + '</a></div>');
      if (contact.stripe_link) payRows.push('<div>💳 <a href="' + escHtml(contact.stripe_link) + '" target="_blank" rel="noopener">Pay with card</a></div>');
      if (payRows.length) {
        document.getElementById('confirm-pay-rows').innerHTML = payRows.join('');
        document.getElementById('confirm-pay').style.display = 'block';
      }

      document.getElementById('confirm-overlay').classList.add('show');
    }

    document.getElementById('confirm-ok').addEventListener('click', function () {
      document.getElementById('confirm-overlay').classList.remove('show');
      location.reload();
    });

    async function submit(opts) {
      var btn = opts.btn;
      var origText = btn.textContent;
      btn.disabled = true; btn.textContent = 'Saving…';
      try {
        var res = await fetch('/api/potluck', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            potluckId: String(potluckId),
            name: opts.name,
            email: opts.email,
            phone: opts.phone,
            handle: '',
            platforms: '',
            rsvp: 'yes',
            guestCount: String(opts.guests),
            dish: opts.dish,
            dishCategory: '',
            dietary: opts.dietary,
            notes: opts.notes,
            utensils: opts.utensils,
            earlyArrive: opts.earlyArrive,
            seating: opts.seating,
            _gotcha: '',
            _turnstile: '',
          }),
        });
        var data = await res.json();
        if (data.ok) {
          showConfirm(opts.firstName, data.contact || {});
          return;
        }
        if (data.error === 'slot_full') showErr(opts.errId, 'Someone just claimed this — refresh to see what else is open.');
        else showErr(opts.errId, 'Something went wrong — try again.');
      } catch {
        showErr(opts.errId, 'Network problem — try again.');
      }
      btn.disabled = false; btn.textContent = origText;
    }

    document.querySelectorAll('.pot-submit[data-id]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.dataset.id;
        var first = val('first-' + id);
        if (!first) {
          var f = document.getElementById('first-' + id);
          if (f) { f.classList.add('invalid'); f.focus(); }
          return;
        }
        document.getElementById('first-' + id).classList.remove('invalid');
        var last = val('last-' + id);
        var name = last ? first + ' ' + last : first;
        clearErr('err-' + id);
        submit({
          btn: btn, errId: 'err-' + id,
          name: name, firstName: first,
          email: val('email-' + id),
          phone: val('phone-' + id),
          guests: guestCounts[id] || 1,
          dish: btn.dataset.dish,
          dietary: val('dietary-' + id),
          notes: val('notes-' + id),
          utensils: checked('utensils-' + id),
          earlyArrive: checked('early-' + id),
          seating: checked('seating-' + id),
        });
      });
    });

    document.getElementById('custom-submit').addEventListener('click', function () {
      var dish = val('custom-dish');
      if (!dish) {
        var d = document.getElementById('custom-dish');
        d.classList.add('invalid'); d.focus(); return;
      }
      document.getElementById('custom-dish').classList.remove('invalid');
      var first = val('custom-first');
      if (!first) {
        var f = document.getElementById('custom-first');
        f.classList.add('invalid'); f.focus(); return;
      }
      document.getElementById('custom-first').classList.remove('invalid');
      var last = val('custom-last');
      var name = last ? first + ' ' + last : first;
      clearErr('err-custom');
      submit({
        btn: document.getElementById('custom-submit'), errId: 'err-custom',
        name: name, firstName: first,
        email: val('custom-email'),
        phone: val('custom-phone'),
        guests: customCount,
        dish: dish,
        dietary: val('custom-dietary'),
        notes: val('custom-notes'),
        utensils: checked('custom-utensils'),
        earlyArrive: checked('custom-early'),
        seating: checked('custom-seating'),
      });
    });

    // ── Copy link ───────────────────────────────────────────────────
    document.getElementById('copy-link').addEventListener('click', function () {
      navigator.clipboard.writeText(location.href).then(function () {
        var t = document.getElementById('toast');
        t.textContent = 'Link copied ✓'; t.classList.add('show');
        setTimeout(function () { t.classList.remove('show'); }, 1800);
      }).catch(function () {});
    });
  })();
</script>
</Base>
