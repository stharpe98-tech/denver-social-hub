---
import Base from '../../layouts/Base.astro';
---
<Base title="Host a potluck" description="Spin up a potluck sign-up sheet in 60 seconds. Anyone can host.">
  <div class="wrap">
    <header class="intro">
      <div class="tag">HOST A POTLUCK</div>
      <h1>Spin up a sign-up sheet.</h1>
      <p class="sub">Free, takes a minute. Pick a date, set a location, and we'll generate the sign-up page. Share the link, neighbors claim a dish.</p>
    </header>

    <form class="card" id="potluck-form">
      <div class="field">
        <label>Title <span class="req">*</span></label>
        <input id="p-title" type="text" maxlength="100" placeholder="Cheesman Summer Potluck" required/>
      </div>
      <div class="field two">
        <div>
          <label>Date</label>
          <input id="p-event-date" type="date"/>
        </div>
        <div>
          <label>Time (optional)</label>
          <input id="p-time" type="text" maxlength="40" placeholder="5–9pm"/>
        </div>
      </div>
      <div class="field">
        <label>Location <span class="req">*</span></label>
        <input id="p-location" type="text" maxlength="80" placeholder="Cheesman Park · south pavilion" required/>
      </div>
      <div class="field">
        <label>Description <span class="opt">(optional)</span></label>
        <textarea id="p-description" rows="3" maxlength="800" placeholder="Bring a dish to share. Drinks, dessert, a side, or a main — whatever you've got."></textarea>
      </div>
      <button type="submit" class="cta" id="submit-btn">Create the sign-up page →</button>
      <div class="err" id="err"></div>
    </form>

    <div class="footnote">
      <p>After you create it, you'll land on a manage page where you can add suggested dishes (apps, mains, drinks, etc.) and share the public sign-up link.</p>
    </div>
  </div>

  <script is:inline>
    (function() {
      var form = document.getElementById('potluck-form');
      var errEl = document.getElementById('err');
      function showErr(msg) { errEl.textContent = msg; errEl.classList.add('show'); }
      function clearErr() { errEl.textContent = ''; errEl.classList.remove('show'); }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        clearErr();
        var title = document.getElementById('p-title').value.trim();
        var loc = document.getElementById('p-location').value.trim();
        if (!title) { showErr('Title is required.'); return; }
        if (!loc) { showErr('Location is required.'); return; }
        var btn = document.getElementById('submit-btn');
        var orig = btn.textContent; btn.disabled = true; btn.textContent = 'Creating…';

        // Build a friendly date_label from the date input
        var dateInput = document.getElementById('p-event-date').value;
        var dateLabel = '';
        if (dateInput) {
          try {
            var d = new Date(dateInput + 'T12:00:00');
            var mn = ['January','February','March','April','May','June','July','August','September','October','November','December'];
            dateLabel = mn[d.getMonth()] + ' ' + d.getDate();
          } catch {}
        }

        try {
          // Use the existing 'create' action (status='upcoming') so the new potluck is immediately public.
          var r = await fetch('/api/potlucks', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'create',
              title: title,
              description: document.getElementById('p-description').value.trim(),
              date_label: dateLabel,
              time_label: document.getElementById('p-time').value.trim(),
              location: loc,
              status: 'upcoming',
              event_date: dateInput || null,
            })
          });
          var d = await r.json();
          if (d && d.ok && d.id) {
            window.location.href = '/potlucks/manage/' + d.id;
            return;
          }
          showErr((d && d.error) || 'Could not create the potluck. Try again.');
        } catch (e) {
          showErr('Network hiccup — try again.');
        }
        btn.disabled = false; btn.textContent = orig;
      });
    })();
  </script>

  <style>
    .wrap {
      max-width: 560px; margin: 0 auto;
      padding: var(--space-6) var(--space-4) var(--space-8);
      background:
        radial-gradient(circle at 20% 18%, rgba(255,255,255,0.45) 0%, transparent 55%),
        radial-gradient(circle at 80% 75%, rgba(0,0,0,0.04) 0%, transparent 55%),
        repeating-linear-gradient(125deg, transparent 0 3px, rgba(0,0,0,0.022) 3px 4px),
        linear-gradient(160deg, #E8DFCF 0%, #D8CBB4 100%);
      min-height: 100vh; box-sizing: border-box;
    }
    .intro { text-align: center; margin-bottom: var(--space-5); }
    .tag { font-family: 'SF Mono', Menlo, monospace; font-size: 11px; letter-spacing: 2px; color: var(--accent, #7C3AED); font-weight: 700; margin-bottom: var(--space-2); }
    .intro h1 { font-family: var(--font-display, 'Playfair Display', serif); font-size: clamp(30px, 5vw, 40px); font-weight: 800; line-height: 1.1; margin-bottom: var(--space-2); }
    .sub { font-size: 15px; color: var(--text-sec, #555); line-height: 1.5; }
    .card { background: #FFFEFA; border: 1.5px solid rgba(0,0,0,0.08); border-radius: var(--radius-lg, 18px); padding: var(--space-5); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .field { margin-bottom: var(--space-3); }
    .field.two { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
    .field label { display: block; font-size: 12px; font-weight: 600; color: var(--text-sec, #555); margin-bottom: 6px; }
    .req { color: #DC2626; }
    .opt { color: var(--text-faint, #888); font-weight: 400; }
    .field input, .field textarea {
      width: 100%; padding: 11px 13px; border-radius: 10px; border: 1.5px solid var(--border, #E5E7EB);
      font-size: 14px; background: #fff; font-family: inherit;
    }
    .field input:focus, .field textarea:focus { outline: none; border-color: var(--accent, #7C3AED); }
    .cta { width: 100%; padding: 14px; border-radius: 999px; border: none; background: var(--accent, #7C3AED); color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: var(--space-3); }
    .cta:hover { filter: brightness(1.08); }
    .cta:disabled { opacity: 0.6; cursor: not-allowed; }
    .err { color: #DC2626; font-size: 13px; margin-top: var(--space-2); display: none; }
    .err.show { display: block; }
    .footnote { text-align: center; margin-top: var(--space-4); font-size: 13px; color: var(--text-sec, #555); line-height: 1.5; max-width: 480px; margin-left: auto; margin-right: auto; }

    @media (max-width: 639px) {
      .wrap { padding: var(--space-5) var(--space-3) var(--space-6); max-width: 100%; }
      .card { padding: var(--space-4); }
      .field.two { grid-template-columns: 1fr; }
    }
  </style>
</Base>
