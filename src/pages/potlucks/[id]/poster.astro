---
import { getDB } from '../../../lib/db';
const db = getDB();
const { id } = Astro.params;
let potluck: any = null;
try {
  if (db && id) {
    potluck = await db.prepare(`SELECT * FROM potlucks WHERE id=?`).bind(id).first();
  }
} catch(e) {}
if (!potluck) return Astro.redirect('/potlucks');

const signupUrl = `https://denversocialhub.com/go/potluck`;
const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${encodeURIComponent(signupUrl)}&bgcolor=ffffff&color=000000&margin=4`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta name="robots" content="noindex"/>
  <title>Poster · {potluck.title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #EDE6D6; font-family: 'DM Sans', sans-serif; min-height: 100vh; padding: 20px 16px 60px; }

    /* Controls */
    .ctrl-bar { max-width: 480px; margin: 0 auto 20px; }
    .ctrl-back { font-size: 13px; color: #6B6B73; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; margin-bottom: 14px; }
    .ctrl-title { font-size: 18px; font-weight: 700; color: #2A2730; margin-bottom: 16px; }
    .ctrl-section { margin-bottom: 14px; }
    .ctrl-label { font-size: 11px; font-weight: 600; color: #6B6B73; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; display: block; }
    .ctrl-input { width: 100%; padding: 10px 13px; background: #fff; border: 1.5px solid #DDD2BB; border-radius: 9px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: #2A2730; outline: none; }
    .ctrl-input:focus { border-color: #7C3AED; }
    .ctrl-input::placeholder { color: #c0b8b0; }

    /* Theme picker */
    .theme-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .theme-btn { padding: 7px 13px; border-radius: 8px; border: 2px solid #DDD2BB; background: #fff; font-size: 15px; cursor: pointer; transition: all 0.15s; -webkit-tap-highlight-color: transparent; }
    .theme-btn.active { border-color: #7C3AED; background: rgba(247,127,0,0.10); }

    /* Download button */
    .dl-btn { width: 100%; padding: 14px; border-radius: 12px; border: none; background: linear-gradient(135deg,#5B21B6,#7C3AED); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 600; cursor: pointer; margin-top: 16px; }

    /* ── POSTER ── */
    .poster-wrap { max-width: 480px; margin: 0 auto; }

    #poster {
      width: 480px;
      max-width: 100%;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.18);
      position: relative;
      font-family: 'DM Sans', sans-serif;
    }

    /* Themes */
    #poster[data-theme="warm"]     { background: linear-gradient(160deg,#fff8f0 0%,#fef3e0 60%,#fff8f0 100%); --pt: #2A2730; --ps: #8a6a40; --pa: #5B21B6; --pb: linear-gradient(135deg,#5B21B6,#7C3AED); --pbb: #fff; --pc: #7C3AED; --pd: rgba(247,127,0,0.10); }
    #poster[data-theme="dark"]     { background: linear-gradient(160deg,#0d0d1e 0%,#1a0a2e 60%,#0d0d1e 100%); --pt: #e8e8f0; --ps: #9898b0; --pa: #a5b4fc; --pb: linear-gradient(135deg,#4f46e5,#818cf8); --pbb: #fff; --pc: #818cf8; --pd: rgba(129,140,248,0.15); }
    #poster[data-theme="clean"]    { background: linear-gradient(160deg,#f0f9ff 0%,#e0f2fe 60%,#f0f9ff 100%); --pt: #111; --ps: #5B21B6; --pa: #5B21B6; --pb: linear-gradient(135deg,#5B21B6,#7c3aed); --pbb: #fff; --pc: #7c3aed; --pd: rgba(14,165,233,0.10); }
    #poster[data-theme="festive"]  { background: linear-gradient(160deg,#fef9c3 0%,#fef08a 60%,#fef9c3 100%); --pt: #1c0a00; --ps: #5B21B6; --pa: #d97706; --pb: linear-gradient(135deg,#d97706,#f59e0b); --pbb: #fff; --pc: #f59e0b; --pd: rgba(245,158,11,0.15); }
    #poster[data-theme="birthday"] { background: linear-gradient(160deg,#fdf2f8 0%,#fce7f3 60%,#fdf2f8 100%); --pt: #1a0010; --ps: #be185d; --pa: #9d174d; --pb: linear-gradient(135deg,#be185d,#ec4899); --pbb: #fff; --pc: #ec4899; --pd: rgba(236,72,153,0.12); }
    #poster[data-theme="halloween"]{ background: linear-gradient(160deg,#0d0800 0%,#1c0a00 60%,#0d0800 100%); --pt: #fef3c7; --ps: #d97706; --pa: #fb923c; --pb: linear-gradient(135deg,#9a3412,#f97316); --pbb: #fff; --pc: #f97316; --pd: rgba(249,115,22,0.15); }
    #poster[data-theme="holiday"]  { background: linear-gradient(160deg,#f0fdf4 0%,#dcfce7 40%,#fef2f2 100%); --pt: #052e16; --ps: #dc2626; --pa: #15803d; --pb: linear-gradient(135deg,#dc2626,#16a34a); --pbb: #fff; --pc: #16a34a; --pd: rgba(22,163,74,0.12); }
    #poster[data-theme="summer"]   { background: linear-gradient(160deg,#fef9c3 0%,#bae6fd 100%); --pt: #1c1200; --ps: #5B21B6; --pa: #5B21B6; --pb: linear-gradient(135deg,#5B21B6,#38bdf8); --pbb: #fff; --pc: #7c3aed; --pd: rgba(14,165,233,0.12); }
    #poster[data-theme="fall"]     { background: linear-gradient(160deg,#fff7ed 0%,#fef3c7 60%,#fef2f2 100%); --pt: #1c0e00; --ps: #9a3412; --pa: #9a3412; --pb: linear-gradient(135deg,#7c2d12,#5B21B6); --pbb: #fff; --pc: #5B21B6; --pd: rgba(194,65,12,0.12); }
    #poster[data-theme="spring"]   { background: linear-gradient(160deg,#fdf4ff 0%,#fce7f3 60%,#f0fdf4 100%); --pt: #1a0030; --ps: #7e22ce; --pa: #7e22ce; --pb: linear-gradient(135deg,#7e22ce,#a855f7); --pbb: #fff; --pc: #a855f7; --pd: rgba(168,85,247,0.12); }

    .poster-inner { padding: 36px 32px 32px; }

    .poster-badge {
      display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--pa); background: var(--pd);
      padding: 5px 14px; border-radius: 100px; margin-bottom: 20px;
    }

    .poster-title {
      font-family: 'Playfair Display', serif; font-size: clamp(28px,6vw,42px);
      font-weight: 900; color: var(--pt); line-height: 1.1; margin-bottom: 20px;
    }

    .poster-divider { height: 3px; background: var(--pb); border-radius: 2px; width: 48px; margin-bottom: 22px; }

    .poster-details { margin-bottom: 24px; }
    .poster-detail { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; }
    .poster-detail-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    .poster-detail-text { font-size: 16px; font-weight: 500; color: var(--pt); line-height: 1.4; }
    .poster-detail-sub { font-size: 13px; color: var(--ps); margin-top: 1px; }

    .poster-bottom { display: flex; align-items: center; gap: 20px; margin-top: 8px; }

    .poster-qr { flex-shrink: 0; }
    .poster-qr img { width: 100px; height: 100px; border-radius: 10px; display: block; border: 3px solid var(--pd); }

    .poster-cta { flex: 1; }
    .poster-cta-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--ps); margin-bottom: 6px; }
    .poster-cta-text { font-size: 15px; font-weight: 600; color: var(--pt); word-break: break-all; margin-bottom: 10px; line-height: 1.3; }
    .poster-cta-btn { display: inline-block; background: var(--pb); color: var(--pbb); padding: 10px 20px; border-radius: 10px; font-size: 14px; font-weight: 700; text-decoration: none; }

    .poster-footer { margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--pd); display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 8px; }
    .poster-hosted { font-size: 13px; color: var(--ps); }
    .poster-hosted strong { color: var(--pt); display: block; font-size: 14px; font-weight: 600; }
    .poster-contact { font-size: 12px; color: var(--ps); text-align: right; }
    .poster-brand { font-size: 11px; color: var(--ps); opacity: 0.6; }
  </style>
</head>
<body>
  <div class="ctrl-bar">
    <a href={potluck?.slug ? `/${potluck.slug}` : `/potlucks/${id}`} class="ctrl-back">← Back to sign-up</a>
    <div class="ctrl-title">🖼 Event Poster</div>

    <div class="ctrl-section">
      <label class="ctrl-label">Hosted by / Presented by</label>
      <input type="text" id="ctrl-hosted" class="ctrl-input" placeholder="e.g. Denver Social Community" value={potluck.hosted_by || 'Denver Social Community'}/>
    </div>
    <div class="ctrl-section">
      <label class="ctrl-label">Contact info on poster</label>
      <input type="text" id="ctrl-contact" class="ctrl-input" placeholder="e.g. @godtminilegs on Discord · (720) 341-6757" value={potluck.contact_display || ''}/>
    </div>
    <div class="ctrl-section">
      <label class="ctrl-label">Tagline</label>
      <input type="text" id="ctrl-tagline" class="ctrl-input" placeholder="e.g. Free · Bring a dish · All welcome" value="Free · Bring a dish · All welcome"/>
    </div>
    <div class="ctrl-section">
      <label class="ctrl-label">Theme</label>
      <div class="theme-row">
        <button class="theme-btn active" data-t="warm">🌞</button>
        <button class="theme-btn" data-t="dark">🌙</button>
        <button class="theme-btn" data-t="clean">✨</button>
        <button class="theme-btn" data-t="festive">🎉</button>
        <button class="theme-btn" data-t="birthday">🎂</button>
        <button class="theme-btn" data-t="halloween">🎃</button>
        <button class="theme-btn" data-t="holiday">🎄</button>
        <button class="theme-btn" data-t="summer">🌊</button>
        <button class="theme-btn" data-t="fall">🍂</button>
        <button class="theme-btn" data-t="spring">🌸</button>
      </div>
    </div>
    <button class="dl-btn" id="dl-btn">⬇ Download Poster</button>
  </div>

  <!-- POSTER PREVIEW -->
  <div class="poster-wrap">
    <div id="poster" data-theme="warm">
      <div class="poster-inner">
        <div class="poster-badge" id="p-badge">Community Potluck</div>
        <div class="poster-title" id="p-title">{potluck.title}</div>
        <div class="poster-divider"></div>
        <div class="poster-details">
          {potluck.date_label && (
            <div class="poster-detail">
              <div class="poster-detail-icon">📅</div>
              <div>
                <div class="poster-detail-text" id="p-date">{potluck.date_label}{potluck.time_label ? ` · ${potluck.time_label}` : ''}</div>
              </div>
            </div>
          )}
          {potluck.location && (
            <div class="poster-detail">
              <div class="poster-detail-icon">📍</div>
              <div>
                <div class="poster-detail-text" id="p-loc">{potluck.location}</div>
                {potluck.location_detail && <div class="poster-detail-sub" id="p-loc-sub">{potluck.location_detail}</div>}
              </div>
            </div>
          )}
          <div class="poster-detail">
            <div class="poster-detail-icon">✨</div>
            <div class="poster-detail-text" id="p-tagline">Free · Bring a dish · All welcome</div>
          </div>
        </div>

        <div class="poster-bottom">
          <div class="poster-qr">
            <img src={qrUrl} alt="QR code to sign up" id="p-qr" crossorigin="anonymous"/>
          </div>
          <div class="poster-cta">
            <div class="poster-cta-label">Sign up at</div>
            <div class="poster-cta-text">denversocialhub.com/go/potluck</div>
            <div class="poster-cta-btn">Sign up free →</div>
          </div>
        </div>

        <div class="poster-footer">
          <div class="poster-hosted">
            Hosted by
            <strong id="p-hosted">{potluck.hosted_by || 'Denver Social Community'}</strong>
          </div>
          <div id="p-contact" class="poster-contact">{potluck.contact_display || ''}</div>
        </div>
        <div class="poster-brand" style="margin-top:10px;text-align:center">denversocialhub.com · No ads, ever.</div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Live update from inputs
    function update() {
      document.getElementById('p-hosted').textContent = document.getElementById('ctrl-hosted').value || 'Denver Social Community';
      document.getElementById('p-contact').textContent = document.getElementById('ctrl-contact').value;
      document.getElementById('p-tagline').textContent = document.getElementById('ctrl-tagline').value || 'Free · Bring a dish · All welcome';
    }
    ['ctrl-hosted','ctrl-contact','ctrl-tagline'].forEach(function(id) {
      document.getElementById(id).addEventListener('input', update);
    });

    // Theme switching
    document.querySelectorAll('.theme-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.theme-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        document.getElementById('poster').setAttribute('data-theme', btn.dataset.t);
      });
    });

    // Download
    document.getElementById('dl-btn').addEventListener('click', async function() {
      var btn = document.getElementById('dl-btn');
      btn.textContent = 'Generating…'; btn.disabled = true;
      try {
        var canvas = await html2canvas(document.getElementById('poster'), {
          scale: 2, useCORS: true, allowTaint: false, backgroundColor: null
        });
        var link = document.createElement('a');
        link.download = 'potluck-poster.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch(e) { alert('Download failed — try screenshotting instead.'); }
      btn.textContent = '⬇ Download Poster'; btn.disabled = false;
    });
  </script>
</body>
</html>
