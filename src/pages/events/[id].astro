---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { id } = Astro.params;
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

let event: any = null;
let rsvps: any[] = [];
let myRsvp = false;

try {
  if (db && id) {
    event = await db.prepare("SELECT * FROM events WHERE id=?").bind(id).first();
    const r = await db.prepare("SELECT r.email,r.name,m.neighborhood FROM event_rsvps r LEFT JOIN members m ON r.email=m.email WHERE r.event_id=?").bind(id).all();
    rsvps = r?.results || [];
    if (user) myRsvp = rsvps.some((r:any) => r.email===user.email);
  }
} catch {}

if (!event) return Astro.redirect("/events");
const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",sports:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",potluck:"🍲",other:"📅" };

// Per-type theme colors: [accent, light bg tint, tag bg, tag text]
const typeThemes: Record<string, { accent: string; grad1: string; grad2: string; tagBg: string; tagText: string }> = {
  dinner:        { accent:"#F05A28", grad1:"#FFF7ED", grad2:"#FEF2F2", tagBg:"#FFF7ED", tagText:"#C2410C" },
  game_night:    { accent:"#7C3AED", grad1:"#F5F3FF", grad2:"#EEF2FF", tagBg:"#EEF2FF", tagText:"#5B21B6" },
  outdoor:       { accent:"#059669", grad1:"#ECFDF5", grad2:"#F0FDF4", tagBg:"#F0FDF4", tagText:"#047857" },
  brewery:       { accent:"#D97706", grad1:"#FFFBEB", grad2:"#FEF3C7", tagBg:"#FFFBEB", tagText:"#92400E" },
  coffee:        { accent:"#92400E", grad1:"#FFFBEB", grad2:"#FEF9EE", tagBg:"#FEF3C7", tagText:"#78350F" },
  arts:          { accent:"#DB2777", grad1:"#FDF2F8", grad2:"#FCE7F3", tagBg:"#FDF2F8", tagText:"#9D174D" },
  music:         { accent:"#7C3AED", grad1:"#F5F3FF", grad2:"#FDF2F8", tagBg:"#F5F3FF", tagText:"#6D28D9" },
  social:        { accent:"#EC4899", grad1:"#FDF2F8", grad2:"#FFF1F2", tagBg:"#FCE7F3", tagText:"#BE185D" },
  group_tickets: { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#EEF2FF", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  camping:       { accent:"#059669", grad1:"#ECFDF5", grad2:"#F0FDF4", tagBg:"#ECFDF5", tagText:"#065F46" },
  sports_outing: { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#DBEAFE", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  bowling:       { accent:"#3B82F6", grad1:"#EFF6FF", grad2:"#E0F2FE", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  active:        { accent:"#059669", grad1:"#ECFDF5", grad2:"#D1FAE5", tagBg:"#ECFDF5", tagText:"#065F46" },
  casino:        { accent:"#DC2626", grad1:"#FEF2F2", grad2:"#FFFBEB", tagBg:"#FEF2F2", tagText:"#991B1B" },
  food_trucks:   { accent:"#EA580C", grad1:"#FFF7ED", grad2:"#FFFBEB", tagBg:"#FFF7ED", tagText:"#C2410C" },
  potluck:       { accent:"#F05A28", grad1:"#FFF7ED", grad2:"#FEF2F2", tagBg:"#FFF7ED", tagText:"#C2410C" },
  sports:        { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#DBEAFE", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  other:         { accent:"#7C3AED", grad1:"#F8F9FB", grad2:"#EEF2FF", tagBg:"#EEF2FF", tagText:"#4338CA" },
};

const theme = typeThemes[event.event_type] || typeThemes.other;

const typeImages: Record<string, string> = {
  dinner:        "https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=900&q=75",
  game_night:    "https://images.unsplash.com/photo-1632501641765-e568d28b0015?w=900&q=75",
  outdoor:       "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=900&q=75",
  brewery:       "https://images.unsplash.com/photo-1535958636474-b021ee887b13?w=900&q=75",
  coffee:        "https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=900&q=75",
  arts:          "https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=900&q=75",
  music:         "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=900&q=75",
  social:        "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=75",
  group_tickets: "https://images.unsplash.com/photo-1540039155733-5bb30b53aa14?w=900&q=75",
  camping:       "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=900&q=75",
  sports_outing: "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=900&q=75",
  bowling:       "https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=900&q=75",
  active:        "https://images.unsplash.com/photo-1522163182402-834f871fd851?w=900&q=75",
  casino:        "https://images.unsplash.com/photo-1596838132731-3301c3fd4317?w=900&q=75",
  food_trucks:   "https://images.unsplash.com/photo-1565123409695-7b5ef63a2efb?w=900&q=75",
  potluck:       "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=900&q=75",
  sports:        "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=900&q=75",
  other:         "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=75",
};
const heroImage = typeImages[event.event_type] || typeImages.other;

const spotsLeft = Math.max(0, (parseInt(event.spots) || 10) - rsvps.length);
const avatarColors = ["#7C3AED","#3B82F6","#10B981","#F59E0B","#EC4899","#EF4444","#6366F1"];
---
<Base title={event.title}>

<div class="det-bg" style={`background-image: url(${heroImage});`}>
  <div class="det-bg-overlay"></div>
</div>

<div class="det-page" style={`--ev-accent: ${theme.accent}; --ev-accent-shadow: ${theme.accent}33;`}>
  <a href="/events" class="det-back">← Back to events</a>

  <!-- Big emoji + type + title -->
  <div class="det-hero-block">
    <div class="det-emoji">{typeEmoji[event.event_type] || '📅'}</div>
    <div class="det-type-tag" style={`background: ${theme.tagBg}; color: ${theme.tagText};`}>{(event.event_type || 'event').replace('_', ' ')}</div>
    <h1 class="det-title">{event.title}</h1>
    <p class="det-subtitle">
      {(event.event_month || 'TBD').slice(0, 3)} {event.event_day || ''} · {myRsvp ? (event.location || event.zone || 'Denver') : (event.zone || 'Denver')}
      {!myRsvp && <span class="det-loc-hint"> · RSVP to see full address</span>}
    </p>
  </div>

  <!-- Info pills -->
  <div class="det-pills">
    <div class="det-pill">
      <span class="det-pill-icon">📅</span>
      <strong>{(event.event_month || 'TBD').slice(0, 3)} {event.event_day || 'TBD'}</strong>
      {event.event_time && <span>· {event.event_time}</span>}
    </div>
    <div class="det-pill">
      <span class="det-pill-icon">📍</span>
      <strong>{myRsvp ? (event.location || event.zone || 'Denver') : (event.zone || 'Denver')}</strong>
    </div>
    <div class="det-pill">
      <span class="det-pill-icon">💰</span>
      <strong>{event.price_cap && event.price_cap !== 'Free' && event.price_cap !== '$0' ? event.price_cap : 'Free'}</strong>
    </div>
    <div class="det-pill">
      <span class="det-pill-icon">👥</span>
      <strong>{event.spots}</strong> max
    </div>
  </div>

  <!-- Description card -->
  {event.description && (
    <div class="det-desc-card">
      <p>{event.description}</p>
    </div>
  )}

  <!-- Spots + RSVP bar -->
  <div class="det-spots-card">
    <div class="det-spots-top">
      <div class="det-spots-label">{spotsLeft > 0 ? (spotsLeft <= 4 ? 'Almost full!' : 'Spots available') : 'Event is full'}</div>
      <div class="det-spots-count">{spotsLeft} left of {event.spots}</div>
    </div>
    <div class="det-bar">
      <div class="det-bar-fill" style={`width: ${Math.round((rsvps.length / (parseInt(event.spots) || 10)) * 100)}%; background: linear-gradient(90deg, ${theme.accent}, ${theme.accent}CC);`}></div>
    </div>
    {user ? (
      <button id="rsvp-btn" class={`det-rsvp-btn ${myRsvp ? 'rsvped' : ''}`} style={myRsvp ? '' : `background: ${theme.accent};`}>
        {myRsvp ? "✓ You're In — Cancel RSVP" : "I'm In"}
      </button>
    ) : (
      <a href={`/login?next=/events/${id}`} class="det-rsvp-btn" style={`background: ${theme.accent};`}>Sign in to RSVP</a>
    )}
    {spotsLeft <= 4 && spotsLeft > 0 && <div class="det-urgent">🔥 Only {spotsLeft} spots left — don't sleep on this</div>}
  </div>

  <!-- Who's going -->
  <div class="det-people-card">
    <div class="det-people-title">Who's going ({rsvps.length})</div>
    {rsvps.length > 0 ? (
      <div class="det-people-list">
        {rsvps.map((r: any, i: number) => (
          <div class="det-person">
            <div class="det-person-av" style={`background:${avatarColors[i % avatarColors.length]}`}>{(r.name || '?')[0]}</div>
            <span class="det-person-name">{r.name}</span>
            {r.neighborhood && <span class="det-person-hood">{r.neighborhood}</span>}
          </div>
        ))}
      </div>
    ) : (
      <div class="det-people-empty">No one's RSVP'd yet. Be the person who starts the wave.</div>
    )}
  </div>

  <!-- Discord CTA -->
  <div class="det-discord">
    <span class="det-discord-icon">💬</span>
    <div class="det-discord-text">
      <strong>Plans happen in Discord first</strong>
      <span>Chat about this event, coordinate rides, or just hang</span>
    </div>
    <a href={event.discord_link || "https://discord.gg/S8SFNkdSgK"} class="det-discord-btn" target="_blank" rel="noopener">Join →</a>
  </div>
</div>

<style is:inline>
  /* ── Full-page background ── */
  .det-bg {
    position: fixed; top: 0; left: 0; right: 0; height: 100vh;
    background-size: cover; background-position: center;
    z-index: -2;
  }
  .det-bg-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(255,255,255,0.7) 0%,
      rgba(255,255,255,0.88) 30%,
      rgba(255,255,255,0.97) 60%,
      rgba(255,255,255,1) 80%
    );
    z-index: -1;
  }

  /* ── Page container ── */
  .det-page { max-width: 600px; margin: 0 auto; padding: 24px 20px 48px; position: relative; z-index: 1; }

  .det-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600;
    color: #6B7280; margin-bottom: 20px; transition: color .2s;
    text-decoration: none;
  }
  .det-back:hover { color: var(--ev-accent, #7C3AED); }

  /* ── Hero block: emoji + tag + title ── */
  .det-hero-block { margin-bottom: 24px; }
  .det-emoji { font-size: 52px; margin-bottom: 8px; }
  .det-type-tag {
    display: inline-block; padding: 5px 14px; border-radius: 8px; font-size: 11px;
    font-weight: 700; font-family: 'Outfit', sans-serif;
    text-transform: capitalize; letter-spacing: 0.04em; margin-bottom: 10px;
  }
  .det-title {
    font-family: 'Outfit', sans-serif; font-size: clamp(26px, 5vw, 32px);
    font-weight: 900; letter-spacing: -0.02em; color: #111827;
    margin-bottom: 6px; line-height: 1.15;
  }
  .det-subtitle { font-size: 14px; color: #6B7280; }
  .det-loc-hint { color: #9CA3AF; font-size: 12px; }

  /* ── Info pills ── */
  .det-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .det-pill {
    display: flex; align-items: center; gap: 6px;
    padding: 10px 16px; border-radius: 12px;
    background: rgba(255,255,255,0.9); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 1px solid #E5E7EB; font-size: 13px; font-weight: 500; color: #374151;
  }
  .det-pill-icon { font-size: 16px; }
  .det-pill strong { font-weight: 700; color: #111827; }

  /* ── Description card ── */
  .det-desc-card {
    background: rgba(255,255,255,0.88); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid #E5E7EB; border-radius: 16px;
    padding: 20px 22px; margin-bottom: 16px;
  }
  .det-desc-card p { font-size: 15px; line-height: 1.8; color: #374151; }

  /* ── Spots + RSVP card ── */
  .det-spots-card {
    background: rgba(255,255,255,0.92); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid #E5E7EB; border-radius: 16px;
    padding: 18px 20px; margin-bottom: 16px;
  }
  .det-spots-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .det-spots-label { font-size: 14px; font-weight: 600; font-family: 'Outfit', sans-serif; color: #111827; }
  .det-spots-count { font-size: 13px; color: #6B7280; }

  .det-bar { height: 8px; background: #E5E7EB; border-radius: 4px; overflow: hidden; margin-bottom: 14px; }
  .det-bar-fill { height: 100%; border-radius: 4px; transition: width .4s ease; }

  .det-rsvp-btn {
    display: block; width: 100%; padding: 14px; border-radius: 14px;
    font-size: 15px; font-weight: 700; font-family: 'Outfit', sans-serif;
    border: none; cursor: pointer; text-align: center; text-decoration: none;
    background: #7C3AED; color: #fff; transition: all .2s;
  }
  .det-rsvp-btn:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 6px 20px var(--ev-accent-shadow, rgba(124,58,237,0.2)); }
  .det-rsvp-btn.rsvped { background: rgba(220,38,38,0.08); color: #DC2626; }
  .det-rsvp-btn.rsvped:hover { background: rgba(220,38,38,0.14); }

  .det-urgent { font-size: 12px; font-weight: 600; color: #DC2626; margin-top: 10px; text-align: center; }

  /* ── People card ── */
  .det-people-card {
    background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid #E5E7EB; border-radius: 16px;
    padding: 18px 20px; margin-bottom: 16px;
  }
  .det-people-title { font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 12px; }
  .det-people-list { display: flex; flex-direction: column; gap: 0; }

  .det-person {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 0; border-bottom: 1px solid #F3F4F6; font-size: 14px;
  }
  .det-person:last-child { border-bottom: none; }
  .det-person-av {
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0;
  }
  .det-person-name { font-family: 'Outfit', sans-serif; font-weight: 600; color: #111827; }
  .det-person-hood { font-size: 12px; color: #9CA3AF; margin-left: auto; }

  .det-people-empty {
    padding: 20px 0; text-align: center; color: #9CA3AF; font-size: 13px; line-height: 1.6;
  }

  /* ── Discord CTA ── */
  .det-discord {
    display: flex; align-items: center; gap: 14px;
    padding: 18px 22px; border-radius: 16px;
    background: rgba(124,58,237,0.04); border: 1px solid rgba(124,58,237,0.1);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  .det-discord-icon { font-size: 24px; flex-shrink: 0; }
  .det-discord-text { flex: 1; }
  .det-discord-text strong { display: block; font-size: 13px; color: #111827; font-family: 'Outfit', sans-serif; }
  .det-discord-text span { font-size: 12px; color: #6B7280; }
  .det-discord-btn {
    padding: 8px 18px; background: #7C3AED; color: #fff;
    border-radius: 50px; font-size: 12px; font-weight: 700;
    font-family: 'Outfit', sans-serif; flex-shrink: 0; text-decoration: none;
    transition: opacity .2s;
  }
  .det-discord-btn:hover { opacity: 0.9; }

  @media (max-width: 768px) {
    .det-page { padding: 20px 16px 48px; }
    .det-pills { gap: 6px; }
    .det-pill { padding: 8px 12px; font-size: 12px; }
  }
</style>

<script define:vars={{ eventId: id, initialRsvp: myRsvp, themeAccent: theme.accent }}>
  let rsvped = initialRsvp;
  const btn = document.getElementById('rsvp-btn');
  if (btn) {
    btn.addEventListener('click', async function() {
      btn.textContent = 'Loading...';
      try {
        const r = await fetch('/api/rsvp', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event_id: eventId }) });
        if (r.status === 401) { location.href = '/login?next=' + location.pathname; return; }
        const d = await r.json();
        if (d.error) { btn.textContent = d.message || 'Error'; return; }
        rsvped = d.rsvped;
        btn.className = 'det-rsvp-btn' + (rsvped ? ' rsvped' : '');
        btn.textContent = rsvped ? "✓ You're In — Cancel RSVP" : "I'm In";
        btn.style.background = rsvped ? '' : themeAccent;
      } catch { btn.textContent = 'Error — try again'; }
    });
  }
</script>

</Base>
