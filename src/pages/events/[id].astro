</style>

<script is:inline>
  (function() {
    var btn = document.getElementById('rsvp-btn');
    if (!btn) return;
    var eventId = btn.getAttribute('data-event-id');
    var rsvped = btn.getAttribute('data-rsvped') === 'true';
    var accent = btn.getAttribute('data-accent');
    var spots = parseInt(btn.getAttribute('data-spots') || '10');

    btn.addEventListener('click', async function() {
      btn.textContent = 'Loading...';
      try {
        var r = await fetch('/api/rsvp', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event_id: eventId }) });
        if (r.status === 401) { location.href = '/login?next=' + location.pathname; return; }
        var d = await r.json();
        if (d.error) { btn.textContent = d.message || 'Error'; return; }
        rsvped = d.rsvped;
        btn.className = 'det-rsvp-btn' + (rsvped ? ' rsvped' : '');
        btn.textContent = rsvped ? "✓ You're In — Cancel RSVP" : "I'm In";
        btn.style.background = rsvped ? '' : accent;
        btn.setAttribute('data-rsvped', rsvped ? 'true' : 'false');
        // Update the count display
        var filled = document.querySelector('.det-rsvp-filled');
        if (filled && typeof d.count === 'number') {
          filled.innerHTML = '<strong>' + d.count + ' of ' + spots + '</strong> spots filled';
        }
        var fill = document.querySelector('.det-rsvp-fill');
        if (fill && typeof d.count === 'number') {
          fill.style.width = Math.round((d.count / spots) * 100) + '%';
        }
        var heroSpots = document.querySelector('.det-hero-spots');
        if (heroSpots && typeof d.count === 'number') {
          heroSpots.textContent = d.count + ' of ' + spots + ' going';
        }
        // Toggle calendar row
        var calRow = document.getElementById('cal-row');
        if (calRow) calRow.style.display = rsvped ? '' : 'none';
      } catch { btn.textContent = 'Error — try again'; }
    });
  })();

  // .ics download
  var icsBtn = document.querySelector('.det-cal-ics');
  if (icsBtn) {
    icsBtn.addEventListener('click', function() {
      var data = icsBtn.getAttribute('data-ics');
      if (!data) return;
      var blob = new Blob([data], { type: 'text/calendar;charset=utf-8' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'denver-social-event.ics';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }

  // ── Message Host modal ──
  var msgBtn = document.getElementById('msgHostBtn');
  var msgOverlay = document.getElementById('msgOverlay');
  var msgClose = document.getElementById('msgClose');
  var msgSend = document.getElementById('msgSend');

  if (msgBtn && msgOverlay) {
    msgBtn.addEventListener('click', function() { msgOverlay.style.display = ''; });
    msgClose && msgClose.addEventListener('click', function() { msgOverlay.style.display = 'none'; });
    msgOverlay.addEventListener('click', function(e) { if (e.target === msgOverlay) msgOverlay.style.display = 'none'; });
  }

  if (msgSend) {
    msgSend.addEventListener('click', async function() {
      var text = document.getElementById('msgText');
      if (!text || !text.value.trim()) { alert('Please type a message'); return; }
      msgSend.textContent = 'Sending...';
      msgSend.disabled = true;
      try {
        var r = await fetch('/api/contact-host', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            event_id: msgSend.getAttribute('data-event-id'),
            host_id: msgSend.getAttribute('data-host-id'),
            message: text.value.trim()
          })
        });
        var d = await r.json();
        if (d.ok) {
          text.value = '';
          msgSend.textContent = '✓ Sent!';
          setTimeout(function() {
            msgOverlay.style.display = 'none';
            msgSend.textContent = 'Send Message';
            msgSend.disabled = false;
          }, 1500);
        } else {
          alert(d.error || 'Failed to send');
          msgSend.textContent = 'Send Message';
          msgSend.disabled = false;
        }
      } catch {
        alert('Failed to send — try again');
        msgSend.textContent = 'Send Message';
        msgSend.disabled = false;
      }
    });
  }

  // ── Post host update ──
  var postUpdateBtn = document.getElementById('postUpdateBtn');
  if (postUpdateBtn) {
    postUpdateBtn.addEventListener('click', async function() {
      var input = document.getElementById('updateText');
      if (!input || !input.value.trim()) { alert('Write something first'); return; }
      postUpdateBtn.textContent = 'Posting...';
      postUpdateBtn.disabled = true;
      try {
        var r = await fetch('/api/event-updates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            event_id: postUpdateBtn.getAttribute('data-event-id'),
            message: input.value.trim()
          })
        });
        var d = await r.json();
        if (d.ok) {
          // Add the update to the list visually
          var list = document.getElementById('updatesList');
          var emptyMsg = document.querySelector('.det-updates-empty');
          if (emptyMsg) emptyMsg.remove();
          if (!list) {
            // Create the list container
            var card = document.querySelector('.det-updates-card');
            list = document.createElement('div');
            list.className = 'det-updates-list';
            list.id = 'updatesList';
            card.appendChild(list);
          }
          var item = document.createElement('div');
          item.className = 'det-update-item';
          var now = new Date();
          item.innerHTML = '<div class="det-update-meta"><strong>You</strong><span class="det-update-time">Just now</span></div><p class="det-update-msg">' + input.value.trim().replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>';
          list.insertBefore(item, list.firstChild);
          input.value = '';
        } else {
          alert(d.error || 'Failed to post');
        }
      } catch {
        alert('Failed to post — try again');
      }
      postUpdateBtn.textContent = 'Post Update';
      postUpdateBtn.disabled = false;
    });
  }

  // Photo upload
  var photoInput = document.getElementById('photo-upload');
  if (photoInput) {
    photoInput.addEventListener('change', async function() {
      var file = this.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { alert('Photo must be under 5MB'); return; }
      var evId = this.getAttribute('data-event-id');
      var reader = new FileReader();
      reader.onload = async function() {
        try {
          var r = await fetch('/api/upload-photo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_id: evId, photo: reader.result })
          });
          var d = await r.json();
          if (d.ok) { location.reload(); }
          else { alert(d.error || 'Upload failed'); }
        } catch { alert('Upload failed — try again'); }
      };
      reader.readAsDataURL(file);
    });
  }
</script>

</Base>
