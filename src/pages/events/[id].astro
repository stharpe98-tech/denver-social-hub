---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { id } = Astro.params;
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

let event: any = null;
let rsvps: any[] = [];
let myRsvp = false;

try {
  if (db && id) {
    event = await db.prepare("SELECT * FROM events WHERE id=?").bind(id).first();
    const r = await db.prepare("SELECT r.member_email as email,r.member_name as name,m.neighborhood FROM event_rsvps r LEFT JOIN members m ON r.member_email=m.email WHERE r.event_id=?").bind(id).all();
    rsvps = r?.results || [];
    if (user) myRsvp = rsvps.some((r:any) => r.email===user.email);
  }
} catch {}

if (!event) return Astro.redirect("/events");

const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",sports:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",potluck:"🍲",other:"📅" };

// Per-type theme colors: [accent, light bg tint, tag bg, tag text]
const typeThemes: Record<string, { accent: string; grad1: string; grad2: string; tagBg: string; tagText: string }> = {
  dinner:        { accent:"#F05A28", grad1:"#FFF7ED", grad2:"#FEF2F2", tagBg:"#FFF7ED", tagText:"#C2410C" },
  game_night:    { accent:"#7C3AED", grad1:"#F5F3FF", grad2:"#EEF2FF", tagBg:"#EEF2FF", tagText:"#5B21B6" },
  outdoor:       { accent:"#059669", grad1:"#ECFDF5", grad2:"#F0FDF4", tagBg:"#F0FDF4", tagText:"#047857" },
  brewery:       { accent:"#D97706", grad1:"#FFFBEB", grad2:"#FEF3C7", tagBg:"#FFFBEB", tagText:"#92400E" },
  coffee:        { accent:"#92400E", grad1:"#FFFBEB", grad2:"#FEF9EE", tagBg:"#FEF3C7", tagText:"#78350F" },
  arts:          { accent:"#DB2777", grad1:"#FDF2F8", grad2:"#FCE7F3", tagBg:"#FDF2F8", tagText:"#9D174D" },
  music:         { accent:"#7C3AED", grad1:"#F5F3FF", grad2:"#FDF2F8", tagBg:"#F5F3FF", tagText:"#6D28D9" },
  social:        { accent:"#EC4899", grad1:"#FDF2F8", grad2:"#FFF1F2", tagBg:"#FCE7F3", tagText:"#BE185D" },
  group_tickets: { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#EEF2FF", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  camping:       { accent:"#059669", grad1:"#ECFDF5", grad2:"#F0FDF4", tagBg:"#ECFDF5", tagText:"#065F46" },
  sports_outing: { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#DBEAFE", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  bowling:       { accent:"#3B82F6", grad1:"#EFF6FF", grad2:"#E0F2FE", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  active:        { accent:"#059669", grad1:"#ECFDF5", grad2:"#D1FAE5", tagBg:"#ECFDF5", tagText:"#065F46" },
  casino:        { accent:"#DC2626", grad1:"#FEF2F2", grad2:"#FFFBEB", tagBg:"#FEF2F2", tagText:"#991B1B" },
  food_trucks:   { accent:"#EA580C", grad1:"#FFF7ED", grad2:"#FFFBEB", tagBg:"#FFF7ED", tagText:"#C2410C" },
  potluck:       { accent:"#F05A28", grad1:"#FFF7ED", grad2:"#FEF2F2", tagBg:"#FFF7ED", tagText:"#C2410C" },
  sports:        { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#DBEAFE", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  other:         { accent:"#7C3AED", grad1:"#F8F9FB", grad2:"#EEF2FF", tagBg:"#EEF2FF", tagText:"#4338CA" },
};

const theme = typeThemes[event.event_type] || typeThemes.other;

const typeImages: Record<string, string> = {
  dinner:        "https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=900&q=75",
  game_night:    "https://images.unsplash.com/photo-1632501641765-e568d28b0015?w=900&q=75",
  outdoor:       "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=900&q=75",
  brewery:       "https://images.unsplash.com/photo-1535958636474-b021ee887b13?w=900&q=75",
  coffee:        "https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=900&q=75",
  arts:          "https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=900&q=75",
  music:         "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=900&q=75",
  social:        "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=75",
  group_tickets: "https://images.unsplash.com/photo-1540039155733-5bb30b53aa14?w=900&q=75",
  camping:       "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=900&q=75",
  sports_outing: "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=900&q=75",
  bowling:       "https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=900&q=75",
  active:        "https://images.unsplash.com/photo-1522163182402-834f871fd851?w=900&q=75",
  casino:        "https://images.unsplash.com/photo-1596838132731-3301c3fd4317?w=900&q=75",
  food_trucks:   "https://images.unsplash.com/photo-1565123409695-7b5ef63a2efb?w=900&q=75",
  potluck:       "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=900&q=75",
  sports:        "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=900&q=75",
  other:         "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=75",
};
const heroImage = typeImages[event.event_type] || typeImages.other;

// ── Google Maps link ──
const venueOrLocation = event.location || event.zone || '';
const mapsQuery = venueOrLocation ? encodeURIComponent(venueOrLocation + (venueOrLocation.toLowerCase().includes('denver') || venueOrLocation.toLowerCase().includes('co') ? '' : ', Denver, CO')) : '';
const googleMapsUrl = mapsQuery ? `https://www.google.com/maps/search/?api=1&query=${mapsQuery}` : '';

// Zone-level maps link (for non-RSVP'd users who only see the zone)
const zoneQuery = event.zone ? encodeURIComponent(event.zone + ', Denver, CO') : '';
const zoneMapsUrl = zoneQuery ? `https://www.google.com/maps/search/?api=1&query=${zoneQuery}` : '';

// Budget display logic
const hasBudget = event.price_cap && event.price_cap !== '' && event.price_cap !== 'Free' && event.price_cap !== '$0';

const spotsLeft = Math.max(0, (parseInt(event.spots) || 10) - rsvps.length);
const avatarColors = ["#7C3AED","#3B82F6","#10B981","#F59E0B","#EC4899","#EF4444","#6366F1"];

// ── Calendar link generation ──
const monthMap: Record<string, string> = {
  January:"01", February:"02", March:"03", April:"04", May:"05", June:"06",
  July:"07", August:"08", September:"09", October:"10", November:"11", December:"12",
  JAN:"01", FEB:"02", MAR:"03", APR:"04", MAY:"05", JUN:"06",
  JUL:"07", AUG:"08", SEP:"09", OCT:"10", NOV:"11", DEC:"12",
  Jan:"01", Feb:"02", Mar:"03", Apr:"04", May:"05", Jun:"06",
  Jul:"07", Aug:"08", Sep:"09", Oct:"10", Nov:"11", Dec:"12"
};
function buildCalendarDate(month: string, day: string, time?: string): { start: string; end: string } | null {
  const mo = monthMap[month];
  if (!mo || !day) return null;
  const d = day.padStart(2, '0');
  const year = new Date().getFullYear();
  if (time) {
    // Try to parse time like "7:00 PM", "7pm", "19:00"
    let h = 18, m = 0;
    const match = time.match(/(\d{1,2}):?(\d{2})?\s*(am|pm)?/i);
    if (match) {
      h = parseInt(match[1]);
      m = parseInt(match[2] || '0');
      if (match[3]?.toLowerCase() === 'pm' && h < 12) h += 12;
      if (match[3]?.toLowerCase() === 'am' && h === 12) h = 0;
    }
    const startStr = `${year}${mo}${d}T${String(h).padStart(2,'0')}${String(m).padStart(2,'0')}00`;
    const endH = h + 2; // Default 2-hour duration
    const endStr = `${year}${mo}${d}T${String(endH).padStart(2,'0')}${String(m).padStart(2,'0')}00`;
    return { start: startStr, end: endStr };
  }
  // All-day event
  return { start: `${year}${mo}${d}`, end: `${year}${mo}${String(parseInt(d)+1).padStart(2,'0')}` };
}

const calDates = buildCalendarDate(event.event_month || '', event.event_day || '');
let googleCalUrl = '';
let icsData = '';
if (calDates) {
  const loc = encodeURIComponent(event.location || event.zone || 'Denver, CO');
  const title = encodeURIComponent(event.title || 'Denver Social Event');
  const desc = encodeURIComponent((event.description || 'Denver Social community event') + '\n\nRSVP: https://denver-social-hub.stharpe98.workers.dev/events/' + id);
  const hasTime = calDates.start.includes('T');
  const dates = hasTime ? `${calDates.start}/${calDates.end}` : `${calDates.start}/${calDates.end}`;
  googleCalUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${dates}&details=${desc}&location=${loc}`;

  // Build .ics content
  const now = new Date().toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
  icsData = [
    'BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//Denver Social//EN',
    'BEGIN:VEVENT',
    `DTSTART:${calDates.start}`, `DTEND:${calDates.end}`,
    `SUMMARY:${event.title}`, `LOCATION:${event.location || event.zone || 'Denver, CO'}`,
    `DESCRIPTION:${(event.description || 'Denver Social community event').replace(/\n/g, '\\n')}`,
    `DTSTAMP:${now}`, `UID:dsn-event-${id}@denversocialhub.com`,
    'END:VEVENT', 'END:VCALENDAR'
  ].join('\n');
}

// ── Host info ──
let host: any = null;
if (db && event.host_id) {
  try {
    host = await db.prepare("SELECT id, name, neighborhood, bio, joined_at, events_attended, suggestions_submitted FROM members WHERE id = ?").bind(event.host_id).first();
  } catch {}
}
const isHost = user && host && user.id === host.id;
const isAdmin = user?.role === 'admin';

// ── Host updates (logistics notes) ──
let eventUpdates: any[] = [];
if (db) {
  try {
    const updResult = await db.prepare("SELECT id, author_name, message, created_at FROM event_updates WHERE event_id = ? ORDER BY created_at DESC LIMIT 10").bind(id).all();
    eventUpdates = updResult?.results || [];
  } catch {}
}

// Check if event is in the past (for photo gallery)
const isPastEvent = !!event.is_past;

// Load photos for past events
let eventPhotos: any[] = [];
if (db && isPastEvent) {
  try {
    const photoResult = await db.prepare("SELECT id, email, name, photo_url, caption, created_at FROM event_photos WHERE event_id=? ORDER BY created_at DESC").bind(id).all();
    eventPhotos = photoResult?.results || [];
  } catch {}
}
---
<Base title={event.title}>

<!-- Tinted full-page background wash -->
<div class="det-bg-wash" style={`background: linear-gradient(170deg, ${theme.grad1} 0%, ${theme.grad2} 35%, #F8F9FB 65%, #FFFFFF 100%);`}></div>

<div class="det-page" style={`--ev-accent: ${theme.accent}; --ev-accent-shadow: ${theme.accent}33;`}>
  <a href="/events" class="det-back">← Back to events</a>

  <!-- Big photo hero card -->
  <div class="det-hero-card">
    <div class="det-hero-img" style={`background-image: url(${heroImage});`}>
      <div class="det-hero-overlay"></div>
      <div class="det-hero-tag" style={`color: ${theme.tagText};`}>{typeEmoji[event.event_type] || '📅'} {(event.event_type || 'event').replace('_', ' ')}</div>
      <div class="det-hero-spots">{rsvps.length} of {event.spots} going</div>
      <div class="det-hero-bottom">
        <h1 class="det-hero-title">{event.title}</h1>
        <p class="det-hero-meta">
          {(event.event_month || 'TBD').slice(0, 3)} {event.event_day || ''} · {myRsvp ? (event.location || event.zone || 'Denver') : (event.zone || 'Denver')}
        </p>
      </div>
    </div>

    <div class="det-hero-body">
      <!-- Info grid -->
      <div class="det-info-grid">
        <div class="det-info-item">
          <div class="det-info-label">When</div>
          <div class="det-info-value">{(event.event_month || 'TBD').slice(0, 3)} {event.event_day || 'TBD'}{event.event_time ? ` · ${event.event_time}` : ''}</div>
        </div>
        <div class="det-info-item">
          <div class="det-info-label">Where</div>
          {myRsvp ? (
            <div class="det-info-value">
              {event.location || event.zone || 'Denver'}
              {googleMapsUrl && <a href={googleMapsUrl} target="_blank" rel="noopener" class="det-maps-link">📍 Map</a>}
            </div>
          ) : (
            <div class="det-info-value">
              {event.zone || 'Denver'}
              {zoneMapsUrl && <a href={zoneMapsUrl} target="_blank" rel="noopener" class="det-maps-link">📍 Area</a>}
              <span class="det-info-rsvp-hint">RSVP for exact spot</span>
            </div>
          )}
        </div>
        {hasBudget ? (
          <div class="det-info-item">
            <div class="det-info-label">Price</div>
            <div class="det-info-value">{event.price_cap}</div>
          </div>
        ) : (
          <div class="det-info-item">
            <div class="det-info-label">Price</div>
            <div class="det-info-value" style="color: #059669;">Free</div>
          </div>
        )}
        <div class="det-info-item">
          <div class="det-info-label">Group Size</div>
          <div class="det-info-value">{event.spots} people max</div>
        </div>
      </div>

      <!-- Point of Contact — RSVP-gated -->
      {myRsvp && event.contact_phone ? (
        <div class="det-contact-bar">
          <span class="det-contact-icon">📞</span>
          <div>
            <div class="det-contact-label">Point of contact</div>
            <a href={`tel:${event.contact_phone}`} class="det-contact-phone">{event.contact_phone}</a>
            <span class="det-contact-hint">Call or text if you can't find the group</span>
          </div>
        </div>
      ) : !myRsvp && (
        <div class="det-contact-bar locked">
          <span class="det-contact-icon">📞</span>
          <div>
            <div class="det-contact-label">Point of contact</div>
            <span class="det-contact-hint">RSVP to see host's number</span>
          </div>
        </div>
      )}

      {event.description && <p class="det-desc">{event.description}</p>}

      <!-- Add to Calendar (only rendered for logged-in users, shown after RSVP) -->
      {user && calDates && (
        <div class="det-cal-row" id="cal-row" style={myRsvp ? '' : 'display:none'}>
          <a href={googleCalUrl} target="_blank" rel="noopener" class="det-cal-btn">
            <span class="det-cal-icon">📅</span> Add to Google Calendar
          </a>
          <button class="det-cal-btn det-cal-ics" data-ics={icsData}>
            <span class="det-cal-icon">🗓️</span> Download .ics
          </button>
        </div>
      )}
    </div>
  </div>

  <!-- Host info -->
  {host && (
    <div class="det-host-card">
      <div class="det-host-left">
        <div class="det-host-av" style={`background: ${theme.accent}`}>{(host.name || '?')[0]}</div>
        <div class="det-host-info">
          <div class="det-host-label">Hosted by</div>
          <div class="det-host-name">{host.name}</div>
          {host.neighborhood && <div class="det-host-hood">📍 {host.neighborhood}</div>}
        </div>
      </div>
      <div class="det-host-right">
        {myRsvp && host && !isHost ? (
          <button class="det-host-msg-btn" id="msgHostBtn" data-host-name={host.name}>💬 Message Host</button>
        ) : !myRsvp && !isHost ? (
          <span class="det-host-rsvp-note">RSVP to contact host</span>
        ) : null}
      </div>
    </div>
  )}

  <!-- Host message modal (hidden) -->
  {myRsvp && host && !isHost && (
    <div class="det-msg-overlay" id="msgOverlay" style="display:none">
      <div class="det-msg-modal">
        <div class="det-msg-header">
          <strong>Message {host.name}</strong>
          <button class="det-msg-close" id="msgClose">✕</button>
        </div>
        <p class="det-msg-note">Your message and email will be shared with the host so they can reply.</p>
        <textarea class="det-msg-input" id="msgText" placeholder="Hey! Quick question about the event..." maxlength="500" rows="4"></textarea>
        <button class="det-msg-send" id="msgSend" data-event-id={id} data-host-id={host.id} style={`background: ${theme.accent}`}>Send Message</button>
      </div>
    </div>
  )}

  <!-- Host updates / logistics -->
  {(eventUpdates.length > 0 || isHost || isAdmin) && (
    <div class="det-updates-card">
      <div class="det-updates-header">
        <div class="det-updates-title">📋 Host Updates</div>
        {eventUpdates.length === 0 && <span class="det-updates-badge">New</span>}
      </div>
      {(isHost || isAdmin) && (
        <div class="det-update-form">
          <textarea class="det-update-input" id="updateText" placeholder="Post a logistics note — parking info, what to bring, meeting spot..." maxlength="500" rows="2"></textarea>
          <button class="det-update-post" id="postUpdateBtn" data-event-id={id} style={`background: ${theme.accent}`}>Post Update</button>
        </div>
      )}
      {eventUpdates.length > 0 ? (
        <div class="det-updates-list" id="updatesList">
          {eventUpdates.map((u: any) => (
            <div class="det-update-item">
              <div class="det-update-meta">
                <strong>{u.author_name}</strong>
                <span class="det-update-time">{new Date(u.created_at + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })}</span>
              </div>
              <p class="det-update-msg">{u.message}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="det-updates-empty">No updates yet. The host will post logistics info here.</p>
      )}
    </div>
  )}

  <!-- RSVP bar -->
  <div class="det-rsvp-bar">
    <div class="det-rsvp-left">
      <div class="det-rsvp-filled"><strong>{rsvps.length} of {event.spots}</strong> spots filled</div>
      <div class="det-rsvp-track"><div class="det-rsvp-fill" style={`width: ${Math.round((rsvps.length / (parseInt(event.spots) || 10)) * 100)}%; background: linear-gradient(90deg, ${theme.accent}, ${theme.accent}CC);`}></div></div>
      {spotsLeft <= 4 && spotsLeft > 0 && <div class="det-urgent">🔥 Only {spotsLeft} left — don't sleep on this</div>}
    </div>
    {user ? (
      <button id="rsvp-btn" class={`det-rsvp-btn ${myRsvp ? 'rsvped' : ''}`} style={myRsvp ? '' : `background: ${theme.accent};`} data-event-id={id} data-rsvped={myRsvp ? 'true' : 'false'} data-accent={theme.accent} data-spots={event.spots || '10'}>
        {myRsvp ? "✓ You're In — Cancel RSVP" : "I'm In"}
      </button>
    ) : (
      <a href={`/login?next=/events/${id}`} class="det-rsvp-btn" style={`background: ${theme.accent};`}>Sign in to RSVP</a>
    )}
  </div>

  <!-- Attendees — pill style -->
  <div class="det-att-card">
    <div class="det-att-title">Who's going ({rsvps.length})</div>
    {rsvps.length > 0 ? (
      <div class="det-att-grid">
        {rsvps.map((r: any, i: number) => (
          <div class="det-att-pill">
            <div class="det-att-av" style={`background:${avatarColors[i % avatarColors.length]}`}>{(r.name || '?')[0]}</div>
            <span class="det-att-name">{r.name}</span>
            {r.neighborhood && <span class="det-att-hood">· {r.neighborhood}</span>}
          </div>
        ))}
      </div>
    ) : (
      <div class="det-att-empty">No one's RSVP'd yet. Be the person who starts the wave.</div>
    )}
  </div>

  <!-- Post-event Photos -->
  {isPastEvent && (
    <div class="det-photos-card">
      <div class="det-photos-header">
        <div class="det-photos-title">📸 Event Photos</div>
        {user && myRsvp && (
          <label class="det-photo-upload-btn">
            <input type="file" accept="image/*" id="photo-upload" style="display:none" data-event-id={id} />
            + Add Photo
          </label>
        )}
      </div>
      {eventPhotos.length > 0 ? (
        <div class="det-photos-grid">
          {eventPhotos.map((p: any) => (
            <div class="det-photo-item">
              <img src={p.photo_url} alt={p.caption || 'Event photo'} loading="lazy" />
              <div class="det-photo-meta">
                <span class="det-photo-name">{p.name}</span>
                {p.caption && <span class="det-photo-caption">{p.caption}</span>}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="det-photos-empty">
          {user && myRsvp
            ? "No photos yet — be the first to share a moment!"
            : "No photos yet. Attendees can upload photos after the event."}
        </div>
      )}
    </div>
  )}

  <!-- Discord CTA -->
  <div class="det-discord">
    <span class="det-discord-icon">💬</span>
    <div class="det-discord-text">
      <strong>Plans happen in Discord first</strong>
      <span>Chat about this event, coordinate rides, or just hang</span>
    </div>
    <a href={event.discord_link || "https://discord.gg/S8SFNkdSgK"} class="det-discord-btn" target="_blank" rel="noopener">Join →</a>
  </div>
</div>

<style is:inline>
  /* ── Tinted background wash ── */
  .det-bg-wash {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    z-index: -1;
  }

  /* ── Page container ── */
  .det-page { max-width: 620px; margin: 0 auto; padding: 24px 20px 48px; position: relative; z-index: 1; }

  .det-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600;
    color: #6B7280; margin-bottom: 16px; transition: color .2s;
    text-decoration: none;
  }
