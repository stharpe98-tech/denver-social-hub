---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { id } = Astro.params;
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

let event: any = null;
let rsvps: any[] = [];
let waitlist: any[] = [];
let comments: any[] = [];
let bringItems: any[] = [];
let myRsvp = false;
let myWaitlist = false;

try {
  if (db && id) {
    event = await db.prepare("SELECT * FROM events WHERE id=?").bind(id).first();
    const r = await db.prepare("SELECT r.*, m.reddit_username, m.karma, m.reliability_score, m.check_in_count FROM event_rsvps r LEFT JOIN members m ON r.member_email=m.email WHERE r.event_id=? AND r.waitlist_position IS NULL ORDER BY r.created_at").bind(id).all();
    rsvps = r?.results || [];
    const w = await db.prepare("SELECT r.*, m.reddit_username, m.karma FROM event_rsvps r LEFT JOIN members m ON r.member_email=m.email WHERE r.event_id=? AND r.waitlist_position IS NOT NULL ORDER BY r.waitlist_position").bind(id).all();
    waitlist = w?.results || [];
    const c = await db.prepare("SELECT * FROM comments WHERE event_id=? ORDER BY created_at ASC").bind(id).all();
    comments = c?.results || [];
    const bi = await db.prepare("SELECT * FROM bring_items WHERE event_id=? ORDER BY id ASC").bind(id).all();
    bringItems = bi?.results || [];
    if (user) {
      myRsvp = rsvps.some((r:any) => r.member_email === user.email);
      myWaitlist = waitlist.some((w:any) => w.member_email === user.email);
    }
  }
} catch (err) { console.error('Event detail error:', err); }

if (!event) return Astro.redirect("/events");

const typeLabel: Record<string,string> = { dinner:"dinner",game_night:"game_night",outdoor:"outdoor",brewery:"brewery",coffee:"coffee",arts:"arts",music:"music",social:"social",other:"event" };
const totalSpots = event.spots ? parseInt(event.spots) : null; // null = unlimited
const spotsLeft = totalSpots !== null ? Math.max(0, totalSpots - rsvps.length) : Infinity;
const isFull = totalSpots !== null && spotsLeft === 0;
const fillPct = totalSpots !== null ? Math.min(100, Math.round(rsvps.length / totalSpots * 100)) : Math.min(50, rsvps.length * 5);

// Karma gate check
const userKarma = user?.karma || 0;
const userAccountAge = user?.reddit_account_created ? Math.floor((Date.now() - new Date(user.reddit_account_created).getTime()) / (1000 * 60 * 60 * 24)) : 0;
const meetsKarmaGate = (!event.karma_min || userKarma >= event.karma_min) && (!event.account_age_min || userAccountAge >= event.account_age_min);
const showLocation = myRsvp && meetsKarmaGate;

// Build threaded comments
const rootComments = comments.filter((c: any) => !c.parent_id);
const childMap: Record<string, any[]> = {};
comments.forEach((c: any) => {
  if (c.parent_id) {
    if (!childMap[c.parent_id]) childMap[c.parent_id] = [];
    childMap[c.parent_id].push(c);
  }
});

// Calendar link
const monthMap: Record<string,string> = {JAN:"01",FEB:"02",MAR:"03",APR:"04",MAY:"05",JUN:"06",JUL:"07",AUG:"08",SEP:"09",OCT:"10",NOV:"11",DEC:"12"};
const mo = monthMap[(event.event_month||'').toUpperCase()];
const d = (event.event_day||'').padStart(2,'0');
const yr = new Date().getFullYear();
let googleCalUrl = '';
if (mo && d !== '00') {
  const start = `${yr}${mo}${d}`;
  const end = `${yr}${mo}${String(parseInt(d)+1).padStart(2,'0')}`;
  googleCalUrl = `https://calendar.google.com/calendar/r/eventedit?text=${encodeURIComponent(event.title)}&dates=${start}/${end}&location=${encodeURIComponent(event.location||event.zone||'Denver')}&details=${encodeURIComponent('Denver events.hub — '+event.description)}`;
}
---
<Base title={event.title}>
<div class="det">
  <!-- LEFT COLUMN -->
  <div class="det-left">
    <!-- Event header -->
    <div class="det-header">
      <div class="det-breadcrumb">
        <a href="/events">&larr; events</a>
        <span class="det-bc-sep">/</span>
        <span>{typeLabel[event.event_type] || 'event'}</span>
      </div>
      <h1 class="det-title">{event.title}</h1>
      <div class="det-tags">
        <span class="tag tag-blue">{typeLabel[event.event_type] || 'event'}</span>
        {event.karma_min > 0 && <span class="tag tag-yellow">requires {event.karma_min}+ karma</span>}
        {event.account_age_min > 0 && <span class="tag tag-yellow">{event.account_age_min}d+ account</span>}
      </div>
    </div>

    <!-- Info grid -->
    <div class="det-info">
      <div class="di-row">
        <span class="di-label">when</span>
        <span class="di-value">{event.event_month} {event.event_day}{event.end_date ? ` — ${event.end_date}` : ''}</span>
      </div>
      <div class="di-row">
        <span class="di-label">where</span>
        <span class="di-value">
          {showLocation && event.location ? event.location : (event.zone || 'Denver')}
          {!showLocation && event.location && <span class="di-locked"> (RSVP to reveal address)</span>}
        </span>
      </div>
      <div class="di-row">
        <span class="di-label">spots</span>
        <span class="di-value">
          <span class="di-fill-bar"><span class="di-fill" style={`width:${fillPct}%`}></span></span>
          {totalSpots !== null ? `${rsvps.length}/${totalSpots}` : `${rsvps.length} going`}
          {totalSpots !== null && spotsLeft <= 3 && spotsLeft > 0 && <span class="di-hot">({spotsLeft} left!)</span>}
          {isFull && <span class="di-full">(full — join waitlist)</span>}
        </span>
      </div>
      {event.price_cap && event.price_cap !== 'Free' && event.price_cap !== '$0' && (
        <div class="di-row">
          <span class="di-label">cost</span>
          <span class="di-value">{event.price_cap}</span>
        </div>
      )}
      {event.host_name && (
        <div class="di-row">
          <span class="di-label">host</span>
          <span class="di-value">{event.host_name}{event.contact_phone && myRsvp ? ` · ${event.contact_phone}` : ''}</span>
        </div>
      )}
    </div>

    {event.description && (
      <div class="det-desc">
        <h3 class="det-sec-title">// description</h3>
        <p>{event.description}</p>
      </div>
    )}

    <!-- Karma gate warning -->
    {user && !meetsKarmaGate && (
      <div class="det-gate">
        <span class="det-gate-icon">🔒</span>
        <div>
          <strong>Karma gate active</strong>
          <p>This event requires {event.karma_min ? `${event.karma_min}+ karma` : ''}{event.karma_min && event.account_age_min ? ' and ' : ''}{event.account_age_min ? `${event.account_age_min}+ day old account` : ''}. Your karma: {userKarma}.</p>
        </div>
      </div>
    )}

    <!-- RSVP / Waitlist actions -->
    <div class="det-actions">
      {!user ? (
        <a href={`/login?next=/events/${id}`} class="btn btn-primary">sign in to rsvp</a>
      ) : myRsvp ? (
        <div class="det-confirmed">
          <span class="det-confirmed-icon">✓</span>
          <span>You're in!</span>
          {googleCalUrl && <a href={googleCalUrl} target="_blank" rel="noopener" class="det-cal-link">+ add to calendar</a>}
        </div>
      ) : myWaitlist ? (
        <div class="det-waitlisted">
          <span>You're on the waitlist</span>
          <span class="det-wl-pos">Position #{waitlist.findIndex((w:any) => w.member_email === user.email) + 1}</span>
        </div>
      ) : !meetsKarmaGate ? (
        <button class="btn btn-ghost" disabled>karma gate: locked</button>
      ) : isFull ? (
        <form method="POST" action="/api/rsvp" style="display:inline">
          <input type="hidden" name="event_id" value={id} />
          <input type="hidden" name="action" value="waitlist" />
          <button type="submit" class="btn btn-ghost">join waitlist ({waitlist.length} ahead)</button>
        </form>
      ) : (
        <form method="POST" action="/api/rsvp" style="display:inline">
          <input type="hidden" name="event_id" value={id} />
          <input type="hidden" name="action" value="rsvp" />
          <button type="submit" class="btn btn-primary">rsvp — claim your spot</button>
        </form>
      )}
    </div>

    <!-- Bring a Thing -->
    {bringItems.length > 0 && (
      <div class="det-bring">
        <h3 class="det-sec-title">// bring a thing</h3>
        <div class="bring-list">
          {bringItems.map((item: any) => (
            <div class:list={["bring-item", { claimed: !!item.claimed_by_user_id }]}>
              <span class="bring-check">{item.claimed_by_user_id ? '✓' : '○'}</span>
              <span class="bring-name">{item.item_name}</span>
              {item.claimed_by_name && <span class="bring-who">{item.claimed_by_name}</span>}
              {!item.claimed_by_user_id && user && myRsvp && (
                <form method="POST" action="/api/bring-claim" style="display:inline">
                  <input type="hidden" name="item_id" value={item.id} />
                  <input type="hidden" name="event_id" value={id} />
                  <button type="submit" class="bring-claim-btn">claim</button>
                </form>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- RIGHT COLUMN -->
  <div class="det-right">
    <!-- Tabs -->
    <div class="det-tabs">
      <button class="det-tab active" data-tab="guests">guests ({rsvps.length})</button>
      <button class="det-tab" data-tab="thread">thread ({comments.length})</button>
      {waitlist.length > 0 && <button class="det-tab" data-tab="waitlist">waitlist ({waitlist.length})</button>}
    </div>

    <!-- Guests panel -->
    <div class="det-panel" id="panel-guests">
      {rsvps.length > 0 ? (
        <div class="guest-list">
          {rsvps.map((r: any) => (
            <div class="guest">
              <div class="guest-avatar">{(r.reddit_username || r.member_name || '?')[0].toUpperCase()}</div>
              <div class="guest-info">
                <span class="guest-name">{r.reddit_username ? `u/${r.reddit_username}` : r.member_name}</span>
                {r.karma > 0 && <span class="guest-karma">{r.karma} karma</span>}
              </div>
              {r.reliability_score > 0.7 && <span class="tag tag-green" style="font-size:10px">reliable</span>}
              {r.checked_in && <span class="tag tag-blue" style="font-size:10px">checked in</span>}
            </div>
          ))}
        </div>
      ) : (
        <p class="det-empty">No RSVPs yet. Be the first!</p>
      )}
    </div>

    <!-- Thread panel (megathread) -->
    <div class="det-panel" id="panel-thread" style="display:none">
      {user && (
        <form method="POST" action="/api/comments" class="thread-form">
          <input type="hidden" name="event_id" value={id} />
          <textarea name="body" rows="2" placeholder="Ask a question or leave a comment..." class="input" style="border-radius:8px;resize:vertical;font-size:13px"></textarea>
          <button type="submit" class="btn btn-primary" style="font-size:12px;padding:8px 16px">post</button>
        </form>
      )}
      {rootComments.length > 0 ? (
        <div class="thread-list">
          {rootComments.map((c: any) => (
            <div class="thread-comment">
              <div class="tc-header">
                <span class="tc-author">{c.author_name || `user_${c.user_id}`}</span>
                {c.author_karma > 0 && <span class="tc-karma">{c.author_karma} karma</span>}
                <span class="tc-time">{new Date(c.created_at).toLocaleDateString()}</span>
              </div>
              <p class="tc-body">{c.body}</p>
              <div class="tc-actions">
                <span class="tc-votes">
                  <button class="tc-vote-btn" data-id={c.id} data-dir="up">▲</button>
                  <span class="tc-score">{(c.upvotes||0) - (c.downvotes||0)}</span>
                  <button class="tc-vote-btn" data-id={c.id} data-dir="down">▼</button>
                </span>
                <button class="tc-reply-btn" data-parent={c.id}>reply</button>
              </div>
              {childMap[c.id] && childMap[c.id].map((reply: any) => (
                <div class="thread-reply">
                  <div class="tc-header">
                    <span class="tc-author">{reply.author_name || `user_${reply.user_id}`}</span>
                    <span class="tc-time">{new Date(reply.created_at).toLocaleDateString()}</span>
                  </div>
                  <p class="tc-body">{reply.body}</p>
                  <div class="tc-actions">
                    <span class="tc-votes">
                      <button class="tc-vote-btn">▲</button>
                      <span class="tc-score">{(reply.upvotes||0) - (reply.downvotes||0)}</span>
                      <button class="tc-vote-btn">▼</button>
                    </span>
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>
      ) : (
        <p class="det-empty">No comments yet. Start the conversation!</p>
      )}
    </div>

    <!-- Waitlist panel -->
    <div class="det-panel" id="panel-waitlist" style="display:none">
      {waitlist.length > 0 ? (
        <div class="guest-list">
          {waitlist.map((w: any, i: number) => (
            <div class="guest">
              <div class="guest-pos">#{i + 1}</div>
              <div class="guest-info">
                <span class="guest-name">{w.reddit_username ? `u/${w.reddit_username}` : w.member_name}</span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="det-empty">Waitlist is empty.</p>
      )}
    </div>
  </div>
</div>
</Base>

<style is:inline>
  .det {
    max-width: 1100px; margin: 0 auto; padding: 24px;
    display: grid; grid-template-columns: 1fr 380px; gap: 24px;
  }

  /* LEFT */
  .det-left { display: flex; flex-direction: column; gap: 20px; }
  .det-breadcrumb {
    font-family: var(--mono); font-size: 12px; color: var(--text-faint);
    display: flex; align-items: center; gap: 6px; margin-bottom: 8px;
  }
  .det-breadcrumb a { color: var(--text-sec); text-decoration: none; }
  .det-breadcrumb a:hover { color: var(--accent); }
  .det-bc-sep { opacity: .4; }
  .det-title { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 10px; }
  .det-tags { display: flex; gap: 6px; flex-wrap: wrap; }

  /* Info grid */
  .det-info {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px; display: flex; flex-direction: column; gap: 10px;
  }
  .di-row { display: flex; align-items: center; gap: 12px; }
  .di-label {
    font-family: var(--mono); font-size: 11px; font-weight: 600;
    color: var(--text-faint); min-width: 56px; text-align: right;
  }
  .di-value { font-size: 14px; color: var(--text); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .di-locked { font-family: var(--mono); font-size: 11px; color: var(--yellow); }
  .di-fill-bar { width: 64px; height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; display: inline-block; }
  .di-fill { height: 100%; border-radius: 2px; background: var(--green); display: block; }
  .di-hot { font-family: var(--mono); font-size: 11px; color: var(--accent); font-weight: 600; }
  .di-full { font-family: var(--mono); font-size: 11px; color: var(--red); }

  /* Description */
  .det-desc { }
  .det-sec-title { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--text-faint); margin-bottom: 8px; }
  .det-desc p { font-size: 14px; color: var(--text-sec); line-height: 1.7; }

  /* Karma gate */
  .det-gate {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 14px 16px; background: var(--yellow-dim);
    border: 1px solid rgba(255,217,61,0.2); border-radius: 8px;
  }
  .det-gate-icon { font-size: 20px; flex-shrink: 0; }
  .det-gate strong { font-family: var(--mono); font-size: 13px; color: var(--yellow); display: block; margin-bottom: 4px; }
  .det-gate p { font-size: 12px; color: var(--text-sec); }

  /* Actions */
  .det-actions { }
  .det-confirmed {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px; background: var(--green-dim);
    border: 1px solid rgba(0,210,106,0.2); border-radius: 8px;
    font-family: var(--mono); font-size: 14px; color: var(--green); font-weight: 700;
  }
  .det-confirmed-icon { font-size: 18px; }
  .det-cal-link { font-size: 12px; color: var(--blue); margin-left: auto; }
  .det-waitlisted {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 16px; background: var(--yellow-dim);
    border: 1px solid rgba(255,217,61,0.2); border-radius: 8px;
    font-family: var(--mono); font-size: 13px; color: var(--yellow);
  }
  .det-wl-pos { font-weight: 700; }

  /* Bring a Thing */
  .det-bring { }
  .bring-list { display: flex; flex-direction: column; gap: 6px; }
  .bring-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; font-size: 13px;
  }
  .bring-item.claimed { opacity: .6; }
  .bring-check { font-family: var(--mono); font-size: 14px; color: var(--text-faint); }
  .bring-item.claimed .bring-check { color: var(--green); }
  .bring-name { flex: 1; color: var(--text); }
  .bring-who { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }
  .bring-claim-btn {
    font-family: var(--mono); font-size: 11px; font-weight: 600;
    padding: 4px 10px; border-radius: 4px; border: 1px solid var(--accent);
    background: var(--accent-dim); color: var(--accent); cursor: pointer;
    transition: all .2s;
  }
  .bring-claim-btn:hover { background: var(--accent); color: #fff; }

  /* RIGHT COLUMN */
  .det-right {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; overflow: hidden; position: sticky; top: 68px;
    max-height: calc(100vh - 84px); display: flex; flex-direction: column;
  }

  /* Tabs */
  .det-tabs {
    display: flex; border-bottom: 1px solid var(--border);
  }
  .det-tab {
    flex: 1; padding: 12px; text-align: center;
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    color: var(--text-faint); background: none; border: none;
    cursor: pointer; transition: all .2s;
    border-bottom: 2px solid transparent;
  }
  .det-tab:hover { color: var(--text-sec); }
  .det-tab.active { color: var(--accent); border-bottom-color: var(--accent); background: var(--accent-dim); }

  /* Panels */
  .det-panel { padding: 16px; overflow-y: auto; flex: 1; }
  .det-empty { font-size: 13px; color: var(--text-faint); text-align: center; padding: 24px 0; }

  /* Guest list */
  .guest-list { display: flex; flex-direction: column; gap: 6px; }
  .guest {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 10px; border-radius: 6px;
    transition: background .2s;
  }
  .guest:hover { background: var(--surface-hover); }
  .guest-avatar {
    width: 32px; height: 32px; border-radius: 6px;
    background: var(--accent-dim); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono); font-size: 13px; font-weight: 700;
    flex-shrink: 0;
  }
  .guest-pos {
    font-family: var(--mono); font-size: 12px; color: var(--text-faint);
    min-width: 28px; text-align: center;
  }
  .guest-info { flex: 1; display: flex; flex-direction: column; }
  .guest-name { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--text); }
  .guest-karma { font-family: var(--mono); font-size: 10px; color: var(--text-faint); }

  /* Thread */
  .thread-form { display: flex; gap: 8px; margin-bottom: 16px; align-items: flex-end; }
  .thread-form textarea { flex: 1; }
  .thread-list { display: flex; flex-direction: column; gap: 12px; }
  .thread-comment {
    padding-bottom: 12px; border-bottom: 1px solid var(--border);
  }
  .tc-header { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .tc-author { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--text); }
  .tc-karma { font-family: var(--mono); font-size: 10px; color: var(--accent); background: var(--accent-dim); padding: 1px 5px; border-radius: 3px; }
  .tc-time { font-family: var(--mono); font-size: 10px; color: var(--text-faint); margin-left: auto; }
  .tc-body { font-size: 13px; color: var(--text-sec); line-height: 1.6; margin-bottom: 6px; }
  .tc-actions { display: flex; align-items: center; gap: 12px; }
  .tc-votes { display: flex; align-items: center; gap: 4px; }
  .tc-vote-btn {
    width: 20px; height: 20px; border-radius: 4px; border: none;
    background: transparent; color: var(--text-faint); font-size: 10px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    font-family: var(--mono); transition: all .15s;
  }
  .tc-vote-btn:hover { color: var(--accent); background: var(--accent-dim); }
  .tc-score { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--text-sec); min-width: 16px; text-align: center; }
  .tc-reply-btn {
    font-family: var(--mono); font-size: 11px; color: var(--text-faint);
    background: none; border: none; cursor: pointer;
    transition: color .2s;
  }
  .tc-reply-btn:hover { color: var(--accent); }
  .thread-reply {
    margin-left: 24px; padding-left: 12px;
    border-left: 2px solid var(--border);
    margin-top: 8px;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .det { grid-template-columns: 1fr; padding: 16px; }
    .det-right { position: static; max-height: none; }
    .det-title { font-size: 22px; }
  }
</style>

<script is:inline>
  // Tab switching
  document.querySelectorAll('.det-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.det-tab').forEach(function(t) { t.classList.remove('active'); });
      document.querySelectorAll('.det-panel').forEach(function(p) { p.style.display = 'none'; });
      tab.classList.add('active');
      var panelId = 'panel-' + tab.getAttribute('data-tab');
      var panel = document.getElementById(panelId);
      if (panel) panel.style.display = 'block';
    });
  });
</script>
