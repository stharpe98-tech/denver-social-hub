---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { id } = Astro.params;
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

let event: any = null;
let rsvps: any[] = [];
let myRsvp = false;

try {
  if (db && id) {
    event = await db.prepare("SELECT * FROM events WHERE id=?").bind(id).first();
    const r = await db.prepare("SELECT r.email,r.name,m.neighborhood FROM event_rsvps r LEFT JOIN members m ON r.email=m.email WHERE r.event_id=?").bind(id).all();
    rsvps = r?.results || [];
    if (user) myRsvp = rsvps.some((r:any) => r.email===user.email);
  }
} catch {}

if (!event) return Astro.redirect("/events");

// Map event types to member interest keywords for matching
const typeToInterests: Record<string, string[]> = {
  dinner: ["Food & Dining","Craft Beer"],
  brewery: ["Craft Beer","Food & Dining"],
  coffee: ["Coffee & Cafes"],
  outdoor: ["Hiking","Outdoors"],
  camping: ["Hiking","Outdoors"],
  active: ["Fitness","Hiking","Outdoors"],
  music: ["Live Music"],
  arts: ["Art & Culture"],
  game_night: ["Board Games","Trivia"],
  bowling: ["Bowling"],
  casino: ["Casino Trips"],
  sports: ["Sports"],
  sports_outing: ["Sports"],
  social: ["Food & Dining","Craft Beer","Live Music"],
  food_trucks: ["Food & Dining"],
  potluck: ["Food & Dining"],
  group_tickets: ["Live Music","Art & Culture","Sports"],
};

// Find members whose interests overlap with this event type
let matchedMembers: any[] = [];
const interestKeywords = typeToInterests[event.event_type] || [];
if (db && interestKeywords.length > 0) {
  try {
    // Build LIKE conditions for each keyword
    const conditions = interestKeywords.map(() => "interests LIKE ?").join(" OR ");
    const params = interestKeywords.map(k => `%${k}%`);
    const rsvpEmails = rsvps.map((r: any) => r.email);
    const q = `SELECT name, neighborhood, interests FROM members WHERE suspended=0 AND (${conditions}) ORDER BY events_attended DESC LIMIT 8`;
    const result = await db.prepare(q).bind(...params).all();
    // Filter out people already RSVP'd and the current user
    matchedMembers = (result.results || []).filter((m: any) =>
      !rsvpEmails.includes(m.email) && m.email !== user?.email
    );
  } catch {}
}

const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",sports:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",potluck:"🍲",other:"📅" };

// Per-type theme colors: [accent, light bg tint, tag bg, tag text]
const typeThemes: Record<string, { accent: string; grad1: string; grad2: string; tagBg: string; tagText: string }> = {
  dinner:        { accent:"#F05A28", grad1:"#FFF7ED", grad2:"#FEF2F2", tagBg:"#FFF7ED", tagText:"#C2410C" },
  game_night:    { accent:"#7C3AED", grad1:"#F5F3FF", grad2:"#EEF2FF", tagBg:"#EEF2FF", tagText:"#5B21B6" },
  outdoor:       { accent:"#059669", grad1:"#ECFDF5", grad2:"#F0FDF4", tagBg:"#F0FDF4", tagText:"#047857" },
  brewery:       { accent:"#D97706", grad1:"#FFFBEB", grad2:"#FEF3C7", tagBg:"#FFFBEB", tagText:"#92400E" },
  coffee:        { accent:"#92400E", grad1:"#FFFBEB", grad2:"#FEF9EE", tagBg:"#FEF3C7", tagText:"#78350F" },
  arts:          { accent:"#DB2777", grad1:"#FDF2F8", grad2:"#FCE7F3", tagBg:"#FDF2F8", tagText:"#9D174D" },
  music:         { accent:"#7C3AED", grad1:"#F5F3FF", grad2:"#FDF2F8", tagBg:"#F5F3FF", tagText:"#6D28D9" },
  social:        { accent:"#EC4899", grad1:"#FDF2F8", grad2:"#FFF1F2", tagBg:"#FCE7F3", tagText:"#BE185D" },
  group_tickets: { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#EEF2FF", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  camping:       { accent:"#059669", grad1:"#ECFDF5", grad2:"#F0FDF4", tagBg:"#ECFDF5", tagText:"#065F46" },
  sports_outing: { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#DBEAFE", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  bowling:       { accent:"#3B82F6", grad1:"#EFF6FF", grad2:"#E0F2FE", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  active:        { accent:"#059669", grad1:"#ECFDF5", grad2:"#D1FAE5", tagBg:"#ECFDF5", tagText:"#065F46" },
  casino:        { accent:"#DC2626", grad1:"#FEF2F2", grad2:"#FFFBEB", tagBg:"#FEF2F2", tagText:"#991B1B" },
  food_trucks:   { accent:"#EA580C", grad1:"#FFF7ED", grad2:"#FFFBEB", tagBg:"#FFF7ED", tagText:"#C2410C" },
  potluck:       { accent:"#F05A28", grad1:"#FFF7ED", grad2:"#FEF2F2", tagBg:"#FFF7ED", tagText:"#C2410C" },
  sports:        { accent:"#2563EB", grad1:"#EFF6FF", grad2:"#DBEAFE", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  other:         { accent:"#7C3AED", grad1:"#F8F9FB", grad2:"#EEF2FF", tagBg:"#EEF2FF", tagText:"#4338CA" },
};

const theme = typeThemes[event.event_type] || typeThemes.other;

const typeImages: Record<string, string> = {
  dinner:        "https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=900&q=75",
  game_night:    "https://images.unsplash.com/photo-1632501641765-e568d28b0015?w=900&q=75",
  outdoor:       "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=900&q=75",
  brewery:       "https://images.unsplash.com/photo-1535958636474-b021ee887b13?w=900&q=75",
  coffee:        "https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=900&q=75",
  arts:          "https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=900&q=75",
  music:         "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=900&q=75",
  social:        "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=75",
  group_tickets: "https://images.unsplash.com/photo-1540039155733-5bb30b53aa14?w=900&q=75",
  camping:       "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=900&q=75",
  sports_outing: "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=900&q=75",
  bowling:       "https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=900&q=75",
  active:        "https://images.unsplash.com/photo-1522163182402-834f871fd851?w=900&q=75",
  casino:        "https://images.unsplash.com/photo-1596838132731-3301c3fd4317?w=900&q=75",
  food_trucks:   "https://images.unsplash.com/photo-1565123409695-7b5ef63a2efb?w=900&q=75",
  potluck:       "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=900&q=75",
  sports:        "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=900&q=75",
  other:         "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=75",
};
const heroImage = typeImages[event.event_type] || typeImages.other;

const spotsLeft = Math.max(0, (parseInt(event.spots) || 10) - rsvps.length);
const avatarColors = ["#7C3AED","#3B82F6","#10B981","#F59E0B","#EC4899","#EF4444","#6366F1"];
---
<Base title={event.title}>

<!-- Tinted full-page background wash -->
<div class="det-bg-wash" style={`background: linear-gradient(170deg, ${theme.grad1} 0%, ${theme.grad2} 35%, #F8F9FB 65%, #FFFFFF 100%);`}></div>

<div class="det-page" style={`--ev-accent: ${theme.accent}; --ev-accent-shadow: ${theme.accent}33;`}>
  <a href="/events" class="det-back">← Back to events</a>

  <!-- Big photo hero card -->
  <div class="det-hero-card">
    <div class="det-hero-img" style={`background-image: url(${heroImage});`}>
      <div class="det-hero-overlay"></div>
      <div class="det-hero-tag" style={`color: ${theme.tagText};`}>{typeEmoji[event.event_type] || '📅'} {(event.event_type || 'event').replace('_', ' ')}</div>
      <div class="det-hero-spots">{rsvps.length} of {event.spots} going</div>
      <div class="det-hero-bottom">
        <h1 class="det-hero-title">{event.title}</h1>
        <p class="det-hero-meta">
          {(event.event_month || 'TBD').slice(0, 3)} {event.event_day || ''} · {myRsvp ? (event.location || event.zone || 'Denver') : (event.zone || 'Denver')}
        </p>
      </div>
    </div>

    <div class="det-hero-body">
      <!-- Info grid -->
      <div class="det-info-grid">
        <div class="det-info-item">
          <div class="det-info-label">When</div>
          <div class="det-info-value">{(event.event_month || 'TBD').slice(0, 3)} {event.event_day || 'TBD'}{event.event_time ? ` · ${event.event_time}` : ''}</div>
        </div>
        <div class="det-info-item">
          <div class="det-info-label">Where</div>
          <div class="det-info-value">{myRsvp ? (event.location || event.zone || 'Denver') : (event.zone || 'Denver')}{!myRsvp ? ' · RSVP for address' : ''}</div>
        </div>
        <div class="det-info-item">
          <div class="det-info-label">Price</div>
          <div class="det-info-value" style={`color: ${event.price_cap && event.price_cap !== 'Free' && event.price_cap !== '$0' ? '#111827' : '#059669'};`}>{event.price_cap && event.price_cap !== 'Free' && event.price_cap !== '$0' ? event.price_cap : 'Free'}</div>
        </div>
        <div class="det-info-item">
          <div class="det-info-label">Group Size</div>
          <div class="det-info-value">{event.spots} people max</div>
        </div>
      </div>

      {event.description && <p class="det-desc">{event.description}</p>}
    </div>
  </div>

  <!-- RSVP bar -->
  <div class="det-rsvp-bar">
    <div class="det-rsvp-left">
      <div class="det-rsvp-filled"><strong>{rsvps.length} of {event.spots}</strong> spots filled</div>
      <div class="det-rsvp-track"><div class="det-rsvp-fill" style={`width: ${Math.round((rsvps.length / (parseInt(event.spots) || 10)) * 100)}%; background: linear-gradient(90deg, ${theme.accent}, ${theme.accent}CC);`}></div></div>
      {spotsLeft <= 4 && spotsLeft > 0 && <div class="det-urgent">🔥 Only {spotsLeft} left — don't sleep on this</div>}
    </div>
    {user ? (
      <button id="rsvp-btn" class={`det-rsvp-btn ${myRsvp ? 'rsvped' : ''}`} style={myRsvp ? '' : `background: ${theme.accent};`} data-event-id={id} data-rsvped={myRsvp ? 'true' : 'false'} data-accent={theme.accent} data-spots={event.spots || '10'}>
        {myRsvp ? "✓ You're In — Cancel RSVP" : "I'm In"}
      </button>
    ) : (
      <a href={`/login?next=/events/${id}`} class="det-rsvp-btn" style={`background: ${theme.accent};`}>Sign in to RSVP</a>
    )}
  </div>

  <!-- Attendees — pill style -->
  <div class="det-att-card">
    <div class="det-att-title">Who's going ({rsvps.length})</div>
    {rsvps.length > 0 ? (
      <div class="det-att-grid">
        {rsvps.map((r: any, i: number) => (
          <div class="det-att-pill">
            <div class="det-att-av" style={`background:${avatarColors[i % avatarColors.length]}`}>{(r.name || '?')[0]}</div>
            <span class="det-att-name">{r.name}</span>
            {r.neighborhood && <span class="det-att-hood">· {r.neighborhood}</span>}
          </div>
        ))}
      </div>
    ) : (
      <div class="det-att-empty">No one's RSVP'd yet. Be the person who starts the wave.</div>
    )}
  </div>

  <!-- Members who'd love this -->
  {matchedMembers.length > 0 && (
    <div class="det-match-card">
      <div class="det-match-title">✨ Members who'd love this</div>
      <div class="det-match-sub">Based on shared interests in {interestKeywords.slice(0, 2).join(' & ')}</div>
      <div class="det-match-grid">
        {matchedMembers.map((m: any, i: number) => {
          const sharedInterests = interestKeywords.filter(k => (m.interests || '').includes(k));
          return (
            <div class="det-match-pill">
              <div class="det-match-av" style={`background:${avatarColors[i % avatarColors.length]}`}>{(m.name || '?')[0]}</div>
              <div class="det-match-info">
                <span class="det-match-name">{m.name}</span>
                {m.neighborhood && <span class="det-match-hood">{m.neighborhood}</span>}
                <span class="det-match-shared">Likes {sharedInterests[0]?.replace(/^[^\w\s]+\s*/, '') || interestKeywords[0]}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- Discord CTA -->
  <div class="det-discord">
    <span class="det-discord-icon">💬</span>
    <div class="det-discord-text">
      <strong>Plans happen in Discord first</strong>
      <span>Chat about this event, coordinate rides, or just hang</span>
    </div>
    <a href={event.discord_link || "https://discord.gg/S8SFNkdSgK"} class="det-discord-btn" target="_blank" rel="noopener">Join →</a>
  </div>
</div>

<style is:inline>
  /* ── Tinted background wash ── */
  .det-bg-wash {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    z-index: -1;
  }

  /* ── Page container ── */
  .det-page { max-width: 620px; margin: 0 auto; padding: 24px 20px 48px; position: relative; z-index: 1; }

  .det-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600;
    color: #6B7280; margin-bottom: 16px; transition: color .2s;
    text-decoration: none;
  }
  .det-back:hover { color: var(--ev-accent, #7C3AED); }

  /* ── Hero card with big photo ── */
  .det-hero-card {
    border-radius: 24px; overflow: hidden; background: #fff;
    border: 1px solid #E5E7EB;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    margin-bottom: 16px;
  }
  .det-hero-img {
    position: relative; height: 280px;
    background-size: cover; background-position: center;
  }
  .det-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 35%, rgba(0,0,0,0.6) 100%);
  }
  .det-hero-tag {
    position: absolute; top: 16px; left: 16px;
    padding: 6px 14px; border-radius: 10px;
    font-size: 12px; font-weight: 700; font-family: 'Outfit', sans-serif;
    background: rgba(255,255,255,0.92); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    display: flex; align-items: center; gap: 5px;
    text-transform: capitalize;
  }
  .det-hero-spots {
    position: absolute; top: 16px; right: 16px;
    padding: 6px 12px; border-radius: 8px;
    font-size: 11px; font-weight: 700; font-family: 'Outfit', sans-serif;
    background: rgba(255,255,255,0.9); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    color: #111827;
  }
  .det-hero-bottom {
    position: absolute; bottom: 20px; left: 20px; right: 20px;
  }
  .det-hero-title {
    font-family: 'Outfit', sans-serif; font-size: clamp(24px, 5vw, 30px);
    font-weight: 900; color: #fff; line-height: 1.15; margin-bottom: 6px;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .det-hero-meta { font-size: 13px; color: rgba(255,255,255,0.85); }

  .det-hero-body { padding: 20px 24px 24px; }

  /* ── Info grid ── */
  .det-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .det-info-item {
    background: #F8F9FB; border: 1px solid #E5E7EB; border-radius: 14px;
    padding: 14px 16px;
  }
  .det-info-label { font-size: 10px; color: #9CA3AF; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; }
  .det-info-value { font-size: 14px; font-weight: 600; font-family: 'Outfit', sans-serif; color: #111827; }

  .det-desc { font-size: 15px; line-height: 1.8; color: #374151; margin: 0; }

  /* ── RSVP bar ── */
  .det-rsvp-bar {
    display: flex; align-items: center; gap: 16px;
    padding: 18px 20px; border-radius: 20px;
    background: #fff; border: 1px solid #E5E7EB;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    margin-bottom: 16px;
  }
  .det-rsvp-left { flex: 1; }
  .det-rsvp-filled { font-size: 13px; font-weight: 600; color: #6B7280; margin-bottom: 8px; }
  .det-rsvp-filled strong { color: #111827; }
  .det-rsvp-track { height: 6px; background: #E5E7EB; border-radius: 3px; overflow: hidden; }
  .det-rsvp-fill { height: 100%; border-radius: 3px; transition: width .4s ease; }

  .det-rsvp-btn {
    padding: 14px 32px; border-radius: 14px;
    font-size: 15px; font-weight: 700; font-family: 'Outfit', sans-serif;
    border: none; cursor: pointer; text-align: center; text-decoration: none;
    background: #7C3AED; color: #fff; transition: all .2s; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .det-rsvp-btn:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 6px 20px var(--ev-accent-shadow, rgba(124,58,237,0.2)); }
  .det-rsvp-btn.rsvped { background: rgba(220,38,38,0.08); color: #DC2626; padding: 14px 20px; }
  .det-rsvp-btn.rsvped:hover { background: rgba(220,38,38,0.14); }

  .det-urgent { font-size: 11px; font-weight: 600; color: #DC2626; margin-top: 6px; }

  /* ── Attendees — pill grid ── */
  .det-att-card {
    background: #fff; border: 1px solid #E5E7EB; border-radius: 20px;
    padding: 18px 20px; margin-bottom: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .det-att-title { font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 14px; }
  .det-att-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .det-att-pill {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 14px 6px 6px; border-radius: 50px;
    background: #F8F9FB; border: 1px solid #E5E7EB;
    font-size: 13px; transition: border-color .15s;
  }
  .det-att-pill:hover { border-color: #D1D5DB; }
  .det-att-av {
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff; flex-shrink: 0;
  }
  .det-att-name { font-weight: 600; font-family: 'Outfit', sans-serif; color: #111827; }
  .det-att-hood { font-size: 11px; color: #9CA3AF; }
  .det-att-empty { padding: 20px 0; text-align: center; color: #9CA3AF; font-size: 13px; line-height: 1.6; }

  /* ── Members who'd love this ── */
  .det-match-card {
    background: #fff; border: 1px solid #E5E7EB; border-radius: 20px;
    padding: 18px 20px; margin-bottom: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .det-match-title {
    font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 700;
    color: #111827; margin-bottom: 4px;
  }
  .det-match-sub {
    font-size: 12px; color: #9CA3AF; margin-bottom: 14px;
  }
  .det-match-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .det-match-pill {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 14px 8px 8px; border-radius: 50px;
    background: #F8F9FB; border: 1px solid #E5E7EB;
    transition: border-color .15s;
  }
  .det-match-pill:hover { border-color: #D1D5DB; }
  .det-match-av {
    width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: #fff; flex-shrink: 0;
  }
  .det-match-info { display: flex; flex-direction: column; gap: 1px; }
  .det-match-name {
    font-weight: 600; font-family: 'Outfit', sans-serif;
    font-size: 13px; color: #111827;
  }
  .det-match-hood { font-size: 10px; color: #9CA3AF; }
  .det-match-shared {
    font-size: 10px; color: var(--ev-accent, #7C3AED); font-weight: 600;
  }

  /* ── Discord CTA ── */
  .det-discord {
    display: flex; align-items: center; gap: 14px;
    padding: 18px 22px; border-radius: 16px;
    background: #fff; border: 1px solid #E5E7EB;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .det-discord-icon { font-size: 24px; flex-shrink: 0; }
  .det-discord-text { flex: 1; }
  .det-discord-text strong { display: block; font-size: 13px; color: #111827; font-family: 'Outfit', sans-serif; }
  .det-discord-text span { font-size: 12px; color: #6B7280; }
  .det-discord-btn {
    padding: 8px 18px; background: #7C3AED; color: #fff;
    border-radius: 50px; font-size: 12px; font-weight: 700;
    font-family: 'Outfit', sans-serif; flex-shrink: 0; text-decoration: none;
    transition: opacity .2s;
  }
  .det-discord-btn:hover { opacity: 0.9; }

  @media (max-width: 768px) {
    .det-page { padding: 20px 16px 48px; }
    .det-hero-img { height: 220px; }
    .det-hero-body { padding: 16px 18px 20px; }
    .det-info-grid { grid-template-columns: 1fr; gap: 8px; }
    .det-rsvp-bar { flex-direction: column; gap: 12px; }
    .det-rsvp-btn { width: 100%; padding: 14px; }
    .det-rsvp-btn.rsvped { padding: 14px; }
  }
</style>

<script is:inline>
  (function() {
    var btn = document.getElementById('rsvp-btn');
    if (!btn) return;
    var eventId = btn.getAttribute('data-event-id');
    var rsvped = btn.getAttribute('data-rsvped') === 'true';
    var accent = btn.getAttribute('data-accent');
    var spots = parseInt(btn.getAttribute('data-spots') || '10');

    btn.addEventListener('click', async function() {
      btn.textContent = 'Loading...';
      try {
        var r = await fetch('/api/rsvp', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event_id: eventId }) });
        if (r.status === 401) { location.href = '/login?next=' + location.pathname; return; }
        var d = await r.json();
        if (d.error) { btn.textContent = d.message || 'Error'; return; }
        rsvped = d.rsvped;
        btn.className = 'det-rsvp-btn' + (rsvped ? ' rsvped' : '');
        btn.textContent = rsvped ? "✓ You're In — Cancel RSVP" : "I'm In";
        btn.style.background = rsvped ? '' : accent;
        btn.setAttribute('data-rsvped', rsvped ? 'true' : 'false');
        // Update the count display
        var filled = document.querySelector('.det-rsvp-filled');
        if (filled && typeof d.count === 'number') {
          filled.innerHTML = '<strong>' + d.count + ' of ' + spots + '</strong> spots filled';
        }
        var fill = document.querySelector('.det-rsvp-fill');
        if (fill && typeof d.count === 'number') {
          fill.style.width = Math.round((d.count / spots) * 100) + '%';
        }
        var heroSpots = document.querySelector('.det-hero-spots');
        if (heroSpots && typeof d.count === 'number') {
          heroSpots.textContent = d.count + ' of ' + spots + ' going';
        }
      } catch { btn.textContent = 'Error — try again'; }
    });
  })();
</script>

</Base>
