---
import Base from '../../layouts/Base.astro';

let user: any = null;
const cookie = Astro.cookies.get('dsn_user')?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
if (!user) return Astro.redirect('/login?next=/groups/new');
---
<Base title="New group" description="Start a new subcommunity inside Denver Social.">
<div class="g-wrap">
  <a href="/groups" class="g-back">← Groups</a>
  <h1 class="g-title">Start a group</h1>
  <p class="g-sub">Build a smaller circle inside Denver Social. You'll be the owner — invite friends, post events, run it your way.</p>

  <form id="new-group-form" class="g-form">
    <div class="g-field">
      <label class="g-label">Group name</label>
      <input type="text" name="name" placeholder="Denver Hikers, Wednesday Trivia Crew…" maxlength="60" required class="g-input" />
      <span class="g-hint">3–60 characters</span>
    </div>

    <div class="g-field">
      <label class="g-label">Description (optional)</label>
      <textarea name="description" rows="4" placeholder="What's this group about? Who's it for?" maxlength="500" class="g-input"></textarea>
    </div>

    <div class="g-field">
      <label class="g-label">Privacy</label>
      <label class="g-radio">
        <input type="radio" name="privacy" value="public" checked />
        <div>
          <strong>Public</strong>
          <span>Anyone can find and join.</span>
        </div>
      </label>
      <label class="g-radio">
        <input type="radio" name="privacy" value="invite_only" />
        <div>
          <strong>Invite only</strong>
          <span>Members join via an invite link from you or another member.</span>
        </div>
      </label>
    </div>

    <button type="submit" class="g-submit" id="submit-btn">Create group</button>
    <div class="g-err" id="err"></div>
  </form>
</div>

<style>
  .g-wrap { max-width: 600px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .g-back { font-size: 13px; color: var(--text-sec); margin-bottom: 24px; display: inline-block; }
  .g-back:hover { color: var(--text); }
  .g-title { font-family: var(--font-display); font-size: clamp(28px, 4vw, 36px); font-weight: 800; letter-spacing: -0.02em; }
  .g-sub { font-size: 15px; color: var(--text-sec); margin-top: 8px; margin-bottom: 28px; line-height: 1.5; }
  .g-form { display: flex; flex-direction: column; gap: 22px; }
  .g-field { display: flex; flex-direction: column; gap: 8px; }
  .g-label { font-size: 14px; font-weight: 600; color: var(--text); }
  .g-input {
    padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;
    font-size: 15px; font-family: var(--font); color: var(--text); background: var(--bg);
    resize: vertical;
  }
  .g-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .g-hint { font-size: 12px; color: var(--text-faint); }
  .g-radio {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 16px; border: 1px solid var(--border); border-radius: 12px; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .g-radio:hover { border-color: var(--border-hover); background: var(--surface); }
  .g-radio input { margin-top: 4px; }
  .g-radio strong { display: block; font-size: 14px; font-weight: 700; color: var(--text); }
  .g-radio span { font-size: 13px; color: var(--text-sec); }
  .g-submit {
    margin-top: 8px; padding: 14px; border-radius: 999px;
    background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font-display); font-weight: 700; font-size: 15px;
    border: none; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;
  }
  .g-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 16px var(--accent-glow); }
  .g-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }
  .g-err { color: #DC2626; font-size: 13px; min-height: 18px; }
</style>

<script>
  const form = document.getElementById('new-group-form') as HTMLFormElement;
  const errEl = document.getElementById('err');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.textContent = '';
    submitBtn.disabled = true;
    const fd = new FormData(form);
    try {
      const res = await fetch('/api/groups', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'create',
          name: fd.get('name'),
          description: fd.get('description'),
          privacy: fd.get('privacy'),
        }),
      });
      const data = await res.json();
      if (data.ok && data.slug) {
        location.href = `/groups/${data.slug}`;
      } else {
        if (errEl) errEl.textContent = data.error === 'name_length' ? 'Name must be 3–60 characters.' : `Couldn't create group (${data.error || 'unknown'}).`;
        submitBtn.disabled = false;
      }
    } catch {
      if (errEl) errEl.textContent = 'Network error. Try again.';
      submitBtn.disabled = false;
    }
  });
</script>
</Base>
