---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';
import { ensureGroupsSchema, GROUP_CATEGORIES, categoryEmoji, categoryLabel } from '../../lib/groups-schema';
import { getCurrentProfile } from '../../lib/profile-auth';
import { getNeighborhood, NEIGHBORHOODS } from '../../lib/neighborhoods';

const db = getDB();
if (db) await ensureGroupsSchema(db);
const me = db ? await getCurrentProfile(Astro.cookies, db, Astro.request) : null;

const params = Astro.url.searchParams;
const catFilter = (params.get('cat') || '').toLowerCase();
const nbhFilter = (params.get('nbh') || '').toLowerCase();

// Curated short list of major Denver-metro hood pills (matches discoverability spec).
const TOP_HOODS = ['downtown','rino','lohi','highlands','five-points','cherry-creek','wash-park','capitol-hill']
  .map(slug => getNeighborhood(slug))
  .filter(Boolean) as Array<{ slug: string; label: string }>;

let myGroups: any[] = [];
let allGroups: any[] = [];
if (db) {
  if (me) {
    const m = await db.prepare(`
      SELECT g.*, gm.role as my_role
      FROM groups g JOIN group_members gm ON gm.group_id = g.id
      WHERE LOWER(gm.member_email) = LOWER(?)
      ORDER BY gm.joined_at DESC LIMIT 24
    `).bind(me.email).all();
    myGroups = (m.results || []) as any[];
  }
  const all = await db.prepare(`
    SELECT * FROM groups ORDER BY member_count DESC, id DESC LIMIT 200
  `).all();
  allGroups = (all.results || []) as any[];
}

const filteredGroups = allGroups.filter((g: any) => {
  if (catFilter && (g.category || 'general') !== catFilter) return false;
  if (nbhFilter && (g.neighborhood || '') !== nbhFilter) return false;
  return true;
});

function hoodLabel(slug: string): string {
  if (!slug) return '';
  const h = NEIGHBORHOODS.find(n => n.slug === slug);
  return h?.label || slug;
}

function buildUrl(opts: { cat?: string | null; nbh?: string | null }): string {
  const sp = new URLSearchParams();
  const nextCat = opts.cat ?? catFilter;
  const nextNbh = opts.nbh ?? nbhFilter;
  if (nextCat) sp.set('cat', nextCat);
  if (nextNbh) sp.set('nbh', nextNbh);
  const s = sp.toString();
  return s ? '/groups?' + s : '/groups';
}

const canCreate = me?.tier === 'organizer';
---
<Base title="Groups" description="Find your people in Denver — hobbies, sports, food, causes.">
<div class="g-wrap">
  <nav class="cb-tabs-strip" aria-label="Community sections">
    <a href="/community" class="cb-tab-link">📌 Flyers</a>
    <a href="/groups" class="cb-tab-link cb-tab-link-on">👥 Groups</a>
  </nav>
  <header class="g-hero">
    <h1>Groups · Find your people</h1>
    <p class="g-sub">Browse by what you're into — hobbies, sports, food, causes. Anyone can join, organizers create.</p>
    <div class="g-hero-actions">
      {canCreate
        ? <a href="/groups/new" class="btn-cta">+ Create a group</a>
        : me
          ? <a href={`/u/${me.slug}`} class="btn-sec">Upgrade to organizer to create</a>
          : <a href="/u/new?next=/groups/new" class="btn-sec">Sign up to host</a>}
    </div>
  </header>

  {me && myGroups.length > 0 && (
    <section class="g-section">
      <h2 class="g-section-title">Your groups</h2>
      <div class="g-grid">
        {myGroups.map((g: any) => (
          <a href={`/groups/${g.slug}`} class="g-card">
            <div class="g-card-emoji">{g.cover_emoji || '👥'}</div>
            <div class="g-card-body">
              <div class="g-card-name">{g.name}</div>
              <div class="g-card-meta">
                <span>{g.member_count} member{g.member_count === 1 ? '' : 's'}</span>
                {g.my_role && g.my_role !== 'member' && <span class="g-card-role">{g.my_role}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="g-section">
    <h2 class="g-section-title">Browse by category</h2>
    <div class="g-pills">
      <a href={buildUrl({ cat: '' })} class:list={["g-pill", { active: !catFilter }]}>All</a>
      {GROUP_CATEGORIES.map((c: any) => (
        <a href={buildUrl({ cat: c.key })} class:list={["g-pill", { active: catFilter === c.key }]}>
          <span>{c.emoji}</span> <span>{c.label}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="g-section">
    <h2 class="g-section-subtitle">Filter by neighborhood</h2>
    <div class="g-pills g-pills-sm">
      <a href={buildUrl({ nbh: '' })} class:list={["g-pill", { active: !nbhFilter }]}>All metro</a>
      {TOP_HOODS.map((h: any) => (
        <a href={buildUrl({ nbh: h.slug })} class:list={["g-pill", { active: nbhFilter === h.slug }]}>
          {h.label}
        </a>
      ))}
    </div>
  </section>

  <section class="g-section">
    <h2 class="g-section-title">
      {catFilter || nbhFilter ? 'Matching groups' : 'All groups'}
      <span class="g-count-pill">{filteredGroups.length}</span>
    </h2>
    {filteredGroups.length === 0 ? (
      <div class="g-empty">
        No groups match those filters yet.
        {canCreate && <> Be first — <a href="/groups/new">create one →</a></>}
      </div>
    ) : (
      <div class="g-grid">
        {filteredGroups.map((g: any) => (
          <a href={`/groups/${g.slug}`} class="g-card">
            <div class="g-card-emoji">{g.cover_emoji || '👥'}</div>
            <div class="g-card-body">
              <div class="g-card-name">{g.name}</div>
              {g.description && <p class="g-card-desc">{g.description}</p>}
              <div class="g-card-tags">
                <span class="g-tag g-tag-cat">{categoryEmoji(g.category || 'general')} {categoryLabel(g.category || 'general')}</span>
                {g.neighborhood && <span class="g-tag g-tag-hood">📍 {hoodLabel(g.neighborhood)}</span>}
                {g.privacy === 'invite_only' && <span class="g-tag g-tag-lock">🔒 Private</span>}
              </div>
              <div class="g-card-meta">
                <span>{g.member_count} member{g.member_count === 1 ? '' : 's'}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</div>

<style>
  .g-wrap { max-width: 1180px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .g-hero { margin-bottom: 32px; }
  .g-hero h1 { font-family: var(--font-display); font-size: clamp(28px, 4vw, 40px); font-weight: 800; letter-spacing: -0.02em; }
  .g-sub { font-size: 15px; color: var(--text-sec); margin-top: 8px; max-width: 600px; }
  .g-hero-actions { margin-top: 16px; display: flex; gap: 8px; flex-wrap: wrap; }

  .g-section { margin-bottom: 32px; }
  .g-section-title { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-size: 20px; font-weight: 700; margin-bottom: 16px; letter-spacing: -0.01em; }
  .g-section-subtitle { font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }
  .g-count-pill { font-size: 12px; font-weight: 700; color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, #fff); padding: 4px 12px; border-radius: 999px; }

  .g-pills { display: flex; gap: 8px; flex-wrap: wrap; }
  .g-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 50px;
    background: var(--bg); border: 1px solid var(--border);
    font-size: 13px; font-weight: 600; color: var(--text);
    text-decoration: none; transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .g-pill:hover { background: var(--surface); border-color: var(--border-hover); }
  .g-pill:active { transform: translateY(1px); }
  .g-pill.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  .g-pills-sm .g-pill { padding: 6px 12px; font-size: 12px; }

  .g-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
  .g-card {
    display: flex; gap: 12px; padding: 16px;
    background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius);
    text-decoration: none; color: var(--text); box-shadow: var(--card-shadow);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .g-card:hover { transform: translateY(-2px); border-color: var(--border-hover); box-shadow: 0 4px 14px rgba(0,0,0,0.08); }
  .g-card:active { transform: translateY(0); }
  .g-card-emoji { font-size: 32px; flex-shrink: 0; line-height: 1; padding-top: 2px; }
  .g-card-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
  .g-card-name { font-family: var(--font-display); font-size: 17px; font-weight: 700; line-height: 1.2; }
  .g-card-desc { font-size: 13px; color: var(--text-sec); line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin: 0; }
  .g-card-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
  .g-tag { font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 999px; background: var(--surface); color: var(--text-sec); }
  .g-tag-cat { background: #EEF2FF; color: #4338CA; }
  .g-tag-hood { background: #F0FDF4; color: #047857; }
  .g-tag-lock { background: #FEF3C7; color: #92400E; }
  .g-card-meta { font-size: 12px; color: var(--text-faint); }
  .g-card-role { color: var(--accent); font-weight: 700; text-transform: capitalize; margin-left: 6px; }

  .g-empty { padding: 24px; border: 1px dashed var(--border); border-radius: 14px; text-align: center; color: var(--text-sec); font-size: 14px; }
  .g-empty a { color: var(--accent); font-weight: 600; }
</style>
</Base>
