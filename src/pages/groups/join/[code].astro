---
import Base from '../../../layouts/Base.astro';
import { getDB } from '../../../lib/db';
import { ensureGroupsSchema } from '../../../lib/groups-schema';

const db = getDB();
const { code } = Astro.params;
let user: any = null;
const cookie = Astro.cookies.get('dsn_user')?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

if (!user) return Astro.redirect(`/login?next=/groups/join/${code}`);

let group: any = null;
let invite: any = null;
let status: 'ok' | 'used' | 'invalid' | 'gone' = 'ok';

if (db && code) {
  await ensureGroupsSchema(db);
  invite = await db.prepare('SELECT * FROM group_invites WHERE code=?').bind(code).first();
  if (!invite) status = 'invalid';
  else if (invite.used_at) status = 'used';
  else {
    group = await db.prepare('SELECT * FROM groups WHERE id=?').bind(invite.group_id).first();
    if (!group) status = 'gone';
  }
}
---
<Base title="Group invite" description="Accept your invite to a Denver Social group.">
<div class="g-wrap">
  {status === 'invalid' && (
    <div class="g-state">
      <div class="g-state-emoji">🤷</div>
      <h1>Invite not found</h1>
      <p>That link doesn't match any invite. Ask whoever shared it to send a fresh one.</p>
      <a href="/groups" class="btn-cta">Back to groups</a>
    </div>
  )}
  {status === 'used' && (
    <div class="g-state">
      <div class="g-state-emoji">✓</div>
      <h1>Invite already used</h1>
      <p>This invite was already claimed. Each invite link is single-use — ask for a new one if you still need access.</p>
      <a href="/groups" class="btn-cta">Browse groups</a>
    </div>
  )}
  {status === 'gone' && (
    <div class="g-state">
      <div class="g-state-emoji">🌫</div>
      <h1>Group no longer exists</h1>
      <p>The group this invite pointed to has been deleted.</p>
      <a href="/groups" class="btn-cta">Browse groups</a>
    </div>
  )}
  {status === 'ok' && group && (
    <div class="g-state">
      <div class="g-state-emoji">🎉</div>
      <h1>Join {group.name}?</h1>
      {group.description && <p class="g-state-desc">{group.description}</p>}
      <p class="g-state-meta">{group.member_count} member{group.member_count === 1 ? '' : 's'} · {group.privacy === 'invite_only' ? '🔒 Invite only' : '🌐 Public'}</p>
      <div class="g-state-actions">
        <button class="btn-cta" id="accept-btn" data-code={code}>Accept invite</button>
        <a href="/groups" class="btn-sec">Maybe later</a>
      </div>
      <div class="g-err" id="err"></div>
    </div>
  )}
</div>

<style>
  .g-wrap { max-width: 540px; margin: 0 auto; padding: 64px clamp(16px, 4vw, 40px); }
  .g-state { text-align: center; }
  .g-state-emoji { font-size: 64px; margin-bottom: 16px; }
  .g-state h1 { font-family: var(--font-display); font-size: clamp(26px, 4vw, 32px); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 14px; }
  .g-state p { font-size: 15px; color: var(--text-sec); line-height: 1.5; margin-bottom: 20px; }
  .g-state-desc { font-size: 16px; color: var(--text); font-style: italic; }
  .g-state-meta { font-size: 13px !important; color: var(--text-faint) !important; }
  .g-state-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 14px; }
  .g-err { color: #DC2626; font-size: 13px; min-height: 18px; }
</style>

<script>
  const btn = document.getElementById('accept-btn');
  const err = document.getElementById('err');
  btn?.addEventListener('click', async () => {
    const code = (btn as HTMLElement).dataset.code;
    if (err) err.textContent = '';
    (btn as HTMLButtonElement).disabled = true;
    try {
      const res = await fetch('/api/groups', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'accept', code }),
      });
      const d = await res.json();
      if (d.ok && d.slug) location.href = `/groups/${d.slug}`;
      else {
        if (err) err.textContent = `Couldn't accept: ${d.error}`;
        (btn as HTMLButtonElement).disabled = false;
      }
    } catch {
      if (err) err.textContent = 'Network error. Try again.';
      (btn as HTMLButtonElement).disabled = false;
    }
  });
</script>
</Base>
