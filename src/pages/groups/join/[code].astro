---
import Base from '../../../layouts/Base.astro';
---
<Base title="Group joining is offline" description="Joining groups is offline while accounts are reworked.">
  <div style="max-width:520px;margin:96px auto;padding:0 24px;text-align:center">
    <h1 style="font-family:var(--font-display);font-size:28px;margin-bottom:12px">Joining groups is offline</h1>
    <p style="color:var(--text-sec);margin-bottom:24px">We're reworking accounts. Invite links will work again soon.</p>
    <a href="/groups" class="btn-sec">Browse groups</a>
  </div>
</Base>
