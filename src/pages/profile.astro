<script is:inline>
  // Edit toggle
  var editToggle = document.getElementById('editToggle');
  var editPanel = document.getElementById('editPanel');
  if (editToggle && editPanel) {
    editToggle.addEventListener('click', function() {
      var isOpen = editPanel.style.display !== 'none';
      editPanel.style.display = isOpen ? 'none' : '';
      editToggle.classList.toggle('open', !isOpen);
    });
  }

  // Add bio button opens edit
  var addBioBtn = document.getElementById('addBioBtn');
  if (addBioBtn && editToggle) {
    addBioBtn.addEventListener('click', function() {
      editPanel.style.display = '';
      editToggle.classList.add('open');
      editPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(function() {
        var bio = editPanel.querySelector('textarea[name="bio"]');
        if (bio) bio.focus();
      }, 300);
    });
  }

  // Delete modal
  var modal = document.getElementById('delete-modal');
  var deleteBtn = document.getElementById('delete-btn');
  var cancelBtn = document.getElementById('cancel-btn');
  if (deleteBtn) {
    deleteBtn.addEventListener('click', function() {
      modal.classList.remove('modal-hidden');
      modal.classList.add('modal-visible');
    });
  }
  if (cancelBtn) {
    cancelBtn.addEventListener('click', function() {
      modal.classList.remove('modal-visible');
      modal.classList.add('modal-hidden');
    });
  }
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        modal.classList.remove('modal-visible');
        modal.classList.add('modal-hidden');
      }
    });
  }
</script>
