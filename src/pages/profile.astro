---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getLevel, getNextLevel } from '../lib/levels';
import { env } from 'cloudflare:workers';

const redditAvailable = !!(env as any).REDDIT_CLIENT_ID;
const discordAvailable = !!(env as any).DISCORD_CLIENT_ID;

const db = getDB();
let user: any = null;
const cookie = Astro.cookies.get('dsn_user')?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
if (!user) return Astro.redirect('/login?next=/profile');

const isSuperAdmin = (user.email || '').toLowerCase() === 'stharpe98@gmail.com';
const isAdmin = isSuperAdmin || user.role === 'admin';

let member: any = null;
let error: string | null = null;
let success = false;

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const name = form.get('name')?.toString().trim();
    const bio = form.get('bio')?.toString().trim() || '';
    const neighborhood = form.get('neighborhood')?.toString().trim() || '';
    const interests = form.getAll('interests').join(',');
    if (db && name) {
      await db.prepare('UPDATE members SET name=?, bio=?, neighborhood=?, interests=? WHERE email=?')
        .bind(name, bio, neighborhood, interests, user.email).run();
      success = true;
      user.name = name;
    }
  } catch { error = 'Failed to save. Try again.'; }
}

let streak: any = null;
let mySuggestions: any[] = [];
let upcomingRsvps: any[] = [];
let pastRsvps: any[] = [];
let myEvents: any[] = [];
let myPotluckRsvps: any[] = [];

try {
  if (db && user?.email) {
    streak = await db.prepare('SELECT * FROM member_streaks WHERE email=?').bind(user.email).first();
    member = await db.prepare('SELECT * FROM members WHERE email=?').bind(user.email).first();

    const sug = await db.prepare('SELECT title, type, status, votes FROM suggestions WHERE member_name=? ORDER BY rowid DESC LIMIT 10')
      .bind(user.name || '').all();
    mySuggestions = sug.results || [];

    const rsvps = await db.prepare(`
      SELECT e.id, e.title, e.event_type, e.event_month, e.event_day, e.zone, e.location, e.is_past, r.party_size
      FROM event_rsvps r JOIN events e ON r.event_id = e.id
      WHERE r.member_email = ? ORDER BY r.rowid DESC LIMIT 50
    `).bind(user.email).all();
    const all = (rsvps.results || []) as any[];
    upcomingRsvps = all.filter(r => !r.is_past);
    pastRsvps = all.filter(r => r.is_past);

    const owned = await db.prepare(
      'SELECT id, title, event_type, event_month, event_day, location, zone, rsvp_count, spots, is_past FROM events WHERE submitted_by = ? ORDER BY id DESC LIMIT 20'
    ).bind(user.name || '').all();
    myEvents = (owned.results || []) as any[];

    const pt = await db.prepare(`
      SELECT p.id, p.title, p.date_label, p.location, p.status, r.dish
      FROM potluck_rsvp r JOIN potlucks p ON r.potluck_id = p.id
      WHERE LOWER(r.email) = LOWER(?) AND r.rsvp = 'yes'
      ORDER BY r.id DESC LIMIT 20
    `).bind(user.email).all();
    myPotluckRsvps = (pt.results || []) as any[];
  }
} catch {}

const neighborhoods = [
  'LoDo / Downtown', 'RiNo / River North', 'Five Points', 'Curtis Park',
  'Capitol Hill', 'Cheesman Park', 'Congress Park', 'Uptown',
  'Cherry Creek', 'Hilltop', 'Stapleton / Central Park',
  'Washington Park', 'Platt Park', 'Baker', 'Green Valley Ranch',
  'Highlands / LoHi', 'Sunnyside', 'Berkeley', "Sloan's Lake",
  'Englewood', 'Littleton', 'Centennial', 'Parker',
  'Lakewood', 'Golden', 'Arvada',
  'Westminster', 'Thornton', 'Broomfield',
  'Aurora', 'Boulder', 'Other / Outside Denver',
];

const interestOptions = [
  '🍽️ Food & Dining', '🍺 Craft Beer', '🥾 Hiking', '🎲 Board Games',
  '🎵 Live Music', '🎨 Art & Culture', '🎳 Bowling', '💪 Fitness',
  '😂 Comedy', '🎰 Casino Trips', '🏔️ Outdoors', '☕ Coffee & Cafes',
  '🧠 Trivia', '🎤 Karaoke', '🏒 Sports', '📸 Photography',
];

const myInterests = (member?.interests || '').split(',').filter(Boolean);
const totalEvts = member?.events_attended || streak?.total_events || 0;
const level = getLevel(totalEvts);
const next = getNextLevel(level);
const memberSince = member?.joined_at
  ? new Date(member.joined_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : 'Recently';

const typeEmoji: Record<string, string> = {
  dinner: '🍽️', game_night: '🎲', outdoor: '🏔️', brewery: '🍺', coffee: '☕',
  arts: '🎨', music: '🎵', social: '🎉', group_tickets: '🎫', camping: '🏕️',
  sports_outing: '🏒', sports: '🏒', bowling: '🎳', active: '🧗', casino: '🎰',
  food_trucks: '🌮', potluck: '🍲', other: '📅',
};

const firstName = (member?.name || user.name || 'friend').split(' ')[0];
const greeting = ["What's good", 'Hey there', 'Yo', "What's up", 'Sup'][Math.floor(Math.random() * 5)];
const socialLevel = totalEvts === 0 ? 'Fresh face in Denver'
  : totalEvts < 3 ? 'Getting out there'
  : totalEvts < 8 ? 'Becoming a regular'
  : totalEvts < 15 ? 'Denver knows your name'
  : 'Absolute legend';

const upcomingCount = upcomingRsvps.length + myPotluckRsvps.length;

const connectResult = Astro.url.searchParams.get('connect');
const connectBanner =
  connectResult === 'reddit_ok'      ? { kind: 'ok',  text: 'Reddit account connected ✓' } :
  connectResult === 'discord_ok'     ? { kind: 'ok',  text: 'Discord account connected ✓' } :
  connectResult === 'reddit_taken'   ? { kind: 'err', text: 'That Reddit account is already linked elsewhere.' } :
  connectResult === 'discord_taken'  ? { kind: 'err', text: 'That Discord account is already linked elsewhere.' } :
  null;
---
<Base title="My profile" description="Your Denver Social home base.">
<div class="p">

  {error && <div class="p-toast err">{error}</div>}
  {success && <div class="p-toast ok">Profile saved ✓</div>}
  {connectBanner && <div class={`p-toast ${connectBanner.kind}`}>{connectBanner.text}</div>}

  <!-- COVER + HERO -->
  <header class="p-cover">
    <div class="p-cover-bg"></div>
    <div class="p-cover-pattern"></div>
    <div class="p-cover-inner">
      <div class="p-identity">
        <div class="p-avatar">{firstName[0]?.toUpperCase() || '?'}</div>
        <div class="p-identity-text">
          <div class="p-eyebrow">{greeting},</div>
          <h1 class="p-name">{firstName}.</h1>
          <p class="p-tagline">{socialLevel} · {level.emoji} {level.name}</p>
          <div class="p-chips">
            {member?.neighborhood && <span class="p-chip">📍 {member.neighborhood}</span>}
            <span class="p-chip">📅 Member since {memberSince}</span>
            {totalEvts > 0 && <span class="p-chip">🎉 {totalEvts} hangout{totalEvts === 1 ? '' : 's'}</span>}
          </div>
        </div>
      </div>
      <div class="p-cover-actions">
        <a href="/events" class="p-btn p-btn-ghost">Browse events</a>
        <a href="/events/new" class="p-btn p-btn-light">+ Plan an event</a>
      </div>
    </div>
  </header>

  {isAdmin && (
    <a href="/admin/dashboard" class="p-admin-card">
      <span class="p-admin-icon">⚙️</span>
      <div class="p-admin-body">
        <strong>Admin dashboard</strong>
        <span>Organizer tools, event approvals, settings.</span>
      </div>
      <span class="p-admin-arrow">›</span>
    </a>
  )}

  <!-- STATS STRIP -->
  <div class="p-stats">
    <div class="p-stat">
      <div class="p-stat-icon">🎉</div>
      <div>
        <div class="p-stat-big">{totalEvts}</div>
        <div class="p-stat-label">hangouts attended</div>
      </div>
    </div>
    <div class="p-stat">
      <div class="p-stat-icon">{(streak?.current_streak || 0) >= 3 ? '🔥' : '⚡'}</div>
      <div>
        <div class="p-stat-big">{streak?.current_streak || 0}</div>
        <div class="p-stat-label">current streak</div>
      </div>
    </div>
    <div class="p-stat">
      <div class="p-stat-icon">💡</div>
      <div>
        <div class="p-stat-big">{mySuggestions.length}</div>
        <div class="p-stat-label">ideas pitched</div>
      </div>
    </div>
    <div class="p-stat">
      <div class="p-stat-icon">🎤</div>
      <div>
        <div class="p-stat-big">{myEvents.length}</div>
        <div class="p-stat-label">events hosted</div>
      </div>
    </div>
  </div>

  <!-- 2-COLUMN GRID -->
  <div class="p-grid">

    <!-- MAIN COLUMN -->
    <main class="p-main">

      <!-- COMING UP -->
      <section class="p-card">
        <div class="p-card-head">
          <h2 class="p-h">Coming up</h2>
          {upcomingCount > 0 && <span class="p-pill-count">{upcomingCount}</span>}
        </div>
        {upcomingCount > 0 ? (
          <div class="p-events">
            {upcomingRsvps.map((r: any) => (
              <a href={`/events/${r.id}`} class="p-event">
                <div class="p-event-date">
                  <div class="p-event-month">{(r.event_month || 'TBD').slice(0, 3)}</div>
                  <div class="p-event-day">{r.event_day || '—'}</div>
                </div>
                <div class="p-event-info">
                  <div class="p-event-title">{r.title}</div>
                  <div class="p-event-sub">{typeEmoji[r.event_type] || '📅'} {r.zone || r.location || 'Denver'}{r.party_size > 1 ? ` · +${r.party_size - 1}` : ''}</div>
                </div>
                <span class="p-badge going">Going</span>
              </a>
            ))}
            {myPotluckRsvps.map((p: any) => (
              <a href={`/potlucks/${p.id}`} class="p-event">
                <div class="p-event-emoji">🍲</div>
                <div class="p-event-info">
                  <div class="p-event-title">{p.title}</div>
                  <div class="p-event-sub">{p.date_label}{p.dish ? ` · bringing ${p.dish}` : ''}</div>
                </div>
                <span class="p-badge potluck">Potluck</span>
              </a>
            ))}
          </div>
        ) : (
          <div class="p-empty">
            <div class="p-empty-icon">📅</div>
            <div class="p-empty-title">Calendar's empty</div>
            <div class="p-empty-sub">Find a hangout that fits your vibe.</div>
            <a href="/events" class="p-btn p-btn-primary">Browse events</a>
          </div>
        )}
      </section>

      {myEvents.length > 0 && (
        <section class="p-card">
          <div class="p-card-head">
            <h2 class="p-h">You're hosting</h2>
            <span class="p-pill-count">{myEvents.length}</span>
          </div>
          <div class="p-events">
            {myEvents.map((ev: any) => (
              <a href={`/events/${ev.id}`} class={`p-event ${ev.is_past ? 'past' : ''}`}>
                <div class="p-event-emoji">{typeEmoji[ev.event_type] || '📅'}</div>
                <div class="p-event-info">
                  <div class="p-event-title">{ev.title}{ev.is_past ? ' · past' : ''}</div>
                  <div class="p-event-sub">{(ev.event_month || '').slice(0, 3)} {ev.event_day || ''} · {ev.rsvp_count || 0}{ev.spots ? `/${ev.spots}` : ''} RSVPs</div>
                </div>
                <span class="p-badge hosting">Host</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {pastRsvps.length > 0 && (
        <section class="p-card">
          <div class="p-card-head">
            <h2 class="p-h">Memories</h2>
            <span class="p-pill-count">{pastRsvps.length}</span>
          </div>
          <div class="p-events">
            {pastRsvps.slice(0, 8).map((r: any) => (
              <a href={`/events/${r.id}`} class="p-event past">
                <div class="p-event-emoji">{typeEmoji[r.event_type] || '📅'}</div>
                <div class="p-event-info">
                  <div class="p-event-title">{r.title}</div>
                  <div class="p-event-sub">{(r.event_month || '').slice(0, 3)} {r.event_day || ''} · {r.zone || r.location}</div>
                </div>
                <span class="p-badge attended">Been</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {mySuggestions.length > 0 && (
        <section class="p-card">
          <div class="p-card-head"><h2 class="p-h">Your ideas</h2></div>
          <div class="p-ideas">
            {mySuggestions.map((s: any) => (
              <div class="p-idea">
                <span class="p-idea-title">{s.title}</span>
                <div class="p-idea-right">
                  <span class="p-idea-votes">↑ {s.votes || 0}</span>
                  <span class={`p-idea-status ${s.status}`}>{s.status}</span>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

    </main>

    <!-- SIDEBAR -->
    <aside class="p-side">

      {next && (
        <section class="p-card p-level-card">
          <div class="p-level-head">
            <span class="p-level-emoji">{next.emoji}</span>
            <div>
              <div class="p-level-target">Next: {next.name}</div>
              <div class="p-level-sub">{next.eventsRequired - totalEvts} more to unlock</div>
            </div>
          </div>
          <div class="p-level-bar"><div class="p-level-fill" style={`width:${Math.min(100, Math.round(totalEvts / next.eventsRequired * 100))}%;`}></div></div>
        </section>
      )}

      <section class="p-card">
        <div class="p-card-head">
          <h2 class="p-h">About you</h2>
          <button class="p-edit-toggle" id="editToggle" type="button">Edit</button>
        </div>
        {member?.bio
          ? <p class="p-bio">"{member.bio}"</p>
          : <p class="p-bio p-bio-empty">No bio yet. <button class="p-bio-link" id="addBioBtn" type="button">Add one →</button></p>}
        {myInterests.length > 0 && (
          <div class="p-tags">
            {myInterests.map((i: string) => <span class="p-tag">{i}</span>)}
          </div>
        )}

        <div class="p-edit-panel" id="editPanel" style="display:none;">
          <form method="POST" class="p-form">
            <div class="p-field">
              <label class="p-label">Name</label>
              <input type="text" name="name" value={member?.name || user.name || ''} required class="p-input" />
            </div>
            <div class="p-field">
              <label class="p-label">Neighborhood</label>
              <select name="neighborhood" class="p-input">
                <option value="">Pick your area…</option>
                {neighborhoods.map(n => <option value={n} selected={member?.neighborhood === n}>{n}</option>)}
              </select>
            </div>
            <div class="p-field">
              <label class="p-label">Bio</label>
              <textarea name="bio" rows={3} placeholder="What should people know about you?" class="p-input" style="resize:vertical">{member?.bio || ''}</textarea>
            </div>
            <div class="p-field">
              <label class="p-label">What are you into?</label>
              <div class="p-pills">
                {interestOptions.map(opt => (
                  <label class="p-pill-wrap">
                    <input type="checkbox" name="interests" value={opt} checked={myInterests.includes(opt)} />
                    <span class="p-pill">{opt}</span>
                  </label>
                ))}
              </div>
            </div>
            <button type="submit" class="p-save">Save changes</button>
          </form>
        </div>
      </section>

      {(redditAvailable || discordAvailable || member?.reddit_username || member?.discord_username) && (
        <section class="p-card">
          <div class="p-card-head"><h2 class="p-h">Linked accounts</h2></div>
          <div class="p-conn-grid">
            {(redditAvailable || member?.reddit_username) && (
              <div class="p-conn">
                <div class="p-conn-left">
                  <span class="p-conn-icon" style="background:#FF4500">🟠</span>
                  <div class="p-conn-text">
                    <strong>Reddit</strong>
                    {member?.reddit_username
                      ? <span>u/{member.reddit_username} · {member.karma || 0} karma</span>
                      : <span>Not connected</span>}
                  </div>
                </div>
                {member?.reddit_username
                  ? <button class="p-conn-btn p-conn-btn-off" data-disconnect="reddit" type="button">Disconnect</button>
                  : <a href="/api/auth/reddit?connect=1&next=/profile" class="p-conn-btn p-conn-btn-on">Connect</a>}
              </div>
            )}
            {(discordAvailable || member?.discord_username) && (
              <div class="p-conn">
                <div class="p-conn-left">
                  <span class="p-conn-icon" style="background:#5865F2">💬</span>
                  <div class="p-conn-text">
                    <strong>Discord</strong>
                    {member?.discord_username
                      ? <span>{member.discord_username}</span>
                      : <span>Not connected</span>}
                  </div>
                </div>
                {member?.discord_username
                  ? <button class="p-conn-btn p-conn-btn-off" data-disconnect="discord" type="button">Disconnect</button>
                  : <a href="/api/auth/discord?connect=1&next=/profile" class="p-conn-btn p-conn-btn-on">Connect</a>}
              </div>
            )}
          </div>
          <div id="p-conn-err" class="p-conn-err"></div>
        </section>
      )}

      <section class="p-card">
        <div class="p-card-head"><h2 class="p-h">Account</h2></div>
        <div class="p-account">
          <a href="/api/logout" class="p-account-row">
            <span>🚪 Sign out</span>
            <span class="p-account-meta">{user.email}</span>
          </a>
          {!isAdmin && (
            <button class="p-account-row p-account-danger" id="delete-btn" type="button">
              <span>🗑 Delete account</span>
              <span class="p-account-meta">Wipes everything</span>
            </button>
          )}
          {isAdmin && (
            <div class="p-account-row p-account-note">
              <span>🛡 Admin account</span>
              <span class="p-account-meta">Can't self-delete</span>
            </div>
          )}
        </div>
      </section>

    </aside>
  </div>

  <!-- DELETE MODAL -->
  <div id="delete-modal" class="modal-hidden">
    <div class="p-modal">
      <div style="font-size:32px;text-align:center;margin-bottom:16px">⚠️</div>
      <h3 class="p-modal-title">Delete your account?</h3>
      <p class="p-modal-text">This permanently deletes everything. Can't be undone.</p>
      <div class="p-modal-btns">
        <form method="POST" action="/api/delete-account">
          <button type="submit" class="p-modal-danger">Yes, delete everything</button>
        </form>
        <button id="cancel-btn" class="p-modal-cancel" type="button">Cancel</button>
      </div>
    </div>
  </div>

</div>

<style is:inline>
  .p { max-width: 1180px; margin: 0 auto; padding: 24px clamp(16px, 4vw, 40px) 80px; }

  .p-toast { padding: 12px 16px; border-radius: 12px; font-size: 13px; font-weight: 600; margin-bottom: 16px; font-family: var(--font-display); }
  .p-toast.err { background: #FEF2F2; color: #DC2626; border: 1px solid rgba(220,38,38,0.1); }
  .p-toast.ok  { background: #F0FDF4; color: #16A34A; border: 1px solid rgba(22,163,74,0.1); }

  /* ═══ COVER + HERO ═══ */
  .p-cover {
    position: relative; border-radius: 28px; overflow: hidden;
    padding: 56px clamp(24px, 5vw, 56px); margin-bottom: 20px;
    min-height: 280px;
  }
  .p-cover-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 15% 20%, rgba(124,58,237,0.55), transparent 45%),
      radial-gradient(circle at 85% 90%, rgba(59,130,246,0.5), transparent 50%),
      radial-gradient(circle at 60% 0%, rgba(16,185,129,0.35), transparent 60%),
      linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
  }
  .p-cover-pattern {
    position: absolute; inset: 0; opacity: 0.18;
    background-image:
      linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
  }
  .p-cover-inner {
    position: relative; z-index: 1;
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 32px; flex-wrap: wrap;
  }
  .p-identity { display: flex; align-items: center; gap: 24px; flex: 1; min-width: 280px; }
  .p-avatar {
    width: 104px; height: 104px; border-radius: 50%;
    background: rgba(255,255,255,0.16);
    border: 3px solid rgba(255,255,255,0.35);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 44px; font-weight: 800; color: #fff;
    flex-shrink: 0; backdrop-filter: blur(8px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }
  .p-identity-text { min-width: 0; }
  .p-eyebrow { font-family: var(--font-display); font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.75); letter-spacing: 0.02em; }
  .p-name { font-family: var(--font-display); font-size: clamp(36px, 5vw, 52px); font-weight: 900; letter-spacing: -0.03em; color: #fff; line-height: 1; margin: 2px 0 8px; }
  .p-tagline { font-size: 16px; color: rgba(255,255,255,0.85); font-weight: 500; margin-bottom: 16px; }
  .p-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .p-chip {
    font-size: 12px; padding: 6px 12px; border-radius: 999px;
    background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.95);
    font-weight: 500; border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(6px);
  }
  .p-cover-actions { display: flex; gap: 10px; flex-shrink: 0; }
  .p-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 12px 22px; border-radius: 999px;
    font-family: var(--font-display); font-weight: 700; font-size: 14px;
    text-decoration: none; border: none; cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .p-btn-light { background: #fff; color: #312e81; }
  .p-btn-light:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
  .p-btn-ghost {
    background: rgba(255,255,255,0.12); color: #fff;
    border: 1px solid rgba(255,255,255,0.25); backdrop-filter: blur(6px);
  }
  .p-btn-ghost:hover { background: rgba(255,255,255,0.20); }
