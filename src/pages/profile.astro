  .p-tag { font-size: 12px; padding: 6px 12px; border-radius: 999px; background: var(--tag-bg); color: var(--tag-text); font-weight: 500; }
  .p-edit-toggle {
    background: var(--surface); border: 1px solid var(--border); color: var(--text-sec);
    font-size: 13px; font-weight: 600; padding: 6px 14px; border-radius: 999px; cursor: pointer;
    font-family: var(--font); transition: background 0.15s, color 0.15s;
  }
  .p-edit-toggle:hover { background: var(--surface-hover); color: var(--text); }

  .p-edit-panel { margin-top: 16px; padding: 16px; background: var(--surface); border-radius: 14px; }
  .p-form { display: flex; flex-direction: column; gap: 14px; }
  .p-field { display: flex; flex-direction: column; gap: 6px; }
  .p-label { font-size: 13px; font-weight: 600; color: var(--text); }
  .p-input {
    padding: 10px 12px; border: 1px solid var(--border); border-radius: 10px;
    font-size: 14px; font-family: var(--font); color: var(--text); background: var(--bg); width: 100%;
  }
  .p-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .p-pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .p-pill-wrap { position: relative; }
  .p-pill-wrap input { position: absolute; opacity: 0; pointer-events: none; }
  .p-pill {
    display: inline-block; padding: 6px 12px; border-radius: 999px;
    background: var(--bg); border: 1px solid var(--border); font-size: 12px; cursor: pointer;
    transition: all 0.15s;
  }
  .p-pill-wrap input:checked + .p-pill { background: var(--accent); color: #fff; border-color: var(--accent); }
  .p-save {
    margin-top: 4px; padding: 12px; border-radius: 999px; background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font-display); font-weight: 700; font-size: 14px; border: none; cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .p-save:hover { transform: translateY(-1px); box-shadow: 0 4px 12px var(--accent-glow); }

  /* Linked accounts */
  .p-conn-grid { display: flex; flex-direction: column; gap: 8px; }
  .p-conn { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 12px 14px; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; }
  .p-conn-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .p-conn-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
  .p-conn-text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .p-conn-text strong { font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--text); }
  .p-conn-text span { font-size: 12px; color: var(--text-sec); }
  .p-conn-btn { font-size: 12px; font-weight: 700; padding: 6px 14px; border-radius: 999px; cursor: pointer; font-family: var(--font); text-decoration: none; }
  .p-conn-btn-on { background: var(--accent); color: #fff; border: none; }
  .p-conn-btn-off { background: var(--bg); color: var(--text-sec); border: 1px solid var(--border); }
  .p-conn-err { color: #DC2626; font-size: 12px; margin-top: 6px; }

  /* Account */
  .p-account { display: flex; flex-direction: column; gap: 8px; }
  .p-account-row {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 14px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    font-size: 14px; font-weight: 600; color: var(--text); text-align: left; font-family: var(--font);
    cursor: pointer; width: 100%;
    text-decoration: none;
  }
  .p-account-row:hover { background: var(--surface-hover); }
  .p-account-meta { font-size: 12px; color: var(--text-sec); font-weight: 500; }
  .p-account-danger { color: #DC2626; }
  .p-account-danger:hover { background: #FEF2F2; border-color: #FCA5A5; }
  .p-account-note { cursor: default; }
  .p-account-note:hover { background: var(--surface); }

  /* Modal */
  .modal-hidden { display: none; }
  #delete-modal {
    position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000;
    align-items: center; justify-content: center; padding: 20px;
  }
  #delete-modal:not(.modal-hidden) { display: flex; }
  .p-modal { background: #fff; padding: 28px; border-radius: 20px; max-width: 400px; width: 100%; }
  .p-modal-title { font-family: var(--font-display); font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 8px; }
  .p-modal-text { font-size: 14px; color: var(--text-sec); text-align: center; margin-bottom: 20px; }
  .p-modal-btns { display: flex; flex-direction: column; gap: 8px; }
  .p-modal-danger {
    padding: 12px; border-radius: 12px; background: #DC2626; color: #fff;
    border: none; font-weight: 700; cursor: pointer; width: 100%; font-family: var(--font);
  }
  .p-modal-cancel {
    padding: 12px; border-radius: 12px; background: var(--surface); color: var(--text);
    border: 1px solid var(--border); font-weight: 600; cursor: pointer; font-family: var(--font);
  }

  /* Responsive */
  @media (max-width: 920px) {
    .p-grid { grid-template-columns: 1fr; }
    .p-stats { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .p-cover { padding: 36px 24px; border-radius: 22px; min-height: 0; }
    .p-cover-inner { flex-direction: column; align-items: stretch; gap: 20px; }
    .p-cover-actions { flex-direction: column; }
    .p-btn { width: 100%; }
    .p-identity { gap: 18px; }
    .p-avatar { width: 80px; height: 80px; font-size: 34px; border-width: 2px; }
    .p-name { font-size: 32px; }
    .p-stat { padding: 16px; }
    .p-stat-big { font-size: 22px; }
    .p-card { padding: 18px; border-radius: 16px; }
  }
</style>

<script>
  const toggle = document.getElementById('editToggle');
  const panel = document.getElementById('editPanel');
  const addBio = document.getElementById('addBioBtn');
  const openEdit = () => {
    if (!panel) return;
    panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    if (panel.style.display === 'block') panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
  };
  toggle?.addEventListener('click', openEdit);
  addBio?.addEventListener('click', openEdit);

  const deleteBtn = document.getElementById('delete-btn');
  const cancelBtn = document.getElementById('cancel-btn');
  const modal = document.getElementById('delete-modal');
  deleteBtn?.addEventListener('click', () => modal?.classList.remove('modal-hidden'));
  cancelBtn?.addEventListener('click', () => modal?.classList.add('modal-hidden'));

  document.querySelectorAll('[data-disconnect]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const provider = (btn as HTMLElement).getAttribute('data-disconnect');
      if (!confirm(`Disconnect ${provider}?`)) return;
      const errEl = document.getElementById('p-conn-err');
      if (errEl) errEl.textContent = '';
      try {
        const res = await fetch('/api/auth/disconnect', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ provider }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) location.reload();
        else if (errEl) errEl.textContent = data?.error === 'last_method' ? "Can't disconnect — it's your only sign-in method." : 'Failed to disconnect.';
      } catch {
        if (errEl) errEl.textContent = 'Network error. Try again.';
      }
    });
  });
</script>
</Base>
