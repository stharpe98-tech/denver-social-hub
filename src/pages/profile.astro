---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getLevel, getNextLevel } from '../lib/levels';

const db = getDB();
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
if (!user) return Astro.redirect("/login");

let member: any = null;
let error: string|null = null;
let success = false;

if (Astro.request.method === "POST") {
  try {
    const form = await Astro.request.formData();
    const name = form.get("name")?.toString().trim();
    const bio  = form.get("bio")?.toString().trim()||"";
    const neighborhood = form.get("neighborhood")?.toString().trim()||"";
    const interests   = form.getAll("interests").join(",");
    const looking_for = form.getAll("looking_for").join(",");
    if (db && name) {
      await db.prepare("UPDATE members SET name=?,bio=?,neighborhood=?,interests=?,looking_for=? WHERE email=?").bind(name,bio,neighborhood,interests,looking_for,user.email).run();
      success = true;
    }
  } catch { error = "Failed to save. Try again."; }
}

let streak: any = null;
try {
  if (db && user?.email) {
    streak = await db.prepare("SELECT * FROM member_streaks WHERE email=?").bind(user.email).first();
    member = await db.prepare("SELECT * FROM members WHERE email=?").bind(user.email).first();
  }
} catch {}

const interestOptions = ["Food & Dining","Craft Beer","Hiking","Board Games","Live Music","Art & Culture","Bowling","Fitness","Comedy","Casino trips","Outdoor adventures","Coffee & Cafes","Trivia nights","Karaoke"];
const lookingOptions  = ["New friends","Hiking buddy","Dinner companion","Workout partner","Explore Denver","Professional networking","Just vibing"];
const myInterests = (member?.interests||"").split(",").filter(Boolean);
const myLooking   = (member?.looking_for||"").split(",").filter(Boolean);
const totalEvts = streak?.total_events||0;
const level = getLevel(totalEvts);
const next  = getNextLevel(level);
---
<Base title="My Profile">
  <div style="max-width:520px;margin:0 auto;padding:24px 20px">
    <h1 style="font-size:24px;color:#fff;margin-bottom:16px">My Profile</h1>
    {error   && <div style="background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.15);border-radius:12px;padding:12px;color:#f87171;font-size:13px;margin-bottom:12px">{error}</div>}
    {success && <div style="background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.15);border-radius:12px;padding:12px;color:#4ade80;font-size:13px;margin-bottom:12px">Profile saved!</div>}
    <div class="card" style="margin-bottom:16px">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
        <div style={`width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;background:${level.color}22;border:2px solid ${level.color}44`}>{level.emoji}</div>
        <div>
          <div style={`font-size:14px;font-weight:700;color:${level.color}`}>{level.name}</div>
          <div style="font-size:12px;color:#6b7a8e">{totalEvts} events attended</div>
        </div>
        {(streak?.current_streak||0)>=3 && <span style="margin-left:auto;font-size:12px;color:#fbbf24;font-weight:700">🔥 {streak.current_streak} streak</span>}
      </div>
      {next && (
        <div>
          <div style="display:flex;justify-content:space-between;font-size:11px;color:#6b7a8e;margin-bottom:4px">
            <span>Next: {next.emoji} {next.name}</span><span>{totalEvts}/{next.eventsRequired}</span>
          </div>
          <div style="height:4px;background:rgba(255,255,255,.06);border-radius:2px">
            <div style={`height:100%;background:${level.color};border-radius:2px;width:${Math.min(100,Math.round(totalEvts/next.eventsRequired*100))}%`}></div>
          </div>
        </div>
      )}
    </div>
    <form method="POST">
      <div class="card">
        <div style="margin-bottom:12px">
          <label style="display:block;font-size:12px;font-weight:600;color:#6b7a8e;margin-bottom:6px">Name</label>
          <input type="text" name="name" value={member?.name||user.name||''} required class="input" />
        </div>
        <div style="margin-bottom:12px">
          <label style="display:block;font-size:12px;font-weight:600;color:#6b7a8e;margin-bottom:6px">Neighborhood</label>
          <input type="text" name="neighborhood" value={member?.neighborhood||''} placeholder="RiNo, Cap Hill, LoDo..." class="input" />
        </div>
        <div style="margin-bottom:12px">
          <label style="display:block;font-size:12px;font-weight:600;color:#6b7a8e;margin-bottom:6px">Bio</label>
          <textarea name="bio" rows={3} placeholder="Tell the crew a bit about yourself..." class="input" style="resize:vertical">{member?.bio||''}</textarea>
        </div>
        <div style="margin-bottom:12px">
          <label style="display:block;font-size:12px;font-weight:600;color:#6b7a8e;margin-bottom:8px">Interests</label>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            {interestOptions.map(opt => (
              <label style="cursor:pointer">
                <input type="checkbox" name="interests" value={opt} checked={myInterests.includes(opt)} style="display:none" />
                <span class={`chip${myInterests.includes(opt)?' selected':''}`}>{opt}</span>
              </label>
            ))}
          </div>
        </div>
        <div style="margin-bottom:20px">
          <label style="display:block;font-size:12px;font-weight:600;color:#6b7a8e;margin-bottom:8px">Looking for</label>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            {lookingOptions.map(opt => (
              <label style="cursor:pointer">
                <input type="checkbox" name="looking_for" value={opt} checked={myLooking.includes(opt)} style="display:none" />
                <span class={`chip${myLooking.includes(opt)?' selected':''}`}>{opt}</span>
              </label>
            ))}
          </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Save Profile</button>
      </div>
    </form>
    <div style="margin-top:16px;display:flex;flex-direction:column;align-items:center;gap:12px">
      <a href="/api/logout" style="font-size:13px;color:#6b7a8e;text-decoration:none">Sign out</a>
      <button onclick="confirmDelete()" style="font-size:12px;color:#4a5568;background:none;border:none;cursor:pointer;text-decoration:underline">
        Delete my account
      </button>
    </div>

    <!-- Delete confirmation modal -->
    <div id="delete-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;align-items:center;justify-content:center;padding:24px">
      <div style="background:#0f1117;border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:28px;max-width:380px;width:100%">
        <div style="font-size:32px;text-align:center;margin-bottom:16px">⚠️</div>
        <h3 style="font-size:18px;color:#fff;text-align:center;margin-bottom:8px">Delete your account?</h3>
        <p style="font-size:13px;color:#6b7a8e;text-align:center;line-height:1.6;margin-bottom:24px">
          This will permanently delete your profile, RSVPs, and all your data. This cannot be undone.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px">
          <form method="POST" action="/api/delete-account">
            <button type="submit" style="width:100%;padding:14px;background:rgba(248,113,113,.15);color:#f87171;border:1.5px solid rgba(248,113,113,.3);border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif">
              Yes, delete everything
            </button>
          </form>
          <button onclick="closeDelete()" style="width:100%;padding:14px;background:rgba(255,255,255,.04);color:#6b7a8e;border:1px solid rgba(255,255,255,.08);border-radius:12px;font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">
            Cancel
          </button>
        </div>
      </div>
    </div>
  </div>
</Base>
<script>
  function confirmDelete() {
    const modal = document.getElementById('delete-modal');
    modal.style.display = 'flex';
  }
  function closeDelete() {
    const modal = document.getElementById('delete-modal');
    modal.style.display = 'none';
  }
  // Close on backdrop click
  document.getElementById('delete-modal')?.addEventListener('click', function(e) {
    if (e.target === this) closeDelete();
  });
</script>
<script>
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const input = chip.previousElementSibling as HTMLInputElement;
      input.checked = !input.checked;
      chip.classList.toggle('selected', input.checked);
    });
  });
</script>
