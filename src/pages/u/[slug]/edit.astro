    .editor-field input, .editor-field textarea { width: 100%; padding: 9px 12px; border-radius: 10px; border: 1.5px solid var(--border); font-size: 14px; background: var(--surface, #F8F9FB); font-family: inherit; }
    .color-row { display: flex; gap: 8px; }
