        function showErr(id, msg) { var el = document.getElementById(id); el.textContent = msg; el.classList.add('show'); }
        function clearErr(id) { var el = document.getElementById(id); el.textContent=''; el.classList.remove('show'); }
        document.getElementById('reauth-send').addEventListener('click', async function() {
          clearErr('reauth-send-err');
          var btn = this; btn.disabled = true; var orig = btn.textContent; btn.textContent = 'Sending…';
