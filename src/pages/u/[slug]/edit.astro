    .claim-cta:hover { filter: brightness(1.08); }
    .claim-cta:active { filter: brightness(0.95); }
    .claim-err { font-size: 13px; color: #DC2626; margin-top: var(--space-2); display: none; }
    .claim-err.show { display: block; }
    .claim-foot { font-size: 12px; color: var(--text-faint); text-align: center; margin-top: var(--space-3); }

    /* Editor */
    .editor { background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-lg, 20px); padding: var(--space-4); }
