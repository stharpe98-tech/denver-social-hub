---
import Base from '../../../layouts/Base.astro';
import { getDB } from '../../../lib/db';
import { canEditProfile, validateSlug } from '../../../lib/profile-auth';
import { PROFILE_TEMPLATES, parseTemplateData, defaultTemplateData, templateSchema } from '../../../lib/profile-templates';

const rawSlug = Astro.params.slug || '';
const v = validateSlug(rawSlug);
if (!v.ok) return Astro.redirect('/404');
const slug = v.slug;

const db = getDB();
if (!db) return new Response('DB unavailable', { status: 500 });

let profile: any = null;
try {
  profile = await db.prepare(
    `SELECT slug, display_name, email, headline, bio, photo_emoji, accent_color,
            offers_json, links_json, contact_email, contact_phone, neighborhood,
            template, template_data, cover_photo_url, avatar_photo_url, status, tier
     FROM profiles WHERE slug = ?`
  ).bind(slug).first();
} catch {
  profile = await db.prepare(
    `SELECT slug, display_name, email, headline, bio, photo_emoji, accent_color,
            offers_json, links_json, contact_email, contact_phone, status
     FROM profiles WHERE slug = ?`
  ).bind(slug).first();
}

if (!profile) return new Response('Not found', { status: 404 });

const authed = await canEditProfile(Astro.cookies, slug);
const isOrganizer = (profile.tier || '') === 'organizer';

// Load bookable offerings + per-offering availability for the booking settings panel.
let bookableOfferings: any[] = [];
let availabilityByOffering: Record<string, any[]> = {};
if (authed && isOrganizer) {
  try {
    const { ensureBookingsSchema } = await import('../../../lib/bookings-schema');
    await ensureBookingsSchema(db);
    bookableOfferings = ((await db.prepare(
      `SELECT id, title, description, duration_min, price_text, capacity_per_slot, archived
       FROM bookable_offerings WHERE profile_slug=? ORDER BY archived ASC, id ASC`
    ).bind(slug).all())?.results || []) as any[];
    if (bookableOfferings.length) {
      const ids = bookableOfferings.map(o => o.id);
      const rules = ((await db.prepare(
        `SELECT id, offering_id, day_of_week, start_time, end_time
         FROM offering_availability WHERE offering_id IN (${ids.map(() => '?').join(',')})
         ORDER BY day_of_week, start_time`
      ).bind(...ids).all())?.results || []) as any[];
      for (const r of rules) {
        const k = String(r.offering_id);
        if (!availabilityByOffering[k]) availabilityByOffering[k] = [];
        availabilityByOffering[k].push(r);
      }
    }
  } catch {}
}

let offers: Array<{ icon?: string; label: string }> = [];
let links: Array<{ icon?: string; label: string; url: string }> = [];
try { const a = JSON.parse(profile.offers_json || '[]'); if (Array.isArray(a)) offers = a; } catch {}
try { const a = JSON.parse(profile.links_json || '[]'); if (Array.isArray(a)) links = a; } catch {}

// Masked email hint for the re-auth screen
const e = profile.email || '';
const atIdx = e.indexOf('@');
const maskedEmail = atIdx > 1 ? e[0] + '***' + e.slice(atIdx - 1) : e;

const accent = /^#[0-9A-Fa-f]{6}$/.test(profile.accent_color || '') ? profile.accent_color : '#7C3AED';
const currentTemplate = (profile.template || 'host').toString();
const templateData = parseTemplateData(profile.template_data);
const templateDataJson = JSON.stringify(templateData);
const SWATCHES = [
  { name: 'purple', hex: '#7C3AED' },
  { name: 'blue',   hex: '#3B82F6' },
  { name: 'green',  hex: '#10B981' },
  { name: 'orange', hex: '#F59E0B' },
  { name: 'pink',   hex: '#EC4899' },
];
---
<Base title={`Edit /u/${slug}`} description="Edit your Denver Social page.">
  <div class="wrap">
    {!authed ? (
      <div class="claim-box">
        <h3 class="claim-h">Edit /u/{slug}</h3>
        <p class="claim-sub">We'll send a code to the email on file ({maskedEmail}).</p>
        <div id="reauth-step1">
          <button class="claim-cta" id="reauth-send">Send me a code</button>
          <div class="claim-err" id="reauth-send-err"></div>
        </div>
        <div id="reauth-step2" hidden>
          <div class="claim-field" style="margin-top:16px">
            <label>6-digit code</label>
            <input id="reauth-code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" placeholder="••••••"/>
          </div>
          <input id="reauth-email" type="email" placeholder="Email on file" autocomplete="email"/>
          <button class="claim-cta" id="reauth-verify" style="margin-top:8px">Verify & edit →</button>
          <button class="claim-link" id="reauth-resend" type="button" style="margin-top:6px">Send me a new code</button>
          <div class="claim-err" id="reauth-verify-err"></div>
          <div class="claim-ok" id="reauth-resend-ok" hidden style="color:#047857;font-size:12px;margin-top:6px">✓ New code sent.</div>
        </div>
        <div class="claim-foot"><a href={`/u/${slug}`} style="color:var(--text-sec)">← View public page</a></div>
      </div>
    ) : (
      <div class="editor" data-slug={slug}>
        <div class="editor-toolbar">
          <span class="editor-status" id="editor-status">● Saved</span>
          <a href={`/u/${slug}`} class="editor-preview" target="_blank">👁 Preview public page</a>
          <a href="#" class="editor-out" id="editor-out">Sign out of editor</a>
        </div>

        <!-- Essentials (always visible) -->
        <div class="editor-field">
          <label>Photos</label>
          <div class="photos-row">
            <div class="photo-card" data-kind="cover">
              <div class="photo-card-label">Cover photo</div>
              <div class="photo-preview cover-preview" id="cover-preview" data-empty={profile.cover_photo_url ? 'false' : 'true'}>
                {profile.cover_photo_url
                  ? <img src={profile.cover_photo_url} alt="Cover preview" id="cover-img"/>
                  : <span class="photo-empty">No cover yet</span>}
              </div>
              <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" id="cover-file" hidden/>
              <div class="photo-actions">
                <button type="button" class="photo-btn" id="cover-choose">Choose photo</button>
                <button type="button" class="photo-rm" id="cover-remove" hidden={!profile.cover_photo_url}>× Remove</button>
              </div>
              <div class="photo-err" id="cover-err"></div>
            </div>
            <div class="photo-card" data-kind="avatar">
              <div class="photo-card-label">Avatar photo</div>
              <div class="photo-preview avatar-preview" id="avatar-preview" data-empty={profile.avatar_photo_url ? 'false' : 'true'}>
                {profile.avatar_photo_url
                  ? <img src={profile.avatar_photo_url} alt="Avatar preview" id="avatar-img"/>
                  : <span class="photo-empty">No avatar yet</span>}
              </div>
              <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" id="avatar-file" hidden/>
              <div class="photo-actions">
                <button type="button" class="photo-btn" id="avatar-choose">Choose photo</button>
                <button type="button" class="photo-rm" id="avatar-remove" hidden={!profile.avatar_photo_url}>× Remove</button>
              </div>
              <div class="photo-err" id="avatar-err"></div>
            </div>
          </div>
          <div class="photo-help">Cover: wide banner image (recommended 1400×400). Avatar: square (300×300). Max 5 MB · JPEG, PNG, WebP, or GIF.</div>
        </div>

        <div class="editor-field"><label>Display name</label>
          <input data-field="display_name" type="text" value={profile.display_name || ''} maxlength="80"/>
        </div>

        <div class="editor-field"><label>Photo / avatar emoji</label>
          <input data-field="photo_emoji" type="text" value={profile.photo_emoji || '👤'} maxlength="16"/>
        </div>

        <div class="editor-field"><label>Bio</label>
          <textarea data-field="bio" rows="4" maxlength="2000" placeholder="Who you are, where you are, what you're up to.">{profile.bio || ''}</textarea>
        </div>

        <div class="editor-field two">
          <div><label>Email shown after Reveal</label>
            <input data-field="contact_email" type="email" value={profile.contact_email || ''} maxlength="120"/>
          </div>
          <div><label>Phone shown after Reveal</label>
            <input data-field="contact_phone" type="text" value={profile.contact_phone || ''} maxlength="40"/>
          </div>
        </div>

        <div class="editor-field"><label>Neighborhood</label>
          <input data-field="neighborhood" type="text" value={profile.neighborhood || ''} maxlength="80" placeholder="Wash Park, Cap Hill, etc."/>
        </div>

        <!-- Template settings — open by default for organizers (templates are core to their page) -->
        <details class="more" open={isOrganizer}>
          <summary>Page template &amp; styling</summary>

          <div class="editor-field"><label>Page template</label>
            <div class="tpl-grid" id="tpl-grid">
              {PROFILE_TEMPLATES.map(t => (
                <button type="button" class:list={["tpl-card", { 'tpl-active': t.key === currentTemplate }]} data-tpl={t.key}>
                  <span class="tpl-emoji">{t.emoji}</span>
                  <span class="tpl-label">{t.label}</span>
                </button>
              ))}
            </div>
            <div class="tpl-hint">Switch any time. Each template surfaces its own extra fields below.</div>
          </div>

          <div class="editor-field"><label>Accent color</label>
            <div class="color-row" id="color-row" data-accent={accent}>
              {SWATCHES.map(s => (
                <span class:list={["swatch", `swatch-${s.name}`, { 'swatch-active': s.hex.toLowerCase() === accent.toLowerCase() }]}
                      data-hex={s.hex} role="button" tabindex="0" aria-label={`Accent ${s.name}`}></span>
              ))}
            </div>
          </div>

          <div class="editor-field"><label>Headline</label>
            <input data-field="headline" type="text" value={profile.headline || ''} maxlength="140" placeholder="What you do, in one line"/>
          </div>

          <div class="editor-field" id="tpl-data-section">
            <label id="tpl-form-heading">Fields for this template</label>
            <div class="tpl-data-help" id="tpl-data-help"></div>
            <div id="tpl-form"></div>
            <details class="tpl-raw">
              <summary>Show raw JSON</summary>
              <textarea id="tpl-data-textarea" rows="10" maxlength="4000" spellcheck="false">{templateDataJson}</textarea>
              <div class="tpl-data-row">
                <span class="tpl-data-status" id="tpl-data-status"></span>
              </div>
            </details>
          </div>
        </details>

        <!-- Advanced: offers + links -->
        <details class="more">
          <summary>Show offers + links</summary>

          <div class="editor-section" id="offers-section">
            <label>What you offer</label>
            <div id="offers-list">
              {offers.map((o, i) => (
                <div class="editor-offer" data-offer-idx={i}>
                  <input class="offer-icon" value={o.icon || ''} placeholder="🏠" maxlength="4"/>
                  <input class="offer-label" value={o.label || ''} placeholder="What you offer" maxlength="120"/>
                  <button class="x" type="button" data-action="remove-offer">×</button>
                </div>
              ))}
            </div>
            <button class="add" type="button" id="add-offer">+ Add an offer</button>
          </div>

          <div class="editor-section" id="links-section">
            <label>Links</label>
            <div id="links-list">
              {links.map((l, i) => (
                <div class="editor-offer" data-link-idx={i}>
                  <input class="link-icon" value={l.icon || ''} placeholder="🌐" maxlength="4"/>
                  <input class="link-label" value={l.label || ''} placeholder="Label" maxlength="40"/>
                  <input class="link-url" value={l.url || ''} placeholder="https://…" maxlength="300"/>
                  <button class="x" type="button" data-action="remove-link">×</button>
                </div>
              ))}
            </div>
            <button class="add" type="button" id="add-link">+ Add a link</button>
          </div>
        </details>

        {isOrganizer && (
          <details class="more">
            <summary>Show booking settings</summary>
            <div class="editor-field">
              <label>Bookable offerings</label>
              <div class="bk-help">Define sessions visitors can book. Each offering has its own weekly availability windows. <a href={`/u/${slug}/bookings`} target="_blank">Open bookings dashboard ↗</a></div>
              <div id="bk-offerings-list">
                {bookableOfferings.map(o => (
                  <div class="bk-offering" data-offering-id={o.id} data-archived={o.archived ? '1' : '0'}>
                    <div class="bk-offering-head">
                      <input class="bk-off-title-in" data-bk-field="title" value={o.title || ''} maxlength="120" placeholder="e.g. 30-min consult"/>
                      <button type="button" class="bk-off-x" data-action="archive-offering" title={o.archived ? 'Unarchive' : 'Archive'}>{o.archived ? '↺' : '×'}</button>
                    </div>
                    {o.archived ? <div class="bk-archived-tag">Archived</div> : null}
                    <div class="bk-off-grid">
                      <label>Duration (min)<input type="number" class="bk-off-num" data-bk-field="duration_min" value={o.duration_min} min="5" max="480"/></label>
                      <label>Price (text)<input type="text" class="bk-off-num" data-bk-field="price_text" value={o.price_text || ''} maxlength="60" placeholder="$45 or Free"/></label>
                      <label>Capacity / slot<input type="number" class="bk-off-num" data-bk-field="capacity_per_slot" value={o.capacity_per_slot} min="1" max="100"/></label>
                    </div>
                    <label class="bk-desc-label">Description<textarea class="bk-off-desc" data-bk-field="description" rows="2" maxlength="2000" placeholder="What's included?">{o.description || ''}</textarea></label>

                    <div class="bk-avail">
                      <div class="bk-avail-h">Weekly availability (Denver / MT)</div>
                      <div class="bk-rules" data-rules-for={o.id}>
                        {(availabilityByOffering[String(o.id)] || []).map(r => (
                          <div class="bk-rule" data-rule-id={r.id}>
                            <span class="bk-rule-dow">{['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][r.day_of_week]}</span>
                            <span class="bk-rule-time">{r.start_time} – {r.end_time}</span>
                            <button type="button" class="bk-rule-x" data-action="delete-rule">×</button>
                          </div>
                        ))}
                      </div>
                      <div class="bk-rule-add">
                        <select class="bk-add-dow">
                          <option value="0">Sun</option><option value="1">Mon</option><option value="2">Tue</option>
                          <option value="3">Wed</option><option value="4">Thu</option><option value="5">Fri</option>
                          <option value="6">Sat</option>
                        </select>
                        <input type="time" class="bk-add-start" value="09:00"/>
                        <span>→</span>
                        <input type="time" class="bk-add-end" value="17:00"/>
                        <button type="button" class="bk-add-rule" data-action="add-rule">+ Add window</button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <button class="add" type="button" id="bk-add-offering">+ Add offering</button>
              <div class="bk-status" id="bk-status"></div>
            </div>
          </details>
        )}
      </div>
    )}
  </div>

  {authed && (
    <script is:inline define:vars={{ slug, currentTemplate, initialTemplateData: templateData, templateExamples: Object.fromEntries(PROFILE_TEMPLATES.map(t => [t.key, defaultTemplateData(t.key)])), templateLabels: Object.fromEntries(PROFILE_TEMPLATES.map(t => [t.key, t.label])), templateSchemas: Object.fromEntries(PROFILE_TEMPLATES.map(t => [t.key, templateSchema(t.key)])) }}>
      (function() {
        var status = document.getElementById('editor-status');
        function setStatus(s, color) {
          status.textContent = s;
          status.style.color = color || '#047857';
        }
        function setSaving() { setStatus('● Saving…', '#6B7280'); }
        function setSaved() { setStatus('● Saved', '#047857'); }
        function setError(e) { setStatus('● Error: ' + e, '#DC2626'); }

        async function save(field, value) {
          setSaving();
          try {
            var r = await fetch('/api/profile/save', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug: slug, field: field, value: value })
            });
            var d = await r.json();
            if (d.ok) setSaved(); else setError(d.error || 'save failed');
          } catch (e) { setError('network'); }
        }

        // Wire all data-field inputs
        document.querySelectorAll('[data-field]').forEach(function(el) {
          el.addEventListener('blur', function() {
            save(el.getAttribute('data-field'), el.value);
          });
        });

        // Swatches
        var row = document.getElementById('color-row');
        row.querySelectorAll('.swatch').forEach(function(sw) {
          sw.addEventListener('click', function() {
            row.querySelectorAll('.swatch').forEach(function(s){ s.classList.remove('swatch-active'); });
            sw.classList.add('swatch-active');
            save('accent_color', sw.getAttribute('data-hex'));
          });
        });

        // Offers list
        function readOffers() {
          var rows = document.querySelectorAll('#offers-list .editor-offer');
          var out = [];
          rows.forEach(function(r) {
            var icon = r.querySelector('.offer-icon').value.trim();
            var label = r.querySelector('.offer-label').value.trim();
            if (icon || label) out.push({ icon: icon, label: label });
          });
          return out;
        }
        function saveOffers() { save('offers_json', JSON.stringify(readOffers())); }

        function attachOfferRow(r) {
          r.querySelectorAll('input').forEach(function(i){ i.addEventListener('blur', saveOffers); });
          var rm = r.querySelector('[data-action=remove-offer]');
          if (rm) rm.addEventListener('click', function() { r.remove(); saveOffers(); });
        }
        document.querySelectorAll('#offers-list .editor-offer').forEach(attachOfferRow);
        document.getElementById('add-offer').addEventListener('click', function() {
          var d = document.createElement('div');
          d.className = 'editor-offer';
          d.innerHTML = '<input class="offer-icon" placeholder="🏠" maxlength="4"/><input class="offer-label" placeholder="What you offer" maxlength="120"/><button class="x" type="button" data-action="remove-offer">×</button>';
          document.getElementById('offers-list').appendChild(d);
          attachOfferRow(d);
          d.querySelector('.offer-icon').focus();
        });

        // Links list
        function readLinks() {
          var rows = document.querySelectorAll('#links-list .editor-offer');
          var out = [];
          rows.forEach(function(r) {
            var icon = r.querySelector('.link-icon').value.trim();
            var label = r.querySelector('.link-label').value.trim();
            var url = r.querySelector('.link-url').value.trim();
            if (label || url) out.push({ icon: icon, label: label, url: url });
          });
          return out;
        }
        function saveLinks() { save('links_json', JSON.stringify(readLinks())); }
        function attachLinkRow(r) {
          r.querySelectorAll('input').forEach(function(i){ i.addEventListener('blur', saveLinks); });
          var rm = r.querySelector('[data-action=remove-link]');
          if (rm) rm.addEventListener('click', function() { r.remove(); saveLinks(); });
        }
        document.querySelectorAll('#links-list .editor-offer').forEach(attachLinkRow);
        document.getElementById('add-link').addEventListener('click', function() {
          var d = document.createElement('div');
          d.className = 'editor-offer';
          d.innerHTML = '<input class="link-icon" placeholder="🌐" maxlength="4"/><input class="link-label" placeholder="Label" maxlength="40"/><input class="link-url" placeholder="https://…" maxlength="300"/><button class="x" type="button" data-action="remove-link">×</button>';
          document.getElementById('links-list').appendChild(d);
          attachLinkRow(d);
          d.querySelector('.link-icon').focus();
        });

        // Template data state — single source of truth
        var tplState = (initialTemplateData && typeof initialTemplateData === 'object') ? initialTemplateData : {};
        var activeTplKey = currentTemplate || 'host';
        var tplTa = document.getElementById('tpl-data-textarea');
        var tplStatus = document.getElementById('tpl-data-status');
        var saveTimer = null;

        function scheduleSave() {
          if (saveTimer) clearTimeout(saveTimer);
          setSaving();
          saveTimer = setTimeout(function() {
            var json = JSON.stringify(tplState);
            if (tplTa) tplTa.value = json;
            save('template_data', json);
          }, 500);
        }

        // Form renderer
        function el(tag, attrs, children) {
          var n = document.createElement(tag);
          if (attrs) for (var k in attrs) {
            if (k === 'class') n.className = attrs[k];
            else if (k === 'text') n.textContent = attrs[k];
            else n.setAttribute(k, attrs[k]);
          }
          if (children) children.forEach(function(c){ if (c) n.appendChild(c); });
          return n;
        }

        function renderField(field, value, onChange) {
          var wrap = el('div', { class: 'tf-field' });
          var label = el('label', { class: 'tf-label', text: field.label });
          wrap.appendChild(label);
          if (field.help) wrap.appendChild(el('div', { class: 'tf-help', text: field.help }));

          if (field.type === 'text' || field.type === 'url' || field.type === 'number') {
            var input = document.createElement('input');
            input.type = field.type === 'number' ? 'number' : (field.type === 'url' ? 'url' : 'text');
            if (field.placeholder) input.placeholder = field.placeholder;
            input.value = value == null ? '' : String(value);
            input.className = 'tf-input';
            input.addEventListener('input', function() {
              var v = input.value;
              if (field.type === 'number') {
                if (v === '') { onChange(undefined); }
                else { var n = Number(v); onChange(isNaN(n) ? v : n); }
              } else {
                onChange(v);
              }
            });
            wrap.appendChild(input);
          } else if (field.type === 'textarea') {
            var ta = document.createElement('textarea');
            ta.rows = 3;
            if (field.placeholder) ta.placeholder = field.placeholder;
            ta.value = value == null ? '' : String(value);
            ta.className = 'tf-input';
            ta.addEventListener('input', function() { onChange(ta.value); });
            wrap.appendChild(ta);
          } else if (field.type === 'string-array') {
            var inp = document.createElement('input');
            inp.type = 'text';
            if (field.placeholder) inp.placeholder = field.placeholder;
            inp.value = Array.isArray(value) ? value.join(', ') : (value == null ? '' : String(value));
            inp.className = 'tf-input';
            inp.addEventListener('input', function() {
              var parts = inp.value.split(',').map(function(s){ return s.trim(); }).filter(function(s){ return s.length > 0; });
              onChange(parts);
            });
            wrap.appendChild(inp);
          } else if (field.type === 'object') {
            var obj = (value && typeof value === 'object' && !Array.isArray(value)) ? value : {};
            var card = el('div', { class: 'tf-obj' });
            (field.fields || []).forEach(function(sub) {
              card.appendChild(renderField(sub, obj[sub.key], function(v) {
                if (v === undefined || v === '' || (Array.isArray(v) && v.length === 0)) { delete obj[sub.key]; }
                else { obj[sub.key] = v; }
                onChange(Object.keys(obj).length ? obj : undefined);
              }));
            });
            wrap.appendChild(card);
          } else if (field.type === 'object-array') {
            var arr = Array.isArray(value) ? value.slice() : [];
            var listEl = el('div', { class: 'tf-list' });
            var addBtn = el('button', { type: 'button', class: 'add' });
            addBtn.textContent = '+ Add another';

            function commit() {
              onChange(arr.length ? arr : undefined);
              redraw();
            }
            function redraw() {
              listEl.innerHTML = '';
              arr.forEach(function(row, idx) {
                var rowEl = el('div', { class: 'tf-row' });
                var rmBtn = el('button', { type: 'button', class: 'tf-rm' });
                rmBtn.textContent = '× Remove';
                rmBtn.addEventListener('click', function() {
                  arr.splice(idx, 1);
                  commit();
                });
                rowEl.appendChild(rmBtn);
                (field.fields || []).forEach(function(sub) {
                  rowEl.appendChild(renderField(sub, row[sub.key], function(v) {
                    if (v === undefined || v === '' || (Array.isArray(v) && v.length === 0)) { delete row[sub.key]; }
                    else { row[sub.key] = v; }
                    onChange(arr.length ? arr : undefined);
                  }));
                });
                listEl.appendChild(rowEl);
              });
              addBtn.disabled = !!(field.max && arr.length >= field.max);
            }
            addBtn.addEventListener('click', function() {
              if (field.max && arr.length >= field.max) return;
              arr.push({});
              commit();
            });
            redraw();
            wrap.appendChild(listEl);
            wrap.appendChild(addBtn);
          }
          return wrap;
        }

        function renderTemplateForm() {
          var container = document.getElementById('tpl-form');
          var heading = document.getElementById('tpl-form-heading');
          var help = document.getElementById('tpl-data-help');
          if (!container) return;
          container.innerHTML = '';
          var schema = templateSchemas[activeTplKey] || [];
          var label = templateLabels[activeTplKey] || activeTplKey;
          if (heading) heading.textContent = 'Fields for the ' + label + ' template';
          if (help) {
            help.textContent = schema.length
              ? 'Fill in only what applies — empty fields stay hidden on your page.'
              : 'This template uses only the universal fields above (name, bio, photo, events).';
          }
          schema.forEach(function(field) {
            container.appendChild(renderField(field, tplState[field.key], function(v) {
              if (v === undefined || v === '' || (Array.isArray(v) && v.length === 0)) { delete tplState[field.key]; }
              else { tplState[field.key] = v; }
              scheduleSave();
            }));
          });
          if (tplTa) tplTa.value = JSON.stringify(tplState);
        }

        // Template picker
        var tplGrid = document.getElementById('tpl-grid');
        if (tplGrid) {
          tplGrid.querySelectorAll('.tpl-card').forEach(function(card) {
            card.addEventListener('click', function() {
              var key = card.getAttribute('data-tpl');
              tplGrid.querySelectorAll('.tpl-card').forEach(function(c){ c.classList.remove('tpl-active'); });
              card.classList.add('tpl-active');
              activeTplKey = key;
              save('template', key);
              renderTemplateForm();
            });
          });
        }

        renderTemplateForm();

        // Raw JSON power-user edit
        if (tplTa) {
          tplTa.addEventListener('blur', function() {
            var raw = tplTa.value.trim() || '{}';
            var parsed;
            try { parsed = JSON.parse(raw); } catch (e) {
              if (tplStatus) { tplStatus.textContent = '✗ Invalid JSON'; tplStatus.style.color = '#DC2626'; }
              return;
            }
            if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
              if (tplStatus) { tplStatus.textContent = '✗ Must be a JSON object'; tplStatus.style.color = '#DC2626'; }
              return;
            }
            if (tplStatus) { tplStatus.textContent = ''; }
            tplState = parsed;
            renderTemplateForm();
            scheduleSave();
          });
        }

        // Photos
        function wirePhoto(kind) {
          var fileIn = document.getElementById(kind + '-file');
          var chooseBtn = document.getElementById(kind + '-choose');
          var removeBtn = document.getElementById(kind + '-remove');
          var preview = document.getElementById(kind + '-preview');
          var errEl = document.getElementById(kind + '-err');
          if (!fileIn || !chooseBtn || !preview) return;

          function setErr(msg) { if (errEl) { errEl.textContent = msg || ''; errEl.style.display = msg ? 'block' : 'none'; } }

          chooseBtn.addEventListener('click', function() { setErr(''); fileIn.click(); });

          fileIn.addEventListener('change', async function() {
            var f = fileIn.files && fileIn.files[0];
            if (!f) return;
            if (f.size > 5 * 1024 * 1024) { setErr('Too large (max 5 MB).'); fileIn.value = ''; return; }
            if (!/^image\//.test(f.type)) { setErr('Not an image.'); fileIn.value = ''; return; }
            var allowed = ['image/jpeg','image/png','image/webp','image/gif'];
            if (allowed.indexOf(f.type) === -1) { setErr('Use JPEG, PNG, WebP, or GIF.'); fileIn.value = ''; return; }
            setSaving();
            var fd = new FormData();
            fd.append('slug', slug);
            fd.append('kind', kind);
            fd.append('file', f);
            try {
              var r = await fetch('/api/profile/upload', { method: 'POST', body: fd });
              var d = await r.json();
              if (!d.ok) { setError(d.error || 'Upload failed'); setErr(d.error || 'Upload failed'); return; }
              preview.setAttribute('data-empty', 'false');
              preview.innerHTML = '<img src="' + d.url + '" alt="' + kind + ' preview" id="' + kind + '-img"/>';
              if (removeBtn) removeBtn.hidden = false;
              setSaved();
            } catch (e) { setError('network'); setErr('Network error.'); }
            fileIn.value = '';
          });

          if (removeBtn) {
            removeBtn.addEventListener('click', async function() {
              setSaving();
              var fd = new FormData();
              fd.append('slug', slug);
              fd.append('kind', kind);
              fd.append('action', 'delete');
              try {
                var r = await fetch('/api/profile/upload', { method: 'POST', body: fd });
                var d = await r.json();
                if (!d.ok) { setError(d.error || 'Delete failed'); setErr(d.error || 'Delete failed'); return; }
                preview.setAttribute('data-empty', 'true');
                preview.innerHTML = '<span class="photo-empty">No ' + kind + ' yet</span>';
                removeBtn.hidden = true;
                setErr('');
                setSaved();
              } catch (e) { setError('network'); setErr('Network error.'); }
            });
          }
        }
        wirePhoto('cover');
        wirePhoto('avatar');

        // Sign out
        document.getElementById('editor-out').addEventListener('click', async function(e) {
          e.preventDefault();
          await fetch('/api/profile/logout', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: slug })
          });
          location.href = '/u/' + slug;
        });

        // ============= Booking settings =============
        var bkRoot = document.getElementById('bk-offerings-list');
        var bkStatus = document.getElementById('bk-status');
        function setBkStatus(msg, color) {
          if (!bkStatus) return;
          bkStatus.textContent = msg;
          bkStatus.style.color = color || '#047857';
        }

        async function bkFetch(action, payload) {
          var url = '/api/bookings/' + action;
          var r = await fetch(url, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          return r.json();
        }

        function wireOfferingRow(row) {
          var id = parseInt(row.dataset.offeringId, 10);
          row.querySelectorAll('[data-bk-field]').forEach(function(inp) {
            inp.addEventListener('blur', async function() {
              var field = inp.getAttribute('data-bk-field');
              var val = inp.value;
              if (field === 'duration_min' || field === 'capacity_per_slot') val = parseInt(val, 10);
              setBkStatus('Saving…', '#6B7280');
              var payload = { action: 'update', id: id, slug: slug };
              payload[field] = val;
              var d = await bkFetch('offerings', payload);
              if (d && d.ok) setBkStatus('Saved', '#047857');
              else setBkStatus(d && d.error || 'Save failed', '#DC2626');
            });
          });
          var x = row.querySelector('[data-action=archive-offering]');
          if (x) x.addEventListener('click', async function() {
            var isArchived = row.dataset.archived === '1';
            if (!isArchived && !confirm('Archive this offering? It will stop appearing on your booking page.')) return;
            var d = await bkFetch('offerings', { action: isArchived ? 'unarchive' : 'archive', id: id, slug: slug });
            if (d && d.ok) location.reload();
            else setBkStatus(d && d.error || 'Failed', '#DC2626');
          });
          // Add rule
          var addBtn = row.querySelector('[data-action=add-rule]');
          if (addBtn) addBtn.addEventListener('click', async function() {
            var dow = parseInt(row.querySelector('.bk-add-dow').value, 10);
            var startT = row.querySelector('.bk-add-start').value;
            var endT = row.querySelector('.bk-add-end').value;
            if (!startT || !endT || startT >= endT) { setBkStatus('End must be after start', '#DC2626'); return; }
            var d = await bkFetch('availability', { action: 'create', offering_id: id, day_of_week: dow, start_time: startT, end_time: endT });
            if (d && d.ok) location.reload();
            else setBkStatus(d && d.error || 'Failed', '#DC2626');
          });
          // Delete rule
          row.querySelectorAll('[data-action=delete-rule]').forEach(function(btn) {
            btn.addEventListener('click', async function() {
              var ruleRow = btn.closest('.bk-rule');
              var rid = parseInt(ruleRow.dataset.ruleId, 10);
              if (!confirm('Remove this availability window?')) return;
              var d = await bkFetch('availability', { action: 'delete', id: rid });
              if (d && d.ok) ruleRow.remove();
              else setBkStatus(d && d.error || 'Failed', '#DC2626');
            });
          });
        }

        if (bkRoot) {
          bkRoot.querySelectorAll('.bk-offering').forEach(wireOfferingRow);
          var addOff = document.getElementById('bk-add-offering');
          if (addOff) addOff.addEventListener('click', async function() {
            var title = prompt('Name this offering (e.g. "30-min consult"):');
            if (!title || !title.trim()) return;
            setBkStatus('Creating…', '#6B7280');
            var d = await bkFetch('offerings', { action: 'create', slug: slug, title: title.trim(), duration_min: 30, capacity_per_slot: 1 });
            if (d && d.ok) location.reload();
            else setBkStatus(d && d.error || 'Failed', '#DC2626');
          });
        }
      })();
    </script>
  )}
  {!authed && (
    <script is:inline define:vars={{ slug }}>
      (function() {
        var step1 = document.getElementById('reauth-step1');
