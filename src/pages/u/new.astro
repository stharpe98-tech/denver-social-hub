---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';
import { getCurrentProfile } from '../../lib/profile-auth';

const db = getDB();
const me = db ? await getCurrentProfile(Astro.cookies, db, Astro.request) : null;
// Pre-fill email for existing regulars so they don't re-auth.
const prefillEmail = me && me.tier === 'regular' ? me.email : '';
const isUpgrade = !!(me && me.tier === 'regular');
const oldSlug = me ? me.slug : '';
---
<Base title="Claim your page — Denver Social" description="Get your own page on Denver Social. Free, takes 2 minutes.">
  <div class="wrap">

    <header class="intro">
      <div class="intro-tag">{isUpgrade ? 'UPGRADE TO ORGANIZER' : 'SIGN UP · ORGANIZER'}</div>
      <h1 class="intro-h1">{isUpgrade ? 'Add a public page to your account.' : 'Your own page on Denver Social.'}</h1>
      <p class="intro-deck">A free, simple page for anyone in Denver with skills, services, or something to share. Pick a URL, pick a color, write a few sentences about what you do, and people can find you.</p>
      <p class="intro-deck" style="margin-top:12px;font-size:14px;"><a href="/profile/new" style="color:var(--accent,#7C3AED)">← What's an organizer page? See both options</a></p>
    </header>

    <section class="who">
      <div class="who-row">
        <div class="who-card">
          <div class="who-emoji">🏠</div>
          <div class="who-h">Realtors & agents</div>
          <p>"Show what neighborhoods you cover, host free buyer meetups, drop your calendar link."</p>
        </div>
        <div class="who-card">
          <div class="who-emoji">🧘</div>
          <div class="who-h">Coaches & instructors</div>
          <p>"Yoga, fitness, music, art, language. List what you teach, link your class schedule."</p>
        </div>
        <div class="who-card">
          <div class="who-emoji">🛠</div>
          <div class="who-h">Makers & freelancers</div>
          <p>"Show your craft, your hours, your prices. Be reachable by neighbors who need you."</p>
        </div>
        <div class="who-card">
          <div class="who-emoji">🐕</div>
          <div class="who-h">Helpers & hustlers</div>
          <p>"Dog-walkers, sitters, tutors, handy folk. Build a tiny local reputation."</p>
        </div>
      </div>
    </section>

    <section class="how">
      <h2 class="how-h">How it works</h2>
      <ol class="how-steps">
        <li><span class="how-num">1</span><div><strong>Pick a URL.</strong> It'll live at <span class="mono">denversocialhub.com/u/yourname</span>. Lowercase letters, numbers, hyphens.</div></li>
        <li><span class="how-num">2</span><div><strong>Get a code.</strong> Enter your email, we send a 6-digit code. No password to remember.</div></li>
        <li><span class="how-num">3</span><div><strong>Fill out your page.</strong> Name, headline, bio, what you offer, links, contact info. Autosaves as you type.</div></li>
        <li><span class="how-num">4</span><div><strong>Share it.</strong> That's it. Your page is live. Edit anytime by sending yourself a new code.</div></li>
      </ol>
    </section>

    <section class="terms">
      <h3 class="terms-h">A few ground rules</h3>
      <ul>
        <li>Be a real person. No impersonation, no fake businesses.</li>
        <li>Skills, services, events, community — yes. Pure ads or affiliate links — no.</li>
        <li>If your page gets reported, we'll review it. Bad-faith pages get taken offline.</li>
        <li>Your email is never shown publicly. Your contact info shows only after a visitor clicks "Get in touch."</li>
      </ul>
    </section>

    <div class="form-anchor"></div>
    <div class="claim-box" id="step-claim">
      <h3 class="claim-h">Ready? Let's go.</h3>
      <p class="claim-sub">Two fields. Two minutes.</p>
      <div class="claim-field">
        <label>Pick your URL</label>
        <div class="slug-row">
          <span class="slug-prefix">denversocialhub.com/u/</span>
          <input id="slug" type="text" placeholder="jimmy" autocomplete="off" maxlength="30"/>
        </div>
        <div class="slug-check" id="slug-check"></div>
      </div>
      <div class="claim-field">
        <label>Your email <span class="opt">(we'll send a code, won't show publicly)</span></label>
        <input id="email" type="email" placeholder="you@example.com" value={prefillEmail} readonly={isUpgrade}/>
        {isUpgrade && <div class="slug-check" style="color:#047857">✓ using your saved account email</div>}
      </div>
      {isUpgrade && <input type="hidden" id="upgrade-old-slug" value={oldSlug}/>}
      <button class="claim-cta" id="send-btn">Send me a code →</button>
      <div class="claim-err" id="send-err"></div>
      <div class="claim-foot">By claiming a page you agree to keep it real — no spam, no impersonation. Page reviewed if reported.</div>
    </div>

    <div class="claim-box" id="step-verify" hidden>
      <h3 class="claim-h">Enter your code</h3>
      <p class="claim-sub" id="verify-sub">Check your email for a 6-digit code.</p>
      <div class="claim-field">
        <label>6-digit code</label>
        <input id="code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" placeholder="••••••"/>
      </div>
      <button class="claim-cta" id="verify-btn">Verify & start editing →</button>
      <button class="claim-link" id="back-btn" type="button">Use a different email/URL</button>
      <div class="claim-err" id="verify-err"></div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var slugInput = document.getElementById('slug');
      var emailInput = document.getElementById('email');
      var codeInput = document.getElementById('code');
      var slugCheck = document.getElementById('slug-check');
      var stepClaim = document.getElementById('step-claim');
      var stepVerify = document.getElementById('step-verify');
      var verifySub = document.getElementById('verify-sub');
      var SLUG_RE = /^[a-z0-9][a-z0-9-]{1,28}[a-z0-9]$/;
      var RESERVED = ['new','admin','api','edit','login'];

      function validSlug(s) {
        if (!s) return { ok: false, msg: '' };
        if (s.length < 3) return { ok: false, msg: 'Too short (min 3)' };
        if (!SLUG_RE.test(s)) return { ok: false, msg: 'Lowercase letters, numbers, hyphens only' };
        if (RESERVED.indexOf(s) >= 0) return { ok: false, msg: 'That URL is reserved' };
        return { ok: true, msg: '✓ looks good' };
      }

      slugInput.addEventListener('input', function() {
        var s = slugInput.value.toLowerCase().trim();
        slugInput.value = s;
        var v = validSlug(s);
        slugCheck.textContent = v.msg;
        slugCheck.style.color = v.ok ? '#047857' : '#DC2626';
      });

      function showErr(id, msg) { var el = document.getElementById(id); el.textContent = msg; el.classList.add('show'); }
      function clearErr(id) { var el = document.getElementById(id); el.textContent=''; el.classList.remove('show'); }

      document.getElementById('send-btn').addEventListener('click', async function() {
        clearErr('send-err');
        var slug = slugInput.value.trim().toLowerCase();
        var email = (emailInput.value || '').trim().toLowerCase();
        var sv = validSlug(slug);
        if (!sv.ok) { showErr('send-err', sv.msg || 'Pick a URL.'); return; }
        if (!email || email.indexOf('@') < 0) { showErr('send-err', 'Enter a valid email.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/code-send', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: slug, email: email })
          });
          var d = await r.json();
          if (d.ok) {
            stepClaim.hidden = true;
            stepVerify.hidden = false;
            verifySub.textContent = 'We sent a code to ' + email + ' for /u/' + slug + '. (If the URL was taken, the code goes to whoever owns it.)';
            codeInput.focus();
          } else {
            showErr('send-err', d.error || 'Could not send code.');
          }
        } catch (e) { showErr('send-err', 'Network error.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('verify-btn').addEventListener('click', async function() {
        clearErr('verify-err');
        var slug = slugInput.value.trim().toLowerCase();
        var email = (emailInput.value || '').trim().toLowerCase();
        var code = (codeInput.value || '').trim();
        if (!/^\d{6}$/.test(code)) { showErr('verify-err', 'Enter the 6-digit code.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Verifying…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/code-verify', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: slug, email: email, code: code })
          });
          var d = await r.json();
          if (d.ok && d.redirect) { location.href = d.redirect; return; }
          showErr('verify-err', d.error || 'Invalid or expired code.');
        } catch (e) { showErr('verify-err', 'Network error.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('back-btn').addEventListener('click', function() {
        stepVerify.hidden = true;
        stepClaim.hidden = false;
        slugInput.focus();
      });

      codeInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') document.getElementById('verify-btn').click(); });
      emailInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') document.getElementById('send-btn').click(); });
    })();
  </script>

  <style>
    .wrap { max-width: 760px; margin: 0 auto; padding: var(--space-5) var(--space-4) var(--space-8); }

    .intro { text-align: center; margin-bottom: var(--space-6); }
    .intro-tag { font-family: 'SF Mono', Menlo, monospace; font-size: 11px; letter-spacing: 2px; color: var(--accent, #7C3AED); font-weight: 700; margin-bottom: var(--space-2); }
    .intro-h1 { font-family: var(--font-display, 'Playfair Display', serif); font-size: clamp(32px, 5vw, 44px); font-weight: 800; line-height: 1.1; margin-bottom: var(--space-2); color: var(--text); }
    .intro-deck { font-size: 16px; line-height: 1.55; color: var(--text-sec, #4B5563); max-width: 560px; margin: 0 auto; }

    .who { margin-bottom: var(--space-6); }
    .who-row { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
    .who-card { background: var(--surface, #F8F9FB); border: 1px solid var(--border); border-radius: 14px; padding: var(--space-3) var(--space-4); }
    .who-emoji { font-size: 28px; margin-bottom: 4px; }
    .who-h { font-weight: 700; font-size: 15px; margin-bottom: 4px; color: var(--text); }
    .who-card p { font-size: 13px; color: var(--text-sec, #4B5563); line-height: 1.45; font-style: italic; }

    .how { margin-bottom: var(--space-6); background: #FAF5FF; border: 1px solid #E9D5FF; border-radius: var(--radius-lg, 20px); padding: var(--space-5); }
    .how-h { font-family: var(--font-display, 'Playfair Display', serif); font-size: 24px; font-weight: 800; text-align: center; margin-bottom: var(--space-4); }
    .how-steps { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-3); }
    .how-steps li { display: flex; gap: var(--space-3); align-items: flex-start; font-size: 15px; line-height: 1.5; color: var(--text); }
    .how-num { width: 32px; height: 32px; border-radius: 50%; background: var(--accent, #7C3AED); color: #fff; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 14px; }
    .how-steps strong { color: var(--text); }
    .mono { font-family: 'SF Mono', Menlo, monospace; background: rgba(124,58,237,0.1); padding: 1px 6px; border-radius: 4px; font-size: 13px; color: var(--accent, #7C3AED); }

    .terms { margin-bottom: var(--space-6); }
    .terms-h { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-faint); margin-bottom: var(--space-2); }
    .terms ul { list-style: none; padding: 0; margin: 0; }
    .terms li { font-size: 14px; color: var(--text-sec, #4B5563); padding: 8px 0; border-bottom: 1px dashed var(--border); line-height: 1.5; }
    .terms li:last-child { border-bottom: none; }
    .terms li::before { content: '— '; color: var(--text-faint); }

    .form-anchor { height: 1px; }

    .claim-box { background: var(--surface, #F8F9FB); border: 1.5px solid var(--border); border-radius: var(--radius-lg, 20px); padding: var(--space-5); max-width: 480px; margin: 0 auto; }
    .claim-h { font-family: var(--font-display, sans-serif); font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 4px; }
    .claim-sub { text-align: center; font-size: 14px; color: var(--text-sec); margin-bottom: var(--space-4); }
    .claim-field { margin-bottom: var(--space-3); }
    .claim-field label { display: block; font-size: 12px; font-weight: 600; color: var(--text-sec); margin-bottom: 6px; }
    .claim-field label .opt { font-weight: 400; color: var(--text-faint); }
    .slug-row { display: flex; align-items: stretch; border: 1.5px solid var(--border); border-radius: 10px; overflow: hidden; background: #fff; }
    .slug-prefix { padding: 10px 12px; background: var(--surface, #F8F9FB); color: var(--text-faint); font-size: 13px; font-family: monospace; border-right: 1px solid var(--border); }
    .slug-row input { flex: 1; border: none; padding: 10px 12px; font-size: 14px; outline: none; font-family: monospace; min-width: 0; }
    .claim-field input[type=email], .claim-field input#code { width: 100%; padding: 10px 12px; border-radius: 10px; border: 1.5px solid var(--border); font-size: 14px; background: #fff; font-family: inherit; }
    #code { font-size: 22px; letter-spacing: 8px; text-align: center; font-family: monospace; }
    .slug-check { font-size: 12px; margin-top: 6px; min-height: 16px; }
    .claim-cta { width: 100%; padding: 14px; border-radius: 999px; border: none; background: var(--accent, #7C3AED); color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: var(--space-2); transition: filter 0.15s; }
    .claim-cta:hover { filter: brightness(1.08); }
    .claim-cta:active { filter: brightness(0.95); }
    .claim-link { display: block; margin: var(--space-3) auto 0; background: none; border: none; cursor: pointer; font-size: 13px; color: var(--text-sec); text-decoration: underline; text-underline-offset: 3px; }
    .claim-err { font-size: 13px; color: #DC2626; margin-top: var(--space-2); display: none; }
    .claim-err.show { display: block; }
    .claim-foot { font-size: 11px; color: var(--text-faint); text-align: center; margin-top: var(--space-3); line-height: 1.5; }

    @media (max-width: 600px) {
      .who-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .slug-prefix { font-size: 11px; padding: 10px 8px; }
      .how { padding: var(--space-4) var(--space-3); }
      .how-num { width: 26px; height: 26px; font-size: 12px; }
    }
  </style>
</Base>
