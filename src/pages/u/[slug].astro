---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';
import { validateSlug } from '../../lib/profile-auth';
import { parseTemplateData } from '../../lib/profile-templates';
import HostTemplate from '../../components/profile-templates/HostTemplate.astro';
import BookClubTemplate from '../../components/profile-templates/BookClubTemplate.astro';
import GameGroupTemplate from '../../components/profile-templates/GameGroupTemplate.astro';
import BibleStudyTemplate from '../../components/profile-templates/BibleStudyTemplate.astro';
import PotteryTemplate from '../../components/profile-templates/PotteryTemplate.astro';
import RunClubTemplate from '../../components/profile-templates/RunClubTemplate.astro';
import WellnessTemplate from '../../components/profile-templates/WellnessTemplate.astro';
import MusicTemplate from '../../components/profile-templates/MusicTemplate.astro';
import CauseTemplate from '../../components/profile-templates/CauseTemplate.astro';
import ServiceProTemplate from '../../components/profile-templates/ServiceProTemplate.astro';
import DogsTemplate from '../../components/profile-templates/DogsTemplate.astro';
import ClimbingTemplate from '../../components/profile-templates/ClimbingTemplate.astro';
import SupperClubTemplate from '../../components/profile-templates/SupperClubTemplate.astro';
import ArtTemplate from '../../components/profile-templates/ArtTemplate.astro';
import LanguageTemplate from '../../components/profile-templates/LanguageTemplate.astro';
import PhotographyTemplate from '../../components/profile-templates/PhotographyTemplate.astro';

const rawSlug = Astro.params.slug || '';
const v = validateSlug(rawSlug);
if (!v.ok) return Astro.redirect('/404');

const db = getDB();
if (!db) return new Response('DB unavailable', { status: 500 });

let profile: any = null;
try {
  profile = await db.prepare(
    `SELECT slug, email, display_name, headline, bio, photo_emoji, accent_color,
            offers_json, links_json, contact_email, contact_phone, neighborhood,
            template, template_data, cover_photo_url, avatar_photo_url, status
     FROM profiles WHERE slug = ?`
  ).bind(v.slug).first();
} catch {
  // Columns may not exist yet on a fresh DB. Fall back to base query.
  profile = await db.prepare(
    `SELECT slug, email, display_name, headline, bio, photo_emoji, accent_color,
            offers_json, links_json, contact_email, contact_phone, status
     FROM profiles WHERE slug = ?`
  ).bind(v.slug).first();
}

if (!profile || profile.status !== 'live') {
  return new Response('Not found', { status: 404 });
}

// Events hosted by this profile, sorted upcoming-first then most-recent past.
const monthOrder: Record<string, number> = { JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11 };
let hostedEvents: any[] = [];
try {
  const rows = (await db.prepare(
    `SELECT id, title, event_month, event_day, location, zone, is_past
     FROM events WHERE LOWER(submitted_by_email) = ?`
  ).bind((profile.email || '').toLowerCase()).all())?.results || [];
  const now = new Date();
  const cm = now.getMonth();
  const cd = now.getDate();
  hostedEvents = (rows as any[]).map((e: any) => {
    const m = monthOrder[(e.event_month || '').toUpperCase()] ?? 99;
    const d = parseInt(e.event_day) || 99;
    const past = !!e.is_past || m < cm || (m === cm && d < cd);
    return { ...e, _m: m, _d: d, _past: past };
  }).sort((a: any, b: any) => {
    if (a._past !== b._past) return a._past ? 1 : -1;
    if (a._past) {
      if (b._m !== a._m) return b._m - a._m;
      return b._d - a._d;
    }
    if (a._m !== b._m) return a._m - b._m;
    return a._d - b._d;
  });
} catch {}

let offers: Array<{ icon?: string; label: string }> = [];
let links: Array<{ icon?: string; label: string; url: string }> = [];
try { const arr = JSON.parse(profile.offers_json || '[]'); if (Array.isArray(arr)) offers = arr; } catch {}
try { const arr = JSON.parse(profile.links_json || '[]'); if (Array.isArray(arr)) links = arr; } catch {}

// Surface "Book a session" if this profile has any active offerings.
let hasBookableOfferings = false;
try {
  const row = await db.prepare(
    `SELECT COUNT(*) AS n FROM bookable_offerings WHERE profile_slug=? AND archived=0`
  ).bind(v.slug).first() as any;
  hasBookableOfferings = !!(row && row.n > 0);
} catch {}

const accent = /^#[0-9A-Fa-f]{6}$/.test(profile.accent_color || '') ? profile.accent_color : '#7C3AED';
const firstName = (profile.display_name || '').split(' ')[0] || 'them';

const templateKey = (profile.template || 'host').toString();
const templateData = parseTemplateData(profile.template_data);

const TEMPLATE_MAP: Record<string, any> = {
  host: HostTemplate,
  book_club: BookClubTemplate,
  game_group: GameGroupTemplate,
  bible_study: BibleStudyTemplate,
  pottery: PotteryTemplate,
  run_club: RunClubTemplate,
  wellness: WellnessTemplate,
  music: MusicTemplate,
  cause: CauseTemplate,
  service_pro: ServiceProTemplate,
  dogs: DogsTemplate,
  climbing: ClimbingTemplate,
  supper_club: SupperClubTemplate,
  art: ArtTemplate,
  language: LanguageTemplate,
  photography: PhotographyTemplate,
};
const TemplateComponent = TEMPLATE_MAP[templateKey] || HostTemplate;
---
<Base title={`${profile.display_name} — Denver Social`} description={profile.headline || `${profile.display_name} on Denver Social`}>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=DM+Serif+Display&family=Bebas+Neue&family=Lora:wght@500;700&family=Space+Mono&display=swap"/>
  <div class="wrap">
    <div class="profile" style={`--profile-accent: ${accent}`} data-slug={profile.slug}>
      {profile.cover_photo_url && (
        <div class="prof-cover"><img src={profile.cover_photo_url} alt="Cover" loading="eager"/></div>
      )}
      <TemplateComponent profile={profile} hostedEvents={hostedEvents} templateData={templateData} links={links} />

      {hasBookableOfferings && (
        <div class="prof-book-row">
          <a href={`/u/${profile.slug}/book`} class="prof-book-cta">📅 Book a session →</a>
        </div>
      )}

      {(offers.length > 0 || links.length > 0 || profile.contact_email || profile.contact_phone) && (
        <div class="prof-extra">
          {offers.length > 0 && (
            <div class="prof-offers">
              <h3 class="prof-h3"><span class="prof-h3-bar"></span>What I offer</h3>
              <div class="prof-offer-grid">
                {offers.map(o => (
                  <div class="prof-offer-card">
                    <div class="prof-offer-icon">{o.icon || '✨'}</div>
                    <div class="prof-offer-label">{o.label}</div>
                  </div>
                ))}
              </div>
            </div>
          )}
          {links.length > 0 && (
            <div class="prof-links">
              {links.map(l => <a href={l.url} class="prof-link" target="_blank" rel="noopener nofollow">{l.icon || '🔗'} {l.label}</a>)}
            </div>
          )}
          {(profile.contact_email || profile.contact_phone) && (
            <div class="prof-contact">
              <button class="prof-cta" id="prof-cta" type="button">📬 Get in touch with {firstName}</button>
              <div class="prof-cta-hint" id="prof-cta-hint">
                {profile.contact_email && profile.contact_phone ? 'Email + phone revealed on click' :
                 profile.contact_email ? 'Email revealed on click' : 'Phone revealed on click'}
              </div>
              <div class="prof-reveal" id="prof-reveal" hidden>
                {profile.contact_email && <div class="prof-reveal-row">📧 <a href={`mailto:${profile.contact_email}`}>{profile.contact_email}</a></div>}
                {profile.contact_phone && <div class="prof-reveal-row">📞 <a href={`tel:${profile.contact_phone}`}>{profile.contact_phone}</a></div>}
              </div>
            </div>
          )}
        </div>
      )}

      <footer class="prof-foot">
        <a href="#" class="prof-share" id="prof-share">🔗 Share this page</a>
        <a href="#" class="prof-report" id="prof-report">🚩 Report</a>
      </footer>
    </div>

    <section class="make-yours">
      <div class="make-yours-inner">
        <div class="make-yours-text">Want a page like this?</div>
        <a href="/profile/new" class="make-yours-cta">Make yours — free →</a>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ slug: profile.slug }}>
    document.addEventListener('DOMContentLoaded', function() {
      var cta = document.getElementById('prof-cta');
      var reveal = document.getElementById('prof-reveal');
      var hint = document.getElementById('prof-cta-hint');
      if (cta && reveal) {
        cta.addEventListener('click', function() {
          reveal.hidden = false;
          cta.hidden = true;
          if (hint) hint.hidden = true;
        });
      }
      var share = document.getElementById('prof-share');
      if (share) {
        share.addEventListener('click', function(e) {
          e.preventDefault();
          var url = location.href;
          if (navigator.share) {
            navigator.share({ url: url }).catch(function(){});
          } else if (navigator.clipboard) {
            navigator.clipboard.writeText(url).then(function() { share.textContent = '✓ Copied!'; setTimeout(function() { share.textContent = '🔗 Share this page'; }, 1500); });
          }
        });
      }
      var report = document.getElementById('prof-report');
      if (report) {
        report.addEventListener('click', function(e) {
          e.preventDefault();
          var reason = prompt('Report this page? Optionally tell us why:');
          if (reason === null) return;
          fetch('/api/profile/report', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: slug, reason: reason || '' })
          }).then(function() { report.textContent = '✓ Reported'; });
        });
      }
    });
  </script>

  <style>
    .wrap { max-width: 880px; margin: 0 auto; padding: var(--space-5) var(--space-4) var(--space-8); }
    .profile { background: var(--bg); border-radius: 20px; overflow: hidden; }
    .prof-cover { width: 100%; aspect-ratio: 14 / 4; overflow: hidden; border-radius: 18px; margin-bottom: 16px; background: var(--surface, #F8F9FB); border: 1.5px solid var(--border); }
    .prof-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .prof-extra { padding: var(--space-4) var(--space-5); background: #fff; border: 1.5px solid var(--border); border-radius: 18px; margin-top: 16px; }
    .prof-book-row { margin-top: 16px; }
    .prof-book-cta {
      display:block;text-align:center;padding:14px 20px;border-radius:50px;
      background: var(--profile-accent, #7C3AED); color:#fff; font-weight:700; font-size:15px;
      text-decoration:none;
      box-shadow: 0 4px 14px color-mix(in srgb, var(--profile-accent, #7C3AED) 28%, transparent);
      transition: transform .15s, filter .15s, box-shadow .15s;
    }
    .prof-book-cta:hover { transform: translateY(-1px); filter: brightness(1.06); }
    .prof-book-cta:active { transform: translateY(0); filter: brightness(0.95); }
    .prof-h3 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-faint); margin-bottom: 14px; display: flex; align-items: center; gap: 10px; }
    .prof-h3-bar { width: 24px; height: 2px; background: var(--profile-accent, #7C3AED); border-radius: 999px; display: inline-block; }
    .prof-offers { margin-bottom: var(--space-4); }
    .prof-offer-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
    .prof-offer-card {
      display: flex; align-items: center; gap: 12px;
      background: color-mix(in srgb, var(--profile-accent, #7C3AED) 4%, var(--surface, #F8F9FB));
      border: 1px solid color-mix(in srgb, var(--profile-accent, #7C3AED) 14%, transparent);
      padding: 12px 14px; border-radius: 12px;
      transition: transform .15s, border-color .15s, box-shadow .15s;
    }
    .prof-offer-card:hover {
      transform: translateY(-1px);
      border-color: var(--profile-accent, #7C3AED);
      box-shadow: 0 6px 18px color-mix(in srgb, var(--profile-accent, #7C3AED) 18%, transparent);
    }
    .prof-offer-icon {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--bg, #fff);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
      box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    }
    .prof-offer-label { font-size: 14px; font-weight: 600; color: var(--text, #1A1A1A); line-height: 1.35; }
    @media (max-width: 480px) { .prof-offer-grid { grid-template-columns: 1fr; } }
    .prof-links { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: var(--space-3); }
    .prof-link { padding: 6px 12px; border-radius: 999px; background: var(--surface, #F8F9FB); border: 1px solid var(--border); font-size: 13px; color: var(--text); text-decoration: none; transition: background 0.15s; }
    .prof-link:hover { background: var(--surface-hover, #F0F2F5); }
    .prof-contact { margin-top: var(--space-3); }
    .prof-cta { width: 100%; padding: 13px; border-radius: 999px; border: none; background: var(--profile-accent); color: #fff; font-weight: 700; font-size: 15px; cursor: pointer; transition: filter 0.15s; }
    .prof-cta:hover { filter: brightness(1.08); }
    .prof-cta:active { filter: brightness(0.95); }
    .prof-cta-hint { font-size: 12px; color: var(--text-faint); text-align: center; margin-top: 6px; }
    .prof-reveal { background: var(--surface, #F8F9FB); border: 1px solid var(--border); border-radius: 12px; padding: 12px 14px; }
    .prof-reveal-row { font-size: 14px; padding: 4px 0; color: var(--text); }
    .prof-reveal-row a { color: var(--profile-accent); text-decoration: none; font-weight: 600; }
    .prof-foot { padding: var(--space-3) var(--space-5); display: flex; justify-content: space-between; font-size: 12px; margin-top: 16px; }
    .prof-share { color: var(--text-sec); text-decoration: none; cursor: pointer; }
    .prof-share:hover { color: var(--text); }
    .prof-report { color: var(--text-faint); text-decoration: none; cursor: pointer; }
    .prof-report:hover { color: var(--text-sec); }

    .make-yours {
      margin-top: 32px;
      padding: 32px 24px;
      border-radius: 20px;
      background: linear-gradient(135deg, #F8F9FB, #EEF2FF, #F0FDF4);
      border: 1px solid var(--border, #E5E7EB);
      text-align: center;
    }
    .make-yours-inner { display: flex; flex-direction: column; align-items: center; gap: 14px; }
    .make-yours-text {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--text, #111827);
      line-height: 1.3;
    }
    .make-yours-cta {
      display: inline-block;
      padding: 12px 24px;
      border-radius: 50px;
      background: var(--cta-bg, #7C3AED);
      color: var(--cta-text, #fff);
      font-weight: 700;
      font-size: 15px;
      text-decoration: none;
      box-shadow: 0 4px 14px rgba(124, 58, 237, 0.25);
      transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
    }
    .make-yours-cta:hover { transform: translateY(-1px); filter: brightness(1.05); box-shadow: 0 6px 20px rgba(124, 58, 237, 0.32); }
    .make-yours-cta:active { transform: translateY(0); filter: brightness(0.95); }
    @media (min-width: 600px) {
      .make-yours-text { font-size: 22px; }
    }
  </style>
</Base>
