---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

const db = getDB();
let chapters: any[] = [];
if (db) {
  try {
    const r = await db.prepare(`
      SELECT TRIM(neighborhood) as neighborhood,
             COUNT(*) as member_count
      FROM members
      WHERE neighborhood IS NOT NULL AND TRIM(neighborhood) != ''
      GROUP BY TRIM(LOWER(neighborhood))
      ORDER BY member_count DESC, neighborhood ASC
    `).all();
    chapters = (r.results || []) as any[];
    // Join event counts per neighborhood
    for (const ch of chapters) {
      try {
        const ev: any = await db.prepare(`
          SELECT COUNT(*) as c FROM events
          WHERE (zone = ? OR location = ?)
            AND (is_past IS NULL OR is_past = 0)
        `).bind(ch.neighborhood, ch.neighborhood).first();
        ch.event_count = ev?.c || 0;
      } catch { ch.event_count = 0; }
    }
  } catch (e: any) {
    console.error('/neighborhoods load failed', e);
  }
}

function emoji(name: string): string {
  const n = (name || '').toLowerCase();
  if (n.includes('rino') || n.includes('river north')) return '🎨';
  if (n.includes('lodo') || n.includes('downtown')) return '🏙';
  if (n.includes('capitol hill') || n.includes('cap hill')) return '🏛';
  if (n.includes('cheesman')) return '🌳';
  if (n.includes('cherry creek')) return '🌸';
  if (n.includes('highlands') || n.includes('lohi')) return '🌄';
  if (n.includes('berkeley')) return '🍦';
  if (n.includes('sloan')) return '🏞';
  if (n.includes('washington park')) return '🌷';
  if (n.includes('park') || n.includes('hill')) return '🌲';
  if (n.includes('boulder')) return '🏔';
  if (n.includes('aurora')) return '🌅';
  if (n.includes('golden')) return '⛰';
  if (n.includes('arvada')) return '🍂';
  return '📍';
}
---
<Base title="Neighborhoods" description="Denver Social chapters — members and events by neighborhood.">
<div class="nb-wrap">
  <header class="nb-head">
    <h1>Neighborhoods</h1>
    <p>Where everyone's based + what's happening in each part of town. Members default into their neighborhood — browse anyone you want.</p>
  </header>

  {chapters.length === 0 ? (
    <div class="nb-empty">No neighborhoods yet — once members fill in their area on /profile, chapters show up here.</div>
  ) : (
    <div class="nb-grid">
      {chapters.map((ch: any) => (
        <article class="nb-card">
          <div class="nb-emoji">{emoji(ch.neighborhood)}</div>
          <h3>{ch.neighborhood}</h3>
          <div class="nb-stats">
            <div class="nb-stat"><strong>{ch.member_count}</strong><span>{ch.member_count === 1 ? 'member' : 'members'}</span></div>
            <div class="nb-stat"><strong>{ch.event_count || 0}</strong><span>upcoming</span></div>
          </div>
        </article>
      ))}
    </div>
  )}

  <section class="nb-pitch">
    <h2>Not seeing your spot?</h2>
    <p>Add your neighborhood on <a href="/profile">your profile</a> and you'll show up here. We don't gate on geo — anyone in any area can join any event.</p>
  </section>
</div>

<style>
  .nb-wrap { max-width: 1100px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .nb-head { text-align: center; margin-bottom: 32px; }
  .nb-head h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 44px); font-weight: 900; letter-spacing: -0.025em; }
  .nb-head p { font-size: 16px; color: var(--text-sec); margin-top: 8px; max-width: 540px; margin-left: auto; margin-right: auto; line-height: 1.55; }

  .nb-empty { padding: 56px 24px; text-align: center; color: var(--text-faint); background: var(--surface); border: 1px dashed var(--border); border-radius: 14px; }

  .nb-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-bottom: 48px; }
  .nb-card {
    padding: 22px; background: var(--bg); border: 1px solid var(--border); border-radius: 16px;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .nb-card:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-lg); border-color: var(--border-hover); }
  .nb-emoji { font-size: 32px; margin-bottom: 8px; }
  .nb-card h3 { font-family: var(--font-display); font-size: 17px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 14px; }
  .nb-stats { display: flex; gap: 16px; }
  .nb-stat { display: flex; flex-direction: column; gap: 2px; }
  .nb-stat strong { font-family: var(--font-display); font-size: 22px; font-weight: 800; color: var(--accent); line-height: 1; }
  .nb-stat span { font-size: 11px; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }

  .nb-pitch {
    padding: 32px clamp(20px, 4vw, 36px); border-radius: 20px;
    background: linear-gradient(135deg, var(--sunset-dim), var(--pink-dim));
    border: 1px solid rgba(249,115,22,0.18); text-align: center;
  }
  .nb-pitch h2 { font-family: var(--font-display); font-size: 22px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 8px; }
  .nb-pitch p { font-size: 15px; color: var(--text-sec); line-height: 1.55; max-width: 480px; margin: 0 auto; }
  .nb-pitch a { color: var(--accent); font-weight: 600; }
</style>
</Base>
