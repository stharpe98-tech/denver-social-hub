// Deprecated — superseded by /community (flyer board). Forwards any
// neighborhood param so external links still land somewhere sensible.
const nbh = Astro.url.searchParams.get('nbh') || Astro.url.searchParams.get('slug') || '';
return Astro.redirect(nbh ? `/community?nbh=${encodeURIComponent(nbh)}` : '/community');
