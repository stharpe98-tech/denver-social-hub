---
import Base from '../../layouts/Base.astro';
import { PARTNER_CATEGORIES } from '../../lib/partners-schema';
---
<Base title="Submit a perk" description="Local business? Post a discount or offer for Denver Social attendees.">
<div class="np-wrap">
  <a href="/perks" class="np-back">← Perks</a>
  <h1 class="np-title">Post your offer.</h1>
  <p class="np-sub">Tell us about your business and what you'd like to give Denver Social attendees. We review and post for free — no contract, no fees, no algorithm.</p>

  <form id="np-form" class="np-form">
    <div class="np-section">
      <h2>Your business</h2>
      <div class="np-field">
        <label class="np-label">Business name <span class="req">*</span></label>
        <input type="text" name="business_name" class="np-input" required maxlength="80" placeholder="Larimer Lounge" />
      </div>
      <div class="np-row">
        <div class="np-field">
          <label class="np-label">Category</label>
          <select name="category" class="np-input">
            {PARTNER_CATEGORIES.map(c => <option value={c.key}>{c.emoji} {c.label}</option>)}
          </select>
        </div>
        <div class="np-field">
          <label class="np-label">Neighborhood</label>
          <input type="text" name="neighborhood" class="np-input" placeholder="RiNo, Cap Hill…" />
        </div>
      </div>
      <div class="np-field">
        <label class="np-label">Website</label>
        <input type="url" name="website" class="np-input" placeholder="https://…" />
      </div>
    </div>

    <div class="np-section">
      <h2>Your offer</h2>
      <div class="np-field">
        <label class="np-label">Headline <span class="req">*</span></label>
        <input type="text" name="offer_title" class="np-input" required maxlength="80" placeholder="15% off for groups of 4+" />
        <span class="np-hint">Short, scannable. Will be the big text on the perk card.</span>
      </div>
      <div class="np-field">
        <label class="np-label">Details</label>
        <textarea name="offer_details" class="np-input np-textarea" rows="3" maxlength="400" placeholder="Show this page at checkout. Valid Sunday–Thursday. Excludes happy hour."></textarea>
      </div>
      <div class="np-field">
        <label class="np-label">How to claim</label>
        <input type="text" name="redemption" class="np-input" maxlength="120" placeholder='Mention "Denver Social" / use code DSN15 / show this page' />
      </div>
      <div class="np-field">
        <label class="np-label">Booking link (if reservation required)</label>
        <input type="url" name="booking_url" class="np-input" placeholder="https://reservations.yoursite.com/…" />
        <span class="np-hint">If guests must book through your site to get the deal, paste the booking URL. The perk card will show a "Book to claim →" button instead of a generic visit link.</span>
      </div>
      <div class="np-field">
        <label class="np-label">RSVPs to unlock</label>
        <input type="number" name="rsvp_threshold" class="np-input" min="0" max="500" step="1" value="0" placeholder="0" />
        <span class="np-hint">Hide the discount until this many people RSVP. Use 0 for an always-on offer. Crowd-funded perks (e.g. 10 RSVPs unlocks 15% off) build buzz before the visit.</span>
      </div>
    </div>

    <div class="np-section">
      <h2>Contact</h2>
      <div class="np-field">
        <label class="np-label">Contact email <span class="req">*</span></label>
        <input type="email" name="contact_email" class="np-input" required placeholder="you@business.com" />
        <span class="np-hint">We'll email you when the listing goes live (or if we need to ask anything).</span>
      </div>
    </div>

    <button type="submit" class="np-submit" id="np-submit">Submit for review</button>
    <div id="np-out" class="np-out"></div>
  </form>
</div>

<style>
  .np-wrap { max-width: 680px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .np-back { font-size: 13px; color: var(--text-sec); text-decoration: none; }
  .np-back:hover { color: var(--text); }
  .np-title { font-family: var(--font-display); font-size: clamp(32px, 5vw, 42px); font-weight: 900; letter-spacing: -0.025em; margin: 16px 0 8px; }
  .np-sub { color: var(--text-sec); font-size: 16px; line-height: 1.55; margin-bottom: 28px; }

  .np-form { display: flex; flex-direction: column; gap: 16px; }
  .np-section {
    background: var(--bg); border: 1px solid var(--border); border-radius: 18px;
    padding: 24px clamp(18px, 3vw, 28px); box-shadow: var(--card-shadow);
  }
  .np-section h2 { font-family: var(--font-display); font-size: 18px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 16px; }

  .np-field { margin-bottom: 16px; }
  .np-field:last-child { margin-bottom: 0; }
  .np-label { display: block; font-family: var(--font-display); font-size: 12px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .req { color: var(--accent); font-weight: 500; text-transform: none; letter-spacing: 0; }
  .np-input {
    width: 100%; padding: 12px 14px;
    background: var(--bg); border: 1px solid var(--border); border-radius: 12px;
    font-size: 15px; color: var(--text); font-family: var(--font);
    -webkit-appearance: none; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .np-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .np-textarea { resize: vertical; min-height: 80px; line-height: 1.5; }
  .np-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 480px) { .np-row { grid-template-columns: 1fr; } }
  .np-hint { display: block; font-size: 12px; color: var(--text-faint); margin-top: 6px; }

  .np-submit {
    padding: 16px; border-radius: 999px; border: none;
    background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font-display); font-size: 16px; font-weight: 700; cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .np-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--accent-glow); }
  .np-submit:disabled { opacity: 0.5; cursor: not-allowed; }

  .np-out { font-size: 14px; text-align: center; padding: 14px; border-radius: 12px; min-height: 0; }
  .np-out.ok { background: #DCFCE7; color: #166534; }
  .np-out.err { background: #FEF2F2; color: #B91C1C; }
</style>

<script is:inline>
  document.getElementById('np-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var out = document.getElementById('np-out');
    var btn = document.getElementById('np-submit');
    out.className = 'np-out'; out.textContent = '';
    btn.disabled = true;
    var data = Object.fromEntries(new FormData(form));
    data.action = 'submit';
    try {
      var res = await fetch('/api/partners', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
      });
      var json = await res.json();
      if (json.ok) {
        out.className = 'np-out ok';
        out.textContent = 'Got it. We\'ll review and post within a day or two — you\'ll hear from us at that email.';
        form.reset();
      } else {
        out.className = 'np-out err';
        out.textContent = 'Could not submit: ' + json.error;
      }
    } catch {
      out.className = 'np-out err';
      out.textContent = 'Network problem. Try again.';
    }
    btn.disabled = false;
  });
</script>
</Base>
