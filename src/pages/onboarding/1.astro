---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
if (!user) return Astro.redirect("/login?next=/onboarding/1");

let error: string | null = null;

if (Astro.request.method === "POST" && db) {
  const form = await Astro.request.formData();
  const neighborhood = (form.get("neighborhood")?.toString() || '').trim();
  const interests = form.getAll("interests").join(",");
  try {
    await db.prepare(
      "UPDATE members SET neighborhood = ?, interests = ?, onboarding_done = 1 WHERE email = ?"
    ).bind(neighborhood, interests, user.email).run();
    return Astro.redirect("/events");
  } catch {
    error = "Something went wrong — try again.";
  }
}

const firstName = (user.name || user.reddit_username || user.discord_username || 'friend').split(' ')[0];

const neighborhoods = [
  "RiNo", "LoDo / Downtown", "Cap Hill", "Cheesman Park", "Five Points",
  "Cherry Creek", "Wash Park", "Baker", "Highlands / LoHi", "Sunnyside",
  "Berkeley", "Sloan's Lake", "Englewood", "Littleton", "Centennial",
  "Lakewood", "Golden", "Arvada", "Westminster", "Aurora", "Boulder",
  "Other / Outside Denver",
];

const interestChips = [
  { emoji: "🥾", label: "Hikes",          value: "hiking" },
  { emoji: "🍽", label: "Dinners",        value: "dinner" },
  { emoji: "☕", label: "Coffee",         value: "coffee" },
  { emoji: "🍺", label: "Brewery",        value: "brewery" },
  { emoji: "🎲", label: "Game nights",    value: "games" },
  { emoji: "🎨", label: "Arts & culture", value: "arts" },
  { emoji: "🎵", label: "Music",          value: "music" },
  { emoji: "🏃", label: "Active",         value: "active" },
  { emoji: "🥂", label: "Mixers",         value: "social" },
];
---
<Base title="Welcome" description="Quick setup so we can match you with nearby events.">
  <div class="ob-wrap">
    <div class="ob-card">
      <span class="ob-eyebrow">Welcome</span>
      <h1>Hey {firstName}. Two quick questions.</h1>
      <p class="ob-sub">Takes about 15 seconds. Skip anything you'd rather not answer.</p>

      {error && <div class="ob-err">{error}</div>}

      <form method="POST" class="ob-form">
        <div class="ob-field">
          <label class="ob-label">Neighborhood <span class="opt">(so we surface nearby events)</span></label>
          <select name="neighborhood" class="ob-input">
            <option value="">— Skip —</option>
            {neighborhoods.map(n => <option value={n}>{n}</option>)}
          </select>
        </div>

        <div class="ob-field">
          <label class="ob-label">What sounds fun? <span class="opt">(pick any)</span></label>
          <div class="ob-chips">
            {interestChips.map(c => (
              <label class="ob-chip">
                <input type="checkbox" name="interests" value={c.value}/>
                <span>{c.emoji} {c.label}</span>
              </label>
            ))}
          </div>
        </div>

        <button type="submit" class="btn-cta ob-submit">Done — show me events →</button>
        <a href="/events" class="ob-skip">Skip for now</a>
      </form>
    </div>
  </div>

  <style>
    .ob-wrap { max-width: 560px; margin: 0 auto; padding: var(--space-7) var(--space-4) var(--space-8); }
    .ob-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--card-shadow-lg); padding: var(--space-6) var(--space-5); }
    .ob-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 4px 12px; border-radius: 999px; margin-bottom: var(--space-3); }
    .ob-card h1 { font-family: var(--font-display); font-size: clamp(24px, 4vw, 30px); font-weight: 800; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 6px; }
    .ob-sub { color: var(--text-sec); font-size: 14px; margin-bottom: var(--space-5); }
    .ob-err { background: var(--red-dim); color: var(--red); border: 1px solid rgba(220,38,38,0.2); border-radius: 10px; padding: 10px 14px; margin-bottom: var(--space-4); font-size: 13px; }
    .ob-field { margin-bottom: var(--space-4); }
    .ob-label { display: block; font-size: 11px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .ob-label .opt { font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-faint); }
    .ob-input { width: 100%; padding: 11px 13px; background: var(--bg); border: 1px solid var(--border); border-radius: 10px; font-size: 15px; color: var(--text); font-family: var(--font); outline: none; transition: border-color 0.15s, box-shadow 0.15s; -webkit-appearance: none; appearance: none; }
    .ob-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
    .ob-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .ob-chip { display: inline-flex; align-items: center; gap: 6px; padding: 9px 14px; background: var(--bg); border: 1px solid var(--border); border-radius: 999px; font-size: 14px; cursor: pointer; transition: border-color 0.15s, background 0.15s; user-select: none; }
    .ob-chip:hover { border-color: var(--accent); }
    .ob-chip input { position: absolute; opacity: 0; pointer-events: none; }
    .ob-chip:has(input:checked) { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); font-weight: 600; }
    .ob-submit { width: 100%; padding: 14px; font-size: 15px; margin-top: var(--space-3); }
    .ob-skip { display: block; text-align: center; margin-top: var(--space-3); font-size: 13px; color: var(--text-faint); text-decoration: underline; text-underline-offset: 3px; }
    .ob-skip:hover { color: var(--text-sec); }
  </style>
</Base>
