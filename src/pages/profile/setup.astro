---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
if (!user) return Astro.redirect("/login");

const interestOptions = [
  "🍽️ Food & Dining","🍺 Craft Beer","🥾 Hiking","🎲 Board Games",
  "🎵 Live Music","🎨 Art & Culture","🎳 Bowling","💪 Fitness",
  "😂 Comedy","🎰 Casino Trips","🏔️ Outdoors","☕ Coffee & Cafes",
  "🧠 Trivia","🎤 Karaoke","🏒 Sports","📸 Photography",
];

const neighborhoods = [
  "LoDo / Downtown","RiNo / River North","Five Points","Curtis Park",
  "Capitol Hill","Cheesman Park","Congress Park","Uptown",
  "Cherry Creek","Hilltop","Stapleton / Central Park",
  "Washington Park","Platt Park","Baker","Green Valley Ranch",
  "Highlands / LoHi","Sunnyside","Berkeley","Sloan's Lake",
  "Englewood","Littleton","Centennial","Parker",
  "Lakewood","Golden","Arvada",
  "Westminster","Thornton","Broomfield",
  "Aurora","Boulder","Other / Outside Denver"
];
---
<Base title="Set up your profile">
  <div class="setup-page">
    <div class="setup-card">
      <h1 class="setup-title">Welcome to Denver Social Hub!</h1>
      <p class="setup-sub">Tell us a bit about yourself so others can connect with you.</p>

      <form id="setup-form">
        <label class="input-label" for="name-input">Your name *</label>
        <input type="text" id="name-input" class="input" placeholder="How you'd like to be called" required value={user.name || ''} />

        <label class="input-label" for="photo-input">Profile photo URL</label>
        <input type="url" id="photo-input" class="input" placeholder="https://i.imgur.com/yourphoto.jpg" />
        <p class="input-hint">Paste a link to a photo — Instagram, Imgur, or any image URL works</p>

        <label class="input-label" for="bio-input">Short bio</label>
        <textarea id="bio-input" class="input textarea" placeholder="A sentence or two about you..." maxlength="280"></textarea>

        <label class="input-label" for="neighborhood-select">Neighborhood</label>
        <select id="neighborhood-select" class="input">
          <option value="">Pick your area</option>
          {neighborhoods.map(n => <option value={n}>{n}</option>)}
        </select>

        <label class="input-label">Interests (pick a few)</label>
        <div class="tag-grid" id="interests-grid">
          {interestOptions.map(opt => (
            <button type="button" class="tag-btn" data-value={opt}>{opt}</button>
          ))}
        </div>

        <label class="input-label" for="instagram-input">Instagram (optional)</label>
        <div class="social-input-row">
          <span class="social-prefix">@</span>
          <input type="text" id="instagram-input" class="input social-input" placeholder="yourhandle" />
        </div>

        <label class="input-label" for="linkedin-input">LinkedIn (optional)</label>
        <input type="url" id="linkedin-input" class="input" placeholder="https://linkedin.com/in/you" />

        <button type="submit" id="save-btn" class="btn btn-primary btn-full">Save & start exploring</button>
        <a href="/events" class="btn btn-ghost btn-full">Skip for now</a>
      </form>

      <div id="setup-status" class="setup-status"></div>
    </div>
  </div>
</Base>

<style is:inline>
  .setup-page {
    max-width: 520px;
    margin: 40px auto 0;
    padding: 0 20px 80px;
  }
  .setup-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px 32px;
  }
  .setup-title {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .setup-sub {
    font-size: 14px;
    color: var(--text-sec);
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .input-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-sec);
    margin-bottom: 6px;
    margin-top: 18px;
  }
  .input-label:first-of-type { margin-top: 0; }
  .input {
    width: 100%;
    padding: 12px 14px;
    background: var(--bg, #0a0a0a);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 15px;
    outline: none;
    transition: border-color .2s;
    box-sizing: border-box;
  }
  .input:focus { border-color: var(--accent); }
  .textarea { min-height: 80px; resize: vertical; font-family: inherit; }
  .input-hint {
    font-size: 12px;
    color: var(--text-faint, #666);
    margin-top: 4px;
  }
  .tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .tag-btn {
    padding: 8px 14px;
    background: var(--bg, #0a0a0a);
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--text-sec);
    font-size: 13px;
    cursor: pointer;
    transition: all .2s;
  }
  .tag-btn:hover { border-color: var(--accent); color: var(--text); }
  .tag-btn.selected {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .social-input-row {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .social-prefix {
    padding: 12px 0 12px 14px;
    background: var(--bg, #0a0a0a);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    color: var(--text-faint);
    font-size: 15px;
  }
  .social-input {
    border-radius: 0 8px 8px 0;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all .2s;
  }
  .btn-full { width: 100%; margin-top: 14px; }
  .btn-primary {
    background: var(--accent);
    color: #fff;
    margin-top: 28px;
  }
  .btn-primary:hover { opacity: .9; transform: translateY(-1px); }
  .btn-primary:disabled { opacity: .5; cursor: not-allowed; transform: none; }
  .btn-ghost {
    background: transparent;
    color: var(--text-sec);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface-raised, rgba(255,255,255,0.05)); }
  .setup-status {
    font-size: 13px;
    margin-top: 12px;
    min-height: 20px;
    text-align: center;
  }
  .setup-status.error { color: var(--red, #ff4757); }

  @media (max-width: 480px) {
    .setup-page { margin-top: 20px; }
    .setup-card { padding: 28px 20px; }
  }
</style>

<script is:inline>
  // Tag selection
  document.querySelectorAll('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => btn.classList.toggle('selected'));
  });

  const form = document.getElementById('setup-form');
  const statusEl = document.getElementById('setup-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('name-input').value.trim();
    if (!name) { statusEl.textContent = 'Name is required.'; statusEl.className = 'setup-status error'; return; }

    const saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    const interests = [...document.querySelectorAll('.tag-btn.selected')].map(b => b.dataset.value);
    const data = {
      name,
      photo_url: document.getElementById('photo-input').value.trim(),
      bio: document.getElementById('bio-input').value.trim(),
      neighborhood: document.getElementById('neighborhood-select').value,
      interests: interests.join(','),
      instagram: document.getElementById('instagram-input').value.trim().replace(/^@/, ''),
      linkedin: document.getElementById('linkedin-input').value.trim(),
    };

    try {
      const res = await fetch('/api/profile/setup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.ok) {
        window.location.href = '/events';
      } else {
        statusEl.textContent = result.error || 'Failed to save.';
        statusEl.className = 'setup-status error';
      }
    } catch {
      statusEl.textContent = 'Network error. Try again.';
      statusEl.className = 'setup-status error';
    }
    saveBtn.disabled = false;
    saveBtn.textContent = 'Save & start exploring';
  });
</script>
