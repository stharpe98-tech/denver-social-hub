---
import Base from '../../layouts/Base.astro';

const initialMode = (Astro.url.searchParams.get('mode') || 'signup').toLowerCase() === 'signin' ? 'signin' : 'signup';
const initialTier = (Astro.url.searchParams.get('tier') || 'regular').toLowerCase() === 'organizer' ? 'organizer' : 'regular';
---
<Base title="Sign in · Sign up — Denver Social" description="Sign in to your /u/ page, or sign up as a regular member or organizer.">
  <div class="wrap" data-init-mode={initialMode} data-init-tier={initialTier}>

    <!-- Top mode toggle: Sign in / Sign up -->
    <div class="mode-toggle" role="tablist" aria-label="Sign in or sign up">
      <button class="mode-btn" id="mode-signin" data-mode="signin" role="tab">Sign in</button>
      <button class="mode-btn" id="mode-signup" data-mode="signup" role="tab">Sign up</button>
    </div>

    <!-- ───────── SIGN IN PANEL ───────── -->
    <section class="panel" id="panel-signin" hidden>
      <header class="intro">
        <h1>Welcome back.</h1>
        <p class="sub">Enter your <span class="mono">/u/yourname</span> URL. We'll email a code to the address on file.</p>
      </header>

      <div class="card" id="si-step1">
        <div class="field">
          <label>Your email <span class="opt">(the one you signed up with)</span></label>
          <input id="si-email" type="email" placeholder="you@example.com" autocomplete="email"/>
        </div>
        <button class="cta" id="si-send-btn">Email me a code →</button>
        <div class="err" id="si-send-err"></div>
        <p class="foot">Don't have an account? <a href="?mode=signup">Sign up →</a></p>
      </div>

      <div class="card" id="si-step2" hidden>
        <h3 class="card-h">Check your inbox</h3>
        <p class="card-sub">We sent a 6-digit code to <span class="mono" id="si-confirm-email"></span>.</p>
        <div class="field">
          <label>6-digit code</label>
          <input id="si-code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" placeholder="••••••"/>
        </div>
        <button class="cta" id="si-verify-btn">Sign in →</button>
        <button class="link" id="si-resend-btn" type="button">Send me a new code</button>
        <button class="link" id="si-back-btn" type="button">Use a different email</button>
        <div class="err" id="si-code-err"></div>
        <div class="ok" id="si-resend-ok" hidden>✓ New code sent.</div>
      </div>
    </section>

    <!-- ───────── SIGN UP PANEL ───────── -->
    <section class="panel" id="panel-signup" hidden>
      <header class="intro">
        <h1>Get on Denver Social.</h1>
        <p class="sub">Pick your kind of presence. Both are free.</p>
      </header>

      <!-- Tier toggle: Regular / Organizer -->
      <div class="tier-toggle" role="tablist" aria-label="Pick a tier">
        <button class="tier-btn" id="tier-regular" data-tier="regular" role="tab">
          <span class="tier-emoji">👋</span>
          <span class="tier-name">Regular</span>
          <span class="tier-blurb">Save your identity. Post on the board. RSVP. Host up to 3 events.</span>
        </button>
        <button class="tier-btn" id="tier-organizer" data-tier="organizer" role="tab">
          <span class="tier-emoji">✨</span>
          <span class="tier-name">Organizer</span>
          <span class="tier-blurb">Public page at /u/yourname, unlimited hosting, groups.</span>
        </button>
      </div>

      <!-- REGULAR sub-panel -->
      <div class="card" id="reg-step1" hidden>
        <div class="field">
          <label>Your name <span class="opt">(shows on RSVPs and posts)</span></label>
          <input id="reg-name" type="text" placeholder="Jamie" maxlength="60" autocomplete="name"/>
        </div>
        <div class="field">
          <label>Your email <span class="opt">(never shown publicly)</span></label>
          <input id="reg-email" type="email" placeholder="you@example.com" autocomplete="email"/>
        </div>
        <button class="cta" id="reg-send-btn">Send me a code →</button>
        <div class="err" id="reg-send-err"></div>
      </div>

      <div class="card" id="reg-step2" hidden>
        <h3 class="card-h">Enter your code</h3>
        <p class="card-sub">We sent a 6-digit code to <span class="mono" id="reg-confirm-email"></span>.</p>
        <div class="field">
          <label>6-digit code</label>
          <input id="reg-code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" placeholder="••••••"/>
        </div>
        <button class="cta" id="reg-verify-btn">Verify & continue →</button>
        <button class="link" id="reg-resend-btn" type="button">Send me a new code</button>
        <button class="link" id="reg-back-btn" type="button">Use a different email</button>
        <div class="err" id="reg-code-err"></div>
        <div class="ok" id="reg-resend-ok" hidden>✓ New code sent.</div>
      </div>

      <!-- ORGANIZER sub-panel -->
      <div class="card" id="org-step1" hidden>
        <div class="field">
          <label>Pick your URL</label>
          <div class="slug-row">
            <span class="slug-prefix">denversocialhub.com/u/</span>
            <input id="org-slug" type="text" placeholder="jimmy" autocomplete="off" autocapitalize="off" maxlength="30"/>
          </div>
          <div class="slug-check" id="org-slug-check"></div>
        </div>
        <div class="field">
          <label>Your email <span class="opt">(never shown publicly)</span></label>
          <input id="org-email" type="email" placeholder="you@example.com" autocomplete="email"/>
        </div>
        <button class="cta" id="org-send-btn">Send me a code →</button>
        <div class="err" id="org-send-err"></div>
      </div>

      <div class="card" id="org-step2" hidden>
        <h3 class="card-h">Enter your code</h3>
        <p class="card-sub">Check your email for a 6-digit code.</p>
        <div class="field">
          <label>6-digit code</label>
          <input id="org-code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" placeholder="••••••"/>
        </div>
        <button class="cta" id="org-verify-btn">Verify & start editing →</button>
        <button class="link" id="org-resend-btn" type="button">Send me a new code</button>
        <button class="link" id="org-back-btn" type="button">Use a different URL</button>
        <div class="err" id="org-code-err"></div>
        <div class="ok" id="org-resend-ok" hidden>✓ New code sent.</div>
      </div>

      <p class="foot">Already on Denver Social? <a href="?mode=signin">Sign in →</a></p>
    </section>

  </div>

  <script is:inline>
    (function() {
      var wrap = document.querySelector('.wrap');
      var initialMode = wrap.dataset.initMode || 'signup';
      var initialTier = wrap.dataset.initTier || 'regular';

      function showErr(id, msg) { var el = document.getElementById(id); el.textContent = msg; el.classList.add('show'); }
      function clearErr(id) { var el = document.getElementById(id); el.textContent = ''; el.classList.remove('show'); }

      // ─── mode toggle (sign in / sign up) ───
      var modeBtns = document.querySelectorAll('.mode-btn');
      function setMode(mode) {
        modeBtns.forEach(function(b) { b.classList.toggle('on', b.dataset.mode === mode); b.setAttribute('aria-selected', b.dataset.mode === mode ? 'true' : 'false'); });
        document.getElementById('panel-signin').hidden = mode !== 'signin';
        document.getElementById('panel-signup').hidden = mode !== 'signup';
        try { var u = new URL(window.location.href); u.searchParams.set('mode', mode); history.replaceState({}, '', u.toString()); } catch (e) {}
      }
      modeBtns.forEach(function(b) { b.addEventListener('click', function() { setMode(b.dataset.mode); }); });

      // ─── tier toggle (regular / organizer) ───
      var tierBtns = document.querySelectorAll('.tier-btn');
      function setTier(tier) {
        tierBtns.forEach(function(b) { b.classList.toggle('on', b.dataset.tier === tier); b.setAttribute('aria-selected', b.dataset.tier === tier ? 'true' : 'false'); });
        document.getElementById('reg-step1').hidden = tier !== 'regular';
        document.getElementById('reg-step2').hidden = true;
        document.getElementById('org-step1').hidden = tier !== 'organizer';
        document.getElementById('org-step2').hidden = true;
        try { var u = new URL(window.location.href); u.searchParams.set('tier', tier); history.replaceState({}, '', u.toString()); } catch (e) {}
      }
      tierBtns.forEach(function(b) { b.addEventListener('click', function() { setTier(b.dataset.tier); }); });

      // ─── slug validation ───
      var SLUG_RE = /^[a-z0-9][a-z0-9-]{1,28}[a-z0-9]$/;
      var RESERVED = ['new','admin','api','edit','login','signin','signup'];
      function validSlug(s) {
        if (!s) return { ok: false, msg: '' };
        if (s.length < 3) return { ok: false, msg: 'Too short (min 3)' };
        if (!SLUG_RE.test(s)) return { ok: false, msg: 'Lowercase letters, numbers, hyphens only' };
        if (RESERVED.indexOf(s) >= 0) return { ok: false, msg: 'That URL is reserved' };
        return { ok: true, msg: '✓ looks good' };
      }

      var orgSlug = document.getElementById('org-slug');
      var orgCheck = document.getElementById('org-slug-check');
      orgSlug.addEventListener('input', function() {
        var s = orgSlug.value.toLowerCase().trim();
        orgSlug.value = s;
        var v = validSlug(s);
        orgCheck.textContent = v.msg;
        orgCheck.style.color = v.ok ? '#047857' : '#DC2626';
      });

      // ─── SIGN IN flow (email-based — works for regulars and organizers) ───
      document.getElementById('si-send-btn').addEventListener('click', async function() {
        clearErr('si-send-err');
        var email = (document.getElementById('si-email').value || '').trim().toLowerCase();
        if (!email || email.indexOf('@') < 0) { showErr('si-send-err', 'Enter a valid email.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/signin-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email }) });
          var d = await r.json();
          if (d && d.ok) {
            document.getElementById('si-step1').hidden = true;
            document.getElementById('si-step2').hidden = false;
            document.getElementById('si-confirm-email').textContent = email;
            document.getElementById('si-code').focus();
          } else { showErr('si-send-err', (d && d.error) || 'Could not send code.'); }
        } catch (e) { showErr('si-send-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('si-verify-btn').addEventListener('click', async function() {
        clearErr('si-code-err');
        var email = (document.getElementById('si-email').value || '').trim().toLowerCase();
        var code = (document.getElementById('si-code').value || '').trim();
        if (!/^\d{6}$/.test(code)) { showErr('si-code-err', 'Enter the 6-digit code.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Verifying…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/signin-verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email, code: code }) });
          var d = await r.json();
          if (d.ok) { location.href = d.redirect || '/profile'; return; }
          showErr('si-code-err', d.error || 'Invalid or expired code.');
        } catch (e) { showErr('si-code-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('si-back-btn').addEventListener('click', function() {
        document.getElementById('si-step2').hidden = true;
        document.getElementById('si-step1').hidden = false;
        document.getElementById('si-email').focus();
      });

      document.getElementById('si-resend-btn').addEventListener('click', async function() {
        var email = (document.getElementById('si-email').value || '').trim().toLowerCase();
        if (!email) return;
        clearErr('si-code-err');
        document.getElementById('si-resend-ok').hidden = true;
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/signin-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email }) });
          var d = await r.json();
          if (d && d.ok) {
            document.getElementById('si-resend-ok').hidden = false;
            setTimeout(function() { document.getElementById('si-resend-ok').hidden = true; }, 4000);
          } else { showErr('si-code-err', (d && d.error) || 'Could not send a new code.'); }
        } catch (e) { showErr('si-code-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      // ─── REGULAR signup flow ───
      document.getElementById('reg-send-btn').addEventListener('click', async function() {
        clearErr('reg-send-err');
        var name = (document.getElementById('reg-name').value || '').trim();
        var email = (document.getElementById('reg-email').value || '').trim().toLowerCase();
        if (!name) { showErr('reg-send-err', 'Enter your name.'); return; }
        if (!email || email.indexOf('@') < 0) { showErr('reg-send-err', 'Enter a valid email.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/regular-code-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, email: email }) });
          var d = await r.json();
          if (d && d.ok) {
            document.getElementById('reg-step1').hidden = true;
            document.getElementById('reg-step2').hidden = false;
            document.getElementById('reg-confirm-email').textContent = email;
            document.getElementById('reg-code').focus();
          } else { showErr('reg-send-err', (d && d.error) || 'Could not send code.'); }
        } catch (e) { showErr('reg-send-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('reg-verify-btn').addEventListener('click', async function() {
        clearErr('reg-code-err');
        var name = (document.getElementById('reg-name').value || '').trim();
        var email = (document.getElementById('reg-email').value || '').trim().toLowerCase();
        var code = (document.getElementById('reg-code').value || '').trim();
        if (!/^\d{6}$/.test(code)) { showErr('reg-code-err', 'Enter the 6-digit code.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Verifying…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/regular-code-verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, email: email, code: code }) });
          var d = await r.json();
          if (d.ok) { location.href = d.redirect || '/profile'; return; }
          showErr('reg-code-err', d.error || 'Invalid or expired code.');
        } catch (e) { showErr('reg-code-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('reg-back-btn').addEventListener('click', function() {
        document.getElementById('reg-step2').hidden = true;
        document.getElementById('reg-step1').hidden = false;
        document.getElementById('reg-email').focus();
      });

      document.getElementById('reg-resend-btn').addEventListener('click', async function() {
        var name = (document.getElementById('reg-name').value || '').trim();
        var email = (document.getElementById('reg-email').value || '').trim().toLowerCase();
        if (!name || !email) return;
        clearErr('reg-code-err');
        document.getElementById('reg-resend-ok').hidden = true;
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/regular-code-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, email: email }) });
          var d = await r.json();
          if (d && d.ok) {
            document.getElementById('reg-resend-ok').hidden = false;
            setTimeout(function() { document.getElementById('reg-resend-ok').hidden = true; }, 4000);
          } else { showErr('reg-code-err', (d && d.error) || 'Could not send a new code.'); }
        } catch (e) { showErr('reg-code-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      // ─── ORGANIZER signup flow ───
      document.getElementById('org-send-btn').addEventListener('click', async function() {
        clearErr('org-send-err');
        var slug = (document.getElementById('org-slug').value || '').trim().toLowerCase();
        var email = (document.getElementById('org-email').value || '').trim().toLowerCase();
        var v = validSlug(slug);
        if (!v.ok) { showErr('org-send-err', v.msg || 'Pick a URL.'); return; }
        if (!email || email.indexOf('@') < 0) { showErr('org-send-err', 'Enter a valid email.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/code-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug: slug, email: email }) });
          var d = await r.json();
          if (d && d.ok) {
            document.getElementById('org-step1').hidden = true;
            document.getElementById('org-step2').hidden = false;
            document.getElementById('org-code').focus();
          } else { showErr('org-send-err', (d && d.error) || 'Could not send code.'); }
        } catch (e) { showErr('org-send-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('org-verify-btn').addEventListener('click', async function() {
        clearErr('org-code-err');
        var slug = (document.getElementById('org-slug').value || '').trim().toLowerCase();
        var email = (document.getElementById('org-email').value || '').trim().toLowerCase();
        var code = (document.getElementById('org-code').value || '').trim();
        if (!/^\d{6}$/.test(code)) { showErr('org-code-err', 'Enter the 6-digit code.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Verifying…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/code-verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug: slug, email: email, code: code }) });
          var d = await r.json();
          if (d.ok) { location.href = d.redirect || ('/u/' + slug + '/edit'); return; }
          showErr('org-code-err', d.error || 'Invalid or expired code.');
        } catch (e) { showErr('org-code-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('org-back-btn').addEventListener('click', function() {
        document.getElementById('org-step2').hidden = true;
        document.getElementById('org-step1').hidden = false;
        document.getElementById('org-slug').focus();
      });

      document.getElementById('org-resend-btn').addEventListener('click', async function() {
        var slug = (document.getElementById('org-slug').value || '').trim().toLowerCase();
        var email = (document.getElementById('org-email').value || '').trim().toLowerCase();
        if (!slug || !email) return;
        clearErr('org-code-err');
        document.getElementById('org-resend-ok').hidden = true;
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/profile/code-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug: slug, email: email }) });
          var d = await r.json();
          if (d && d.ok) {
            document.getElementById('org-resend-ok').hidden = false;
            setTimeout(function() { document.getElementById('org-resend-ok').hidden = true; }, 4000);
          } else { showErr('org-code-err', (d && d.error) || 'Could not send a new code.'); }
        } catch (e) { showErr('org-code-err', 'Network hiccup — try again.'); }
        btn.textContent = orig; btn.disabled = false;
      });

      // initial state
      setMode(initialMode);
      setTier(initialTier);
    })();
  </script>

  <style>
    .wrap {
      max-width: 520px; margin: 0 auto;
      padding: var(--space-6) var(--space-4) var(--space-8);
      background:
        radial-gradient(circle at 20% 18%, rgba(255,255,255,0.45) 0%, transparent 55%),
        radial-gradient(circle at 80% 75%, rgba(0,0,0,0.04) 0%, transparent 55%),
        repeating-linear-gradient(125deg, transparent 0 3px, rgba(0,0,0,0.022) 3px 4px),
        linear-gradient(160deg, #E8DFCF 0%, #D8CBB4 100%);
      min-height: 100vh; box-sizing: border-box;
    }

    .mode-toggle {
      display: flex; gap: 0; background: rgba(0,0,0,0.08);
      padding: 4px; border-radius: 999px; margin: 0 auto var(--space-5);
      max-width: 320px;
    }
    .mode-btn {
      flex: 1; padding: 10px 18px; border: none; background: transparent;
      font-size: 14px; font-weight: 700; color: #555; cursor: pointer; border-radius: 999px;
      font-family: inherit; transition: background 0.15s, color 0.15s;
    }
    .mode-btn.on { background: #fff; color: #1A1A1A; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }

    .intro { text-align: center; margin-bottom: var(--space-4); }
    .intro h1 { font-family: var(--font-display, 'Playfair Display', serif); font-size: clamp(28px, 5vw, 36px); font-weight: 800; line-height: 1.1; margin-bottom: var(--space-2); }
    .sub { font-size: 15px; color: var(--text-sec, #555); line-height: 1.5; }
    .mono { font-family: 'SF Mono', Menlo, monospace; background: rgba(124,58,237,0.10); padding: 1px 6px; border-radius: 4px; font-size: 0.92em; color: var(--accent, #7C3AED); }

    .tier-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: var(--space-4); }
    .tier-btn {
      background: #FFFEFA; border: 1.5px solid rgba(0,0,0,0.08);
      padding: 18px 16px; border-radius: 14px; cursor: pointer; text-align: left;
      transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
      display: flex; flex-direction: column; gap: 6px; font-family: inherit;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .tier-btn:hover { transform: translateY(-2px); border-color: rgba(0,0,0,0.18); }
    .tier-btn.on { border-color: var(--accent, #7C3AED); box-shadow: 0 6px 20px rgba(124,58,237,0.18); background: linear-gradient(135deg, #FFFEFA, #FAF5FF); }
    .tier-btn.on .tier-name { color: var(--accent, #7C3AED); }
    .tier-emoji { font-size: 24px; }
    .tier-name { font-weight: 800; font-size: 16px; color: #1A1A1A; }
    .tier-blurb { font-size: 12px; color: var(--text-sec, #555); line-height: 1.4; }

    .card { background: #FFFEFA; border: 1.5px solid rgba(0,0,0,0.08); border-radius: var(--radius-lg, 18px); padding: var(--space-4) var(--space-5); margin-bottom: var(--space-3); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .card-h { font-family: var(--font-display, serif); font-size: 20px; font-weight: 800; text-align: center; margin-bottom: 4px; }
    .card-sub { text-align: center; font-size: 14px; color: var(--text-sec, #555); margin-bottom: var(--space-3); }

    .field { margin-bottom: var(--space-3); }
    .field label { display: block; font-size: 12px; font-weight: 600; color: var(--text-sec, #555); margin-bottom: 6px; }
    .field label .opt { font-weight: 400; color: var(--text-faint, #888); }
    .field input { width: 100%; padding: 11px 13px; border-radius: 10px; border: 1.5px solid var(--border, #E5E7EB); font-size: 14px; background: #fff; font-family: inherit; }
    .field input:focus { outline: none; border-color: var(--accent, #7C3AED); }
