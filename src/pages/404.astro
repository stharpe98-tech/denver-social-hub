---
import Base from '../layouts/Base.astro';
---
<Base title="Not Found" description="That page doesn't exist.">
  <div class="nf-wrap">
    <div class="nf-emoji">🏔️</div>
    <h1>Lost in Denver</h1>
    <p>That page doesn't exist. Happens to the best of us.</p>
    <a href="/" class="btn-cta">Back home →</a>
  </div>

  <style>
    .nf-wrap { max-width: 480px; margin: 0 auto; padding: var(--space-8) var(--space-5); text-align: center; }
    .nf-emoji { font-size: 64px; margin-bottom: var(--space-3); }
    .nf-wrap h1 { font-family: var(--font-display); font-size: clamp(28px, 4vw, 36px); font-weight: 800; color: var(--text); margin-bottom: var(--space-2); letter-spacing: -0.02em; }
    .nf-wrap p { color: var(--text-sec); font-size: 16px; margin-bottom: var(--space-5); }
  </style>
</Base>
