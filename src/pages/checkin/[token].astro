---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const db = getDB();
const { token } = Astro.params;

let rsvp: any = null;
let event: any = null;
let status: 'ok' | 'already' | 'invalid' = 'invalid';

if (db && token) {
  rsvp = await db.prepare('SELECT * FROM event_rsvps WHERE checkin_token=?').bind(token).first();
  if (rsvp) {
    event = await db.prepare('SELECT id, title, event_month, event_day, location, zone FROM events WHERE id=?').bind(rsvp.event_id).first();
    if (rsvp.checked_in) {
      status = 'already';
    } else {
      await db.prepare("UPDATE event_rsvps SET checked_in=1, checked_in_at=datetime('now') WHERE checkin_token=?").bind(token).run();
      status = 'ok';
    }
  }
}
---
<Base title="Check in" description="Mark yourself as arrived at a Denver Social event.">
<div class="ci-wrap">
  {status === 'invalid' && (
    <div class="ci-card ci-card-bad">
      <div class="ci-emoji">🤔</div>
      <h1>Check-in link not found</h1>
      <p>That link doesn't match any RSVP. Ask the host if you think this is wrong.</p>
      <a href="/events" class="btn-cta">Back to events</a>
    </div>
  )}
  {status === 'already' && event && (
    <div class="ci-card">
      <div class="ci-emoji">👋</div>
      <h1>You're already checked in!</h1>
      <p>For <strong>{event.title}</strong> on {event.event_month} {event.event_day}.</p>
      <p class="ci-sub">Have fun.</p>
      <a href={`/events/${event.id}`} class="btn-cta">Back to the event</a>
    </div>
  )}
  {status === 'ok' && event && (
    <div class="ci-card ci-card-ok">
      <div class="ci-emoji">🎉</div>
      <h1>You're checked in!</h1>
      <p>For <strong>{event.title}</strong> on {event.event_month} {event.event_day}{event.location ? ` at ${event.location}` : ''}.</p>
      <p class="ci-sub">Find the host, grab a seat, you're set.</p>
      <a href={`/events/${event.id}`} class="btn-cta">Back to the event</a>
    </div>
  )}
</div>

<style is:inline>
  .ci-wrap { max-width: 460px; margin: 0 auto; padding: 64px 24px; }
  .ci-card { text-align: center; padding: 36px clamp(20px, 4vw, 40px); border-radius: 24px; background: var(--bg); border: 1px solid var(--border); box-shadow: 0 8px 32px rgba(0,0,0,0.06); }
  .ci-card-ok {
    background: linear-gradient(160deg, var(--sunset-dim), var(--pink-dim), rgba(16,185,129,0.10));
    border-color: rgba(249,115,22,0.25);
  }
  .ci-card-bad { background: var(--surface); border-color: var(--border); }
  .ci-emoji { font-size: 64px; margin-bottom: 14px; }
  .ci-card h1 { font-family: var(--font-display); font-size: clamp(24px, 4vw, 30px); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 12px; color: var(--text); }
  .ci-card p { font-size: 16px; color: var(--text-sec); line-height: 1.5; margin-bottom: 12px; }
  .ci-card strong { color: var(--text); font-weight: 700; }
  .ci-sub { font-size: 14px !important; }
  .ci-card .btn-cta { margin-top: 16px; }
</style>
</Base>
