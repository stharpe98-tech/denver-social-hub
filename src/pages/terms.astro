---
import Base from '../layouts/Base.astro';
---
<Base title="Terms of Service">
  <div style="max-width:600px;margin:0 auto;padding:24px 20px">
    <h1 style="font-size:28px;color:#fff;margin-bottom:16px">Terms of Service</h1>
    <div style="font-size:14px;color:#6b7a8e;line-height:1.8">
      <p style="margin-bottom:8px"><b style="color:#e8ecf4">Free to use.</b> Denver Social is free. No membership fees, ever.</p>
      <p style="margin-bottom:8px"><b style="color:#e8ecf4">Your data.</b> We store your name and email to run the service. We don't sell your data.</p>
      <p style="margin-bottom:8px"><b style="color:#e8ecf4">Event costs.</b> Each event may have its own costs between you and the venue — DSN doesn't take a cut.</p>
      <p style="margin-bottom:8px"><b style="color:#e8ecf4">Deposits.</b> Some events require a refundable deposit. Show up → get it back. No-show → it goes to the Spot a Stranger fund.</p>
      <p style="margin-bottom:8px"><b style="color:#e8ecf4">Account termination.</b> We can remove accounts that violate our Code of Conduct.</p>
      <p style="margin-bottom:8px"><b style="color:#e8ecf4">Liability.</b> Denver Social organizes events but isn't liable for what happens at them. Attend at your own risk.</p>
      <p style="margin-top:20px;font-size:12px;color:#4a5568">Last updated: March 2026</p>
    </div>
  </div>
</Base>
