---
import Base from '../layouts/Base.astro';
---
<Base title="Terms of Service" description="Plain-English terms for using Denver Social.">
  <div class="legal-page">
    <h1>Terms of Service</h1>
    <p><b>Free to use.</b> Denver Social is free. No membership fees, ever.</p>
    <p><b>Your data.</b> We store your name and email to run the service. We don't sell your data.</p>
    <p><b>Event costs.</b> Each event may have its own costs between you and the venue — Denver Social doesn't take a cut.</p>
    <p><b>Deposits.</b> Some events require a refundable deposit. Show up → get it back. No-show → forfeited.</p>
    <p><b>Account termination.</b> We can remove accounts that violate our Code of Conduct.</p>
    <p><b>Liability.</b> Denver Social organizes events but isn't liable for what happens at them. Attend at your own risk.</p>
    <p class="legal-updated">Last updated: March 2026</p>
  </div>

  <style>
    .legal-page { max-width: 640px; margin: 0 auto; padding: var(--space-7) var(--space-5); }
    .legal-page h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 40px); font-weight: 800; color: var(--text); margin-bottom: var(--space-5); letter-spacing: -0.02em; }
    .legal-page p { font-size: 15px; color: var(--text-sec); line-height: 1.7; margin-bottom: var(--space-3); }
    .legal-page p b { color: var(--text); font-weight: 600; }
    .legal-page .legal-updated { font-size: 12px; color: var(--text-faint); margin-top: var(--space-5); }
  </style>
</Base>
