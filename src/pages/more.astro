---
import Base from '../layouts/Base.astro';

const tiles = [
  { href: '/welcome',        emoji: '👋', label: 'New here',        sub: 'Say hi, see other intros' },
  { href: '/neighborhoods',  emoji: '📍', label: 'Neighborhoods',   sub: 'Find your local chapter' },
  { href: '/help-out',       emoji: '🤝', label: 'Help out',        sub: 'Favors board — give & ask' },
  { href: '/calendar',       emoji: '📆', label: 'Calendar',        sub: 'Denver dates we all share' },
  { href: '/profile',        emoji: '👤', label: 'Your profile',    sub: 'Hangouts, streak, level' },
  { href: '/about',          emoji: 'ℹ️',  label: 'About',           sub: 'What this is' },
  { href: '/help',           emoji: '❓', label: 'Help & Safety',   sub: 'FAQ + rules + transparency' },
  { href: '/contact',        emoji: '✉️', label: 'Contact',         sub: 'Send us a message' },
];
---
<Base title="More" description="Everything else on Denver Social — in one place.">
<div class="m-wrap">
  <header class="m-head">
    <h1>More</h1>
    <p>Everything else, in one place.</p>
  </header>

  <div class="m-grid">
    {tiles.map(t => (
      <a href={t.href} class="m-tile">
        <span class="m-emoji">{t.emoji}</span>
        <div>
          <strong>{t.label}</strong>
          <span>{t.sub}</span>
        </div>
        <span class="m-arrow">›</span>
      </a>
    ))}
  </div>
</div>

<style>
  .m-wrap { max-width: 760px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .m-head { margin-bottom: 24px; text-align: center; }
  .m-head h1 { font-family: var(--font-display); font-size: clamp(30px, 5vw, 40px); font-weight: 900; letter-spacing: -0.025em; }
  .m-head p { font-size: 15px; color: var(--text-sec); margin-top: 6px; }

  .m-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
  @media (min-width: 540px) { .m-grid { grid-template-columns: 1fr 1fr; } }

  .m-tile {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 18px; background: var(--bg);
    border: 1px solid var(--border); border-radius: 14px;
    text-decoration: none; color: var(--text);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .m-tile:hover { transform: translateY(-1px); box-shadow: var(--card-shadow); border-color: var(--border-hover); }
  .m-emoji { font-size: 28px; flex-shrink: 0; line-height: 1; }
  .m-tile strong { display: block; font-family: var(--font-display); font-size: 15px; font-weight: 800; color: var(--text); }
  .m-tile span:not(.m-emoji):not(.m-arrow) { display: block; font-size: 13px; color: var(--text-sec); margin-top: 2px; }
  .m-tile > div { flex: 1; min-width: 0; }
  .m-arrow { font-size: 26px; color: var(--text-faint); flex-shrink: 0; }
</style>
</Base>
