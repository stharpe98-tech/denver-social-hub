---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" description="Get in touch with Denver Social.">
<div class="ct-wrap">
  <header class="ct-head">
    <span class="ct-eyebrow">Contact</span>
    <h1>Drop us a line.</h1>
    <p class="ct-lede">Question, idea, business inquiry, or just want to say hi? This goes straight to Seth's inbox.</p>
  </header>

  <form id="contact-form" class="ct-form">
    <div class="ct-field">
      <label for="ct-name">Your name <span class="req">*</span></label>
      <input type="text" id="ct-name" class="ct-input" placeholder="Sarah" required />
    </div>
    <div class="ct-field">
      <label for="ct-email">Email <span class="opt">(include if you want a reply)</span></label>
      <input type="email" id="ct-email" class="ct-input" placeholder="you@example.com" />
    </div>
    <div class="ct-field">
      <label for="ct-subject">Subject</label>
      <input type="text" id="ct-subject" class="ct-input" placeholder="What's this about?" />
    </div>
    <div class="ct-field">
      <label for="ct-message">Message <span class="req">*</span></label>
      <textarea id="ct-message" class="ct-input ct-textarea" rows="5" placeholder="Tell us what's on your mind…" required></textarea>
      <span class="ct-charcount"><span id="ct-chars">0</span>/2000</span>
    </div>
    <button type="submit" class="ct-submit">Send message →</button>
    <div class="ct-error" id="ct-err"></div>
  </form>

  <div class="ct-success" id="ct-ok">
    <span class="ct-success-emoji">📬</span>
    <h2>Got it.</h2>
    <p>Thanks for reaching out. If you included your email, we'll get back to you soon.</p>
    <a href="/" class="btn-sec">Back home</a>
  </div>
</div>

<style>
  .ct-wrap { max-width: 560px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }

  .ct-head { margin-bottom: 28px; text-align: center; }
  .ct-eyebrow {
    display: inline-block; font-family: var(--font-display);
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-dim);
    padding: 6px 14px; border-radius: 999px; margin-bottom: 16px;
  }
  .ct-head h1 {
    font-family: var(--font-display); font-size: clamp(30px, 5vw, 40px);
    font-weight: 900; letter-spacing: -0.025em; color: var(--text); margin-bottom: 10px;
  }
  .ct-lede { font-size: 16px; color: var(--text-sec); line-height: 1.55; max-width: 480px; margin: 0 auto; }

  .ct-form {
    display: flex; flex-direction: column; gap: 16px;
    padding: 24px clamp(20px, 4vw, 28px);
    background: var(--bg); border: 1px solid var(--border); border-radius: 18px;
  }
  .ct-field { display: flex; flex-direction: column; gap: 8px; }
  .ct-field label {
    font-family: var(--font-display); font-size: 12px; font-weight: 700;
    color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.06em;
  }
  .req { color: var(--accent); font-weight: 500; text-transform: none; letter-spacing: 0; }
  .opt { color: var(--text-faint); font-weight: 500; text-transform: none; letter-spacing: 0; }
  .ct-input {
    width: 100%; padding: 12px 14px;
    background: var(--bg); border: 1px solid var(--border); border-radius: 12px;
    font-size: 15px; color: var(--text); font-family: var(--font);
    -webkit-appearance: none; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .ct-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .ct-textarea { resize: vertical; min-height: 120px; line-height: 1.55; }
  .ct-charcount { font-size: 11px; color: var(--text-faint); text-align: right; }

  .ct-submit {
    padding: 14px; border-radius: 999px; border: none;
    background: var(--cta-bg); color: var(--cta-text);
    font-family: var(--font-display); font-size: 15px; font-weight: 700;
    cursor: pointer; margin-top: 4px;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .ct-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--cta-glow); }
  .ct-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

  .ct-error {
    display: none; background: #FEF2F2; border: 1px solid #FCA5A5;
    border-radius: 12px; padding: 12px 16px; color: #991B1B; font-size: 14px;
  }
  .ct-error.show { display: block; }

  .ct-success {
    display: none; text-align: center;
    padding: 36px clamp(20px, 4vw, 36px); border-radius: 20px;
    background: linear-gradient(135deg, var(--sunset-dim), var(--pink-dim));
    border: 1px solid rgba(249,115,22,0.18);
  }
  .ct-success.show { display: block; }
  .ct-success-emoji { font-size: 44px; display: block; margin-bottom: 8px; }
  .ct-success h2 { font-family: var(--font-display); font-size: 26px; font-weight: 900; letter-spacing: -0.02em; color: var(--text); margin-bottom: 8px; }
  .ct-success p { font-size: 15px; color: var(--text-sec); line-height: 1.55; max-width: 380px; margin: 0 auto 18px; }
</style>

<script is:inline>
  const form = document.getElementById('contact-form');
  const msgField = document.getElementById('ct-message');
  const charSpan = document.getElementById('ct-chars');

  msgField.addEventListener('input', () => {
    charSpan.textContent = msgField.value.length;
    charSpan.style.color = msgField.value.length > 2000 ? '#DC2626' : '';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    const errEl = document.getElementById('ct-err');
    errEl.classList.remove('show');
    btn.disabled = true;
    const orig = btn.textContent;
    btn.textContent = 'Sending…';
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: document.getElementById('ct-name').value.trim(),
          email: document.getElementById('ct-email').value.trim(),
          subject: document.getElementById('ct-subject').value.trim(),
          message: msgField.value.trim(),
        }),
      });
      const data = await res.json();
      if (data.ok) {
        form.style.display = 'none';
        document.getElementById('ct-ok').classList.add('show');
      } else {
        errEl.textContent = data.error || 'Something went wrong.';
        errEl.classList.add('show');
        btn.disabled = false;
        btn.textContent = orig;
      }
    } catch {
      errEl.textContent = 'Network error — try again.';
      errEl.classList.add('show');
      btn.disabled = false;
      btn.textContent = orig;
    }
  });
</script>
</Base>
