---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const { handle } = Astro.params;
const db = getDB();
let member: any = null;
let events: any[] = [];

try {
  if (db && handle) {
    // Look up by reddit_username, discord_username, name, or email-local-part
    member = await db.prepare(
      `SELECT id, name, email, bio, neighborhood, reddit_username, discord_username, avatar_url, karma, role, points
       FROM members
       WHERE LOWER(reddit_username) = LOWER(?)
          OR LOWER(discord_username) = LOWER(?)
          OR LOWER(name) = LOWER(?)
          OR LOWER(email) = LOWER(?)
       LIMIT 1`
    ).bind(handle, handle, handle, handle + '@reddit.local').first();

    if (member) {
      const evRes = await db.prepare(
        "SELECT id, title, event_type, event_month, event_day, location, zone, rsvp_count, spots, is_past FROM events WHERE LOWER(submitted_by) = LOWER(?) OR LOWER(submitted_by) = LOWER(?) ORDER BY is_past ASC, id DESC LIMIT 30"
      ).bind(member.name || '', member.reddit_username || '').all();
      events = (evRes.results ?? []) as any[];
    }
  }
} catch (e) { console.error(e); }

const upcoming = events.filter((e:any) => !e.is_past);
const past = events.filter((e:any) => e.is_past);

const typeLabel: Record<string, string> = { dinner: '🍽 Dinner', game_night: '🎲 Games', outdoor: '🌲 Outdoors', brewery: '🍺 Brewery', coffee: '☕ Coffee', arts: '🎨 Arts', music: '🎵 Music', social: '🥂 Social', sports_outing: '⚾ Sports', active: '🏃 Active', other: '✨ Event' };

const displayName = member?.name || member?.reddit_username || member?.discord_username || handle;
const initials = (displayName || '?').split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
---
<Base title={member ? `${displayName} on Denver Social` : 'Organizer not found'} description={member ? `Events hosted by ${displayName}.` : ''}>
  <div class="op-wrap">
    {!member ? (
      <div class="op-404">
        <h1>Organizer not found</h1>
        <p>We couldn't find <code>{handle}</code>. They may have changed their name, or the link is wrong.</p>
        <a href="/events" class="btn-cta">Back to events</a>
      </div>
    ) : (
      <>
        <header class="op-header">
          {member.avatar_url
            ? <img src={member.avatar_url} alt={displayName} class="op-avatar-img"/>
            : <div class="op-avatar">{initials}</div>}
          <div>
            <h1>{displayName}</h1>
            <div class="op-meta">
              {member.neighborhood && <span>📍 {member.neighborhood}</span>}
              {member.role === 'admin' && <span class="op-pill">Organizer</span>}
              {typeof member.karma === 'number' && member.karma > 0 && <span>🔥 {member.karma} karma</span>}
              {typeof member.points === 'number' && member.points > 0 && <span>⭐ {member.points} pts</span>}
            </div>
            {member.bio && <p class="op-bio">{member.bio}</p>}
          </div>
        </header>

        {upcoming.length > 0 && (
          <section class="op-sec">
            <h2>Upcoming events</h2>
            <div class="op-list">
              {upcoming.map((ev:any) => (
                <a href={`/events/${ev.id}`} class="op-row">
                  <span class="op-tag">{typeLabel[ev.event_type] ?? '✨ Event'}</span>
                  <div class="op-row-main">
                    <div class="op-row-title">{ev.title}</div>
                    <div class="op-row-meta">📅 {ev.event_month} {ev.event_day} · 📍 {ev.zone || ev.location || 'Denver'} · {ev.rsvp_count || 0}{ev.spots ? `/${ev.spots}` : ''} going</div>
                  </div>
                  <span class="op-arrow">›</span>
                </a>
              ))}
            </div>
          </section>
        )}

        {past.length > 0 && (
          <section class="op-sec">
            <h2>Past events ({past.length})</h2>
            <div class="op-list">
              {past.slice(0, 10).map((ev:any) => (
                <a href={`/events/${ev.id}`} class="op-row op-row-faded">
                  <span class="op-tag">{typeLabel[ev.event_type] ?? '✨ Event'}</span>
                  <div class="op-row-main">
                    <div class="op-row-title">{ev.title}</div>
                    <div class="op-row-meta">{ev.event_month} {ev.event_day} · {ev.rsvp_count || 0} went</div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        {upcoming.length === 0 && past.length === 0 && (
          <div class="op-empty">{displayName} hasn't posted any events yet.</div>
        )}
      </>
    )}
  </div>

  <style>
    .op-wrap { max-width: 720px; margin: 0 auto; padding: var(--space-6) var(--space-4) var(--space-8); }
    .op-404 { text-align: center; padding: var(--space-8) var(--space-4); }
    .op-404 h1 { font-family: var(--font-display); font-size: 28px; font-weight: 800; margin-bottom: var(--space-3); }
    .op-404 p { color: var(--text-sec); margin-bottom: var(--space-4); }
    .op-404 code { background: var(--surface); padding: 2px 6px; border-radius: 4px; font-size: 14px; }

    .op-header { display: flex; gap: var(--space-4); margin-bottom: var(--space-6); align-items: flex-start; }
    .op-avatar, .op-avatar-img { width: 72px; height: 72px; border-radius: 50%; flex-shrink: 0; }
    .op-avatar { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 26px; font-weight: 800; }
    .op-avatar-img { object-fit: cover; }
    .op-header h1 { font-family: var(--font-display); font-size: clamp(24px, 4vw, 32px); font-weight: 800; letter-spacing: -0.02em; }
    .op-meta { display: flex; gap: 12px; flex-wrap: wrap; font-size: 13px; color: var(--text-sec); margin-top: 6px; }
    .op-pill { background: var(--tag-bg); color: var(--tag-text); padding: 2px 10px; border-radius: 999px; font-weight: 600; font-size: 12px; }
    .op-bio { color: var(--text); font-size: 14px; line-height: 1.55; margin-top: var(--space-3); }

    .op-sec { margin-bottom: var(--space-6); }
    .op-sec h2 { font-family: var(--font-display); font-size: 18px; font-weight: 700; margin-bottom: var(--space-3); letter-spacing: -0.01em; }
    .op-list { display: flex; flex-direction: column; gap: 8px; }
    .op-row { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; }
    .op-row:hover { transform: translateY(-1px); box-shadow: var(--card-shadow-lg); border-color: var(--border-hover); }
    .op-row-faded { opacity: 0.7; }
    .op-tag { font-size: 12px; font-weight: 600; padding: 4px 10px; background: var(--tag-bg); color: var(--tag-text); border-radius: 999px; white-space: nowrap; flex-shrink: 0; }
    .op-row-main { flex: 1; min-width: 0; }
    .op-row-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
    .op-row-meta { font-size: 13px; color: var(--text-sec); }
    .op-arrow { font-size: 22px; color: var(--text-faint); flex-shrink: 0; }
    .op-empty { padding: var(--space-5); border: 1px dashed var(--border); border-radius: var(--radius); text-align: center; color: var(--text-faint); font-size: 14px; }
  </style>
</Base>
