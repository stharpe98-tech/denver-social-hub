    .dish-status { background: #1a1108; border: 1px solid #2a1a08; border-radius: 14px; overflow: hidden; margin-bottom: 24px; }
    .dish-status-head { background: #221508; padding: 9px 16px; font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: #c4956a; }
