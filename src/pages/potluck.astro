<body>
  <div class="hero">
    <span class="sun">🌞</span>
    <div class="hero-title">Summer Kickoff<br/>Potluck</div>
    <div class="hero-sub">bring a dish, bring a friend, or just show up</div>
    <div class="badges">
      <span class="badge">📅 May 30th · 12pm–4pm</span>
      <span class="badge">📍 Cheeseman Park</span>
      <span class="badge">🎟 Free · Always</span>
    </div>
  </div>
  <div class="page">
    <div class="vibe">
      <div class="vibe-hed">Come hang.<br/>Eat food.<br/>Meet people.</div>
      <p class="vibe-body">Bring something if you can.<br/>Bring a friend if you want.<br/><em>Solo is totally fine —<br/>that's literally how half of us met.</em></p>
    </div>
    <div class="inclusive">
      <p><strong>Can't bring food? Still come.</strong><br/>Seriously. There's always too much anyway.<br/>Nobody's gonna notice and nobody cares.</p>
    </div>
    <div class="bring">
      <div class="bring-label">Ideas for what to bring</div>
      <div class="pills">
        <span class="pill">🥗 Salad</span>
        <span class="pill">🥪 Sandwiches</span>
        <span class="pill">🍰 Dessert</span>
        <span class="pill">🥤 Drinks</span>
        <span class="pill">🥖 Bread &amp; dips</span>
        <span class="pill soft">or just yourself 🤷</span>
      </div>
    </div>
    <div class="divider"></div>
    <div id="form-wrap">
      <div class="form-head">
        <h2>Sign up</h2>
        <p>30 seconds — helps us not end up with five pasta salads</p>
      </div>
      <div class="dish-status">
        <div class="dish-status-head">🍽 Dishes already claimed</div>
        <div class="dish-list" id="dish-list">
          {initialDishes.length === 0
            ? <span class="dish-empty">Nothing yet — be the first!</span>
            : initialDishes.map(d => (
                <span class={`dish-chip ${d.count >= 2 ? 'full' : 'one'}`}>
                  {d.dish} <span class="chip-count">({d.count}/2)</span>
                </span>
              ))
          }
        </div>
      </div>
      <div class="sec-label">About you</div>
      <div class="field">
        <label>Name <span class="req">*</span></label>
        <input type="text" id="f-name" placeholder="First name is fine" />
        <div class="err-msg hidden" id="e-name">Name is required</div>
      </div>
      <div class="field">
        <label>Where do you know us from?</label>
        <div class="checks" id="platform-checks">
          <div class="check-item" data-val="Discord"><div class="check-box"></div><div class="check-label">🎮 Discord<span class="check-sub">Denver Social Community</span></div></div>
          <div class="check-item" data-val="Facebook"><div class="check-box"></div><div class="check-label">📘 Facebook<span class="check-sub">Facebook group or event</span></div></div>
          <div class="check-item" data-val="Reddit"><div class="check-box"></div><div class="check-label">🤙 Reddit<span class="check-sub">r/Denver or r/DenverMeets</span></div></div>
          <div class="check-item" data-val="Other"><div class="check-box"></div><div class="check-label">👋 Other / friend of a friend</div></div>
        </div>
      </div>
      <div class="field">
        <label>Username or name on that platform</label>
        <input type="text" id="f-handle" placeholder="Discord tag, Facebook name, Reddit handle…" />
      </div>
      <div class="divider"></div>
      <div class="sec-label">Are you coming?</div>
      <div class="field">
        <label>RSVP <span class="req">*</span></label>
        <div class="rsvp-row">
          <button type="button" class="rsvp-btn yes" id="rsvp-yes" onclick="setRsvp('yes')">✅ Yes, I'm in!</button>
          <button type="button" class="rsvp-btn no" id="rsvp-no" onclick="setRsvp('no')">❌ Can't make it</button>
        </div>
        <div class="err-msg hidden" id="e-rsvp">Let us know if you're coming</div>
      </div>
      <div id="attending-fields" class="hidden">
        <div class="field">
          <label>How many people total? <span class="req">*</span></label>
          <div class="guest-row">
            <button type="button" class="g-btn" onclick="changeGuests(-1)">−</button>
            <div class="g-count" id="guest-count">1</div>
            <button type="button" class="g-btn" onclick="changeGuests(1)">+</button>
            <div class="g-label" id="guest-label">just me</div>
          </div>
        </div>
        <div class="divider"></div>
        <div class="sec-label">What are you bringing?</div>
        <div class="field">
          <label>Dish name <span class="req">*</span></label>
          <input type="text" id="f-dish" placeholder="e.g. Pasta salad, brownies, lemonade…" oninput="checkDish(this.value)" />
          <div id="dish-feedback"></div>
          <div class="err-msg hidden" id="e-dish"></div>
        </div>
        <div class="field">
          <label>Category <span class="req">*</span></label>
          <select id="f-category">
            <option value="">Pick one…</option>
            <option>🥗 Appetizer / Snack</option>
            <option>🍗 Main Dish</option>
            <option>🥘 Side Dish</option>
            <option>🍰 Dessert</option>
            <option>🥤 Drinks</option>
            <option>🎉 Surprise me</option>
          </select>
          <div class="err-msg hidden" id="e-category">Pick a category</div>
        </div>
        <div class="field">
          <label>Dietary notes / allergens</label>
          <textarea id="f-dietary" placeholder="Gluten-free, nut allergy, vegan… Leave blank if none."></textarea>
        </div>
        <div class="divider"></div>
        <div class="sec-label">A few more things…</div>
        <div class="checks">
          <div class="check-item" data-extra="utensils"><div class="check-box"></div><div class="check-label">🥄 I'll bring serving utensils<span class="check-sub">Spoons, tongs, forks</span></div></div>
          <div class="check-item" data-extra="earlyArrive"><div class="check-box"></div><div class="check-label">⏰ I can arrive early to help set up<span class="check-sub">~30 min before the group</span></div></div>
          <div class="check-item" data-extra="seating"><div class="check-box"></div><div class="check-label">🪑 I'll bring chairs or blankets<span class="check-sub">Open grass — super helpful!</span></div></div>
        </div>
      </div>
      <button class="submit-btn" id="submit-btn" onclick="submitForm()">🌞 Count me in!</button>
    </div>
    <div id="success-wrap" class="result hidden">
      <span class="result-emoji">🎉</span>
      <div class="result-title" id="success-title">You're in!</div>
      <p class="result-sub">See you at Cheeseman on May 30th. West side between 9th &amp; 10th Ave.</p>
      <div class="result-detail" id="success-detail"></div>
      <button class="result-btn" onclick="resetForm()">Submit another response</button>
    </div>
    <div id="error-wrap" class="result hidden">
      <span class="result-emoji">😬</span>
      <div class="result-title">Something went wrong</div>
      <p class="result-sub">Couldn't save your response. Try again in a sec.</p>
      <button class="result-btn" onclick="showForm()">← Try again</button>
    </div>
  </div>
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="nav-icon">🏠</span>Home</a>
    <a href="/events" class="nav-item"><span class="nav-icon">📅</span>Events</a>
    <a href="/potluck" class="nav-item" style="color:#f77f00"><span class="nav-icon">🌞</span>Potluck</a>
    <a href="/recs" class="nav-item"><span class="nav-icon">⭐</span>Recs</a>
  </nav>
  <script define:vars={{ initialDishes }}>
    const MAX = 2;
    let rsvp = '';
    let guestCount = 1;
    let platforms = [];
    let extras = { utensils: false, earlyArrive: false, seating: false };
    let dishes = initialDishes;
    let dishBlocked = false;
    fetch('/api/potluck').then(r => r.json()).then(d => { dishes = d; renderDishList(); }).catch(() => {});
    function renderDishList() {
      const el = document.getElementById('dish-list');
      if (!dishes.length) { el.innerHTML = '<span class="dish-empty">Nothing yet — be the first!</span>'; return; }
      el.innerHTML = dishes.map(d => `<span class="dish-chip ${d.count >= MAX ? 'full' : 'one'}">${d.dish} <span class="chip-count">(${d.count}/${MAX})</span></span>`).join('');
    }
    function setRsvp(val) {
      rsvp = val;
      document.getElementById('rsvp-yes').classList.toggle('active', val === 'yes');
      document.getElementById('rsvp-no').classList.toggle('active', val === 'no');
      document.getElementById('attending-fields').classList.toggle('hidden', val !== 'yes');
      document.getElementById('e-rsvp').classList.add('hidden');
      document.getElementById('submit-btn').textContent = val === 'no' ? "😢 Submit (we'll miss you)" : '🌞 Count me in!';
    }
    function changeGuests(delta) {
      guestCount = Math.max(1, Math.min(10, guestCount + delta));
      document.getElementById('guest-count').textContent = guestCount;
      document.getElementById('guest-label').textContent = guestCount === 1 ? 'just me' : 'people total';
    }
    function checkDish(val) {
      const key = val.trim().toLowerCase();
      const fb = document.getElementById('dish-feedback');
      document.getElementById('e-dish').classList.add('hidden');
      if (key.length < 2) { fb.innerHTML = ''; dishBlocked = false; updateBtn(); return; }
      const match = dishes.find(d => d.dish === key);
      const count = match ? match.count : 0;
      if (count >= MAX) { fb.innerHTML = `<div class="dish-feedback block">🚫 "${val.trim()}" is already claimed twice — pick something different!</div>`; dishBlocked = true; }
      else if (count === 1) { fb.innerHTML = `<div class="dish-feedback warn">⚠️ Someone else is also bringing this. 1 slot left — maybe pick something else?</div>`; dishBlocked = false; }
      else { fb.innerHTML = `<div class="dish-feedback ok">✅ Nobody's bringing this yet — it's all yours!</div>`; dishBlocked = false; }
      updateBtn();
    }
    function updateBtn() { document.getElementById('submit-btn').disabled = dishBlocked; }
    document.querySelectorAll('#platform-checks .check-item').forEach(el => {
      el.addEventListener('click', () => {
        const val = el.dataset.val; const idx = platforms.indexOf(val);
        if (idx === -1) platforms.push(val); else platforms.splice(idx, 1);
        el.classList.toggle('active', platforms.includes(val));
        el.querySelector('.check-box').textContent = platforms.includes(val) ? '✓' : '';
      });
    });
    document.querySelectorAll('[data-extra]').forEach(el => {
      el.addEventListener('click', () => {
        const key = el.dataset.extra; extras[key] = !extras[key];
        el.classList.toggle('active', extras[key]);
        el.querySelector('.check-box').textContent = extras[key] ? '✓' : '';
      });
    });
    function validate() {
      let ok = true;
      if (!document.getElementById('f-name').value.trim()) { document.getElementById('e-name').classList.remove('hidden'); ok = false; } else document.getElementById('e-name').classList.add('hidden');
      if (!rsvp) { document.getElementById('e-rsvp').classList.remove('hidden'); ok = false; } else document.getElementById('e-rsvp').classList.add('hidden');
      if (rsvp === 'yes') {
        const dish = document.getElementById('f-dish').value.trim();
        const cat = document.getElementById('f-category').value;
        if (!dish || dishBlocked) { const em = document.getElementById('e-dish'); em.textContent = dishBlocked ? `"${dish}" is already claimed twice!` : 'Please bring something!'; em.classList.remove('hidden'); ok = false; } else document.getElementById('e-dish').classList.add('hidden');
        if (!cat) { document.getElementById('e-category').classList.remove('hidden'); ok = false; } else document.getElementById('e-category').classList.add('hidden');
      }
      return ok;
    }
    async function submitForm() {
      if (!validate()) return;
      const btn = document.getElementById('submit-btn'); btn.disabled = true; btn.textContent = 'Saving…';
      const payload = { name: document.getElementById('f-name').value.trim(), handle: document.getElementById('f-handle').value.trim(), platforms: platforms.join(', '), rsvp, guestCount: String(guestCount), dish: rsvp === 'yes' ? document.getElementById('f-dish').value.trim() : '', dishCategory: rsvp === 'yes' ? document.getElementById('f-category').value : '', dietary: rsvp === 'yes' ? document.getElementById('f-dietary').value.trim() : '', ...extras };
      try {
        const res = await fetch('/api/potluck', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        const data = await res.json();
        if (data.ok) showSuccess(payload); else showError();
      } catch { showError(); }
    }
    function showSuccess(p) {
      document.getElementById('form-wrap').classList.add('hidden');
      document.getElementById('error-wrap').classList.add('hidden');
      document.getElementById('success-wrap').classList.remove('hidden');
      document.getElementById('success-title').textContent = `You're in, ${p.name.split(' ')[0]}!`;
      let detail = '';
      if (p.rsvp === 'yes' && p.dish) { detail += `🍽 <strong>Dish:</strong> ${p.dish} · ${p.dishCategory}<br/>`; detail += `👥 <strong>Headcount:</strong> ${p.guestCount} ${parseInt(p.guestCount)===1?'person':'people'}<br/>`; if (p.utensils) detail += '🥄 Bringing serving utensils<br/>'; if (p.earlyArrive) detail += '⏰ Arriving early<br/>'; if (p.seating) detail += '🪑 Bringing chairs / blankets'; }
      document.getElementById('success-detail').innerHTML = detail || (p.rsvp === 'no' ? "We'll miss you! See you at the next one 🤙" : '');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function showError() { document.getElementById('form-wrap').classList.add('hidden'); document.getElementById('success-wrap').classList.add('hidden'); document.getElementById('error-wrap').classList.remove('hidden'); }
    function showForm() { document.getElementById('form-wrap').classList.remove('hidden'); document.getElementById('error-wrap').classList.add('hidden'); }
    function resetForm() { location.reload(); }
  </script>
</body>
</html>
