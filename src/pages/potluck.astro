    .g-count { flex: 1; text-align: center; font-size: 20px; font-weight: 600; color: #fff; }
    .g-label { font-size: 13px; color: #4a3020; white-space: nowrap; }
    .checks { display: flex; flex-direction: column; gap: 10px; }
