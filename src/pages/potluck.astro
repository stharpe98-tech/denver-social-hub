---
import { getDB } from '../lib/db';
const db = getDB();

let initialDishes: {dish: string, count: number}[] = [];
try {
  if (db) {
    const { results } = await db.prepare(`
      SELECT LOWER(dish) as dish, COUNT(*) as count
      FROM potluck_rsvp
      WHERE dish IS NOT NULL AND dish != '' AND rsvp = 'yes'
      GROUP BY LOWER(dish)
    `).all();
    initialDishes = (results ?? []) as any;
  }
} catch {}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Summer Kickoff Potluck · May 30th · Denver Social Community</title>
  <meta name="description" content="Come hang, eat food, meet people. Cheeseman Park, May 30th 12–4pm. Bring a dish if you can — just show up if you can't." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
