---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { ensureCommunitySchema, seedCommunityCalendar, CALENDAR_KINDS } from '../lib/community-schema';

const db = getDB();
let entries: any[] = [];
if (db) {
  await ensureCommunitySchema(db);
  await seedCommunityCalendar(db);
  const r = await db.prepare(`
    SELECT * FROM community_calendar
    ORDER BY
      CASE WHEN sort_month IS NULL THEN 1 ELSE 0 END,
      sort_month ASC, sort_day ASC, id ASC
  `).all();
  entries = (r.results || []) as any[];
}

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

// Group by month
const grouped: Record<string, any[]> = {};
for (const e of entries) {
  const key = e.sort_month ? MONTHS[e.sort_month - 1] : 'Anytime';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(e);
}
const monthOrder = [...MONTHS, 'Anytime'];

function kindMeta(k: string) {
  return CALENDAR_KINDS.find(c => c.key === k) || { emoji: '📅', label: 'Date' };
}
---
<Base title="Community calendar" description="Denver dates the community shares — holidays, local traditions, the first warm day.">
<div class="cal-wrap">
  <header class="cal-head">
    <h1>Community calendar</h1>
    <p>Denver dates the community shares — holidays, big local events, traditions. Not RSVPs, just things on the horizon.</p>
  </header>

  {entries.length === 0 ? (
    <div class="cal-empty">No dates yet.</div>
  ) : (
    <div class="cal-months">
      {monthOrder.filter(m => grouped[m]).map(monthKey => (
        <section class="cal-month">
          <h2>{monthKey}</h2>
          <div class="cal-entries">
            {grouped[monthKey].map((e: any) => {
              const k = kindMeta(e.kind);
              return (
                <article class="cal-entry">
                  <span class="cal-emoji">{k.emoji}</span>
                  <div class="cal-body">
                    <strong>{e.title}</strong>
                    <span class="cal-when">{e.date_label}</span>
                    {e.description && <p>{e.description}</p>}
                  </div>
                  {e.url && <a href={e.url} target="_blank" rel="noopener" class="cal-link">↗</a>}
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  )}

  <section class="cal-pitch">
    <p>Missing a Denver tradition? <a href="/contact">Tell us</a> and we'll add it.</p>
  </section>
</div>

<style>
  .cal-wrap { max-width: 760px; margin: 0 auto; padding: 32px clamp(16px, 4vw, 40px) 80px; }
  .cal-head { text-align: center; margin-bottom: 32px; }
  .cal-head h1 { font-family: var(--font-display); font-size: clamp(30px, 5vw, 40px); font-weight: 900; letter-spacing: -0.025em; }
  .cal-head p { font-size: 15px; color: var(--text-sec); max-width: 540px; margin: 8px auto 0; line-height: 1.55; }

  .cal-empty { padding: 56px 24px; text-align: center; color: var(--text-faint); background: var(--surface); border: 1px dashed var(--border); border-radius: 14px; }

  .cal-months { display: flex; flex-direction: column; gap: 24px; }
  .cal-month h2 {
    font-family: var(--font-display); font-size: 13px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-sec);
    margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }
  .cal-entries { display: flex; flex-direction: column; gap: 8px; }
  .cal-entry {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 14px 16px; background: var(--bg);
    border: 1px solid var(--border); border-radius: 14px;
    transition: border-color 0.15s;
  }
  .cal-entry:hover { border-color: var(--border-hover); }
  .cal-emoji { font-size: 24px; line-height: 1.3; flex-shrink: 0; }
  .cal-body { flex: 1; min-width: 0; }
  .cal-body strong { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text); display: block; }
  .cal-when { font-size: 12px; color: var(--text-sec); }
  .cal-body p { font-size: 13px; color: var(--text-sec); margin-top: 4px; line-height: 1.5; }
  .cal-link { font-size: 22px; color: var(--accent); text-decoration: none; flex-shrink: 0; }
  .cal-link:hover { color: var(--text); }

  .cal-pitch { margin-top: 32px; padding: 18px; text-align: center; background: var(--surface); border-radius: 14px; font-size: 14px; color: var(--text-sec); }
  .cal-pitch a { color: var(--accent); font-weight: 600; }
</style>
</Base>
