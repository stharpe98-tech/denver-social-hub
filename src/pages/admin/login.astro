---
import Base from '../../layouts/Base.astro';
import { isAdmin } from '../../lib/admin-auth';
if (await isAdmin(Astro.cookies)) return Astro.redirect('/admin/dashboard');
---
<Base title="Admin sign in" description="Sign in to the Denver Social admin dashboard via emailed code.">
  <div class="al-wrap">
    <div class="al-card">
      <div class="al-icon" aria-hidden="true">⚙</div>
      <h1>Admin sign in</h1>
      <p class="al-sub" id="al-sub">Enter your email — we'll send a 6-digit code.</p>

      <div id="step-request">
        <div class="al-field">
          <label for="al-email">Email</label>
          <input id="al-email" type="email" autocomplete="email" placeholder="you@example.com" />
        </div>
        <button class="btn-cta al-btn" id="send-btn">Send code</button>
        <div class="al-err" id="send-err"></div>
      </div>

      <div id="step-verify" hidden>
        <div class="al-field">
          <label for="al-code">6-digit code</label>
          <input id="al-code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" placeholder="••••••" />
        </div>
        <button class="btn-cta al-btn" id="verify-btn">Verify & sign in</button>
        <button class="al-link" id="back-btn" type="button">Use a different email</button>
        <div class="al-err" id="verify-err"></div>
      </div>
    </div>
  </div>

  <style>
    .al-wrap { max-width: 440px; margin: 0 auto; padding: var(--space-7) var(--space-4) var(--space-8); }
    .al-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--card-shadow-lg);
      padding: var(--space-6) var(--space-5);
    }
    .al-icon {
      font-size: 32px; line-height: 1;
      display: flex; align-items: center; justify-content: center;
      width: 56px; height: 56px;
      background: var(--accent-dim); color: var(--accent);
      border-radius: 14px;
      margin: 0 auto var(--space-3);
    }
    .al-card h1 {
      font-family: var(--font-display);
      font-size: clamp(24px, 3.5vw, 30px);
      font-weight: 800;
      text-align: center;
      margin-bottom: var(--space-2);
      letter-spacing: -0.02em;
    }
    .al-sub { color: var(--text-sec); font-size: 14px; text-align: center; margin-bottom: var(--space-5); }
    .al-field { margin-bottom: var(--space-3); }
    .al-field label {
      display: block; font-size: 11px; font-weight: 700;
      color: var(--text-sec); margin-bottom: 6px;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    .al-field input {
      width: 100%; padding: 12px 14px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; font-size: 14px; color: var(--text);
      font-family: var(--font); outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    #al-code { font-size: 22px; letter-spacing: 8px; text-align: center; }
    .al-field input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
    .al-btn { width: 100%; padding: 12px; font-size: 14px; margin-top: var(--space-2); }
    .al-link {
      display: block; margin: var(--space-3) auto 0;
      background: none; border: none; cursor: pointer;
      font-size: 13px; color: var(--text-sec); font-family: var(--font);
      text-decoration: underline; text-underline-offset: 3px;
    }
    .al-link:hover { color: var(--text); }
    .al-err { font-size: 13px; color: var(--red); margin-top: var(--space-2); display: none; }
    .al-err.show { display: block; }
  </style>

  <script is:inline>
    (function() {
      var stepRequest = document.getElementById('step-request');
      var stepVerify = document.getElementById('step-verify');
      var sub = document.getElementById('al-sub');
      var emailInput = document.getElementById('al-email');
      var codeInput = document.getElementById('al-code');

      function showErr(id, msg) {
        var el = document.getElementById(id);
        el.textContent = msg;
        el.classList.add('show');
      }
      function clearErr(id) {
        var el = document.getElementById(id);
        el.textContent = '';
        el.classList.remove('show');
      }

      document.getElementById('send-btn').addEventListener('click', async function() {
        clearErr('send-err');
        var email = (emailInput.value || '').trim().toLowerCase();
        if (!email || email.indexOf('@') < 0) { showErr('send-err', 'Enter a valid email.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Sending…'; btn.disabled = true;
        try {
          var r = await fetch('/api/admin/code-send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email }),
          });
          var d = await r.json();
          if (d.ok) {
            stepRequest.hidden = true;
            stepVerify.hidden = false;
            sub.textContent = 'Check ' + email + ' for a 6-digit code.';
            codeInput.focus();
          } else {
            showErr('send-err', d.error || 'Could not send code.');
          }
        } catch (e) {
          showErr('send-err', 'Network error. Try again.');
        }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('verify-btn').addEventListener('click', async function() {
        clearErr('verify-err');
        var email = (emailInput.value || '').trim().toLowerCase();
        var code = (codeInput.value || '').trim();
        if (!/^\d{6}$/.test(code)) { showErr('verify-err', 'Enter the 6-digit code.'); return; }
        var btn = this; var orig = btn.textContent;
        btn.textContent = 'Verifying…'; btn.disabled = true;
        try {
          var r = await fetch('/api/admin/code-verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, code: code }),
          });
          var d = await r.json();
          if (d.ok) { location.href = '/admin/dashboard'; return; }
          showErr('verify-err', d.error || 'Invalid or expired code.');
        } catch (e) {
          showErr('verify-err', 'Network error. Try again.');
        }
        btn.textContent = orig; btn.disabled = false;
      });

      document.getElementById('back-btn').addEventListener('click', function() {
        stepVerify.hidden = true;
        stepRequest.hidden = false;
        sub.textContent = "Enter your email — we'll send a 6-digit code.";
        emailInput.focus();
      });

      codeInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') document.getElementById('verify-btn').click();
      });
      emailInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') document.getElementById('send-btn').click();
      });
    })();
  </script>
</Base>
