---
import Base from '../../layouts/Base.astro';
import { getDB } from '../../lib/db';

const token = Astro.url.searchParams.get('token');
let error = '';

if (token) {
  const db = getDB();
  if (db) {
    try {
      const row: any = await db.prepare(
        `SELECT * FROM magic_tokens WHERE token = ?`
      ).bind(token).first();

      if (!row) {
        error = 'Invalid or already used link.';
      } else if (Date.now() > row.expires) {
        error = 'This link has expired. Please request a new one.';
        await db.prepare(`DELETE FROM magic_tokens WHERE token = ?`).bind(token).run();
      } else {
        // Valid — log in as admin
        await db.prepare(`DELETE FROM magic_tokens WHERE token = ?`).bind(token).run();
        const val = encodeURIComponent(JSON.stringify({ email: row.email, name: 'Seth', admin: true }));
        return new Response(null, {
          status: 302,
          headers: {
            Location: '/admin/dashboard',
            'Set-Cookie': `dsn_user=${val}; Path=/; Max-Age=604800; SameSite=Lax`,
          },
        });
      }
    } catch {
      error = 'Something went wrong. Try again.';
    }
  }
} else {
  error = 'No token provided.';
}
---
<Base title="Verifying...">
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px">
    <div style="background:#18181c;border:1px solid #2e2e36;border-radius:24px;padding:48px 40px;width:100%;max-width:400px;text-align:center">
      <div style="font-size:48px;margin-bottom:16px">❌</div>
      <div style="color:#fff;font-size:18px;font-weight:700;margin-bottom:8px">Link problem</div>
      <div style="color:#888;font-size:14px;line-height:1.6;margin-bottom:24px">{error}</div>
      <a href="/admin" style="background:#F05A28;color:#fff;text-decoration:none;padding:12px 28px;border-radius:50px;font-weight:700;font-size:14px">Try Again →</a>
    </div>
  </div>
</Base>
