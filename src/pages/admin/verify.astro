---
import { getDB } from '../../lib/db';

export const prerender = false;

if (Astro.request.method === 'POST') {
  try {
    const { code, email } = await Astro.request.json();
    if (!code || !email) {
      return new Response(JSON.stringify({ error: 'Code and email required' }), { status: 400 });
    }
    const db = getDB();
    if (!db) return new Response(JSON.stringify({ error: 'DB unavailable' }), { status: 500 });

    const row: any = await db.prepare(
      `SELECT * FROM magic_tokens WHERE token = ? AND email = ?`
    ).bind(code.toString(), email.trim().toLowerCase()).first();

    if (!row) {
      return new Response(JSON.stringify({ error: 'Incorrect code. Try again.' }), { status: 400 });
    }
    if (Date.now() > row.expires) {
      await db.prepare(`DELETE FROM magic_tokens WHERE token = ?`).bind(code).run();
      return new Response(JSON.stringify({ error: 'Code expired. Request a new one.' }), { status: 400 });
    }

    await db.prepare(`DELETE FROM magic_tokens WHERE token = ?`).bind(code).run();
    const val = encodeURIComponent(JSON.stringify({ email: row.email, name: 'Seth', admin: true }));

    return new Response(JSON.stringify({ ok: true }), {
      status: 200,
      headers: {
        'Set-Cookie': `dsn_user=${val}; Path=/; Max-Age=604800; SameSite=Lax`,
        'Content-Type': 'application/json',
      },
    });
  } catch {
    return new Response(JSON.stringify({ error: 'Something went wrong.' }), { status: 500 });
  }
}

return Astro.redirect('/admin');
---
