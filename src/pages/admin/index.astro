---
import AdminBase from '../../layouts/AdminBase.astro';

const cookie = Astro.request.headers.get('cookie') || '';
const userMatch = cookie.match(/dsn_user=([^;]+)/);
let isAdmin = false;
if (userMatch) {
  try {
    const user = JSON.parse(decodeURIComponent(userMatch[1]));
    isAdmin = user.email === 'stharpe98@gmail.com';
  } catch {}
}
if (isAdmin) return Astro.redirect('/admin/dashboard');
---
<AdminBase title="Admin Login — Denver Social">
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;">

    <div style="width:100%;max-width:420px;">

      <!-- Logo -->
      <div style="text-align:center;margin-bottom:48px;">
        <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:16px;">
          <div style="width:40px;height:40px;background:#F05A28;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;">🌆</div>
          <span style="font-family:'Instrument Serif',serif;font-size:22px;font-weight:900;color:#fff;">Denver Social</span>
        </div>
        <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#F05A28;font-weight:600;">Admin Access</div>
      </div>

      <!-- STEP 1: Email -->
      <div id="stepEmail">
        <h1 style="font-family:'Instrument Serif',serif;font-size:36px;font-weight:900;color:#fff;text-align:center;margin-bottom:8px;line-height:1.1;">
          Welcome <span style="font-style:italic;color:#F05A28;">back.</span>
        </h1>
        <p style="text-align:center;color:#6b7a8e;font-size:15px;margin-bottom:36px;font-weight:300;">
          Enter your email and we'll send you a 6-digit code.
        </p>

        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:28px;">
          <label style="display:block;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#6b7a8e;margin-bottom:8px;">Email Address</label>
          <input
            type="email"
            id="emailInput"
            placeholder="you@example.com"
            class="input"
            style="margin-bottom:16px;"
          />
          <button id="sendBtn" style="width:100%;background:#F05A28;color:#fff;border:none;border-radius:50px;padding:15px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:opacity 0.2s;letter-spacing:0.3px;">
            Send My Code →
          </button>
          <div id="sendError" style="color:#f87171;font-size:13px;margin-top:12px;display:none;text-align:center;"></div>
        </div>

        <p style="text-align:center;color:#2d3748;font-size:12px;margin-top:20px;">
          Only authorized admins can access this area.
        </p>
      </div>

      <!-- STEP 2: OTP -->
      <div id="stepOtp" style="display:none;">
        <h1 style="font-family:'Instrument Serif',serif;font-size:36px;font-weight:900;color:#fff;text-align:center;margin-bottom:8px;line-height:1.1;">
          Check your <span style="font-style:italic;color:#F05A28;">inbox.</span>
        </h1>
        <p style="text-align:center;color:#6b7a8e;font-size:15px;margin-bottom:8px;font-weight:300;">
          We sent a 6-digit code to
        </p>
        <p id="sentTo" style="text-align:center;color:#F05A28;font-size:15px;font-weight:600;margin-bottom:36px;"></p>

        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:28px;">
          <label style="display:block;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#6b7a8e;margin-bottom:20px;text-align:center;">Enter Code</label>

          <div id="otpInputs" style="display:flex;gap:10px;justify-content:center;margin-bottom:24px;">
            <input type="text" maxlength="1" style="width:52px;height:64px;text-align:center;font-size:28px;font-weight:700;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:14px;color:#fff;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;"/>
            <input type="text" maxlength="1" style="width:52px;height:64px;text-align:center;font-size:28px;font-weight:700;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:14px;color:#fff;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;"/>
            <input type="text" maxlength="1" style="width:52px;height:64px;text-align:center;font-size:28px;font-weight:700;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:14px;color:#fff;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;"/>
            <input type="text" maxlength="1" style="width:52px;height:64px;text-align:center;font-size:28px;font-weight:700;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:14px;color:#fff;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;"/>
            <input type="text" maxlength="1" style="width:52px;height:64px;text-align:center;font-size:28px;font-weight:700;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:14px;color:#fff;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;"/>
            <input type="text" maxlength="1" style="width:52px;height:64px;text-align:center;font-size:28px;font-weight:700;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:14px;color:#fff;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;"/>
          </div>

          <button id="verifyBtn" disabled style="width:100%;background:#F05A28;color:#fff;border:none;border-radius:50px;padding:15px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;opacity:0.4;transition:opacity 0.2s;">
            Verify Code →
          </button>
          <div id="otpError" style="color:#f87171;font-size:13px;margin-top:12px;display:none;text-align:center;"></div>
        </div>

        <div style="display:flex;justify-content:center;gap:20px;margin-top:20px;">
          <a id="resendLink" style="color:#6b7a8e;font-size:13px;cursor:pointer;text-decoration:underline;">Resend code</a>
          <span style="color:#2d3748;">·</span>
          <a id="backLink" style="color:#6b7a8e;font-size:13px;cursor:pointer;text-decoration:underline;">Change email</a>
        </div>
      </div>

    </div>
  </div>

  <script>
    let currentEmail = '';
    const sendBtn = document.getElementById('sendBtn') as HTMLButtonElement;
    const verifyBtn = document.getElementById('verifyBtn') as HTMLButtonElement;
    const otpBoxes = document.querySelectorAll<HTMLInputElement>('#otpInputs input');

    sendBtn.addEventListener('click', sendCode);
    document.getElementById('emailInput')!.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendCode(); });
    verifyBtn.addEventListener('click', verifyCode);
    document.getElementById('resendLink')!.addEventListener('click', () => { showStep('email'); setTimeout(sendCode, 100); });
    document.getElementById('backLink')!.addEventListener('click', () => showStep('email'));

    otpBoxes.forEach((box, i) => {
      box.addEventListener('input', () => {
        box.value = box.value.replace(/\D/g, '');
        if (box.value && i < 5) otpBoxes[i + 1].focus();
        const full = [...otpBoxes].map(b => b.value).join('');
        verifyBtn.disabled = full.length < 6;
        verifyBtn.style.opacity = full.length < 6 ? '0.4' : '1';
        verifyBtn.style.cursor = full.length < 6 ? 'not-allowed' : 'pointer';
        if (full.length === 6) verifyCode();
      });
      box.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && !box.value && i > 0) otpBoxes[i - 1].focus();
      });
      box.addEventListener('focus', () => { box.style.borderColor = '#F05A28'; box.style.background = 'rgba(240,90,40,0.08)'; });
      box.addEventListener('blur', () => { box.style.borderColor = box.value ? 'rgba(240,90,40,0.5)' : 'rgba(255,255,255,.1)'; box.style.background = 'rgba(255,255,255,.05)'; });
    });

    function showStep(step: string) {
      (document.getElementById('stepEmail') as HTMLElement).style.display = step === 'email' ? 'block' : 'none';
      (document.getElementById('stepOtp') as HTMLElement).style.display = step === 'otp' ? 'block' : 'none';
    }

    async function sendCode() {
      const email = (document.getElementById('emailInput') as HTMLInputElement).value.trim();
      const errEl = document.getElementById('sendError')!;
      errEl.style.display = 'none';
      if (!email || !email.includes('@')) {
        errEl.textContent = 'Please enter a valid email.';
        errEl.style.display = 'block';
        return;
      }
      currentEmail = email;
      sendBtn.disabled = true;
      sendBtn.textContent = 'Sending...';
      try {
        const res = await fetch('/api/magic-link', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (!res.ok) throw new Error();
        (document.getElementById('sentTo') as HTMLElement).textContent = email;
        otpBoxes.forEach(b => { b.value = ''; b.style.borderColor = 'rgba(255,255,255,.1)'; });
        verifyBtn.disabled = true;
        verifyBtn.style.opacity = '0.4';
        showStep('otp');
        otpBoxes[0].focus();
      } catch {
        errEl.textContent = 'Something went wrong. Try again.';
        errEl.style.display = 'block';
      }
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send My Code →';
    }

    async function verifyCode() {
      const code = [...otpBoxes].map(b => b.value).join('');
      if (code.length < 6) return;
      const errEl = document.getElementById('otpError')!;
      errEl.style.display = 'none';
      verifyBtn.disabled = true;
      verifyBtn.textContent = 'Verifying...';
      try {
        const res = await fetch('/admin/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, email: currentEmail }),
        });
        const data = await res.json() as any;
        if (data.ok) {
          window.location.href = '/admin/dashboard';
        } else {
          errEl.textContent = data.error || 'Incorrect code. Try again.';
          errEl.style.display = 'block';
          otpBoxes.forEach(b => { b.value = ''; b.style.borderColor = 'rgba(255,0,0,.4)'; });
          otpBoxes[0].focus();
        }
      } catch {
        errEl.textContent = 'Something went wrong. Try again.';
        errEl.style.display = 'block';
      }
      verifyBtn.disabled = false;
      verifyBtn.textContent = 'Verify Code →';
    }
  </script>
</AdminBase>
