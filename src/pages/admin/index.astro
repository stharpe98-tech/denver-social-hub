---
import AdminBase from '../../layouts/AdminBase.astro';
import { getOrgSession } from '../../lib/admin-auth';

// If a valid org session already exists, skip the magic-link UI.
if (getOrgSession(Astro)) return Astro.redirect('/admin/dashboard');
---
<AdminBase title="Admin — Denver Social" centered={true}>
<style>
  .login-wrap {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  /* LEFT */
  .login-left {
    position: relative;
    overflow: hidden;
    background: #0a0c14;
    display: flex;
    flex-direction: column;
    padding: 48px;
  }
  .login-left-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 90% 70% at 10% 90%, rgba(167,139,250,0.25) 0%, transparent 55%),
      radial-gradient(ellipse 70% 60% at 90% 10%, rgba(56,189,248,0.12) 0%, transparent 50%),
      radial-gradient(ellipse 50% 50% at 50% 50%, rgba(244,114,182,0.08) 0%, transparent 50%);
    z-index: 0;
  }
  .login-left-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
    background-size: 44px 44px;
    z-index: 0;
  }
  .login-left-content { position: relative; z-index: 2; display: flex; flex-direction: column; height: 100%; }
  .login-brand { display: flex; align-items: center; gap: 12px; }
  .login-brand-icon { width: 42px; height: 42px; background: linear-gradient(135deg,#A78BFA,#38BDF8); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; box-shadow: 0 0 28px rgba(167,139,250,0.4); }
  .login-brand-name { font-family: 'Space Grotesk', sans-serif; font-size: 20px; color: #fff; font-weight: 700; }

  .login-hero { margin-top: auto; padding-bottom: 12px; }
  .login-eyebrow { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #A78BFA; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
  .login-eyebrow::before { content: ''; width: 20px; height: 2px; background: linear-gradient(90deg,#A78BFA,#38BDF8); display: inline-block; }
  .login-h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(40px, 4.5vw, 62px); font-weight: 700; color: #fff; line-height: 1.0; letter-spacing: -1.5px; margin-bottom: 20px; }
  .login-h1 em { font-style: italic; background: linear-gradient(135deg,#A78BFA,#F472B6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .login-sub { color: rgba(255,255,255,0.3); font-size: 15px; line-height: 1.7; font-weight: 300; max-width: 320px; margin-bottom: 40px; }
  .login-stats { display: flex; gap: 28px; }
  .login-stat-num { font-family: 'JetBrains Mono', monospace; font-size: 26px; font-weight: 700; color: #fff; line-height: 1; }
  .login-stat-lbl { font-size: 10px; color: rgba(255,255,255,.3); text-transform: uppercase; letter-spacing: 1.2px; margin-top: 3px; }

  /* RIGHT */
  .login-right {
    background: #0F1117;
    display: flex; align-items: center; justify-content: center;
    padding: 48px 40px;
  }
  .login-form-wrap { width: 100%; max-width: 380px; }

  .login-step-title { font-family: 'Space Grotesk', sans-serif; font-size: 32px; font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: 6px; }
  .login-step-title em { font-style: italic; background: linear-gradient(135deg,#A78BFA,#F472B6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .login-step-sub { color: #5A5672; font-size: 14px; margin-bottom: 32px; line-height: 1.6; }
  .login-step-sub span { color: #A78BFA; font-weight: 600; }

  .form-card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 20px; padding: 28px; margin-bottom: 16px; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
  .form-label { display: block; font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #5A5672; margin-bottom: 10px; }
  .form-input {
    width: 100%; padding: 14px 16px;
    background: rgba(255,255,255,.05); border: 1.5px solid rgba(255,255,255,.08);
    border-radius: 12px; font-size: 15px; color: #E4E2EC;
    font-family: 'Inter', sans-serif; outline: none; transition: all 0.2s;
    margin-bottom: 16px;
  }
  .form-input:focus { border-color: #A78BFA; background: rgba(167,139,250,.06); box-shadow: 0 0 0 3px rgba(167,139,250,0.1); }
  .form-btn {
    width: 100%; background: linear-gradient(135deg,#A78BFA,#8B5CF6); color: #fff; border: none;
    border-radius: 50px; padding: 15px; font-size: 15px; font-weight: 700;
    cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s;
    letter-spacing: 0.2px; box-shadow: 0 0 24px rgba(167,139,250,0.3);
  }
  .form-btn:hover { box-shadow: 0 0 32px rgba(167,139,250,0.45); transform: translateY(-1px); }
  .form-btn:disabled { opacity: 0.35; cursor: not-allowed; box-shadow: none; transform: none; }

  /* OTP boxes */
  .otp-row { display: flex; gap: 8px; justify-content: center; margin-bottom: 24px; }
  .otp-box {
    width: 50px; height: 60px; text-align: center; font-size: 26px; font-weight: 700;
    background: rgba(255,255,255,.05); border: 1.5px solid rgba(255,255,255,.1);
    border-radius: 14px; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none;
    transition: all 0.18s;
  }
  .otp-box:focus { border-color: #A78BFA; background: rgba(167,139,250,.07); box-shadow: 0 0 0 3px rgba(167,139,250,0.1); }
  .otp-box.filled { border-color: rgba(167,139,250,0.5); }
  .otp-box.error { border-color: rgba(239,68,68,0.6); background: rgba(239,68,68,.06); }

  .form-links { display: flex; justify-content: center; gap: 18px; }
  .form-link { color: #5A5672; font-size: 12px; cursor: pointer; text-decoration: underline; background: none; border: none; font-family: 'Inter', sans-serif; transition: color 0.15s; }
  .form-link:hover { color: #A78BFA; }
  .form-error { color: #f87171; font-size: 13px; margin-top: 10px; display: none; text-align: center; }
  .form-footer { text-align: center; color: #5A5672; font-size: 12px; margin-top: 16px; }

  /* Mobile */
  @media (max-width: 768px) {
    .login-wrap { grid-template-columns: 1fr; }
    .login-left { display: none; }
    .login-right { padding: 40px 24px; min-height: 100vh; }
  }
</style>

<div class="login-wrap">
  <!-- LEFT -->
  <div class="login-left">
    <div class="login-left-bg"></div>
    <div class="login-left-grid"></div>
    <div class="login-left-content">
      <div class="login-brand">
        <div class="login-brand-icon">🌆</div>
        <span class="login-brand-name">Denver Social</span>
      </div>
      <div class="login-hero">
        <div class="login-eyebrow">Admin Portal</div>
        <h1 class="login-h1">Your city.<br>Your <em>crew.</em><br>Your dashboard.</h1>
        <p class="login-sub">Manage events, members, and everything happening across Denver Social.</p>
        <div class="login-stats">
          <div><div class="login-stat-num">88+</div><div class="login-stat-lbl">Members</div></div>
          <div><div class="login-stat-num">12+</div><div class="login-stat-lbl">Events</div></div>
          <div><div class="login-stat-num">RiNo</div><div class="login-stat-lbl">Home base</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="login-right">
    <div class="login-form-wrap">

      <!-- STEP 1: Email -->
      <div id="stepEmail">
        <h2 class="login-step-title">Welcome <em>back.</em></h2>
        <p class="login-step-sub">Enter your email and we'll send a 6-digit code to your inbox.</p>
        <div class="form-card">
          <label class="form-label">Email Address</label>
          <input type="email" id="emailInput" class="form-input" placeholder="stharpe98@gmail.com" />
          <button id="sendBtn" class="form-btn">Send My Code →</button>
          <div id="sendError" class="form-error"></div>
        </div>
        <div class="form-footer">Only authorized admins can access this area.</div>
      </div>

      <!-- STEP 2: OTP -->
      <div id="stepOtp" style="display:none">
        <h2 class="login-step-title">Check your <em>inbox.</em></h2>
        <p class="login-step-sub">6-digit code sent to <span id="sentTo"></span></p>
        <div class="form-card">
          <label class="form-label" style="text-align:center;display:block;margin-bottom:18px;">Enter Code</label>
          <div class="otp-row" id="otpInputs">
            <input type="text" maxlength="1" class="otp-box" inputmode="numeric" />
            <input type="text" maxlength="1" class="otp-box" inputmode="numeric" />
            <input type="text" maxlength="1" class="otp-box" inputmode="numeric" />
            <input type="text" maxlength="1" class="otp-box" inputmode="numeric" />
            <input type="text" maxlength="1" class="otp-box" inputmode="numeric" />
            <input type="text" maxlength="1" class="otp-box" inputmode="numeric" />
          </div>
          <button id="verifyBtn" class="form-btn" disabled>Verify Code →</button>
          <div id="otpError" class="form-error"></div>
        </div>
        <div class="form-links">
          <button class="form-link" id="resendLink">Resend code</button>
          <button class="form-link" id="backLink">Change email</button>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  let currentEmail = '';
  const sendBtn = document.getElementById('sendBtn') as HTMLButtonElement;
  const verifyBtn = document.getElementById('verifyBtn') as HTMLButtonElement;
  const otpBoxes = document.querySelectorAll<HTMLInputElement>('.otp-box');

  sendBtn.addEventListener('click', sendCode);
  document.getElementById('emailInput')!.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendCode(); });
  verifyBtn.addEventListener('click', verifyCode);
  document.getElementById('resendLink')!.addEventListener('click', () => { showStep('email'); setTimeout(sendCode, 100); });
  document.getElementById('backLink')!.addEventListener('click', () => showStep('email'));

  otpBoxes.forEach((box, i) => {
    box.addEventListener('input', () => {
      box.value = box.value.replace(/\D/g, '');
      box.classList.toggle('filled', !!box.value);
      if (box.value && i < 5) otpBoxes[i + 1].focus();
      const full = [...otpBoxes].map(b => b.value).join('');
      verifyBtn.disabled = full.length < 6;
      if (full.length === 6) verifyCode();
    });
    box.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !box.value && i > 0) { otpBoxes[i - 1].focus(); otpBoxes[i-1].classList.remove('filled'); }
    });
    box.addEventListener('paste', (e) => {
      e.preventDefault();
      const text = e.clipboardData?.getData('text').replace(/\D/g,'').slice(0,6) || '';
      text.split('').forEach((ch, idx) => { if (otpBoxes[idx]) { otpBoxes[idx].value = ch; otpBoxes[idx].classList.add('filled'); } });
      if (text.length === 6) verifyCode();
    });
  });

  function showStep(step: string) {
    (document.getElementById('stepEmail') as HTMLElement).style.display = step === 'email' ? 'block' : 'none';
    (document.getElementById('stepOtp') as HTMLElement).style.display = step === 'otp' ? 'block' : 'none';
  }

  async function sendCode() {
    const email = (document.getElementById('emailInput') as HTMLInputElement).value.trim();
    const errEl = document.getElementById('sendError')!;
    errEl.style.display = 'none';
    if (!email || !email.includes('@')) { errEl.textContent = 'Please enter a valid email.'; errEl.style.display = 'block'; return; }
    currentEmail = email;
    sendBtn.disabled = true; sendBtn.textContent = 'Sending...';
    try {
      const res = await fetch('/api/magic-link', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
      if (!res.ok) throw new Error();
      (document.getElementById('sentTo') as HTMLElement).textContent = email;
      otpBoxes.forEach(b => { b.value = ''; b.classList.remove('filled','error'); });
      verifyBtn.disabled = true;
      showStep('otp');
      otpBoxes[0].focus();
    } catch {
      errEl.textContent = 'Something went wrong. Try again.'; errEl.style.display = 'block';
    }
    sendBtn.disabled = false; sendBtn.textContent = 'Send My Code →';
  }

  async function verifyCode() {
    const code = [...otpBoxes].map(b => b.value).join('');
    if (code.length < 6) return;
    const errEl = document.getElementById('otpError')!;
    errEl.style.display = 'none';
    verifyBtn.disabled = true; verifyBtn.textContent = 'Verifying...';
    try {
      const res = await fetch('/admin/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code, email: currentEmail }) });
      const data = await res.json() as any;
      if (data.ok) {
        window.location.href = '/admin/dashboard';
      } else {
        errEl.textContent = data.error || 'Incorrect code. Try again.'; errEl.style.display = 'block';
        otpBoxes.forEach(b => { b.value = ''; b.classList.remove('filled'); b.classList.add('error'); });
        otpBoxes[0].focus();
        setTimeout(() => otpBoxes.forEach(b => b.classList.remove('error')), 1500);
      }
    } catch {
      errEl.textContent = 'Something went wrong. Try again.'; errEl.style.display = 'block';
    }
    verifyBtn.disabled = false; verifyBtn.textContent = 'Verify Code →';
  }
</script>
</AdminBase>
