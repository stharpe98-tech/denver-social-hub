---
import { getDB } from '../../lib/db';
import { requireApprovedOrg } from '../../lib/admin-auth';
import { ensureEventSyncSchema } from '../../lib/event-sync/schema';
import { SYNC_KINDS, findKind } from '../../lib/event-sync/kinds';

const gate = await requireApprovedOrg(Astro);
if (gate instanceof Response) return gate;

const db = getDB();
let sources: any[] = [];
if (db) {
  await ensureEventSyncSchema(db);
  const { results } = await db.prepare(
    "SELECT id, kind, label, config, webhook_token, enabled, last_synced_at, last_status, last_error, last_count FROM event_sources ORDER BY id DESC"
  ).all();
  sources = results ?? [];
}

const origin = Astro.url.origin;

function describeConfig(kind: string, configJson: string | null): string {
  if (!configJson) return '';
  try {
    const c = JSON.parse(configJson);
    if (kind === 'discord') return `guild ${c.guild_id || '?'}`;
    if (kind === 'ics' || kind === 'rss') return c.url || '';
    if (kind === 'eventbrite') return `org ${c.organization_id || '?'}`;
    if (kind === 'luma') return `calendar ${c.calendar_api_id || '?'}`;
    if (kind === 'ticketmaster') return [c.city, c.state_code, c.classification].filter(Boolean).join(' · ');
    if (kind === 'facebook') return `page ${c.page_id || '?'}`;
    return '';
  } catch { return ''; }
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Event Sync · Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #f7f5f2; color: #1c1917; font-family: 'Inter', sans-serif; min-height: 100vh; }
    body { padding-bottom: 60px; }
    .lh { background: #f7f5f2; border-bottom: 1px solid #e4ddd4; padding: 28px 20px; }
    .lh-in { max-width: 880px; margin: 0 auto; }
    .lh-back { color: #8a8a96; font-size: 13px; text-decoration: none; margin-bottom: 10px; display: inline-flex; align-items: center; gap: 4px; font-family: 'JetBrains Mono', monospace; }
    .lh h1 { font-size: clamp(20px,5vw,26px); font-weight: 700; color: #1c1917; margin-bottom: 4px; }
    .lh p { font-size: 13px; color: #8a8a96; font-family: 'JetBrains Mono', monospace; }
    .lp { max-width: 880px; margin: 0 auto; padding: 20px 16px; }

    .card { background: #fff; border: 1px solid #e4ddd4; border-radius: 12px; padding: 18px; margin-bottom: 16px; }
    .card-title { font-size: 11px; font-weight: 600; color: #8a8a96; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 14px; }

    .field { margin-bottom: 12px; }
    .field label { display: block; font-size: 11px; color: #8a8a96; margin-bottom: 5px; font-family: 'JetBrains Mono', monospace; }
    .inp { width: 100%; padding: 11px 13px; background: #f7f5f2; border: 1px solid #e4ddd4; border-radius: 7px; color: #1c1917; font-family: 'Inter', sans-serif; font-size: 14px; outline: none; -webkit-appearance: none; }
    .inp:focus { border-color: #7C3AED; }

    .btn { padding: 11px 16px; border-radius: 8px; border: none; background: #7C3AED; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; }
    .btn:hover { background: #6D28D9; }
    .btn:disabled { opacity: 0.6; cursor: progress; }
    .btn-sec { background: transparent; color: #6a6a76; border: 1px solid #e4ddd4; padding: 9px 14px; border-radius: 8px; font-size: 13px; cursor: pointer; }
    .btn-sec:hover { border-color: #7C3AED; color: #7C3AED; }
    .btn-danger { background: transparent; color: #8a8a96; border: 1px solid #e4ddd4; padding: 9px 14px; border-radius: 8px; font-size: 13px; cursor: pointer; }
    .btn-danger:hover { border-color: #ff4757; color: #ff4757; }

    .run-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
    .sec-label { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #8a8a96; margin: 24px 0 12px; }

    /* Source kind grid (the "all on one page" part) */
    .kind-grid { display: grid; gap: 16px; grid-template-columns: 1fr; }
    @media (min-width: 720px) { .kind-grid { grid-template-columns: 1fr 1fr; } }

    .kind-card {
      background: #fff; border: 1px solid #e4ddd4; border-radius: 12px;
      padding: 18px; display: flex; flex-direction: column;
    }
    .kind-head { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
    .kind-icon { font-size: 22px; line-height: 1; }
    .kind-name { font-size: 15px; font-weight: 700; color: #1c1917; }
    .kind-desc { font-size: 13px; color: #6a6a76; line-height: 1.45; margin-bottom: 10px; }
    .note { background: #FEF9C3; border: 1px solid #FDE68A; color: #713F12; font-size: 12px; padding: 10px 12px; border-radius: 8px; margin-bottom: 12px; line-height: 1.4; }
    .help { font-size: 11px; color: #8a8a96; margin-top: 4px; line-height: 1.4; }
    .add-row { margin-top: auto; padding-top: 4px; }
    .kind-status { font-size: 11px; color: #6a6a76; font-family: 'JetBrains Mono', monospace; margin-top: 8px; }
    .kind-status.ok { color: #047857; }
    .kind-status.err { color: #b91c1c; }

    /* Connected source list */
    .src { background: #fff; border: 1px solid #e4ddd4; border-radius: 10px; padding: 14px 16px; margin-bottom: 10px; }
    .src.disabled { opacity: 0.55; }
    .src-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
    .src-title { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .kind-pill { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px; background: #EEF2FF; color: #4338CA; }
    .src-label { font-size: 14px; font-weight: 600; color: #1c1917; }
    .src-cfg { font-size: 12px; color: #6a6a76; font-family: 'JetBrains Mono', monospace; margin-bottom: 8px; word-break: break-all; }
    .src-meta { font-size: 11px; color: #8a8a96; font-family: 'JetBrains Mono', monospace; }
    .src-status-ok { color: #047857; }
    .src-status-err { color: #b91c1c; }
    .src-actions { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
    .empty { text-align: center; padding: 32px; color: #8a8a96; font-style: italic; font-size: 13px; }
    .run-result { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6a6a76; margin-top: 8px; white-space: pre-wrap; }
    .hide { display: none; }
    .webhook-info { background: #F0FDF4; border: 1px solid #BBF7D0; padding: 10px 12px; border-radius: 8px; margin-top: 10px; }
    .webhook-info code { display: block; background: #fff; border: 1px solid #BBF7D0; padding: 6px 8px; border-radius: 6px; font-size: 11px; word-break: break-all; margin-top: 4px; font-family: 'JetBrains Mono', monospace; }
    .webhook-label { font-size: 11px; font-weight: 600; color: #047857; text-transform: uppercase; letter-spacing: 0.5px; }
    .copy-btn { font-size: 11px; padding: 3px 8px; border-radius: 6px; border: 1px solid #BBF7D0; background: #fff; color: #047857; cursor: pointer; margin-left: 6px; }
  </style>
</head>
<body>
  <div class="lh">
    <div class="lh-in">
      <a href="/admin/dashboard" class="lh-back">← Admin</a>
      <h1>🤖 Event Sync</h1>
      <p>multi-source bot · pulls events into /events</p>
    </div>
  </div>

  <div class="lp">

    <div class="card">
      <div class="run-row">
        <div>
          <div class="card-title" style="margin-bottom: 2px;">Run pull-based sources now</div>
          <div style="font-size:12px;color:#8a8a96">Cron runs every 2 hours. Webhook sources receive events via push and aren't included.</div>
        </div>
        <button class="btn" id="runBtn">Sync all</button>
      </div>
      <div class="run-result hide" id="runResult"></div>
    </div>

    <div class="sec-label">Add a source</div>
    <div class="kind-grid">
      {SYNC_KINDS.map((k) => (
        <div class="kind-card" data-kind={k.kind}>
          <div class="kind-head">
            <span class="kind-icon">{k.icon}</span>
            <span class="kind-name">{k.label}</span>
          </div>
          <p class="kind-desc">{k.description}</p>
          {k.note && <div class="note">{k.note}</div>}

          <div class="field">
            <label>label</label>
            <input type="text" class="inp" data-field-name="__label" placeholder={`e.g. ${k.label}`} />
          </div>

          {k.fields.map((f) => (
            <div class="field">
              <label>{f.label}{f.required ? ' *' : ''}</label>
              <input
                type={f.type === 'password' ? 'password' : 'text'}
                class="inp"
                data-field-name={f.name}
                placeholder={f.placeholder || ''}
              />
              {f.help && <div class="help">{f.help}</div>}
            </div>
          ))}

          <div class="add-row">
            <button class="btn js-add" data-kind={k.kind}>Add {k.label}</button>
            <div class="kind-status hide" data-status></div>
          </div>
        </div>
      ))}
    </div>

    <div class="sec-label">Connected sources ({sources.length})</div>

    {sources.length === 0 ? (
      <div class="empty">No sources yet — add one above.</div>
    ) : (
      sources.map((s: any) => {
        const def = findKind(s.kind);
        const webhookUrl = s.kind === 'webhook' ? `${origin}/api/sync/webhook/${s.id}` : '';
        return (
          <div class={"src" + (s.enabled ? "" : " disabled")} data-id={s.id}>
            <div class="src-top">
              <div class="src-title">
                <span class="kind-pill">{def?.icon || ''} {s.kind}</span>
                <span class="src-label">{s.label || '(no label)'}</span>
              </div>
              <div style="font-size:11px;color:#8a8a96">#{s.id}</div>
            </div>
            {describeConfig(s.kind, s.config) && (
              <div class="src-cfg">{describeConfig(s.kind, s.config)}</div>
            )}
            <div class="src-meta">
              {s.last_synced_at ? (
                <>
                  last sync: {new Date(s.last_synced_at).toLocaleString()} ·
                  {s.last_status === 'ok' ? (
                    <span class="src-status-ok"> ok · {s.last_count ?? 0} events</span>
                  ) : (
                    <span class="src-status-err"> error: {s.last_error || 'unknown'}</span>
                  )}
                </>
              ) : (
                <span>never run</span>
              )}
            </div>
            {s.kind === 'webhook' && (
              <div class="webhook-info">
                <div class="webhook-label">Inbound webhook</div>
                <div style="font-size:11px;color:#6a6a76;margin-top:4px">POST events to this URL with the token:</div>
                <code>{webhookUrl}</code>
                <code>Authorization: Bearer {s.webhook_token || '(rotate to generate)'}<button class="copy-btn js-copy" data-copy={s.webhook_token || ''}>copy</button></code>
              </div>
            )}
            <div class="src-actions">
              <button class="btn-sec js-toggle" data-id={s.id}>{s.enabled ? 'Disable' : 'Enable'}</button>
              {s.kind === 'webhook' && (
                <button class="btn-sec js-rotate" data-id={s.id}>Rotate token</button>
              )}
              <button class="btn-danger js-delete" data-id={s.id}>Delete</button>
            </div>
          </div>
        );
      })
    )}
  </div>

  <script is:inline>
    async function call(body) {
      const res = await fetch('/api/admin/sync', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      return res.json();
    }

    document.querySelectorAll('.js-add').forEach(btn => btn.addEventListener('click', async () => {
      const kind = btn.getAttribute('data-kind');
      const card = btn.closest('.kind-card');
      const statusEl = card.querySelector('[data-status]');
      const payload = { action: 'create', kind };
      card.querySelectorAll('input[data-field-name]').forEach(inp => {
        const name = inp.getAttribute('data-field-name');
        if (name === '__label') payload.label = inp.value.trim();
        else payload[name] = inp.value.trim();
      });
      btn.disabled = true;
      statusEl.classList.remove('hide', 'ok', 'err');
      statusEl.textContent = 'Adding…';
      try {
        const r = await call(payload);
        if (r.ok) { statusEl.classList.add('ok'); statusEl.textContent = 'Added — reloading…'; setTimeout(() => location.reload(), 600); }
        else { statusEl.classList.add('err'); statusEl.textContent = r.error || 'Failed'; btn.disabled = false; }
      } catch (e) {
        statusEl.classList.add('err'); statusEl.textContent = 'Network error'; btn.disabled = false;
      }
    }));

    document.querySelectorAll('.js-toggle').forEach(b => b.addEventListener('click', async () => {
      const r = await call({ action: 'toggle', id: parseInt(b.dataset.id) });
      if (r.ok) location.reload(); else alert(r.error || 'Failed');
    }));

    document.querySelectorAll('.js-rotate').forEach(b => b.addEventListener('click', async () => {
      if (!confirm('Rotate the token? Existing webhook senders will need the new one.')) return;
      const r = await call({ action: 'rotate_token', id: parseInt(b.dataset.id) });
      if (r.ok) location.reload(); else alert(r.error || 'Failed');
    }));

    document.querySelectorAll('.js-delete').forEach(b => b.addEventListener('click', async () => {
      if (!confirm('Delete this source? Events already imported will stay.')) return;
      const r = await call({ action: 'delete', id: parseInt(b.dataset.id) });
      if (r.ok) location.reload(); else alert(r.error || 'Failed');
    }));

    document.querySelectorAll('.js-copy').forEach(b => b.addEventListener('click', async (e) => {
      e.stopPropagation();
      const v = b.getAttribute('data-copy');
      if (!v) return;
      try { await navigator.clipboard.writeText(v); b.textContent = 'copied'; setTimeout(() => b.textContent = 'copy', 1500); } catch {}
    }));

    const runBtn = document.getElementById('runBtn');
    const out = document.getElementById('runResult');
    runBtn.addEventListener('click', async () => {
      runBtn.disabled = true; runBtn.textContent = 'Syncing…';
      out.classList.remove('hide');
      out.textContent = 'Running…';
      try {
        const r = await call({ action: 'run' });
        if (!r.ok) { out.textContent = 'Error: ' + (r.error || 'unknown'); }
        else {
          const t = r.result.total;
          const lines = [`Total: +${t.inserted} new · ${t.updated} updated · ${t.errors} errors`];
          for (const s of r.result.bySource) {
            if (s.status === 'ok') lines.push(`  ✓ [${s.kind}] ${s.label || '(unlabeled)'}: +${s.inserted} / ~${s.updated}`);
            else if (s.status === 'skipped') lines.push(`  ◦ [${s.kind}] ${s.label || '(unlabeled)'}: skipped (${s.error})`);
            else lines.push(`  ✗ [${s.kind}] ${s.label || '(unlabeled)'}: ${s.error}`);
          }
          out.textContent = lines.join('\n');
          setTimeout(() => location.reload(), 1500);
        }
      } catch (e) {
        out.textContent = 'Network error';
      }
      runBtn.disabled = false; runBtn.textContent = 'Sync all';
    });
  </script>
</body>
</html>
