---
import { requireApprovedOrg, isSuperAdmin } from '../../lib/admin-auth';
import { getDB } from '../../lib/db';

const gate = await requireApprovedOrg(Astro);
if (gate instanceof Response) return gate;
const org = gate;
const isSuper = isSuperAdmin(org);

const db = getDB();
let cfg: Record<string, string> = {};
if (db) {
  const rows = await db.prepare("SELECT key, value FROM config").all();
  (rows.results ?? []).forEach((r: any) => { cfg[r.key] = r.value || ''; });
}

const v = (k: string) => cfg[k] || '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Site settings · Denver Social</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #FAFAF8; --surface: #FFFFFF; --border: #E8E4DE;
      --text: #1A1A1A; --text-sec: #6B6560; --text-faint: #A09890;
      --accent: #0EA5E9; --accent-dim: rgba(14,165,233,0.10);
      --mint: #10B981; --red: #DC2626;
    }
    html, body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; font-size: 14px; padding-bottom: 60px; }

    .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .topbar-left { display: flex; align-items: center; gap: 16px; }
    .back-link { color: var(--text-sec); text-decoration: none; font-size: 13px; padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border); }
    .back-link:hover { background: var(--bg); color: var(--text); }
    .topbar h1 { font-family: 'Cormorant Garamond', sans-serif; font-size: 18px; font-weight: 700; }

    .page { max-width: 760px; margin: 0 auto; padding: 28px 20px; }

    .group { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 22px; margin-bottom: 18px; }
    .group-head { margin-bottom: 16px; }
    .group-title { font-family: 'Cormorant Garamond', sans-serif; font-size: 17px; font-weight: 700; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
    .group-sub { font-size: 13px; color: var(--text-sec); line-height: 1.5; }
    .group-sub a { color: var(--accent); font-weight: 600; }

    .row { margin-bottom: 12px; }
    .row label { display: block; font-size: 11px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; }
    .row label .opt { font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-faint); }
    .row input, .row textarea {
      width: 100%; padding: 10px 12px;
      background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
      font-family: inherit; font-size: 14px; color: var(--text);
      outline: none; transition: border-color 0.15s, box-shadow 0.15s;
      -webkit-appearance: none;
    }
    .row input:focus, .row textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media (max-width: 500px) { .row-2 { grid-template-columns: 1fr; } }

    .check-row { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; cursor: pointer; }
    .check-row input { width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent); }

    .save-row { display: flex; align-items: center; gap: 12px; margin-top: 14px; flex-wrap: wrap; }
    .test-btn {
      padding: 10px 18px; border-radius: 999px;
      background: var(--bg); border: 1px solid var(--border); color: var(--text-sec);
      font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .test-btn:hover { border-color: var(--text-faint); color: var(--text); }
    .test-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .test-result { font-size: 13px; padding: 8px 12px; border-radius: 8px; flex-basis: 100%; display: none; line-height: 1.45; }
    .test-result.show { display: block; }
    .test-result.ok { background: rgba(16,185,129,0.10); color: #047857; border: 1px solid rgba(16,185,129,0.25); }
    .test-result.err { background: rgba(220,38,38,0.08); color: var(--red); border: 1px solid rgba(220,38,38,0.20); }
    .save-btn {
      padding: 10px 20px; border-radius: 999px; border: none;
      background: var(--accent); color: #fff;
      font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
      cursor: pointer; transition: box-shadow 0.15s, transform 0.15s;
      box-shadow: 0 1px 3px rgba(14,165,233,0.25);
    }
    .save-btn:hover { box-shadow: 0 6px 18px rgba(14,165,233,0.35); transform: translateY(-1px); }
    .save-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .save-note { font-size: 13px; color: var(--mint); font-weight: 500; opacity: 0; transition: opacity 0.15s; }
    .save-note.show { opacity: 1; }

    code { background: var(--bg); padding: 2px 6px; border-radius: 4px; font-size: 12px; color: var(--text-sec); }

    /* Step-by-step setup blocks */
    .steps {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 14px 16px;
      margin-top: 12px; margin-bottom: 14px;
    }
    .steps-title { font-family: 'Cormorant Garamond', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-sec); margin-bottom: 10px; }
    .steps ol { list-style: none; padding: 0; margin: 0; counter-reset: step; display: flex; flex-direction: column; gap: 10px; }
    .steps ol li {
      counter-increment: step;
      display: flex; align-items: flex-start; gap: 10px;
      font-size: 13px; line-height: 1.5; color: var(--text-sec);
    }
    .steps ol li::before {
      content: counter(step);
      flex-shrink: 0; width: 22px; height: 22px;
      background: var(--accent-dim); color: var(--accent);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', sans-serif; font-size: 11px; font-weight: 800;
    }
    .steps strong { color: var(--text); font-weight: 600; }
    .steps code { font-size: 12px; }
    .step-btn {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 5px 12px; border-radius: 999px;
      background: var(--accent); color: #fff;
      font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700;
      text-decoration: none; margin-left: 6px;
      transition: box-shadow 0.15s, transform 0.15s;
    }
    .step-btn:hover { box-shadow: 0 4px 12px rgba(14,165,233,0.32); transform: translateY(-1px); }
    .step-btn-ghost { background: var(--bg); color: var(--text-sec); border: 1px solid var(--border); }
    .step-btn-ghost:hover { box-shadow: none; color: var(--text); border-color: var(--text-faint); }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/admin/dashboard" class="back-link">← Dashboard</a>
    <h1>Site settings</h1>
  </div>
  <span style="font-size:12px;color:var(--text-faint)">{org.email}</span>
</div>

<div class="page">

  <!-- EMAIL (Resend) -->
  <form class="group" data-group="email">
    <div class="group-head">
      <div class="group-title">📧 Email (Resend)</div>
      <p class="group-sub">Powers RSVP confirmations, daily reminders, email magic-code login, and admin OTP. Free tier covers 100 emails/day.</p>
    </div>
    <div class="steps">
      <div class="steps-title">Set up in 3 steps</div>
      <ol>
        <li>Sign up at Resend (free) <a href="https://resend.com/signup" target="_blank" rel="noopener" class="step-btn">Open Resend →</a></li>
        <li>In Resend, go to <strong>API Keys</strong> → <strong>Create API Key</strong> → name it "Denver Social". Copy the <code>re_…</code> key. <a href="https://resend.com/api-keys" target="_blank" rel="noopener" class="step-btn-ghost step-btn">API Keys page →</a></li>
        <li>Paste below + set your <strong>From email</strong>. Use <code>onboarding@resend.dev</code> while testing, then add and verify your own domain later. <a href="https://resend.com/domains" target="_blank" rel="noopener" class="step-btn-ghost step-btn">Verify a domain →</a></li>
      </ol>
    </div>
    <div class="row"><label>Resend API Key</label><input type="password" name="resend_api_key" value={v('resend_api_key')} placeholder="re_xxxxxxxxxxxxxxx" autocomplete="off"/></div>
    <div class="row-2">
      <div class="row"><label>From email</label><input type="text" name="from_email" value={v('from_email')} placeholder="Denver Social <onboarding@resend.dev>"/></div>
      <div class="row"><label>Site URL <span class="opt">(used in email links)</span></label><input type="text" name="site_url" value={v('site_url')} placeholder="https://denversocialhub.com"/></div>
    </div>
    <div class="save-row">
      <button class="save-btn" type="submit">Save</button>
      <button class="test-btn" type="button" data-test="resend">Test connection</button>
      <span class="save-note">Saved ✓</span>
      <span class="test-result"></span>
    </div>
  </form>

  <!-- DISCORD OAUTH -->
  <form class="group" data-group="discord">
    <div class="group-head">
      <div class="group-title">💬 Discord login</div>
      <p class="group-sub">Lets members sign in with their Discord account.</p>
    </div>
    <div class="steps">
      <div class="steps-title">Set up in 4 steps</div>
      <ol>
        <li>Open Discord Developer Portal → <strong>New Application</strong> → name it "Denver Social". <a href="https://discord.com/developers/applications" target="_blank" rel="noopener" class="step-btn">Developer Portal →</a></li>
        <li>In the app's sidebar, click <strong>OAuth2</strong>. Copy the <strong>Client ID</strong> and <strong>Client Secret</strong> (you may need to "Reset Secret" the first time).</li>
        <li>In <strong>OAuth2 → Redirects</strong>, click <strong>Add Redirect</strong> and paste exactly: <code>https://denversocialhub.com/api/auth/discord/callback</code> → Save Changes.</li>
        <li>Paste the Client ID + Secret below and hit Save. The "Continue with Discord" button shows up immediately on /login.</li>
      </ol>
    </div>
    <div class="row"><label>Discord Client ID</label><input type="text" name="discord_client_id" value={v('discord_client_id')} placeholder="1234567890123456789" autocomplete="off"/></div>
    <div class="row"><label>Discord Client Secret</label><input type="password" name="discord_client_secret" value={v('discord_client_secret')} placeholder="••••••••••••••••••••••••" autocomplete="off"/></div>
    <div class="save-row">
      <button class="save-btn" type="submit">Save</button>
      <button class="test-btn" type="button" data-test="discord">Test connection</button>
      <span class="save-note">Saved ✓</span>
      <span class="test-result"></span>
    </div>
  </form>

  <!-- SMS (Twilio) -->
  <form class="group" data-group="sms">
    <div class="group-head">
      <div class="group-title">📱 SMS (Twilio)</div>
      <p class="group-sub">Texts you a one-liner whenever someone RSVPs. Optional. Twilio gives you a free trial number + ~$15 credit.</p>
    </div>
    <div class="steps">
      <div class="steps-title">Set up in 4 steps</div>
      <ol>
        <li>Sign up for Twilio. <a href="https://www.twilio.com/try-twilio" target="_blank" rel="noopener" class="step-btn">Start Twilio →</a></li>
        <li>On your Twilio <strong>Console dashboard</strong>, copy the <strong>Account SID</strong> and <strong>Auth Token</strong>. <a href="https://console.twilio.com" target="_blank" rel="noopener" class="step-btn-ghost step-btn">Twilio Console →</a></li>
        <li>Get a phone number to send from: <strong>Phone Numbers → Buy a number</strong> (or use the free trial number Twilio gives you). <a href="https://console.twilio.com/us1/develop/phone-numbers/manage/search" target="_blank" rel="noopener" class="step-btn-ghost step-btn">Buy a number →</a></li>
        <li>Paste Account SID, Auth Token, the From number (E.164: <code>+15551234567</code>), and your personal phone where you want notifications.</li>
      </ol>
    </div>
    <div class="row-2">
      <div class="row"><label>Account SID</label><input type="text" name="twilio_account_sid" value={v('twilio_account_sid')} placeholder="AC…"/></div>
      <div class="row"><label>Auth token</label><input type="password" name="twilio_auth_token" value={v('twilio_auth_token')} placeholder="••••••••" autocomplete="off"/></div>
    </div>
    <div class="row-2">
      <div class="row"><label>From number <span class="opt">(E.164)</span></label><input type="text" name="twilio_from" value={v('twilio_from')} placeholder="+15551234567"/></div>
      <div class="row"><label>Your phone <span class="opt">(where notifications go)</span></label><input type="text" name="twilio_to" value={v('twilio_to')} placeholder="+17205551234"/></div>
    </div>
    <div class="save-row">
      <button class="save-btn" type="submit">Save</button>
      <button class="test-btn" type="button" data-test="twilio">Test connection</button>
      <span class="save-note">Saved ✓</span>
      <span class="test-result"></span>
    </div>
  </form>

  <!-- BOT PROTECTION -->
  <form class="group" data-group="turnstile">
    <div class="group-head">
      <div class="group-title">🛡 Bot protection (Cloudflare Turnstile)</div>
      <p class="group-sub">Stops bots from spamming sign-ups. Free, invisible to real visitors.</p>
    </div>
    <div class="steps">
      <div class="steps-title">Set up in 3 steps</div>
      <ol>
        <li>Open Cloudflare dashboard → <strong>Turnstile</strong>. <a href="https://dash.cloudflare.com/?to=/:account/turnstile" target="_blank" rel="noopener" class="step-btn">Open Turnstile →</a></li>
        <li>Click <strong>Add site</strong>. Name it "Denver Social", add domains <code>denversocialhub.com</code> + your worker preview domain, choose <strong>Managed</strong> widget mode → Save.</li>
        <li>Copy the <strong>Secret key</strong> (not site key — that's already wired) and paste below.</li>
      </ol>
    </div>
    <div class="row"><label>Turnstile secret key</label><input type="password" name="turnstile_secret_key" value={v('turnstile_secret_key')} placeholder="0x4AAAAAAA…" autocomplete="off"/></div>
    <div class="save-row">
      <button class="save-btn" type="submit">Save</button>
      <button class="test-btn" type="button" data-test="turnstile">Test connection</button>
      <span class="save-note">Saved ✓</span>
      <span class="test-result"></span>
    </div>
  </form>

  <!-- CONTACT & PAYMENT DEFAULTS -->
  <form class="group" data-group="contact">
    <div class="group-head">
      <div class="group-title">📞 Contact &amp; payment defaults</div>
      <p class="group-sub">Shown to attendees on the post-signup confirmation. Never appears in public HTML — only delivered to confirmed RSVPs.</p>
    </div>
    <div class="row"><label>Organizer email <span class="opt">(gets notified on every sign-up)</span></label><input type="text" name="organizer_email" value={v('organizer_email')} placeholder="you@example.com"/></div>
    <div class="row-2">
      <div class="row"><label>Contact phone</label><input type="text" name="contact_phone" value={v('contact_phone')} placeholder="(720) 555-1234"/></div>
      <div class="row"><label>Discord handle</label><input type="text" name="contact_discord" value={v('contact_discord')} placeholder="@yourhandle"/></div>
    </div>
    <div class="row"><label>Discord invite URL</label><input type="text" name="contact_discord_url" value={v('contact_discord_url')} placeholder="https://discord.gg/…"/></div>
    <div class="row-2">
      <div class="row"><label>Venmo handle</label><input type="text" name="venmo_handle" value={v('venmo_handle')} placeholder="@yourvenmo"/></div>
      <div class="row"><label>Cash App handle</label><input type="text" name="cashapp_handle" value={v('cashapp_handle')} placeholder="$yourcashtag"/></div>
    </div>
    <div class="row"><label>Stripe payment link <span class="opt">(optional)</span></label><input type="text" name="stripe_link" value={v('stripe_link')} placeholder="https://buy.stripe.com/…"/></div>
    <div class="save-row"><button class="save-btn" type="submit">Save</button><span class="save-note">Saved ✓</span></div>
  </form>

  <!-- INTEGRATIONS -->
  <form class="group" data-group="webhook">
    <div class="group-head">
      <div class="group-title">⚡ Zapier / webhook</div>
      <p class="group-sub">Every confirmed sign-up POSTs JSON to a URL you choose. Pipes RSVPs into Google Sheets, Slack, Notion, anything.</p>
    </div>
    <div class="steps">
      <div class="steps-title">Set up in 3 steps</div>
      <ol>
        <li>Open Zapier → create a new Zap. Trigger: <strong>Webhooks by Zapier → Catch Hook</strong>. <a href="https://zapier.com/app/zaps" target="_blank" rel="noopener" class="step-btn">Open Zapier →</a></li>
        <li>Copy the URL Zapier shows (looks like <code>https://hooks.zapier.com/hooks/catch/…</code>).</li>
        <li>Paste below + add an action (e.g. <em>"Add row to Google Sheet"</em>) in Zapier to send RSVPs anywhere.</li>
      </ol>
    </div>
    <div class="row"><label>Webhook URL</label><input type="text" name="webhook_url" value={v('webhook_url')} placeholder="https://hooks.zapier.com/hooks/catch/…"/></div>
    <div class="save-row">
      <button class="save-btn" type="submit">Save</button>
      <button class="test-btn" type="button" data-test="webhook">Test connection</button>
      <span class="save-note">Saved ✓</span>
      <span class="test-result"></span>
    </div>
  </form>

  {isSuper && (
    <form class="group" data-group="coming_soon">
      <div class="group-head">
        <div class="group-title">🚧 Coming-soon mode <span style="font-size:11px;background:var(--accent-dim);color:var(--accent);padding:2px 8px;border-radius:999px;margin-left:6px">super</span></div>
        <p class="group-sub">While ON, public visitors see <code>/coming-soon</code>. Signed-in members + admins always bypass.</p>
      </div>
      <label class="check-row" style="margin-bottom:12px">
        <input type="checkbox" name="coming_soon_mode" data-bool="on" data-bool-off="off" checked={(v('coming_soon_mode') || 'on').toLowerCase() !== 'off'}/>
        <span>Show "Coming soon" page to public visitors</span>
      </label>
      <div class="row-2">
        <div class="row"><label>Launch date <span class="opt">(shown on splash)</span></label><input type="text" name="launch_date" value={v('launch_date')} placeholder="May 30, 2026"/></div>
        <div class="row"><label>Preview key <span class="opt">(share <code>?preview=…</code>)</span></label><input type="text" name="preview_key" value={v('preview_key')} placeholder="auto-generated"/></div>
      </div>
      <div class="row"><label>Teaser text <span class="opt">(optional)</span></label><input type="text" name="launch_teaser" value={v('launch_teaser')} placeholder="Custom one-liner for the splash"/></div>
      <div class="save-row"><button class="save-btn" type="submit">Save</button><span class="save-note">Saved ✓</span></div>
    </form>
  )}

</div>

<script is:inline>
  document.querySelectorAll('form.group').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = form.querySelector('.save-btn');
      var note = form.querySelector('.save-note');
      var origText = btn.textContent;
      btn.disabled = true; btn.textContent = 'Saving…';
      note.classList.remove('show');

      var entries = Array.from(form.querySelectorAll('[name]'));
      var ops = entries.map(function(el) {
        var key = el.getAttribute('name');
        var value;
        if (el.type === 'checkbox') {
          value = el.checked ? (el.dataset.bool || 'on') : (el.dataset.boolOff || 'off');
        } else {
          value = el.value.trim();
        }
        return fetch('/api/potlucks', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'set_config', key: key, value: value }),
        }).then(function(r) { return r.json(); });
      });

      try {
        var results = await Promise.all(ops);
        var ok = results.every(function(r) { return r.ok; });
        note.textContent = ok ? 'Saved ✓' : 'Some fields failed';
        note.style.color = ok ? 'var(--mint)' : 'var(--red)';
        note.classList.add('show');
        setTimeout(function() { note.classList.remove('show'); }, 2500);
      } catch (err) {
        note.textContent = 'Network error';
        note.style.color = 'var(--red)';
        note.classList.add('show');
      }
      btn.disabled = false; btn.textContent = origText;
    });
  });

  // Test buttons — hit /api/admin/test-integration and show result inline
  document.querySelectorAll('.test-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var kind = btn.getAttribute('data-test');
      var form = btn.closest('form');
      var result = form.querySelector('.test-result');
      result.className = 'test-result';
      result.textContent = '';
      btn.disabled = true;
      var orig = btn.textContent;
      btn.textContent = 'Testing…';
      try {
        var r = await fetch('/api/admin/test-integration', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ kind: kind }),
        });
        var d = await r.json();
        if (d.ok) {
          result.className = 'test-result show ok';
          result.textContent = d.message || 'Works ✓';
        } else {
          result.className = 'test-result show err';
          result.textContent = d.error || 'Test failed.';
        }
      } catch (e) {
        result.className = 'test-result show err';
        result.textContent = 'Network error: ' + (e && e.message ? e.message : 'unknown');
      }
      btn.disabled = false;
      btn.textContent = orig;
    });
  });
</script>

</body>
</html>
