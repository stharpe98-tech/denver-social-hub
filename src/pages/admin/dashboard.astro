---
import AdminBase from '../../layouts/AdminBase.astro';
import { getDB } from '../../lib/db';

const cookie = Astro.request.headers.get('cookie') || '';
const userMatch = cookie.match(/dsn_user=([^;]+)/);
let isAdmin = false;
if (userMatch) {
  try { const u = JSON.parse(decodeURIComponent(userMatch[1])); isAdmin = u.email === 'stharpe98@gmail.com'; } catch {}
}
if (!isAdmin) return Astro.redirect('/admin');

const db = getDB();
let members: any[] = [], events: any[] = [], suggestions: any[] = [];
if (db) {
  try {
    members    = (await db.prepare(`SELECT * FROM members ORDER BY id DESC`).all())?.results || [];
    events     = (await db.prepare(`SELECT * FROM events ORDER BY id DESC`).all())?.results || [];
    suggestions = (await db.prepare(`SELECT * FROM suggestions ORDER BY votes DESC LIMIT 10`).all())?.results || [];
  } catch {}
}
const onboarded = members.filter((m:any) => m.onboarding_done).length;
const typeEmoji: Record<string,string> = {
  dinner:'🍽️', game_night:'🎲', outdoor:'🏔️', brewery:'🍺', bowling:'🎳',
  arts:'🎨', music:'🎵', social:'🎉', group_tickets:'🎫', other:'📅'
};
---
<AdminBase title="Dashboard — Denver Social">
<style>
  :root {
    --bg:#07090f; --s1:#0f1117; --s2:#141720; --s3:#1a1d27;
    --border:rgba(255,255,255,.07); --coral:#F05A28; --coral-dim:rgba(240,90,40,.1);
    --text:#e8ecf4; --muted:#5a6478; --green:#22c55e; --red:#ef4444;
    --blue:#3b82f6; --sw:240px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;}

  /* LAYOUT */
  .shell{display:flex;min-height:100vh;}
  .main{margin-left:var(--sw);flex:1;min-width:0;}

  /* SIDEBAR */
  .sidebar{
    width:var(--sw);position:fixed;top:0;left:0;bottom:0;
    background:var(--s1);border-right:1px solid var(--border);
    display:flex;flex-direction:column;z-index:100;
    transition:transform .25s;
  }
  .sb-top{padding:20px 16px;border-bottom:1px solid var(--border);}
  .sb-brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
  .sb-icon{width:34px;height:34px;background:var(--coral);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
  .sb-name{font-family:'Instrument Serif',serif;font-size:16px;font-weight:900;color:var(--text);}
  .sb-name small{display:block;font-family:'DM Sans',sans-serif;font-size:9px;font-weight:400;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;font-style:normal;}

  .sb-nav{flex:1;padding:12px 8px;overflow-y:auto;display:flex;flex-direction:column;gap:2px;}
  .sb-section{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);padding:12px 10px 6px;}
  .sb-link{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:var(--muted);font-size:13px;font-weight:500;transition:all .15s;cursor:pointer;border:none;background:none;width:100%;text-align:left;}
  .sb-link:hover{background:var(--s2);color:var(--text);}
  .sb-link.active{background:var(--coral-dim);color:var(--coral);}
  .sb-link-icon{font-size:16px;width:20px;text-align:center;flex-shrink:0;}
  .sb-badge{margin-left:auto;background:var(--coral);color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:50px;}

  .sb-bottom{padding:12px 8px;border-top:1px solid var(--border);}
  .sb-user{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;}
  .sb-avatar{width:32px;height:32px;background:var(--coral);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;flex-shrink:0;}
  .sb-user-info{flex:1;min-width:0;}
  .sb-user-name{font-size:13px;font-weight:600;color:var(--text);}
  .sb-user-role{font-size:10px;color:var(--muted);}

  /* TOPBAR */
  .topbar{
    height:56px;border-bottom:1px solid var(--border);background:rgba(7,9,15,.8);
    backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:space-between;
    padding:0 28px;position:sticky;top:0;z-index:40;
  }
  .topbar-left{display:flex;align-items:center;gap:14px;}
  .hamburger{display:none;background:none;border:none;color:var(--text);font-size:20px;cursor:pointer;padding:4px;}
  .topbar-title{font-family:'Instrument Serif',serif;font-size:20px;font-weight:900;color:var(--text);}
  .topbar-right{display:flex;align-items:center;gap:10px;}
  .topbar-btn{background:none;border:1px solid var(--border);border-radius:8px;padding:7px 14px;font-size:12px;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
  .topbar-btn:hover{border-color:rgba(255,255,255,.15);color:var(--text);}
  .topbar-btn.danger:hover{border-color:var(--red);color:var(--red);}

  /* CONTENT */
  .content{padding:28px;}

  /* PANELS */
  .panel{display:none;}
  .panel.active{display:block;}

  /* STATS ROW */
  .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;}
  .stat-card{background:var(--s1);border:1px solid var(--border);border-radius:16px;padding:20px 22px;}
  .stat-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
  .stat-icon{font-size:20px;}
  .stat-trend{font-size:11px;color:var(--green);font-weight:600;}
  .stat-num{font-family:'Instrument Serif',serif;font-size:34px;font-weight:900;color:var(--text);line-height:1;margin-bottom:4px;}
  .stat-lbl{font-size:12px;color:var(--muted);}

  /* TABLE */
  .table-card{background:var(--s1);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-bottom:24px;}
  .table-head{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
  .table-title{font-size:15px;font-weight:600;color:var(--text);}
  .table-search{background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;width:200px;transition:border-color .2s;}
  .table-search:focus{border-color:var(--coral);}
  .table-search::placeholder{color:var(--muted);}
  table{width:100%;border-collapse:collapse;}
  th{padding:11px 20px;text-align:left;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);font-weight:700;background:var(--s2);border-bottom:1px solid var(--border);}
  td{padding:13px 20px;font-size:13px;border-bottom:1px solid var(--border);}
  tr:last-child td{border-bottom:none;}
  tr:hover td{background:rgba(255,255,255,.015);}
  .td-name{font-weight:600;color:var(--text);}
  .td-muted{color:var(--muted);}
  .badge{display:inline-block;font-size:10px;font-weight:700;padding:3px 9px;border-radius:50px;}
  .badge-green{background:rgba(34,197,94,.1);color:var(--green);}
  .badge-muted{background:rgba(255,255,255,.05);color:var(--muted);}
  .badge-coral{background:var(--coral-dim);color:var(--coral);}
  .badge-blue{background:rgba(59,130,246,.1);color:var(--blue);}
  .action-btn{background:none;border:1px solid var(--border);border-radius:7px;padding:5px 10px;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;color:var(--muted);transition:all .15s;}
  .action-btn:hover{border-color:var(--coral);color:var(--coral);}
  .action-btn.del:hover{border-color:var(--red);color:var(--red);}

  /* SETTINGS */
  .settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  .settings-card{background:var(--s1);border:1px solid var(--border);border-radius:16px;padding:24px;}
  .settings-card-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:4px;}
  .settings-card-sub{font-size:12px;color:var(--muted);margin-bottom:20px;line-height:1.5;}
  .settings-field{margin-bottom:16px;}
  .settings-label{display:block;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:7px;}
  .settings-input{width:100%;background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:11px 14px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;}
  .settings-input:focus{border-color:var(--coral);}
  .settings-input::placeholder{color:var(--muted);}
  .settings-select{width:100%;background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:11px 14px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;cursor:pointer;}
  .settings-toggle{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--border);}
  .settings-toggle:last-child{border-bottom:none;padding-bottom:0;}
  .settings-toggle-info{}
  .settings-toggle-label{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px;}
  .settings-toggle-desc{font-size:12px;color:var(--muted);}
  .toggle-switch{position:relative;width:40px;height:22px;flex-shrink:0;}
  .toggle-switch input{opacity:0;width:0;height:0;}
  .toggle-track{position:absolute;inset:0;background:var(--s3);border-radius:50px;cursor:pointer;transition:background .2s;border:1px solid var(--border);}
  .toggle-track::after{content:'';position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:2px;left:2px;transition:transform .2s;}
  input:checked + .toggle-track{background:var(--coral);border-color:var(--coral);}
  input:checked + .toggle-track::after{transform:translateX(18px);}
  .save-btn{background:var(--coral);color:#fff;border:none;border-radius:50px;padding:11px 24px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:opacity .2s;margin-top:16px;}
  .save-btn:hover{opacity:.88;}

  /* EMPTY */
  .empty{padding:48px;text-align:center;color:var(--muted);}
  .empty-icon{font-size:36px;margin-bottom:12px;}

  /* TOAST */
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--s2);border:1px solid var(--border);border-radius:50px;padding:11px 22px;font-size:13px;font-weight:500;color:var(--text);z-index:999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  /* MOBILE */
  @media(max-width:900px){
    .sidebar{transform:translateX(-100%);}
    .sidebar.open{transform:translateX(0);}
    .main{margin-left:0;}
    .hamburger{display:block;}
    .stats-row{grid-template-columns:1fr 1fr;}
    .settings-grid{grid-template-columns:1fr;}
    .topbar{padding:0 16px;}
    .content{padding:16px;}
    .sb-overlay{display:block;}
  }
  @media(max-width:480px){
    .stats-row{grid-template-columns:1fr 1fr;}
    table{font-size:12px;}
    th,td{padding:10px 12px;}
  }

  /* Overlay for mobile sidebar */
  .sb-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99;}
</style>

<div class="shell">
  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-top">
      <a href="/" class="sb-brand">
        <div class="sb-icon">🌆</div>
        <div class="sb-name">Denver Social <small>Admin</small></div>
      </a>
    </div>
    <nav class="sb-nav">
      <div class="sb-section">Overview</div>
      <button class="sb-link active" onclick="showPanel('overview',this)"><span class="sb-link-icon">📊</span> Dashboard</button>
      <div class="sb-section">Manage</div>
      <button class="sb-link" onclick="showPanel('members',this)"><span class="sb-link-icon">👥</span> Members <span class="sb-badge" id="memberBadge">{members.length}</span></button>
      <button class="sb-link" onclick="showPanel('events',this)"><span class="sb-link-icon">📅</span> Events <span class="sb-badge" id="eventBadge">{events.length}</span></button>
      <button class="sb-link" onclick="showPanel('suggestions',this)"><span class="sb-link-icon">💡</span> Suggestions</button>
      <div class="sb-section">Config</div>
      <button class="sb-link" onclick="showPanel('settings',this)"><span class="sb-link-icon">⚙️</span> Settings</button>
      <button class="sb-link" onclick="showPanel('content',this)"><span class="sb-link-icon">✏️</span> Site Content</button>
    </nav>
    <div class="sb-bottom">
      <div class="sb-user">
        <div class="sb-avatar">S</div>
        <div class="sb-user-info">
          <div class="sb-user-name">Seth</div>
          <div class="sb-user-role">Administrator</div>
        </div>
      </div>
    </div>
  </aside>
  <div class="sb-overlay" id="sbOverlay" onclick="closeSidebar()"></div>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="toggleSidebar()">☰</button>
        <div class="topbar-title" id="topbarTitle">Dashboard</div>
      </div>
      <div class="topbar-right">
        <a href="/" class="topbar-btn" target="_blank">← View Site</a>
        <a href="/api/logout" class="topbar-btn danger">Log Out</a>
      </div>
    </div>

    <div class="content">

      <!-- OVERVIEW -->
      <div class="panel active" id="panel-overview">
        <div class="stats-row">
          <div class="stat-card">
            <div class="stat-card-top"><span class="stat-icon">👥</span><span class="stat-trend">↑ growing</span></div>
            <div class="stat-num">{members.length}</div>
            <div class="stat-lbl">Total Members</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-top"><span class="stat-icon">✅</span><span class="stat-trend">{members.length > 0 ? Math.round(onboarded/members.length*100) : 0}%</span></div>
            <div class="stat-num">{onboarded}</div>
            <div class="stat-lbl">Onboarded</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-top"><span class="stat-icon">📅</span><span class="stat-trend">active</span></div>
            <div class="stat-num">{events.length}</div>
            <div class="stat-lbl">Total Events</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-top"><span class="stat-icon">💡</span><span class="stat-trend">from crew</span></div>
            <div class="stat-num">{suggestions.length}</div>
            <div class="stat-lbl">Suggestions</div>
          </div>
        </div>

        <!-- Recent members -->
        <div class="table-card">
          <div class="table-head"><div class="table-title">Recent Members</div><a href="#" onclick="showPanel('members',null)" style="font-size:12px;color:var(--coral);text-decoration:none;">View all →</a></div>
          {members.length === 0 ? (
            <div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>
          ) : (
            <table>
              <thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Status</th></tr></thead>
              <tbody>
                {members.slice(0,5).map((m:any) => (
                  <tr>
                    <td class="td-name">{m.name || '—'}</td>
                    <td class="td-muted">{m.email}</td>
                    <td class="td-muted">{m.neighborhood || '—'}</td>
                    <td><span class={`badge ${m.onboarding_done ? 'badge-green' : 'badge-muted'}`}>{m.onboarding_done ? '✓ Active' : 'Pending'}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

        <!-- Recent events -->
        <div class="table-card">
          <div class="table-head"><div class="table-title">Upcoming Events</div><a href="#" onclick="showPanel('events',null)" style="font-size:12px;color:var(--coral);text-decoration:none;">View all →</a></div>
          {events.length === 0 ? (
            <div class="empty"><div class="empty-icon">📅</div><p>No events yet.</p></div>
          ) : (
            <table>
              <thead><tr><th>Event</th><th>Date</th><th>Location</th><th>Type</th></tr></thead>
              <tbody>
                {events.slice(0,4).map((e:any) => (
                  <tr>
                    <td class="td-name">{e.emoji || typeEmoji[e.type] || '📅'} {e.title}</td>
                    <td class="td-muted">{e.date_label || e.date || 'TBD'}</td>
                    <td class="td-muted">{e.location || '—'}</td>
                    <td><span class={`badge ${e.featured ? 'badge-coral' : 'badge-muted'}`}>{e.featured ? '⭐ Featured' : e.type || 'event'}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>

      <!-- MEMBERS -->
      <div class="panel" id="panel-members">
        <div class="table-card">
          <div class="table-head">
            <div class="table-title">All Members ({members.length})</div>
            <input class="table-search" placeholder="Search members..." oninput="filterTable('members-table',this.value)" />
          </div>
          {members.length === 0 ? (
            <div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>
          ) : (
            <table id="members-table">
              <thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Bio</th><th>Status</th><th></th></tr></thead>
              <tbody>
                {members.map((m:any) => (
                  <tr data-search={`${m.name} ${m.email} ${m.neighborhood}`}>
                    <td class="td-name">{m.name || '—'}</td>
                    <td class="td-muted" style="font-size:12px">{m.email}</td>
                    <td class="td-muted">{m.neighborhood || '—'}</td>
                    <td class="td-muted" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px">{m.bio || '—'}</td>
                    <td><span class={`badge ${m.onboarding_done ? 'badge-green' : 'badge-muted'}`}>{m.onboarding_done ? '✓ Active' : 'Pending'}</span></td>
                    <td><button class="action-btn del" onclick={`removeMember('${m.id}','${m.name||m.email}')`}>Remove</button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>

      <!-- EVENTS -->
      <div class="panel" id="panel-events">
        <div class="table-card">
          <div class="table-head">
            <div class="table-title">All Events ({events.length})</div>
            <div style="display:flex;gap:8px;align-items:center">
              <input class="table-search" placeholder="Search events..." oninput="filterTable('events-table',this.value)" />
              <a href="/events/new" style="background:var(--coral);color:#fff;text-decoration:none;font-size:12px;font-weight:700;padding:8px 16px;border-radius:8px;white-space:nowrap">+ Add Event</a>
            </div>
          </div>
          {events.length === 0 ? (
            <div class="empty"><div class="empty-icon">📅</div><p>No events yet. <a href="/events/new" style="color:var(--coral)">Create one →</a></p></div>
          ) : (
            <table id="events-table">
              <thead><tr><th>Title</th><th>Date</th><th>Location</th><th>Capacity</th><th>Status</th><th></th></tr></thead>
              <tbody>
                {events.map((e:any) => (
                  <tr data-search={`${e.title} ${e.location} ${e.type}`}>
                    <td class="td-name">{typeEmoji[e.type] || '📅'} {e.title}</td>
                    <td class="td-muted">{e.date_label || e.date || 'TBD'}</td>
                    <td class="td-muted">{e.location || '—'}</td>
                    <td class="td-muted">{e.capacity ? `up to ${e.capacity}` : '—'}</td>
                    <td>
                      {e.featured
                        ? <span class="badge badge-coral">⭐ Featured</span>
                        : <span class="badge badge-muted">{e.type || 'event'}</span>}
                    </td>
                    <td style="display:flex;gap:6px">
                      <a href={`/events/${e.id}`} class="action-btn" style="text-decoration:none">View</a>
                      <button class="action-btn del" onclick={`deleteEvent('${e.id}','${e.title}')`}>Delete</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>

      <!-- SUGGESTIONS -->
      <div class="panel" id="panel-suggestions">
        <div class="table-card">
          <div class="table-head"><div class="table-title">Community Suggestions</div></div>
          {suggestions.length === 0 ? (
            <div class="empty"><div class="empty-icon">💡</div><p>No suggestions yet.</p></div>
          ) : (
            <table>
              <thead><tr><th>Idea</th><th>Votes</th><th>Status</th><th></th></tr></thead>
              <tbody>
                {suggestions.map((s:any) => (
                  <tr>
                    <td class="td-name">{s.text || s.title || '—'}</td>
                    <td><span class="badge badge-blue">▲ {s.votes || 0}</span></td>
                    <td><span class={`badge ${s.status === 'planned' ? 'badge-coral' : s.status === 'done' ? 'badge-green' : 'badge-muted'}`}>{s.status || 'open'}</span></td>
                    <td style="display:flex;gap:6px">
                      <button class="action-btn" onclick={`markSuggestion('${s.id}','planned')`}>Plan</button>
                      <button class="action-btn" onclick={`markSuggestion('${s.id}','done')`}>Done</button>
                      <button class="action-btn del" onclick={`deleteSuggestion('${s.id}')`}>Delete</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>

      <!-- SETTINGS -->
      <div class="panel" id="panel-settings">
        <div class="settings-grid">

          <div class="settings-card">
            <div class="settings-card-title">Site Settings</div>
            <div class="settings-card-sub">Control how the public site looks and behaves.</div>
            <div class="settings-toggle">
              <div class="settings-toggle-info">
                <div class="settings-toggle-label">Maintenance Mode</div>
                <div class="settings-toggle-desc">Show a "coming soon" page to visitors</div>
              </div>
