---
import AdminBase from '../../layouts/AdminBase.astro';
import { getDB } from '../../lib/db';

const cookie = Astro.request.headers.get('cookie') || '';
const userMatch = cookie.match(/dsn_user=([^;]+)/);
let isAdmin = false;
if (userMatch) {
  try { const u = JSON.parse(decodeURIComponent(userMatch[1])); isAdmin = u.email === 'stharpe98@gmail.com'; } catch {}
}
if (!isAdmin) return Astro.redirect('/admin');

const db = getDB();
let members: any[] = [], events: any[] = [], suggestions: any[] = [], announcements: any[] = [], spotlights: any[] = [], pageViews = 0;
if (db) {
  try {
    members = (await db.prepare(`SELECT * FROM members ORDER BY id DESC`).all())?.results || [];
    events = (await db.prepare(`SELECT * FROM events ORDER BY id DESC`).all())?.results || [];
    suggestions = (await db.prepare(`SELECT * FROM suggestions ORDER BY votes DESC LIMIT 20`).all())?.results || [];
    announcements = (await db.prepare(`SELECT * FROM announcements ORDER BY id DESC`).all())?.results || [];
    spotlights = (await db.prepare(`SELECT * FROM member_spotlights ORDER BY id DESC`).all())?.results || [];
    const pvResult = await db.prepare(`SELECT COUNT(*) as c FROM page_views`).first() as any;
    pageViews = pvResult?.c || 0;
  } catch {}
}
const onboarded = members.filter((m: any) => m.onboarding_done).length;
const suspended = members.filter((m: any) => m.suspended).length;
const pendingApproval = members.filter((m: any) => !m.approved && m.onboarding_done).length;
const featuredEvents = events.filter((e: any) => e.featured).length;
const pastEvents = events.filter((e: any) => e.is_past).length;
const typeEmoji: Record<string, string> = {
  dinner:'🍽️', game_night:'🎲', outdoor:'🏔️', brewery:'🍺', bowling:'🎳',
  arts:'🎨', music:'🎵', social:'🎉', group_tickets:'🎫', sports:'⚾',
  coffee:'☕', casino:'🎰', active:'🧗', food_trucks:'🚚', potluck:'🥘', other:'📅'
};
const membersJSON = JSON.stringify(members.map((m: any) => ({ id:m.id, name:m.name, email:m.email, neighborhood:m.neighborhood, bio:m.bio, role:m.role, onboarding_done:m.onboarding_done, approved:m.approved, suspended:m.suspended, suspended_reason:m.suspended_reason, no_show_count:m.no_show_count, events_attended:m.events_attended, points:m.points, discord_username:m.discord_username, age_range:m.age_range, interests:m.interests, event_types:m.event_types, food_prefs:m.food_prefs, joined_at:m.joined_at, referral_code:m.referral_code })));
---
<AdminBase title="Dashboard — Denver Social">
<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
  :root {
    --bg:#0F1117; --white:rgba(255,255,255,0.04); --card:rgba(255,255,255,0.04);
    --border:rgba(255,255,255,0.07); --border-light:rgba(255,255,255,0.05);
    --text:#E4E2EC; --text-secondary:#8A859E; --text-hint:#5A5672;
    --accent:#A78BFA; --accent-light:rgba(167,139,250,0.12); --accent-hover:#8B5CF6;
    --green:#34D399; --green-light:rgba(52,211,153,0.10);
    --red:#EF4444; --red-light:rgba(239,68,68,0.10);
    --blue:#38BDF8; --blue-light:rgba(56,189,248,0.10);
    --purple:#A78BFA; --purple-light:rgba(167,139,250,0.10);
    --pink:#F472B6; --orange:#FB923C;
    --radius:14px; --radius-sm:8px;
    --shadow-sm:0 1px 2px rgba(0,0,0,.2);
    --shadow:0 2px 8px rgba(0,0,0,.25);
    --shadow-lg:0 8px 32px rgba(0,0,0,.4);
    --font:'Inter',system-ui,-apple-system,sans-serif;
    --font-heading:'Space Grotesk',sans-serif;
    --font-mono:'JetBrains Mono',monospace;
    --hover-row:rgba(255,255,255,0.025);
    --glass-blur:blur(12px);
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg)!important;color:var(--text)!important;font-family:var(--font)!important;overflow:auto!important;height:auto!important;display:block!important;-webkit-font-smoothing:antialiased;line-height:1.5}
  /* Keep ambient gradients from AdminBase visible */
  body::after{display:none!important}
  ::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:3px}::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,0.14)}
  .topnav{background:rgba(15,17,23,0.85);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
  .topnav-inner{max-width:1280px;margin:0 auto;padding:0 28px;display:flex;align-items:center;height:56px;gap:20px}
  .brand{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--text);flex-shrink:0}
  .brand-icon{width:30px;height:30px;background:linear-gradient(135deg,#A78BFA,#38BDF8);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 0 20px rgba(167,139,250,0.3)}
  .brand-name{font-family:var(--font-heading);font-size:15px;font-weight:700;letter-spacing:-.02em}
  .brand-tag{font-size:9px;font-weight:600;color:var(--accent);background:var(--accent-light);padding:2px 7px;border-radius:50px}
  .tabs{display:flex;gap:1px;margin-left:12px;overflow-x:auto;flex:1}
  .tab{padding:6px 12px;font-size:12px;font-weight:500;color:var(--text-secondary);border-radius:var(--radius-sm);cursor:pointer;border:none;background:none;font-family:var(--font);transition:all .15s;white-space:nowrap}
  .tab:hover{color:var(--text);background:rgba(255,255,255,0.06)}
  .tab.active{color:var(--accent);background:var(--accent-light);font-weight:600}
  .tab .tab-badge{font-size:9px;background:var(--red);color:#fff;padding:1px 5px;border-radius:50px;margin-left:4px;font-weight:700}
  .nav-right{margin-left:auto;display:flex;align-items:center;gap:6px;flex-shrink:0}
  .nav-btn{padding:6px 12px;font-size:11px;font-weight:500;color:var(--text-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);background:rgba(255,255,255,0.04);cursor:pointer;font-family:var(--font);transition:all .15s;text-decoration:none;backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur)}
  .nav-btn:hover{border-color:rgba(255,255,255,0.15);color:var(--text);background:rgba(255,255,255,0.07)}
  .nav-btn.danger:hover{border-color:rgba(239,68,68,0.5);color:var(--red);background:rgba(239,68,68,0.08)}
  .theme-toggle{width:28px;height:28px;border-radius:50%;border:1px solid var(--border);background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;transition:all .2s;flex-shrink:0}
  .theme-toggle:hover{border-color:var(--accent);box-shadow:0 0 12px rgba(167,139,250,0.2)}
  .avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#A78BFA,#F472B6);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;box-shadow:0 0 12px rgba(167,139,250,0.3)}
  .page{max-width:1280px;margin:0 auto;padding:24px 28px 60px;position:relative;z-index:1}
  .panel{display:none}.panel.active{display:block;animation:fadeIn .2s ease}
  @keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px}
  .stat{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);transition:background .15s,border-color .15s,box-shadow .15s}
  .stat:hover{background:rgba(255,255,255,0.07);border-color:rgba(255,255,255,0.12);box-shadow:0 4px 20px rgba(0,0,0,0.2)}
  .stat-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
  .stat-icon{font-size:18px}.stat-trend{font-size:10px;font-weight:600;color:var(--green)}
  .stat-num{font-family:var(--font-mono);font-size:28px;font-weight:700;letter-spacing:-.03em;line-height:1;margin-bottom:2px}
  .stat-label{font-size:11px;font-weight:500;color:var(--text-hint)}
  .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:16px;backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);transition:background .15s,border-color .15s}
  .card:hover{background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.10)}
  .card-head{padding:14px 20px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;border-bottom:1px solid var(--border-light)}
  .card-title{font-family:var(--font-heading);font-size:14px;font-weight:600}
  .search-input{padding:6px 12px;font-size:12px;color:var(--text);font-family:var(--font);border:1px solid var(--border);border-radius:var(--radius-sm);background:rgba(255,255,255,0.04);outline:none;width:180px;transition:border-color .15s,background .15s}
  .search-input:focus{border-color:var(--accent);background:rgba(167,139,250,0.06);box-shadow:0 0 0 2px rgba(167,139,250,0.1)}
  .search-input::placeholder{color:var(--text-hint)}
  table{width:100%;border-collapse:collapse}
  th{padding:8px 18px;text-align:left;font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-hint);background:rgba(255,255,255,0.02);border-bottom:1px solid var(--border-light)}
  td{padding:10px 18px;font-size:12px;border-bottom:1px solid var(--border-light);color:var(--text)}
  tr:last-child td{border-bottom:none}
  tr:hover td{background:var(--hover-row)}
  .td-name{font-weight:600}.td-muted{color:var(--text-secondary)}
  .badge{display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 8px;border-radius:50px}
  .badge-green{background:var(--green-light);color:var(--green)}
  .badge-muted{background:rgba(255,255,255,0.06);color:var(--text-hint)}
  .badge-accent{background:var(--accent-light);color:var(--accent)}
  .badge-blue{background:var(--blue-light);color:var(--blue)}
  .badge-red{background:var(--red-light);color:var(--red)}
  .badge-purple{background:var(--purple-light);color:var(--purple)}
  .btn{padding:5px 12px;font-size:11px;font-weight:600;cursor:pointer;font-family:var(--font);border-radius:var(--radius-sm);transition:all .15s;border:1px solid var(--border);background:rgba(255,255,255,0.04);color:var(--text-secondary);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur)}
  .btn:hover{border-color:rgba(255,255,255,0.15);color:var(--text);background:rgba(255,255,255,0.07)}
  .btn.del:hover{border-color:rgba(239,68,68,0.5);color:var(--red);background:rgba(239,68,68,0.08)}
  .btn-primary{background:linear-gradient(135deg,#A78BFA,#8B5CF6);color:#fff;border:none;padding:7px 16px;font-size:12px;font-weight:600;border-radius:var(--radius-sm);cursor:pointer;font-family:var(--font);transition:all .15s;box-shadow:0 0 20px rgba(167,139,250,0.25)}
  .btn-primary:hover{background:linear-gradient(135deg,#8B5CF6,#7C3AED);box-shadow:0 0 28px rgba(167,139,250,0.35)}
  .btn-sm{padding:4px 10px;font-size:10px}
  .settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .settings-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:22px;backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);transition:background .15s,border-color .15s}
  .settings-card:hover{background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.10)}
  .settings-title{font-family:var(--font-heading);font-size:14px;font-weight:600;margin-bottom:3px}
  .settings-sub{font-size:12px;color:var(--text-secondary);margin-bottom:16px}
  .field{margin-bottom:14px}.field-label{display:block;font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text-hint);margin-bottom:5px}
  .field-input{width:100%;padding:9px 12px;font-size:12px;color:var(--text);font-family:var(--font);border:1px solid var(--border);border-radius:var(--radius-sm);background:rgba(255,255,255,0.04);outline:none;transition:border-color .15s,background .15s}
  .field-input:focus{border-color:var(--accent);background:rgba(167,139,250,0.06);box-shadow:0 0 0 2px rgba(167,139,250,0.1)}
  .field-input::placeholder{color:var(--text-hint)}
  .field-select{width:100%;padding:9px 12px;font-size:12px;color:var(--text);font-family:var(--font);border:1px solid var(--border);border-radius:var(--radius-sm);background:rgba(255,255,255,0.04);outline:none;cursor:pointer}
  .field-select option{background:#1a1c24;color:var(--text)}
  .toggle-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border-light)}
  .toggle-row:last-of-type{border-bottom:none;padding-bottom:0}
  .toggle-label{font-size:12px;font-weight:600}.toggle-desc{font-size:11px;color:var(--text-hint);margin-top:1px}
  .toggle{position:relative;width:38px;height:22px;flex-shrink:0}
  .toggle input{opacity:0;width:0;height:0}
  .toggle-track{position:absolute;inset:0;background:rgba(255,255,255,0.1);border-radius:50px;cursor:pointer;transition:background .2s}
  .toggle-track::after{content:'';position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:3px;left:3px;transition:transform .2s;box-shadow:var(--shadow)}
  input:checked+.toggle-track{background:var(--accent);box-shadow:0 0 12px rgba(167,139,250,0.3)}
  input:checked+.toggle-track::after{transform:translateX(16px)}
  .create-form{display:none;margin-bottom:16px}.create-form.open{display:block;animation:fadeIn .2s ease}
  .form-grid{padding:18px 20px;display:grid;grid-template-columns:1fr;gap:12px}
  .form-2col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .type-chip{padding:8px 14px;font-size:12px;font-weight:500;border-radius:var(--radius-sm);border:1px solid var(--border);background:rgba(255,255,255,0.04);color:var(--text-secondary);cursor:pointer;font-family:var(--font);transition:all .15s}
  .type-chip:hover{border-color:rgba(167,139,250,0.4);color:var(--text);background:rgba(255,255,255,0.06)}
  .type-chip.selected{border-color:var(--accent);background:var(--accent-light);color:var(--accent);font-weight:600;box-shadow:0 0 12px rgba(167,139,250,0.15)}
  .evt-field{display:none}.evt-field.show{display:block}
  .empty{padding:40px;text-align:center;color:var(--text-hint)}.empty-icon{font-size:32px;margin-bottom:10px;opacity:.5}
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:rgba(30,28,40,0.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);color:#fff;border:1px solid rgba(255,255,255,0.12);border-radius:var(--radius);padding:10px 22px;font-size:12px;font-weight:500;z-index:9999;opacity:0;transition:all .3s;pointer-events:none;box-shadow:var(--shadow-lg)}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}.toast.error{background:rgba(239,68,68,0.9);border-color:rgba(239,68,68,0.4)}
  /* Modal */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);z-index:200;align-items:center;justify-content:center}
  .modal-overlay.open{display:flex}
  .modal{background:rgba(26,28,36,0.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:var(--radius);width:90%;max-width:560px;max-height:80vh;overflow-y:auto;box-shadow:var(--shadow-lg);border:1px solid rgba(255,255,255,0.10)}
  .modal-head{padding:16px 20px;border-bottom:1px solid var(--border-light);display:flex;align-items:center;justify-content:space-between}
  .modal-head h3{font-family:var(--font-heading);font-size:15px;font-weight:600}
  .modal-body{padding:20px}
  .detail-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-light);font-size:12px}
  .detail-row:last-child{border-bottom:none}
  .detail-key{color:var(--text-hint);font-weight:500}
  .detail-val{color:var(--text);font-weight:500;text-align:right;max-width:60%;word-break:break-word}
  .modal-actions{padding:16px 20px;border-top:1px solid var(--border-light);display:flex;gap:8px;flex-wrap:wrap}
  .mob-menu{display:none;background:none;border:none;font-size:18px;cursor:pointer;color:var(--text)}
  .mob-tabs{display:none}
  @media(max-width:768px){.tabs{display:none}.mob-menu{display:block}.mob-tabs.open{display:flex;flex-direction:column;position:absolute;top:56px;left:0;right:0;background:rgba(15,17,23,0.95);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border-bottom:1px solid var(--border);padding:8px 12px;z-index:99;box-shadow:var(--shadow-lg)}.mob-tabs .tab{width:100%;text-align:left;padding:10px 14px}.topnav-inner{padding:0 14px}.page{padding:16px 14px 60px}.stats{grid-template-columns:1fr 1fr}.settings-grid,.form-2col{grid-template-columns:1fr}.nav-btn.view-site{display:none}}
  @media(max-width:480px){.stats{grid-template-columns:1fr}}
</style>

<style is:inline>
  html.dark{--bg:#090b10;--white:rgba(255,255,255,0.03);--card:rgba(255,255,255,0.03);--border:rgba(255,255,255,0.05);--border-light:rgba(255,255,255,0.04);--text:#E4E2EC;--text-secondary:#8A859E;--text-hint:#5A5672;--accent:#A78BFA;--accent-light:rgba(167,139,250,0.12);--accent-hover:#8B5CF6;--green:#34D399;--green-light:rgba(52,211,153,0.10);--red:#EF4444;--red-light:rgba(239,68,68,0.10);--blue:#38BDF8;--blue-light:rgba(56,189,248,0.10);--purple:#A78BFA;--purple-light:rgba(167,139,250,0.10);--shadow-sm:0 1px 2px rgba(0,0,0,.3);--shadow:0 2px 8px rgba(0,0,0,.35);--shadow-lg:0 8px 32px rgba(0,0,0,.5);--hover-row:rgba(255,255,255,.02)}
  html.dark body{background:var(--bg)!important;color:var(--text)!important}
</style>

<nav class="topnav">
  <div class="topnav-inner">
    <a href="/" class="brand"><div class="brand-icon">🌆</div><span class="brand-name">Denver Social</span><span class="brand-tag">Admin</span></a>
    <div class="tabs" id="tabs">
      <button class="tab active" data-panel="overview">Overview</button>
      <button class="tab" data-panel="members">Members{pendingApproval > 0 ? <span class="tab-badge">{pendingApproval}</span> : null}</button>
      <button class="tab" data-panel="events">Events</button>
      <button class="tab" data-panel="suggestions">Suggestions</button>
      <button class="tab" data-panel="announcements">Announcements</button>
      <button class="tab" data-panel="spotlights">Spotlights</button>
      <button class="tab" data-panel="settings">Settings</button>
      <button class="tab" data-panel="content">Content</button>
    </div>
    <button class="mob-menu" id="mob-menu">☰</button>
    <div class="nav-right">
      <button class="theme-toggle" id="theme-toggle" title="Toggle dark mode">☀️</button>
      <a href="/" class="nav-btn view-site" target="_blank">← Site</a>
      <a href="/api/logout" class="nav-btn danger">Log Out</a>
      <div class="avatar">S</div>
    </div>
  </div>
  <div class="mob-tabs" id="mob-tabs">
    <button class="tab active" data-panel="overview">Overview</button>
    <button class="tab" data-panel="members">Members</button>
    <button class="tab" data-panel="events">Events</button>
    <button class="tab" data-panel="suggestions">Suggestions</button>
    <button class="tab" data-panel="announcements">Announcements</button>
    <button class="tab" data-panel="spotlights">Spotlights</button>
    <button class="tab" data-panel="settings">Settings</button>
    <button class="tab" data-panel="content">Content</button>
  </div>
</nav>

<div class="page">

  <!-- ═══ OVERVIEW ═══ -->
  <div class="panel active" id="panel-overview">
    <div class="stats">
      <div class="stat"><div class="stat-top"><span class="stat-icon">👥</span><span class="stat-trend">↑</span></div><div class="stat-num">{members.length}</div><div class="stat-label">Members</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">✅</span><span class="stat-trend">{members.length>0?Math.round(onboarded/members.length*100):0}%</span></div><div class="stat-num">{onboarded}</div><div class="stat-label">Onboarded</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">📅</span></div><div class="stat-num">{events.length}</div><div class="stat-label">Events</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">⭐</span></div><div class="stat-num">{featuredEvents}</div><div class="stat-label">Featured</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">💡</span></div><div class="stat-num">{suggestions.length}</div><div class="stat-label">Suggestions</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">📢</span></div><div class="stat-num">{announcements.length}</div><div class="stat-label">Announcements</div></div>
      {suspended>0&&<div class="stat"><div class="stat-top"><span class="stat-icon">🚫</span></div><div class="stat-num" style="color:var(--red)">{suspended}</div><div class="stat-label">Suspended</div></div>}
      {pendingApproval>0&&<div class="stat"><div class="stat-top"><span class="stat-icon">⏳</span></div><div class="stat-num" style="color:var(--accent)">{pendingApproval}</div><div class="stat-label">Pending approval</div></div>}
    </div>
    <div class="card">
      <div class="card-head"><div class="card-title">Recent members</div><button class="btn" data-panel="members">View all →</button></div>
      {members.length===0?<div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>:(
        <table><thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Status</th></tr></thead><tbody>
          {members.slice(0,5).map((m:any)=><tr><td class="td-name">{m.name||'—'}</td><td class="td-muted">{m.email}</td><td class="td-muted">{m.neighborhood||'—'}</td><td>{m.suspended?<span class="badge badge-red">Suspended</span>:m.onboarding_done?<span class="badge badge-green">Active</span>:<span class="badge badge-muted">Pending</span>}</td></tr>)}
        </tbody></table>)}
    </div>
    <div class="card">
      <div class="card-head"><div class="card-title">Upcoming events</div><button class="btn" data-panel="events">View all →</button></div>
      {events.filter((e:any)=>!e.is_past).length===0?<div class="empty"><div class="empty-icon">📅</div><p>No upcoming events.</p></div>:(
        <table><thead><tr><th>Event</th><th>Date</th><th>Location</th><th>RSVPs</th></tr></thead><tbody>
          {events.filter((e:any)=>!e.is_past).slice(0,5).map((e:any)=><tr><td class="td-name">{typeEmoji[e.event_type]||'📅'} {e.title}</td><td class="td-muted">{e.event_month&&e.event_day?`${e.event_month} ${e.event_day}`:'TBD'}</td><td class="td-muted">{e.location||'—'}</td><td class="td-muted">{e.rsvp_count||0}/{e.spots||'—'}</td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ MEMBERS ═══ -->
  <div class="panel" id="panel-members">
    <div class="card">
      <div class="card-head">
        <div class="card-title">All members ({members.length})</div>
        <div style="display:flex;gap:6px;align-items:center">
          <select class="field-select" id="member-filter" style="width:auto;padding:6px 10px;font-size:11px">
            <option value="all">All</option><option value="active">Active</option><option value="pending">Pending</option><option value="suspended">Suspended</option><option value="unapproved">Needs approval</option>
          </select>
          <input class="search-input" id="search-members" placeholder="Search..." />
        </div>
      </div>
      {members.length===0?<div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>:(
        <table id="members-table"><thead><tr><th>Name</th><th>Email</th><th>Hood</th><th>Status</th><th>Role</th><th>Events</th><th>No-shows</th><th></th></tr></thead><tbody>
          {members.map((m:any)=><tr data-search={`${m.name} ${m.email} ${m.neighborhood}`} data-status={m.suspended?'suspended':m.onboarding_done?(m.approved?'active':'unapproved'):'pending'} data-mid={m.id}>
            <td class="td-name" style="cursor:pointer" data-action="view-member" data-id={m.id}>{m.name||'—'}</td>
            <td class="td-muted" style="font-size:11px">{m.email}</td>
            <td class="td-muted">{m.neighborhood||'—'}</td>
            <td>{m.suspended?<span class="badge badge-red">Suspended</span>:!m.approved&&m.onboarding_done?<span class="badge badge-accent">Needs approval</span>:m.onboarding_done?<span class="badge badge-green">Active</span>:<span class="badge badge-muted">Pending</span>}</td>
            <td><span class={`badge ${m.role==='admin'?'badge-purple':'badge-muted'}`}>{m.role||'member'}</span></td>
            <td class="td-muted">{m.events_attended||0}</td>
            <td class="td-muted">{m.no_show_count||0}</td>
            <td style="display:flex;gap:4px;flex-wrap:wrap">
              {!m.approved&&m.onboarding_done&&<button class="btn btn-sm" data-action="approve-member" data-id={m.id}>✓ Approve</button>}
              {m.suspended?<button class="btn btn-sm" data-action="unsuspend-member" data-id={m.id}>Unsuspend</button>:<button class="btn btn-sm del" data-action="suspend-member" data-id={m.id} data-name={m.name||m.email}>Suspend</button>}
              <button class="btn btn-sm del" data-action="remove-member" data-id={m.id} data-name={m.name||m.email}>Remove</button>
            </td>
          </tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ EVENTS ═══ -->
  <div class="panel" id="panel-events">
    <div class="create-form card" id="create-event-form">
      <div class="card-head"><div class="card-title">Create new event</div><button class="btn" id="cancel-create">✕ Cancel</button></div>
      <div class="form-grid">
        <div class="field" style="margin-bottom:4px">
          <label class="field-label">What type of event?</label>
          <div id="type-picker" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px">
            <button type="button" class="type-chip" data-type="dinner">🍽️ Dinner</button>
            <button type="button" class="type-chip" data-type="brewery">🍺 Brewery</button>
            <button type="button" class="type-chip" data-type="outdoor">🏔️ Outdoor</button>
            <button type="button" class="type-chip" data-type="game_night">🎲 Game Night</button>
            <button type="button" class="type-chip" data-type="bowling">🎳 Bowling</button>
            <button type="button" class="type-chip" data-type="sports">⚾ Sports</button>
            <button type="button" class="type-chip" data-type="music">🎵 Music</button>
            <button type="button" class="type-chip" data-type="arts">🎨 Arts</button>
            <button type="button" class="type-chip" data-type="coffee">☕ Coffee</button>
            <button type="button" class="type-chip" data-type="casino">🎰 Casino</button>
            <button type="button" class="type-chip" data-type="potluck">🥘 Potluck</button>
            <button type="button" class="type-chip" data-type="social">🎉 Social</button>
            <button type="button" class="type-chip" data-type="other">📅 Other</button>
          </div>
          <input type="hidden" id="evt-type" value="" />
        </div>
        <div id="evt-core" style="display:none">
          <div class="form-2col">
            <div class="field" style="grid-column:span 2"><label class="field-label">Event name</label><input class="field-input" id="evt-title" /></div>
            <div class="field"><label class="field-label">Where</label><input class="field-input" id="evt-location" /></div>
            <div class="field"><label class="field-label">Zone</label><input class="field-input" id="evt-zone" value="RiNo" /></div>
            <div class="field"><label class="field-label">Month</label><select class="field-select" id="evt-month"><option value="">Pick</option><option>JAN</option><option>FEB</option><option>MAR</option><option>APR</option><option>MAY</option><option>JUN</option><option>JUL</option><option>AUG</option><option>SEP</option><option>OCT</option><option>NOV</option><option>DEC</option></select></div>
            <div class="field"><label class="field-label">Day</label><input class="field-input" id="evt-day" placeholder="e.g. 17th" /></div>
            <div class="field"><label class="field-label">Spots</label><input class="field-input" id="evt-spots" type="number" value="10" min="1" /></div>
            <div class="field"><label class="field-label" id="price-label">Price cap</label><input class="field-input" id="evt-price" /></div>
            <!-- Type-specific -->
            <div class="field evt-field" data-for="outdoor"><label class="field-label">Difficulty</label><select class="field-select" id="evt-difficulty"><option value="">Select</option><option value="easy">Easy</option><option value="moderate">Moderate</option><option value="hard">Hard</option></select></div>
            <div class="field evt-field" data-for="outdoor"><label class="field-label">Pet friendly?</label><select class="field-select" id="evt-pet"><option value="0">No</option><option value="1">Yes</option></select></div>
            <div class="field evt-field" data-for="outdoor"><label class="field-label">Cell service</label><select class="field-select" id="evt-cell"><option value="">Unknown</option><option value="good">Good</option><option value="spotty">Spotty</option><option value="none">None</option></select></div>
            <div class="field evt-field" data-for="outdoor"><label class="field-label">Packing list</label><input class="field-input" id="evt-packing" placeholder="Water, sunscreen..." /></div>
            <div class="field evt-field" data-for="dinner brewery coffee"><label class="field-label">Reservation by</label><input class="field-input" id="evt-reservation" placeholder="Seth / TBD" /></div>
            <div class="field evt-field" data-for="dinner brewery coffee"><label class="field-label">Price per person</label><input class="field-input" id="evt-ppp" placeholder="$20-30" /></div>
            <div class="field evt-field" data-for="casino sports music arts"><label class="field-label">Ticket / payment link</label><input class="field-input" id="evt-payment" placeholder="https://..." /></div>
            <div class="field evt-field" data-for="casino sports"><label class="field-label">Min group size</label><input class="field-input" id="evt-mingroup" type="number" value="4" min="1" /></div>
            <div class="field evt-field" data-for="casino sports music"><label class="field-label">Deposit?</label><select class="field-select" id="evt-deposit"><option value="0">No</option><option value="1">Yes — $10</option></select></div>
            <div class="field evt-field" data-for="casino sports music"><label class="field-label">Deposit $</label><input class="field-input" id="evt-depositamt" value="10" type="number" /></div>
            <div class="field evt-field" data-for="dinner casino sports music potluck"><label class="field-label">Commit deadline</label><input class="field-input" id="evt-deadline" placeholder="May 15th" /></div>
            <div class="field evt-field" data-for="potluck" style="grid-column:span 2"><label class="field-label">Potluck categories</label><input class="field-input" id="evt-potluck-cats" value="Appetizers,Mains,Sides,Desserts,Drinks" /></div>
            <div class="field evt-field" data-for="potluck"><label class="field-label">Host</label><input class="field-input" id="evt-potluck-host" placeholder="Seth's place" /></div>
            <div class="field evt-field" data-for="potluck"><label class="field-label">What to bring</label><input class="field-input" id="evt-potluck-bring" placeholder="Your dish + drinks" /></div>
            <div class="field evt-field" data-for="all"><label class="field-label">Plus-ones?</label><select class="field-select" id="evt-plusone"><option value="1">Yes</option><option value="0">No</option></select></div>
          </div>
          <div class="field" style="margin-top:12px"><label class="field-label">Description</label><textarea class="field-input" id="evt-desc" rows="2" style="resize:vertical"></textarea></div>
          <div style="display:flex;align-items:center;gap:14px;margin-top:10px"><label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);cursor:pointer"><input type="checkbox" id="evt-featured" /> ⭐ Featured</label><button class="btn-primary" style="margin-left:auto" id="submit-event">Create Event</button></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-head"><div class="card-title">All events ({events.length})</div><div style="display:flex;gap:6px;align-items:center"><input class="search-input" id="search-events" placeholder="Search..." /><button class="btn-primary" id="toggle-create">+ Add Event</button></div></div>
      {events.length===0?<div class="empty"><div class="empty-icon">📅</div><p>No events.</p></div>:(
        <table id="events-table"><thead><tr><th>Title</th><th>Date</th><th>Location</th><th>RSVPs</th><th>Status</th><th></th></tr></thead><tbody>
          {events.map((e:any)=><tr data-search={`${e.title} ${e.location} ${e.event_type}`} data-eid={e.id}><td class="td-name">{typeEmoji[e.event_type]||'📅'} {e.title}</td><td class="td-muted">{e.event_month&&e.event_day?`${e.event_month} ${e.event_day}`:'TBD'}</td><td class="td-muted">{e.location||'—'}</td><td class="td-muted">{e.rsvp_count||0}/{e.spots||'—'}</td><td>{e.is_past?<span class="badge badge-muted">Past</span>:e.featured?<span class="badge badge-accent">⭐ Featured</span>:<span class="badge badge-muted">{e.event_type||'event'}</span>}</td><td style="display:flex;gap:4px"><button class="btn btn-sm" data-action="toggle-feature" data-id={e.id} data-featured={e.featured?'1':'0'}>{e.featured?'Unfeature':'⭐'}</button><button class="btn btn-sm del" data-action="delete-event" data-id={e.id} data-title={e.title}>Delete</button></td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ SUGGESTIONS ═══ -->
  <div class="panel" id="panel-suggestions">
    <div class="card">
      <div class="card-head"><div class="card-title">Community suggestions</div></div>
      {suggestions.length===0?<div class="empty"><div class="empty-icon">💡</div><p>No suggestions yet.</p></div>:(
        <table><thead><tr><th>Idea</th><th>Votes</th><th>Status</th><th></th></tr></thead><tbody>
          {suggestions.map((s:any)=><tr data-sid={s.id}><td class="td-name">{s.text||s.title||'—'}</td><td><span class="badge badge-blue">▲ {s.votes||0}</span></td><td><span class={`badge ${s.status==='planned'?'badge-accent':s.status==='done'?'badge-green':'badge-muted'}`}>{s.status||'open'}</span></td><td style="display:flex;gap:4px"><button class="btn btn-sm" data-action="mark-suggestion" data-id={s.id} data-status="planned">Plan</button><button class="btn btn-sm" data-action="mark-suggestion" data-id={s.id} data-status="done">Done</button><button class="btn btn-sm del" data-action="delete-suggestion" data-id={s.id}>Del</button></td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ ANNOUNCEMENTS ═══ -->
  <div class="panel" id="panel-announcements">
    <div class="card">
      <div class="card-head"><div class="card-title">Announcements</div></div>
      <div style="padding:16px 20px;display:flex;gap:8px">
        <input class="field-input" id="new-announcement" placeholder="Write an announcement..." style="flex:1" />
        <button class="btn-primary" id="post-announcement">Post</button>
      </div>
      {announcements.length===0?<div class="empty"><div class="empty-icon">📢</div><p>No announcements yet.</p></div>:(
        <table><thead><tr><th>Message</th><th>Posted</th><th></th></tr></thead><tbody>
          {announcements.map((a:any)=><tr><td class="td-name">{a.text}</td><td class="td-muted">{a.created_at?.slice(0,10)||'—'}</td><td><button class="btn btn-sm del" data-action="delete-announcement" data-id={a.id}>Delete</button></td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ SPOTLIGHTS ═══ -->
  <div class="panel" id="panel-spotlights">
    <div class="card">
      <div class="card-head"><div class="card-title">Member spotlights</div></div>
      <div style="padding:16px 20px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">
        <input class="field-input" id="spot-email" placeholder="Member email" />
        <input class="field-input" id="spot-week" placeholder="Week of (e.g. May 12)" />
        <input class="field-input" id="spot-blurb" placeholder="Spotlight blurb..." style="grid-column:span 2" />
        <button class="btn-primary" id="post-spotlight">Add Spotlight</button>
      </div>
      {spotlights.length===0?<div class="empty"><div class="empty-icon">🌟</div><p>No spotlights yet.</p></div>:(
        <table><thead><tr><th>Member</th><th>Blurb</th><th>Week</th><th></th></tr></thead><tbody>
          {spotlights.map((s:any)=><tr><td class="td-name">{s.member_email}</td><td class="td-muted" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{s.blurb}</td><td class="td-muted">{s.week_of}</td><td><button class="btn btn-sm del" data-action="delete-spotlight" data-id={s.id}>Delete</button></td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ SETTINGS ═══ -->
  <div class="panel" id="panel-settings">
    <div class="settings-grid">
      <div class="settings-card">
        <div class="settings-title">Site controls</div><div class="settings-sub">Toggle major features.</div>
        <div class="toggle-row"><div><div class="toggle-label">Maintenance mode</div><div class="toggle-desc">Show "coming soon" page</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_maintenance"><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">New signups</div><div class="toggle-desc">Allow new members</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_signups" checked><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">Member directory</div><div class="toggle-desc">Public members page</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_directory" checked><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">Suggestions</div><div class="toggle-desc">Let members submit ideas</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_suggestions" checked><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">AI chatbot</div><div class="toggle-desc">Groq chatbot on site</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_chatbot" checked><span class="toggle-track"></span></label></div>
      </div>
