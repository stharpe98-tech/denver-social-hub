// ============ ANALYTICS ============
function loadAnalytics(){
  var script=document.createElement('script');
  script.src='https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js';
  script.onload=function(){
    chartJS=window.Chart;
    apiGet('analytics').then(function(data){
      var d=data||{};
      var chartCfg={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,labels:{color:'#8A859E',font:{size:10}}},tooltip:{backgroundColor:'rgba(20,18,30,0.95)',borderColor:'rgba(255,255,255,0.1)',borderWidth:1,titleColor:'#E8E6F0',bodyColor:'#8A859E',padding:10,cornerRadius:8}},scales:{x:{ticks:{color:'#5A5672',font:{size:10}},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#5A5672',font:{size:10}},grid:{color:'rgba(255,255,255,0.04)'}}}};

      // Members by Month
      if(d.membersByMonth&&d.membersByMonth.length){
        var labels=d.membersByMonth.map(function(i){return i.month||i.label||''});
        var vals=d.membersByMonth.map(function(i){return i.count||i.value||0});
        new chartJS($('#chart-members'),{type:'line',data:{labels:labels,datasets:[{label:'Members',data:vals,borderColor:'#A78BFA',backgroundColor:'rgba(167,139,250,0.1)',fill:true,tension:0.4,pointRadius:3}]},options:chartCfg});
      }

      // Events by Type
      if(d.eventsByType&&d.eventsByType.length){
        var tLabels=d.eventsByType.map(function(i){return i.type||i.label||''});
        var tVals=d.eventsByType.map(function(i){return i.count||i.value||0});
        var colors=['#A78BFA','#38BDF8','#F472B6','#34D399','#FB923C','#EF4444','#FBBF24','#818CF8','#6EE7B7','#F9A8D4','#93C5FD','#FCA5A5'];
        new chartJS($('#chart-events-type'),{type:'doughnut',data:{labels:tLabels,datasets:[{data:tVals,backgroundColor:colors.slice(0,tLabels.length),borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:'#8A859E',font:{size:10},padding:8}}}}});
      }

      // RSVPs by Month
      if(d.rsvpsByMonth&&d.rsvpsByMonth.length){
        var rLabels=d.rsvpsByMonth.map(function(i){return i.month||i.label||''});
        var rVals=d.rsvpsByMonth.map(function(i){return i.count||i.value||0});
        new chartJS($('#chart-rsvps'),{type:'bar',data:{labels:rLabels,datasets:[{label:'RSVPs',data:rVals,backgroundColor:'rgba(56,189,248,0.5)',borderColor:'#38BDF8',borderWidth:1,borderRadius:4}]},options:chartCfg});
      }

      // Top Events
      if(d.topEvents&&d.topEvents.length){
        var eLabels=d.topEvents.map(function(i){return(i.title||'').substring(0,20)});
        var eVals=d.topEvents.map(function(i){return i.rsvp_count||i.count||0});
        new chartJS($('#chart-top-events'),{type:'bar',data:{labels:eLabels,datasets:[{label:'RSVPs',data:eVals,backgroundColor:'rgba(244,114,182,0.5)',borderColor:'#F472B6',borderWidth:1,borderRadius:4}]},options:Object.assign({},chartCfg,{indexAxis:'y'})});
      }

      // Page views
      if(d.viewsByPath&&d.viewsByPath.length){
        var pLabels=d.viewsByPath.map(function(i){return i.path||i.label||''});
        var pVals=d.viewsByPath.map(function(i){return i.count||i.value||0});
        new chartJS($('#chart-pageviews'),{type:'bar',data:{labels:pLabels,datasets:[{label:'Views',data:pVals,backgroundColor:'rgba(52,211,153,0.5)',borderColor:'#34D399',borderWidth:1,borderRadius:4}]},options:chartCfg});
      }

      // Ratings
      if(d.ratingsByEvent&&d.ratingsByEvent.length){
        var rtLabels=d.ratingsByEvent.map(function(i){return(i.title||'').substring(0,20)});
        var rtVals=d.ratingsByEvent.map(function(i){return i.avg_rating||i.rating||0});
        new chartJS($('#chart-ratings'),{type:'bar',data:{labels:rtLabels,datasets:[{label:'Avg Rating',data:rtVals,backgroundColor:'rgba(251,146,60,0.5)',borderColor:'#FB923C',borderWidth:1,borderRadius:4}]},options:chartCfg});
      }

      // If no data for some charts, show placeholder
      if(!d.membersByMonth||!d.membersByMonth.length)$('#chart-members').parentElement.innerHTML='<div class="empty" style="padding:20px"><div class="empty-icon">📊</div><p>No data yet</p></div>';
      if(!d.eventsByType||!d.eventsByType.length)$('#chart-events-type').parentElement.innerHTML='<div class="empty" style="padding:20px"><div class="empty-icon">📊</div><p>No data yet</p></div>';
      if(!d.rsvpsByMonth||!d.rsvpsByMonth.length)$('#chart-rsvps').parentElement.innerHTML='<div class="empty" style="padding:20px"><div class="empty-icon">📊</div><p>No data yet</p></div>';
      if(!d.topEvents||!d.topEvents.length)$('#chart-top-events').parentElement.innerHTML='<div class="empty" style="padding:20px"><div class="empty-icon">📊</div><p>No data yet</p></div>';
      if(!d.viewsByPath||!d.viewsByPath.length)$('#chart-pageviews').parentElement.innerHTML='<div class="empty" style="padding:20px"><div class="empty-icon">📊</div><p>No data yet</p></div>';
      if(!d.ratingsByEvent||!d.ratingsByEvent.length)$('#chart-ratings').parentElement.innerHTML='<div class="empty" style="padding:20px"><div class="empty-icon">📊</div><p>No data yet</p></div>';
    }).catch(function(err){console.error('Analytics load error:',err)});
  };
  document.head.appendChild(script);
}

// ============ SETTINGS ============
function loadSettings(){
  fetch('/api/admin/settings').then(function(r){return r.json()}).then(function(d){
    if(d.error)return;
    $$('[data-setting]').forEach(function(el){
      var k=el.getAttribute('data-setting');
      if(d[k]===undefined)return;
      if(el.type==='checkbox')el.checked=d[k]==='1';
      else if(el.tagName==='TEXTAREA')el.value=d[k];
      else el.value=d[k];
    });
  }).catch(function(){});
}
function gatherAll(){
  var s={};
  $$('[data-setting]').forEach(function(el){
    var k=el.getAttribute('data-setting');
    s[k]=el.type==='checkbox'?(el.checked?'1':'0'):el.value;
  });
  return s;
}
function doSave(){
  api('/api/admin/settings',gatherAll()).then(function(){toast('Saved')}).catch(function(err){toast('Failed: '+err.message,true)});
}
$$('.js-save').forEach(function(b){b.addEventListener('click',doSave)});

// Load settings on init
loadSettings();

// ============ APPEARANCE SUB-TABS ============
$$('.app-tab').forEach(function(t){t.addEventListener('click',function(){
  $$('.app-tab').forEach(function(x){x.classList.remove('active')});
  $$('.app-panel').forEach(function(p){p.classList.remove('active')});
  this.classList.add('active');
  var target=$('#apptab-'+this.getAttribute('data-apptab'));
  if(target)target.classList.add('active');
})});

// ============ COLOR PICKER SYNC ============
// Sync color picker <-> hex input
$$('.color-picker').forEach(function(cp){
  var settingKey=cp.getAttribute('data-setting');
  var hexInput=document.querySelector('.color-hex[data-mirror="'+settingKey+'"]');
  if(!hexInput)return;
  cp.addEventListener('input',function(){hexInput.value=this.value.toUpperCase()});
  hexInput.addEventListener('input',function(){
    var v=this.value.trim();
    if(/^#[0-9a-fA-F]{6}$/.test(v))cp.value=v;
  });
  hexInput.addEventListener('change',function(){
    var v=this.value.trim();
    if(v.length===6&&!/^#/.test(v))v='#'+v;
    if(/^#[0-9a-fA-F]{6}$/.test(v)){cp.value=v;this.value=v.toUpperCase()}
  });
});

// Also sync color pickers when settings load
var origLoadSettings=loadSettings;
loadSettings=function(){
  origLoadSettings();
  // After settings load, sync hex inputs from color pickers
  setTimeout(function(){
    $$('.color-picker').forEach(function(cp){
      var settingKey=cp.getAttribute('data-setting');
      var hexInput=document.querySelector('.color-hex[data-mirror="'+settingKey+'"]');
      if(hexInput)hexInput.value=cp.value.toUpperCase();
    });
  },300);
};

// ============ DANGER ZONE ============
$('#clear-pending').addEventListener('click',function(){
  if(!confirm('Clear all pending members? This cannot be undone.'))return;
  api('/api/admin/member',{action:'clear_pending'}).then(function(){toast('Cleared');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)});
});
$('#clear-past-events').addEventListener('click',function(){
  if(!confirm('Archive all past events?'))return;
  api('/api/admin/event',{action:'archive_past'}).then(function(){toast('Archived');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)});
});
$('#export-csv').addEventListener('click',function(){
  var members=window.__members||[];
  if(!members.length){toast('No members.',true);return}
  var csv='Name,Email,Neighborhood,Role,Status,Events Attended,Points,Joined\n';
  members.forEach(function(m){
    var status=m.suspended?'Suspended':m.approved?'Active':'Pending';
    csv+='"'+((m.name||'').replace(/"/g,'""'))+'","'+(m.email||'')+'","'+((m.neighborhood||'').replace(/"/g,'""'))+'","'+(m.role||'member')+'","'+status+'",'+
      (m.events_attended||0)+','+(m.points||0)+',"'+((m.joined_at||'').slice(0,10))+'"\n';
  });
  var a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download='dsn-members-'+new Date().toISOString().slice(0,10)+'.csv';
  a.click();
  toast('CSV downloaded');
});
$('#export-all-data').addEventListener('click',function(){
  var data={members:window.__members,events:window.__events};
  var a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));
  a.download='dsn-data-'+new Date().toISOString().slice(0,10)+'.json';
  a.click();
  toast('Data exported');
});

// ============ COPY EDITOR ============
function loadCopyEditor(){
  fetch('/api/admin/content').then(function(r){return r.json()}).then(function(data){
    if(data.error)return;
    $$('.ce-field').forEach(function(f){
      var k=f.getAttribute('data-key');
      if(data[k]!==undefined){f.value=data[k];}
    });
    $('#ce-loading').style.display='none';
    $('#ce-content').style.display='block';
  }).catch(function(){
    $('#ce-loading').innerHTML='<div class="empty"><div class="empty-icon">⚠️</div><div class="empty-title">Failed to load content</div></div>';
  });
}

$('#ce-save').addEventListener('click',function(){
  var btn=this;
  var payload={};
  $$('.ce-field').forEach(function(f){
    payload[f.getAttribute('data-key')]=f.value;
  });
  btn.disabled=true;btn.textContent='Saving...';
  fetch('/api/admin/content',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload)
  }).then(function(r){return r.json()}).then(function(data){
    btn.disabled=false;btn.textContent='💾 Save All Copy';
    var msg=$('#ce-msg');
    if(data.success){
      msg.style.display='block';msg.style.background='rgba(52,211,153,0.1)';msg.style.color='var(--green)';msg.style.border='1px solid rgba(52,211,153,0.2)';
      msg.textContent='✓ Copy saved! Changes will appear on page reload.';
      setTimeout(function(){msg.style.display='none'},4000);
    } else {
      msg.style.display='block';msg.style.background='rgba(239,68,68,0.1)';msg.style.color='var(--red)';msg.style.border='1px solid rgba(239,68,68,0.2)';
      msg.textContent='Error: '+(data.error||'Unknown error');
    }
  }).catch(function(){
    btn.disabled=false;btn.textContent='💾 Save All Copy';
    toast('Network error');
  });
});

