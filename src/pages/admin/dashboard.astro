(function(){var $=function(s){return document.querySelector(s)},$$=function(s){return document.querySelectorAll(s)};function toast(m,e){var el=$('#toast');if(!el)return;el.textContent=m;el.className=e?'toast show error':'toast show';setTimeout(function(){el.className='toast'},3000)}function api(u,b){return fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(function(r){return r.json()}).then(function(d){if(d.error)throw new Error(d.error);return d})}var titles={overview:'Overview',members:'Members',events:'Events',suggestions:'Suggestions',settings:'Settings',content:'Content'};function showPanel(id){$$('.panel').forEach(function(p){p.classList.remove('active')});var t=$('#panel-'+id);if(t)t.classList.add('active');$$('.tab').forEach(function(b){b.classList.remove('active')});$$('.tab[data-panel="'+id+'"]').forEach(function(b){b.classList.add('active')});var mob=$('#mob-tabs');if(mob)mob.classList.remove('open')}$$('[data-panel]').forEach(function(b){b.addEventListener('click',function(){showPanel(this.getAttribute('data-panel'))})});var mobMenu=$('#mob-menu'),mobTabs=$('#mob-tabs');if(mobMenu)mobMenu.addEventListener('click',function(){mobTabs.classList.toggle('open')});function bindSearch(i,t){var inp=$('#'+i);if(!inp)return;inp.addEventListener('input',function(){var q=this.value.toLowerCase();$$('#'+t+' tr[data-search]').forEach(function(r){r.style.display=(r.getAttribute('data-search')||'').toLowerCase().indexOf(q)>=0?'':'none'})})}bindSearch('search-members','members-table');bindSearch('search-events','events-table');document.addEventListener('click',function(e){var btn=e.target.closest('[data-action]');if(!btn)return;var act=btn.getAttribute('data-action'),id=btn.getAttribute('data-id');if(act==='remove-member'){var nm=btn.getAttribute('data-name');if(!confirm('Remove '+nm+'?'))return;btn.disabled=true;btn.textContent='...';api('/api/admin/member',{action:'delete',id:parseInt(id)}).then(function(){toast(nm+' removed.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Remove'})}if(act==='delete-event'){var tt=btn.getAttribute('data-title');if(!confirm('Delete "'+tt+'"?'))return;btn.disabled=true;btn.textContent='...';api('/api/admin/event',{action:'delete',id:parseInt(id)}).then(function(){toast('"'+tt+'" deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Delete'})}if(act==='toggle-feature'){var f=btn.getAttribute('data-featured')==='1';api('/api/admin/event',{action:'feature',id:parseInt(id),featured:!f}).then(function(){toast(f?'Unfeatured':'Featured ⭐');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}if(act==='mark-suggestion'){var st=btn.getAttribute('data-status');api('/api/admin/suggestion',{action:'status',id:parseInt(id),status:st}).then(function(){toast('Marked '+st+' ✓');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}if(act==='delete-suggestion'){if(!confirm('Delete this suggestion?'))return;api('/api/admin/suggestion',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)})}});$('#toggle-create').addEventListener('click',function(){$('#create-event-form').classList.toggle('open')});$('#cancel-create').addEventListener('click',function(){$('#create-event-form').classList.remove('open')});$('#submit-event').addEventListener('click',function(){var t=$('#evt-title').value.trim();if(!t){toast('Title required.',true);return}api('/api/admin/event',{action:'create',title:t,event_type:$('#evt-type').value,location:$('#evt-location').value.trim(),zone:$('#evt-zone').value.trim(),event_month:$('#evt-month').value.trim(),event_day:$('#evt-day').value.trim(),spots:$('#evt-spots').value,price_cap:$('#evt-price').value.trim(),description:$('#evt-desc').value.trim(),featured:$('#evt-featured').checked}).then(function(){toast('Event created! 🎉');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});function gatherAll(){var s={};$$('[data-setting]').forEach(function(el){var k=el.getAttribute('data-setting');s[k]=el.type==='checkbox'?(el.checked?'1':'0'):el.value});return s}function doSave(){api('/api/admin/settings',gatherAll()).then(function(){toast('Settings saved ✓')}).catch(function(err){toast('Failed: '+err.message,true)})}$$('.js-save').forEach(function(b){b.addEventListener('click',doSave)});fetch('/api/admin/settings').then(function(r){return r.json()}).then(function(d){if(d.error)return;$$('[data-setting]').forEach(function(el){var k=el.getAttribute('data-setting');if(d[k]===undefined)return;if(el.type==='checkbox')el.checked=d[k]==='1';else el.value=d[k]})}).catch(function(){});$('#clear-pending').addEventListener('click',function(){if(!confirm('Clear all pending members?'))return;api('/api/admin/member',{action:'clear_pending'}).then(function(){toast('Cleared.');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});$('#export-csv').addEventListener('click',function(){var rows=$$('#members-table tbody tr');if(!rows.length){toast('No members.',true);return}var csv='Name,Email,Neighborhood,Bio,Status\n';rows.forEach(function(row){var cells=row.querySelectorAll('td');var vals=[];for(var i=0;i<5;i++)vals.push('"'+(cells[i]?cells[i].textContent.trim().replace(/"/g,'""'):'')+'"');csv+=vals.join(',')+'\n'});var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='dsn-members-'+new Date().toISOString().slice(0,10)+'.csv';a.click();toast('CSV downloaded ✓')});var themeBtn=$('#theme-toggle');function setTheme(dark){if(dark){document.documentElement.classList.add('dark');themeBtn.textContent='🌙'}