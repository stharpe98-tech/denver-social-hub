<script is:inline define:vars={{ membersJSON, eventsJSON }}>
  window.__members = JSON.parse(membersJSON);
  window.__events = JSON.parse(eventsJSON);
</script>

<script is:inline>
(function(){
var $=function(s){return document.querySelector(s)};
var $$=function(s){return document.querySelectorAll(s)};
var chartJS=null;
var loadedPanels={overview:true};

function toast(m,e){var el=$('#toast');if(!el)return;el.textContent=m;el.className=e?'toast show error':'toast show';setTimeout(function(){el.className='toast'},3000)}
function api(u,b){return fetch(u,b?{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}:void 0).then(function(r){return r.json()}).then(function(d){if(d.error)throw new Error(d.error);return d})}
function apiGet(t){return fetch('/api/admin/data?table='+t).then(function(r){return r.json()})}
function apiPost(b){return fetch('/api/admin/data',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(function(r){return r.json()}).then(function(d){if(d.error)throw new Error(d.error);return d})}
function esc(s){if(!s)return'';var d=document.createElement('div');d.textContent=s;return d.innerHTML}

// ============ SIDEBAR + PANELS ============
var panelTitles={overview:'Overview',members:'Members',events:'Events',suggestions:'Suggestions',copyeditor:'Copy Editor',announcements:'Announcements',spotlights:'Spotlights',reports:'Reports',partners:'Partners',restaurants:'Restaurants',pages:'Pages',plugins:'Plugins',analytics:'Analytics',appearance:'Appearance',settings:'Settings'};
var panelSubs={overview:'Dashboard overview and quick stats',members:'Manage all community members',events:'Create and manage events',suggestions:'Community ideas and feedback',copyeditor:'Edit headlines, subtitles, and copy across every page',announcements:'Broadcast messages',spotlights:'Highlight outstanding members',reports:'Review member reports',partners:'Business partnerships and deals',restaurants:'Denver restaurant database',pages:'Custom page management',plugins:'Code injection and plugins',analytics:'Charts and data insights',appearance:'Per-page colors, typography, layout and branding',settings:'Configuration and toggles'};

function showPanel(id){
  $$('.panel').forEach(function(p){p.classList.remove('active')});
  var t=$('#panel-'+id);if(t)t.classList.add('active');
  $$('.nav-item').forEach(function(b){b.classList.remove('active')});
  $$('.nav-item[data-panel="'+id+'"]').forEach(function(b){b.classList.add('active')});
  $('#main-title').textContent=panelTitles[id]||id;
  $('#main-title-sub').textContent=panelSubs[id]||'';
  // Close mobile sidebar
  $('#sidebar').classList.remove('mob-open');
  $('#sidebar-overlay').classList.remove('open');
  // Lazy load panel data
  if(!loadedPanels[id]){
    loadedPanels[id]=true;
    if(id==='reports')loadReports();
    if(id==='partners')loadPartners();
    if(id==='restaurants')loadRestaurants();
    if(id==='pages')loadPages();
    if(id==='plugins')loadPlugins();
    if(id==='analytics')loadAnalytics();
    if(id==='settings'||id==='appearance')loadSettings();
    if(id==='copyeditor')loadCopyEditor();
  }
}

$$('[data-panel]').forEach(function(b){b.addEventListener('click',function(e){
  e.preventDefault();showPanel(this.getAttribute('data-panel'));
})});

// Sidebar toggle
$('#sidebar-toggle').addEventListener('click',function(){
  var sb=$('#sidebar'),mn=$('#main');
  sb.classList.toggle('collapsed');
  mn.classList.toggle('shifted');
  this.textContent=sb.classList.contains('collapsed')?'▶':'◀';
});

// Mobile sidebar
$('#mob-sidebar-toggle').addEventListener('click',function(){
  $('#sidebar').classList.toggle('mob-open');
  $('#sidebar-overlay').classList.toggle('open');
});
$('#sidebar-overlay').addEventListener('click',function(){
  $('#sidebar').classList.remove('mob-open');
  this.classList.remove('open');
});

// Refresh
$('#refresh-btn').addEventListener('click',function(){location.reload()});

// ============ SEARCH + FILTER ============
function bindSearch(inputId,tableId){
  var inp=$('#'+inputId);if(!inp)return;
  inp.addEventListener('input',function(){
    var q=this.value.toLowerCase();
    $$('#'+tableId+' tr[data-search]').forEach(function(r){
      r.style.display=(r.getAttribute('data-search')||'').toLowerCase().indexOf(q)>=0?'':'none';
    });
  });
}
bindSearch('search-members','members-table');
bindSearch('search-events','events-table');

var mf=$('#member-filter');if(mf)mf.addEventListener('change',function(){
  var v=this.value;
  $$('#members-table tbody tr').forEach(function(r){
    if(v==='all')r.style.display='';
    else r.style.display=r.getAttribute('data-status')===v?'':'none';
  });
});

var ef=$('#event-filter');if(ef)ef.addEventListener('change',function(){
  var v=this.value;
  $$('#events-table tbody tr').forEach(function(r){
    if(v==='all')r.style.display='';
    else{
      var st=r.getAttribute('data-estatus');
      if(v==='upcoming')r.style.display=(st==='upcoming'||st==='featured')?'':'none';
      else if(v==='past')r.style.display=st==='past'?'':'none';
      else if(v==='featured')r.style.display=st==='featured'?'':'none';
      else r.style.display='';
    }
  });
});

var sf=$('#suggestion-filter');if(sf)sf.addEventListener('change',function(){
  var v=this.value;
  $$('#suggestions-table tbody tr').forEach(function(r){
    if(v==='all')r.style.display='';
    else r.style.display=r.getAttribute('data-sstatus')===v?'':'none';
  });
});

// ============ BULK ACTIONS ============
var selAll=$('#select-all-members');
if(selAll)selAll.addEventListener('change',function(){
  var checked=this.checked;
  $$('.member-check').forEach(function(c){
    if(c.closest('tr').style.display!=='none')c.checked=checked;
  });
  updateBulkBar();
});
document.addEventListener('change',function(e){if(e.target.classList.contains('member-check'))updateBulkBar()});
function updateBulkBar(){
  var checked=$$('.member-check:checked');
  var bar=$('#bulk-bar'),cnt=$('#bulk-count');
  if(checked.length>0){bar.classList.add('show');cnt.textContent=checked.length}
  else{bar.classList.remove('show')}
}
$('#bulk-cancel').addEventListener('click',function(){
  $$('.member-check').forEach(function(c){c.checked=false});
  if(selAll)selAll.checked=false;
  updateBulkBar();
});
$('#bulk-approve').addEventListener('click',function(){
  var ids=[];$$('.member-check:checked').forEach(function(c){ids.push(parseInt(c.value))});
  if(!ids.length)return;if(!confirm('Approve '+ids.length+' members?'))return;
  Promise.all(ids.map(function(id){return api('/api/admin/member',{action:'approve',id:id})}))
    .then(function(){toast('Approved '+ids.length+' members');setTimeout(function(){location.reload()},500)})
    .catch(function(err){toast('Failed: '+err.message,true)});
});
$('#bulk-suspend').addEventListener('click',function(){
  var ids=[];$$('.member-check:checked').forEach(function(c){ids.push(parseInt(c.value))});
  if(!ids.length)return;var reason=prompt('Reason for suspending '+ids.length+' members?','Policy violation');
  if(!reason)return;
  Promise.all(ids.map(function(id){return api('/api/admin/member',{action:'suspend',id:id,reason:reason})}))
    .then(function(){toast('Suspended '+ids.length+' members');setTimeout(function(){location.reload()},500)})
    .catch(function(err){toast('Failed: '+err.message,true)});
});

// ============ MEMBER + EVENT ACTIONS ============
document.addEventListener('click',function(e){
  var btn=e.target.closest('[data-action]');if(!btn)return;
  var act=btn.getAttribute('data-action'),id=btn.getAttribute('data-id');

  if(act==='remove-member'){
    var nm=btn.getAttribute('data-name');if(!confirm('Remove '+nm+'?'))return;
    btn.disabled=true;btn.textContent='...';
    api('/api/admin/member',{action:'delete',id:parseInt(id)}).then(function(){toast(nm+' removed.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Remove'});
  }
  if(act==='approve-member'){
    api('/api/admin/member',{action:'approve',id:parseInt(id)}).then(function(){toast('Approved');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='suspend-member'){
    var nm2=btn.getAttribute('data-name');var reason=prompt('Reason for suspending '+nm2+'?','Policy violation');if(!reason)return;
    api('/api/admin/member',{action:'suspend',id:parseInt(id),reason:reason}).then(function(){toast(nm2+' suspended.');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='unsuspend-member'){
    api('/api/admin/member',{action:'unsuspend',id:parseInt(id)}).then(function(){toast('Unsuspended');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-event'){
    var tt=btn.getAttribute('data-title');if(!confirm('Delete "'+tt+'"?'))return;
    btn.disabled=true;btn.textContent='...';
    api('/api/admin/event',{action:'delete',id:parseInt(id)}).then(function(){toast('"'+tt+'" deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Delete'});
  }
  if(act==='toggle-feature'){
    var f=btn.getAttribute('data-featured')==='1';
    api('/api/admin/event',{action:'feature',id:parseInt(id),featured:!f}).then(function(){toast(f?'Unfeatured':'Featured');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='view-rsvps'){
    var evtTitle=btn.getAttribute('data-title');
    $('#rsvp-modal-title').textContent='RSVPs for: '+evtTitle;
    $('#rsvp-modal-body').innerHTML='<div class="empty">Loading...</div>';
    $('#rsvp-modal').classList.add('open');
    apiGet('rsvps&event_id='+id).then(function(data){
      var rsvps=data.results||data||[];
      if(!rsvps.length){$('#rsvp-modal-body').innerHTML='<div class="empty"><div class="empty-icon">📋</div><p>No RSVPs yet.</p></div>';return}
      var h='<table><thead><tr><th>Name</th><th>Email</th><th>Plus One</th><th>Status</th></tr></thead><tbody>';
      rsvps.forEach(function(r){h+='<tr><td class="td-name">'+esc(r.member_name||r.name||'--')+'</td><td class="td-muted">'+esc(r.member_email||r.email||'--')+'</td><td class="td-muted">'+(r.plus_one?'Yes':'No')+'</td><td><span class="badge badge-green">'+(r.status||'confirmed')+'</span></td></tr>'});
      h+='</tbody></table>';
      $('#rsvp-modal-body').innerHTML=h;
    }).catch(function(err){$('#rsvp-modal-body').innerHTML='<div class="empty">Failed to load: '+esc(err.message)+'</div>'});
  }
  if(act==='mark-suggestion'){
    var st=btn.getAttribute('data-status');
    api('/api/admin/suggestion',{action:'status',id:parseInt(id),status:st}).then(function(){toast('Marked '+st);setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='promote-suggestion'){
    var sTitle=btn.getAttribute('data-title');if(!confirm('Promote "'+sTitle+'" to a new event?'))return;
    apiPost({table:'suggestions',action:'promote',id:parseInt(id)}).then(function(){toast('Promoted to event');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-suggestion'){
    if(!confirm('Delete this suggestion?'))return;
    api('/api/admin/suggestion',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-announcement'){
    if(!confirm('Delete this announcement?'))return;
    api('/api/admin/announcement',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-spotlight'){
    if(!confirm('Delete this spotlight?'))return;
    api('/api/admin/spotlight',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='resolve-report'){
    apiPost({table:'reports',action:'resolve',id:parseInt(id)}).then(function(){toast('Report resolved');loadReports()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='dismiss-report'){
    apiPost({table:'reports',action:'dismiss',id:parseInt(id)}).then(function(){toast('Report dismissed');loadReports()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='toggle-partner'){
    var active=btn.getAttribute('data-active')==='1';
    apiPost({table:'partners',action:'update',id:parseInt(id),active:active?0:1}).then(function(){toast(active?'Deactivated':'Activated');loadPartners()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-partner'){
    if(!confirm('Delete this partner?'))return;
    apiPost({table:'partners',action:'delete',id:parseInt(id)}).then(function(){toast('Deleted');loadPartners()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-restaurant'){
    if(!confirm('Delete this restaurant?'))return;
    apiPost({table:'restaurants',action:'delete',id:parseInt(id)}).then(function(){toast('Deleted');loadRestaurants()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='edit-restaurant'){
    var restData=window.__restaurants||[];
    var rest=null;restData.forEach(function(r){if(String(r.id)===String(id))rest=r});
    if(!rest)return;
    $('#rest-name').value=rest.name||'';$('#rest-zone').value=rest.zone||'';
    $('#rest-category').value=rest.category||'';$('#rest-price').value=rest.price_range||'$$';
    $('#rest-address').value=rest.address||'';$('#rest-phone').value=rest.phone||'';
    $('#rest-rating').value=rest.rating||'';$('#rest-hours').value=rest.hours||'';
    $('#rest-notes').value=rest.notes||'';$('#rest-edit-id').value=rest.id;
    $('#restaurant-modal-title').textContent='Edit Restaurant';
    $('#restaurant-modal').classList.add('open');
  }
  if(act==='delete-page'){
    if(!confirm('Delete this page?'))return;
    apiPost({table:'pages',action:'delete',id:parseInt(id)}).then(function(){toast('Deleted');loadPages()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='toggle-page'){
    var pub=btn.getAttribute('data-published')==='1';
    apiPost({table:'pages',action:'update',id:parseInt(id),published:pub?0:1}).then(function(){toast(pub?'Unpublished':'Published');loadPages()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='delete-plugin'){
    if(!confirm('Delete this plugin?'))return;
    apiPost({table:'plugins',action:'delete',id:parseInt(id)}).then(function(){toast('Deleted');loadPlugins()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='toggle-plugin'){
    var en=btn.getAttribute('data-enabled')==='1';
    apiPost({table:'plugins',action:'update',id:parseInt(id),enabled:en?0:1}).then(function(){toast(en?'Disabled':'Enabled');loadPlugins()}).catch(function(err){toast('Failed: '+err.message,true)});
  }
  if(act==='view-member'){
    var mem=null;(window.__members||[]).forEach(function(m){if(String(m.id)===String(id))mem=m});
    if(!mem)return;
    $('#modal-member-name').textContent=mem.name||mem.email;
    var rows=[['Email',mem.email],['Neighborhood',mem.neighborhood||'--'],['Bio',mem.bio||'--'],['Role',mem.role||'member'],['Discord',mem.discord_username||'--'],['Phone',mem.phone||'--'],['Age Range',mem.age_range||'--'],['Interests',mem.interests||'--'],['Event Types',mem.event_types||'--'],['Food Prefs',mem.food_prefs||'--'],['Points',mem.points||0],['Events Attended',mem.events_attended||0],['No-Shows',mem.no_show_count||0],['Joined',mem.joined_at?mem.joined_at.slice(0,10):'--'],['Referral Code',mem.referral_code||'--'],['Status',mem.suspended?'Suspended'+(mem.suspended_reason?' ('+mem.suspended_reason+')':''):mem.approved?'Active':'Pending Approval']];
    var html='';rows.forEach(function(r){html+='<div class="detail-row"><span class="detail-key">'+esc(String(r[0]))+'</span><span class="detail-val">'+esc(String(r[1]))+'</span></div>'});
    $('#modal-member-body').innerHTML=html;
    var acts='';
    if(!mem.approved)acts+='<button class="btn btn-sm" data-action="approve-member" data-id="'+mem.id+'">Approve</button>';
    if(mem.suspended)acts+='<button class="btn btn-sm" data-action="unsuspend-member" data-id="'+mem.id+'">Unsuspend</button>';
    else acts+='<button class="btn btn-sm del" data-action="suspend-member" data-id="'+mem.id+'" data-name="'+esc(mem.name||mem.email)+'">Suspend</button>';
    acts+='<button class="btn btn-sm del" data-action="remove-member" data-id="'+mem.id+'" data-name="'+esc(mem.name||mem.email)+'">Remove</button>';
    $('#modal-member-actions').innerHTML=acts;
    $('#member-modal').classList.add('open');
  }
});

// ============ MODALS ============
$('#close-member-modal').addEventListener('click',function(){$('#member-modal').classList.remove('open')});
$('#member-modal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('open')});
$('#close-rsvp-modal').addEventListener('click',function(){$('#rsvp-modal').classList.remove('open')});
$('#rsvp-modal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('open')});
$('#close-edit-modal').addEventListener('click',function(){$('#edit-modal').classList.remove('open')});
$('#edit-modal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('open')});
$('#close-restaurant-modal').addEventListener('click',function(){$('#restaurant-modal').classList.remove('open')});
$('#restaurant-modal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('open')});

// ============ ANNOUNCEMENTS ============
$('#post-announcement').addEventListener('click',function(){
  var t=$('#new-announcement').value.trim();if(!t){toast('Write something.',true);return}
  api('/api/admin/announcement',{action:'create',text:t}).then(function(){toast('Posted');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
});

// ============ SPOTLIGHTS ============
$('#post-spotlight').addEventListener('click',function(){
  var e=$('#spot-email').value.trim(),w=$('#spot-week').value.trim(),b=$('#spot-blurb').value.trim();
  if(!e||!w||!b){toast('Fill all fields.',true);return}
  api('/api/admin/spotlight',{action:'create',member_email:e,week_of:w,blurb:b}).then(function(){toast('Spotlight added');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)});
});

// ============ CREATE EVENT ============
$('#toggle-create').addEventListener('click',function(){$('#create-event-form').classList.toggle('open')});
$('#cancel-create').addEventListener('click',function(){$('#create-event-form').classList.remove('open')});

var typeHints={dinner:{title:'e.g. RiNo Ramen Night',loc:'e.g. Uncle Ramen',price:'$20-30/person',desc:'Dietary notes?'},brewery:{title:'e.g. Brewery Crawl',loc:'e.g. Sunnyside',price:'$15-25',desc:'How many stops?'},outdoor:{title:'e.g. Bear Creek Hike',loc:'e.g. Bear Creek Trail',price:'Free',desc:'Distance? Terrain?'},game_night:{title:'e.g. Game Night',loc:'e.g. Board game cafe',price:'Free/$5',desc:'What games?'},bowling:{title:'e.g. Cosmic Bowling',loc:'e.g. Punch Bowl Social',price:'$15-20',desc:'Lanes?'},sports:{title:'e.g. Rockies Game',loc:'e.g. Coors Field',price:'$25-40/ticket',desc:'Tailgate?'},music:{title:'e.g. Red Rocks Night',loc:'e.g. Red Rocks',price:'$30-60',desc:'Who is playing?'},arts:{title:'e.g. Paint and Sip',loc:'e.g. Painting w/ Twist',price:'$35',desc:'Supplies included?'},coffee:{title:'e.g. Sunday Coffee',loc:'e.g. Crema',price:'Buy your own',desc:'Casual hangout?'},casino:{title:'e.g. Blackhawk Night',loc:'e.g. Isle Casino',price:'Bring $50-100',desc:'Carpool?'},potluck:{title:'e.g. Summer Potluck',loc:'e.g. Wash Park',price:'Free - bring a dish',desc:'Theme?'},social:{title:'e.g. Block Party',loc:'e.g. RiNo Art District',price:'Free',desc:'Vibe?'},other:{title:'e.g. Custom Event',loc:'Location',price:'Varies',desc:'Details?'}};

function showTypeFields(type){
  $$('.evt-field').forEach(function(f){
    var ft=f.getAttribute('data-for');
    f.classList.toggle('show',ft==='all'||ft.split(' ').indexOf(type)>=0);
  });
  var h=typeHints[type]||typeHints.other;
  $('#evt-title').placeholder=h.title;$('#evt-location').placeholder=h.loc;
  $('#evt-price').placeholder=h.price;$('#evt-desc').placeholder=h.desc;
  $('#evt-core').style.display='';
}

$$('.type-chip').forEach(function(c){c.addEventListener('click',function(){
  $$('.type-chip').forEach(function(x){x.classList.remove('selected')});
  this.classList.add('selected');
  $('#evt-type').value=this.getAttribute('data-type');
  showTypeFields(this.getAttribute('data-type'));
})});

$('#submit-event').addEventListener('click',function(){
  var t=$('#evt-title').value.trim(),ty=$('#evt-type').value;
  if(!ty){toast('Pick a type.',true);return}
  if(!t){toast('Name the event.',true);return}
  var b={action:'create',title:t,event_type:ty,location:$('#evt-location').value.trim(),zone:$('#evt-zone').value.trim(),event_month:$('#evt-month').value,event_day:$('#evt-day').value.trim(),spots:$('#evt-spots').value,price_cap:$('#evt-price').value.trim(),description:$('#evt-desc').value.trim(),featured:$('#evt-featured').checked,plus_one_allowed:$('#evt-plusone')?$('#evt-plusone').value:'1'};
  function g(id){var el=$('#'+id);return el&&el.offsetParent?el.value:''}
  if(g('evt-difficulty'))b.difficulty=g('evt-difficulty');
  if(g('evt-pet'))b.pet_friendly=parseInt(g('evt-pet'));
  if(g('evt-cell'))b.cell_service=g('evt-cell');
  if(g('evt-packing'))b.packing_list=g('evt-packing');
  if(g('evt-reservation'))b.reservation_by=g('evt-reservation');
  if(g('evt-ppp'))b.price_per_person=g('evt-ppp');
  if(g('evt-payment'))b.payment_link=g('evt-payment');
  if(g('evt-mingroup'))b.min_group_size=parseInt(g('evt-mingroup'));
  if(g('evt-deposit')){b.deposit_required=parseInt(g('evt-deposit'));b.deposit_amount=parseFloat(g('evt-depositamt'))||10}
  if(g('evt-deadline'))b.commit_deadline=g('evt-deadline');
  if(g('evt-potluck-cats'))b.potluck_categories=g('evt-potluck-cats');
  if(g('evt-potluck-host'))b.reservation_by=g('evt-potluck-host');
  if(g('evt-potluck-bring'))b.packing_list=g('evt-potluck-bring');
  api('/api/admin/event',b).then(function(){toast('Event created');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)});
});

// ============ REPORTS ============
function loadReports(){
  apiGet('reports').then(function(data){
    var reports=data.results||data||[];
    $('#reports-count').textContent=reports.length+' total';
    if(!reports.length){$('#reports-body').innerHTML='<div class="empty"><div class="empty-icon">🛡️</div><p>No reports. Community is peaceful.</p></div>';return}
    var h='<table><thead><tr><th>Reported Member</th><th>Reporter</th><th>Reason</th><th>Status</th><th>Actions</th></tr></thead><tbody>';
    reports.forEach(function(r){
      var statusBadge=r.status==='resolved'?'badge-green':r.status==='dismissed'?'badge-muted':'badge-orange';
      h+='<tr><td class="td-name">'+esc(r.reported_member_name||'ID:'+r.reported_member_id)+'</td>';
      h+='<td class="td-muted">'+esc(r.reporter_email||'--')+'</td>';
      h+='<td class="td-muted" style="max-width:200px;word-break:break-word">'+esc(r.reason||'--')+(r.details?' - '+esc(r.details):'')+'</td>';
      h+='<td><span class="badge '+statusBadge+'">'+(r.status||'pending')+'</span></td>';
      h+='<td class="td-actions">';
      if(r.status==='pending'){
        h+='<button class="btn btn-sm" data-action="resolve-report" data-id="'+r.id+'">Resolve</button>';
        h+='<button class="btn btn-sm del" data-action="dismiss-report" data-id="'+r.id+'">Dismiss</button>';
      }
      h+='</td></tr>';
    });
    h+='</tbody></table>';
    $('#reports-body').innerHTML=h;
  }).catch(function(err){$('#reports-body').innerHTML='<div class="empty">Failed to load reports: '+esc(err.message)+'</div>'});
}

// ============ PARTNERS ============
function loadPartners(){
  apiGet('partners').then(function(data){
    var partners=data.results||data||[];
    if(!partners.length){$('#partners-body').innerHTML='<div class="empty"><div class="empty-icon">🤝</div><p>No partners yet.</p></div>';return}
    var h='<table><thead><tr><th>Business</th><th>Category</th><th>Neighborhood</th><th>Deal</th><th>Status</th><th>Actions</th></tr></thead><tbody>';
    partners.forEach(function(p){
      h+='<tr data-search="'+esc(p.business_name+' '+p.neighborhood+' '+p.category)+'">';
      h+='<td class="td-name">'+(p.logo_emoji||'🏪')+' '+esc(p.business_name||'--')+'</td>';
      h+='<td class="td-muted">'+esc(p.category||'--')+'</td>';
      h+='<td class="td-muted">'+esc(p.neighborhood||'--')+'</td>';
      h+='<td class="td-muted" style="max-width:180px;word-break:break-word">'+esc(p.deal||'--')+'</td>';
      h+='<td>'+(p.active?'<span class="badge badge-green">Active</span>':'<span class="badge badge-muted">Inactive</span>')+'</td>';
      h+='<td class="td-actions"><button class="btn btn-sm" data-action="toggle-partner" data-id="'+p.id+'" data-active="'+(p.active?'1':'0')+'">'+(p.active?'Deactivate':'Activate')+'</button><button class="btn btn-sm del" data-action="delete-partner" data-id="'+p.id+'">Delete</button></td></tr>';
    });
    h+='</tbody></table>';$('#partners-body').innerHTML=h;
    // Bind search
    var si=$('#search-partners');if(si){si.oninput=function(){var q=this.value.toLowerCase();$('#partners-body').querySelectorAll('tr[data-search]').forEach(function(r){r.style.display=(r.getAttribute('data-search')||'').toLowerCase().indexOf(q)>=0?'':'none'})}}
  }).catch(function(err){$('#partners-body').innerHTML='<div class="empty">Failed: '+esc(err.message)+'</div>'});

  apiGet('partner_inquiries').then(function(data){
    var inq=data.results||data||[];
    if(!inq.length){$('#inquiries-body').innerHTML='<div class="empty"><div class="empty-icon">📨</div><p>No inquiries yet.</p></div>';return}
    var h='<table><thead><tr><th>Business</th><th>Contact</th><th>Message</th><th>Date</th></tr></thead><tbody>';
    inq.forEach(function(i){
      h+='<tr><td class="td-name">'+esc(i.business_name||'--')+'</td><td class="td-muted">'+esc(i.contact_email||i.email||'--')+'</td><td class="td-muted" style="max-width:250px;word-break:break-word">'+esc(i.message||'--')+'</td><td class="td-muted">'+esc((i.created_at||'--').slice(0,10))+'</td></tr>';
    });
    h+='</tbody></table>';$('#inquiries-body').innerHTML=h;
  }).catch(function(){});
}

