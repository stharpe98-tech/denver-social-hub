---
import AdminBase from '../../layouts/AdminBase.astro';
import { getDB } from '../../lib/db';

const cookie = Astro.request.headers.get('cookie') || '';
const userMatch = cookie.match(/dsn_user=([^;]+)/);
let isAdmin = false;
if (userMatch) {
  try { const u = JSON.parse(decodeURIComponent(userMatch[1])); isAdmin = u.email === 'stharpe98@gmail.com'; } catch {}
}
if (!isAdmin) return Astro.redirect('/admin');

const db = getDB();
let members: any[] = [], events: any[] = [], suggestions: any[] = [];
if (db) {
  try {
    members = (await db.prepare(`SELECT * FROM members ORDER BY id DESC`).all())?.results || [];
    events = (await db.prepare(`SELECT * FROM events ORDER BY id DESC`).all())?.results || [];
    suggestions = (await db.prepare(`SELECT * FROM suggestions ORDER BY votes DESC LIMIT 20`).all())?.results || [];
  } catch {}
}
const onboarded = members.filter((m: any) => m.onboarding_done).length;
const typeEmoji: Record<string, string> = {
  dinner:'🍽️', game_night:'🎲', outdoor:'🏔️', brewery:'🍺', bowling:'🎳',
  arts:'🎨', music:'🎵', social:'🎉', group_tickets:'🎫', sports:'⚾',
  coffee:'☕', casino:'🎰', active:'🧗', food_trucks:'🚚', other:'📅'
};
---
<AdminBase title="Dashboard — Denver Social">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  :root {
    --bg:#f8f7f4; --white:#ffffff; --card:#ffffff;
    --border:#e8e5df; --border-light:#f0ede8;
    --text:#1a1a1a; --text-secondary:#6b6560; --text-hint:#a09a93;
    --accent:#e07830; --accent-light:#fef3eb; --accent-hover:#c96520;
    --green:#16a34a; --green-light:#f0fdf4;
    --red:#dc2626; --red-light:#fef2f2;
    --blue:#2563eb; --blue-light:#eff6ff;
    --radius:12px; --radius-sm:8px;
    --shadow-sm:0 1px 2px rgba(0,0,0,.04);
    --shadow:0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-lg:0 4px 12px rgba(0,0,0,.06);
    --font:'Outfit',system-ui,-apple-system,sans-serif;
    --hover-row:#faf9f7;
  }

  .dark {
    --bg:#0e1015; --white:#16181f; --card:#1a1c24;
    --border:#2a2d36; --border-light:#22242c;
    --text:#e4e5ea; --text-secondary:#9498a4; --text-hint:#5c6070;
    --accent:#e8943a; --accent-light:rgba(232,148,58,.12); --accent-hover:#d4822e;
    --green:#4ade80; --green-light:rgba(74,222,128,.1);
    --red:#fb7185; --red-light:rgba(251,113,133,.1);
    --blue:#60a5fa; --blue-light:rgba(96,165,250,.1);
    --shadow-sm:0 1px 2px rgba(0,0,0,.2);
    --shadow:0 1px 3px rgba(0,0,0,.25);
    --shadow-lg:0 4px 12px rgba(0,0,0,.3);
    --hover-row:rgba(255,255,255,.025);
  }

  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
  body {
    background:var(--bg) !important; color:var(--text) !important; font-family:var(--font) !important;
    overflow:auto !important; height:auto !important; display:block !important;
    -webkit-font-smoothing:antialiased; line-height:1.5;
  }
  body::before, body::after { display:none !important; }

  /* ═══ TOP NAV ═══ */
  .topnav {
    background:var(--white); border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:100;
  }
  .topnav-inner {
    max-width:1200px; margin:0 auto; padding:0 32px;
    display:flex; align-items:center; height:60px; gap:32px;
  }
  .brand { display:flex; align-items:center; gap:10px; text-decoration:none; color:var(--text); flex-shrink:0; }
  .brand-icon {
    width:32px; height:32px; background:var(--accent); border-radius:8px;
    display:flex; align-items:center; justify-content:center; font-size:15px;
  }
  .brand-name { font-size:16px; font-weight:700; letter-spacing:-.02em; }
  .brand-tag { font-size:10px; font-weight:500; color:var(--accent); background:var(--accent-light); padding:2px 8px; border-radius:50px; margin-left:4px; }

  .tabs { display:flex; gap:2px; margin-left:24px; }
  .tab {
    padding:8px 16px; font-size:13px; font-weight:500; color:var(--text-secondary);
    border-radius:var(--radius-sm); cursor:pointer; border:none; background:none;
    font-family:var(--font); transition:all .15s; position:relative;
  }
  .tab:hover { color:var(--text); background:var(--bg); }
  .tab.active { color:var(--accent); background:var(--accent-light); font-weight:600; }

  .nav-right { margin-left:auto; display:flex; align-items:center; gap:8px; }
  .nav-btn {
    padding:7px 14px; font-size:12px; font-weight:500; color:var(--text-secondary);
    border:1px solid var(--border); border-radius:var(--radius-sm); background:var(--white);
    cursor:pointer; font-family:var(--font); transition:all .15s; text-decoration:none;
  }
  .nav-btn:hover { border-color:#ccc; color:var(--text); }
  .nav-btn.danger:hover { border-color:var(--red); color:var(--red); }
  .avatar {
    width:30px; height:30px; border-radius:50%; background:var(--accent);
    display:flex; align-items:center; justify-content:center;
    font-size:12px; font-weight:600; color:#fff; cursor:default;
  }

  /* ═══ CONTENT ═══ */
  .page { max-width:1200px; margin:0 auto; padding:28px 32px 60px; }
  .panel { display:none; }
  .panel.active { display:block; animation:fadeIn .25s ease; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

  /* ═══ STATS ═══ */
  .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:28px; }
  .stat {
    background:var(--card); border:1px solid var(--border); border-radius:var(--radius);
    padding:20px 22px; box-shadow:var(--shadow-sm);
  }
  .stat-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
  .stat-icon { font-size:20px; }
  .stat-trend { font-size:11px; font-weight:600; color:var(--green); }
  .stat-num { font-size:32px; font-weight:700; letter-spacing:-.03em; line-height:1; margin-bottom:2px; color:var(--text); }
  .stat-label { font-size:12px; font-weight:500; color:var(--text-hint); }

  /* ═══ CARDS / TABLES ═══ */
  .card {
    background:var(--card); border:1px solid var(--border); border-radius:var(--radius);
    overflow:hidden; margin-bottom:20px; box-shadow:var(--shadow-sm);
  }
  .card-head {
    padding:16px 22px; display:flex; align-items:center; justify-content:space-between;
    gap:12px; flex-wrap:wrap; border-bottom:1px solid var(--border-light);
  }
  .card-title { font-size:15px; font-weight:600; color:var(--text); }
  .search-input {
    padding:7px 14px; font-size:13px; color:var(--text); font-family:var(--font);
    border:1px solid var(--border); border-radius:var(--radius-sm); background:var(--bg);
    outline:none; width:200px; transition:border-color .15s;
  }
  .search-input:focus { border-color:var(--accent); }
  .search-input::placeholder { color:var(--text-hint); }

  table { width:100%; border-collapse:collapse; }
  th {
    padding:10px 22px; text-align:left; font-size:11px; font-weight:600;
    letter-spacing:.06em; text-transform:uppercase; color:var(--text-hint);
    background:var(--bg); border-bottom:1px solid var(--border-light);
  }
  td { padding:12px 22px; font-size:13px; border-bottom:1px solid var(--border-light); color:var(--text); }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:var(--hover-row); }
  .td-name { font-weight:600; }
  .td-muted { color:var(--text-secondary); }

  .badge { display:inline-flex; align-items:center; font-size:11px; font-weight:600; padding:3px 10px; border-radius:50px; }
  .badge-green { background:var(--green-light); color:var(--green); }
  .badge-muted { background:var(--bg); color:var(--text-hint); }
  .badge-accent { background:var(--accent-light); color:var(--accent); }
  .badge-blue { background:var(--blue-light); color:var(--blue); }

  .btn {
    padding:6px 14px; font-size:12px; font-weight:600; cursor:pointer;
    font-family:var(--font); border-radius:var(--radius-sm); transition:all .15s;
    border:1px solid var(--border); background:var(--white); color:var(--text-secondary);
  }
  .btn:hover { border-color:#bbb; color:var(--text); }
  .btn.del:hover { border-color:var(--red); color:var(--red); background:var(--red-light); }
  .btn-primary {
    background:var(--accent); color:#fff; border:none; padding:8px 20px;
    font-size:13px; font-weight:600; border-radius:var(--radius-sm); cursor:pointer;
    font-family:var(--font); transition:all .15s;
  }
  .btn-primary:hover { background:var(--accent-hover); }

  /* ═══ SETTINGS ═══ */
  .settings-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
  .settings-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:24px; box-shadow:var(--shadow-sm); }
  .settings-title { font-size:15px; font-weight:600; margin-bottom:3px; }
  .settings-sub { font-size:13px; color:var(--text-secondary); margin-bottom:20px; }
  .field { margin-bottom:16px; }
  .field-label { display:block; font-size:11px; font-weight:600; letter-spacing:.05em; text-transform:uppercase; color:var(--text-hint); margin-bottom:6px; }
  .field-input {
    width:100%; padding:10px 14px; font-size:13px; color:var(--text); font-family:var(--font);
    border:1px solid var(--border); border-radius:var(--radius-sm); background:var(--white); outline:none;
  }
  .field-input:focus { border-color:var(--accent); }
  .field-input::placeholder { color:var(--text-hint); }
  .field-select { width:100%; padding:10px 14px; font-size:13px; color:var(--text); font-family:var(--font); border:1px solid var(--border); border-radius:var(--radius-sm); background:var(--white); outline:none; cursor:pointer; }

  .toggle-row { display:flex; align-items:center; justify-content:space-between; padding:14px 0; border-bottom:1px solid var(--border-light); }
  .toggle-row:last-of-type { border-bottom:none; padding-bottom:0; }
  .toggle-label { font-size:13px; font-weight:600; color:var(--text); }
  .toggle-desc { font-size:12px; color:var(--text-hint); margin-top:1px; }
  .toggle { position:relative; width:42px; height:24px; flex-shrink:0; }
  .toggle input { opacity:0; width:0; height:0; }
  .toggle-track {
    position:absolute; inset:0; background:#ddd; border-radius:50px; cursor:pointer;
    transition:background .2s;
  }
  .toggle-track::after {
    content:''; position:absolute; width:18px; height:18px; background:#fff;
    border-radius:50%; top:3px; left:3px; transition:transform .2s; box-shadow:var(--shadow);
  }
  input:checked + .toggle-track { background:var(--accent); }
  input:checked + .toggle-track::after { transform:translateX(18px); }

  /* ═══ CREATE FORM ═══ */
  .create-form { display:none; margin-bottom:20px; }
  .create-form.open { display:block; animation:fadeIn .2s ease; }
  .form-grid { padding:20px 22px; display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .span2 { grid-column:span 2; }

  /* ═══ EMPTY / TOAST ═══ */
  .empty { padding:48px; text-align:center; color:var(--text-hint); }
  .empty-icon { font-size:36px; margin-bottom:12px; opacity:.5; }
  .toast {
    position:fixed; bottom:28px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--text); color:#fff; border-radius:var(--radius); padding:12px 24px;
    font-size:13px; font-weight:500; z-index:9999; opacity:0; transition:all .3s ease;
    pointer-events:none; box-shadow:var(--shadow-lg);
  }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
  .toast.error { background:var(--red); }

  /* ═══ MOBILE ═══ */
  .mob-menu { display:none; background:none; border:none; font-size:20px; cursor:pointer; color:var(--text); }
  .theme-toggle {
    width:32px; height:32px; border-radius:50%; border:1px solid var(--border);
    background:var(--bg); display:flex; align-items:center; justify-content:center;
    cursor:pointer; font-size:15px; transition:all .2s; flex-shrink:0;
  }
  .theme-toggle:hover { border-color:var(--accent); }
  .mob-tabs { display:none; }
  @media(max-width:768px) {
    .tabs { display:none; }
    .mob-menu { display:block; }
    .mob-tabs.open { display:flex; flex-direction:column; position:absolute; top:60px; left:0; right:0; background:var(--white); border-bottom:1px solid var(--border); padding:8px 16px; z-index:99; box-shadow:var(--shadow-lg); }
    .mob-tabs .tab { width:100%; text-align:left; padding:12px 16px; border-radius:var(--radius-sm); }
    .topnav-inner { padding:0 16px; }
    .page { padding:20px 16px 60px; }
    .stats { grid-template-columns:1fr 1fr; }
    .settings-grid { grid-template-columns:1fr; }
    .form-grid { grid-template-columns:1fr; }
    .span2 { grid-column:span 1; }
    .nav-btn.view-site { display:none; }
  }
  @media(max-width:480px) { .stats { grid-template-columns:1fr; } }
</style>

<!-- ═══ TOP NAVIGATION ═══ -->
<nav class="topnav">
  <div class="topnav-inner">
    <a href="/" class="brand">
      <div class="brand-icon">🌆</div>
      <span class="brand-name">Denver Social</span>
      <span class="brand-tag">Admin</span>
    </a>

    <div class="tabs" id="tabs">
      <button class="tab active" data-panel="overview">Overview</button>
      <button class="tab" data-panel="members">Members</button>
      <button class="tab" data-panel="events">Events</button>
      <button class="tab" data-panel="suggestions">Suggestions</button>
      <button class="tab" data-panel="settings">Settings</button>
      <button class="tab" data-panel="content">Content</button>
    </div>

    <button class="mob-menu" id="mob-menu">☰</button>

    <div class="nav-right">
      <button class="theme-toggle" id="theme-toggle" title="Toggle dark mode">☀️</button>
      <a href="/" class="nav-btn view-site" target="_blank">← View Site</a>
      <a href="/api/logout" class="nav-btn danger">Log Out</a>
      <div class="avatar">S</div>
    </div>
  </div>
  <div class="mob-tabs" id="mob-tabs">
    <button class="tab active" data-panel="overview">Overview</button>
    <button class="tab" data-panel="members">Members</button>
    <button class="tab" data-panel="events">Events</button>
    <button class="tab" data-panel="suggestions">Suggestions</button>
    <button class="tab" data-panel="settings">Settings</button>
    <button class="tab" data-panel="content">Content</button>
  </div>
</nav>

<div class="page">

  <!-- ═══ OVERVIEW ═══ -->
  <div class="panel active" id="panel-overview">
    <div class="stats">
      <div class="stat"><div class="stat-top"><span class="stat-icon">👥</span><span class="stat-trend">↑ growing</span></div><div class="stat-num">{members.length}</div><div class="stat-label">Total members</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">✅</span><span class="stat-trend">{members.length > 0 ? Math.round(onboarded / members.length * 100) : 0}%</span></div><div class="stat-num">{onboarded}</div><div class="stat-label">Onboarded</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">📅</span><span class="stat-trend">active</span></div><div class="stat-num">{events.length}</div><div class="stat-label">Total events</div></div>
      <div class="stat"><div class="stat-top"><span class="stat-icon">💡</span><span class="stat-trend">from crew</span></div><div class="stat-num">{suggestions.length}</div><div class="stat-label">Suggestions</div></div>
    </div>

    <div class="card">
      <div class="card-head"><div class="card-title">Recent members</div><button class="btn" data-panel="members">View all →</button></div>
      {members.length===0?<div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>:(
        <table><thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Status</th></tr></thead><tbody>
          {members.slice(0,5).map((m:any)=><tr><td class="td-name">{m.name||'—'}</td><td class="td-muted">{m.email}</td><td class="td-muted">{m.neighborhood||'—'}</td><td><span class={`badge ${m.onboarding_done?'badge-green':'badge-muted'}`}>{m.onboarding_done?'✓ Active':'Pending'}</span></td></tr>)}
        </tbody></table>)}
    </div>

    <div class="card">
      <div class="card-head"><div class="card-title">Upcoming events</div><button class="btn" data-panel="events">View all →</button></div>
      {events.length===0?<div class="empty"><div class="empty-icon">📅</div><p>No events yet.</p></div>:(
        <table><thead><tr><th>Event</th><th>Date</th><th>Location</th><th>Type</th></tr></thead><tbody>
          {events.slice(0,5).map((e:any)=><tr><td class="td-name">{typeEmoji[e.event_type]||'📅'} {e.title}</td><td class="td-muted">{e.event_month&&e.event_day?`${e.event_month} ${e.event_day}`:'TBD'}</td><td class="td-muted">{e.location||'—'}</td><td><span class={`badge ${e.featured?'badge-accent':'badge-muted'}`}>{e.featured?'⭐ Featured':(e.event_type||'event')}</span></td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ MEMBERS ═══ -->
  <div class="panel" id="panel-members">
    <div class="card">
      <div class="card-head"><div class="card-title">All members ({members.length})</div><input class="search-input" id="search-members" placeholder="Search members..." /></div>
      {members.length===0?<div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>:(
        <table id="members-table"><thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Bio</th><th>Status</th><th></th></tr></thead><tbody>
          {members.map((m:any)=><tr data-search={`${m.name} ${m.email} ${m.neighborhood}`}><td class="td-name">{m.name||'—'}</td><td class="td-muted" style="font-size:12px">{m.email}</td><td class="td-muted">{m.neighborhood||'—'}</td><td class="td-muted" style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px">{m.bio||'—'}</td><td><span class={`badge ${m.onboarding_done?'badge-green':'badge-muted'}`}>{m.onboarding_done?'✓ Active':'Pending'}</span></td><td><button class="btn del" data-action="remove-member" data-id={m.id} data-name={m.name||m.email}>Remove</button></td></tr>)}
        </tbody></table>)}
    </div>
  </div>

  <!-- ═══ EVENTS ═══ -->
  <div class="panel" id="panel-events">
    <div class="create-form card" id="create-event-form">
      <div class="card-head"><div class="card-title">Create new event</div><button class="btn" id="cancel-create">✕ Cancel</button></div>
      <div class="form-grid">
        <div class="field span2"><label class="field-label">Title</label><input class="field-input" id="evt-title" placeholder="e.g. Friday Night Bowling" /></div>
        <div class="field"><label class="field-label">Type</label><select class="field-select" id="evt-type"><option value="social">🎉 Social</option><option value="dinner">🍽️ Dinner</option><option value="game_night">🎲 Game Night</option><option value="outdoor">🏔️ Outdoor</option><option value="brewery">🍺 Brewery</option><option value="bowling">🎳 Bowling</option><option value="arts">🎨 Arts</option><option value="music">🎵 Music</option><option value="sports">⚾ Sports</option><option value="coffee">☕ Coffee</option><option value="casino">🎰 Casino</option><option value="other">📅 Other</option></select></div>
        <div class="field"><label class="field-label">Location</label><input class="field-input" id="evt-location" placeholder="e.g. Elitch Lanes" /></div>
        <div class="field"><label class="field-label">Zone</label><input class="field-input" id="evt-zone" placeholder="e.g. LoHi" /></div>
        <div class="field"><label class="field-label">Month</label><input class="field-input" id="evt-month" placeholder="e.g. May" /></div>
        <div class="field"><label class="field-label">Day</label><input class="field-input" id="evt-day" placeholder="e.g. 17th" /></div>
        <div class="field"><label class="field-label">Spots</label><input class="field-input" id="evt-spots" type="number" value="10" min="1" /></div>
        <div class="field"><label class="field-label">Price Cap</label><input class="field-input" id="evt-price" placeholder="e.g. $25" /></div>
        <div class="field span2"><label class="field-label">Description</label><textarea class="field-input" id="evt-desc" rows="3" placeholder="What's the plan?" style="resize:vertical"></textarea></div>
        <div class="span2" style="display:flex;align-items:center;gap:16px"><label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-secondary);cursor:pointer"><input type="checkbox" id="evt-featured" /> ⭐ Featured</label><button class="btn-primary" style="margin-left:auto" id="submit-event">Create Event</button></div>
      </div>
    </div>
    <div class="card">
      <div class="card-head"><div class="card-title">All events ({events.length})</div><div style="display:flex;gap:8px;align-items:center"><input class="search-input" id="search-events" placeholder="Search events..." /><button class="btn-primary" id="toggle-create">+ Add Event</button></div></div>
      {events.length===0?<div class="empty"><div class="empty-icon">📅</div><p>No events yet.</p></div>:(
        <table id="events-table"><thead><tr><th>Title</th><th>Date</th><th>Location</th><th>Spots</th><th>Status</th><th></th></tr></thead><tbody>
