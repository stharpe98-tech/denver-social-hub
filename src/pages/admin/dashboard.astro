---
import AdminBase from '../../layouts/AdminBase.astro';
import { getDB } from '../../lib/db';

const cookie = Astro.request.headers.get('cookie') || '';
const userMatch = cookie.match(/dsn_user=([^;]+)/);
let isAdmin = false;
if (userMatch) {
  try { const u = JSON.parse(decodeURIComponent(userMatch[1])); isAdmin = u.email === 'stharpe98@gmail.com'; } catch {}
}
if (!isAdmin) return Astro.redirect('/admin');

const db = getDB();
let members: any[] = [], events: any[] = [], suggestions: any[] = [];
if (db) {
  try {
    members = (await db.prepare(`SELECT * FROM members ORDER BY id DESC`).all())?.results || [];
    events = (await db.prepare(`SELECT * FROM events ORDER BY id DESC`).all())?.results || [];
    suggestions = (await db.prepare(`SELECT * FROM suggestions ORDER BY votes DESC LIMIT 20`).all())?.results || [];
  } catch {}
}
const onboarded = members.filter((m: any) => m.onboarding_done).length;
const typeEmoji: Record<string, string> = {
  dinner:'🍽️', game_night:'🎲', outdoor:'🏔️', brewery:'🍺', bowling:'🎳',
  arts:'🎨', music:'🎵', social:'🎉', group_tickets:'🎫', sports:'⚾',
  coffee:'☕', casino:'🎰', active:'🧗', food_trucks:'🚚', other:'📅'
};
---
<AdminBase title="Dashboard — Denver Social">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=JetBrains+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600;700&display=swap');

  :root {
    --bg:#06080e; --s1:rgba(255,255,255,.028); --s2:rgba(255,255,255,.045);
    --glass:rgba(255,255,255,.035); --glass-border:rgba(255,255,255,.07);
    --text:#eaecf2; --dim:#8892a4; --faint:#4b5263;
    --accent:#e8943a; --accent-dim:rgba(232,148,58,.1); --accent-glow:rgba(232,148,58,.25);
    --green:#4ade80; --red:#fb7185; --blue:#60a5fa;
    --sw:260px; --radius:16px; --radius-sm:10px;
    --font-display:'Playfair Display',Georgia,serif;
    --font-body:'DM Sans',system-ui,sans-serif;
    --font-mono:'JetBrains Mono',monospace;
  }

  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
  body {
    background:var(--bg) !important; color:var(--text); font-family:var(--font-body);
    overflow:auto !important; height:auto !important; display:block !important;
    -webkit-font-smoothing:antialiased;
  }
  /* Noise grain overlay */
  body::after {
    content:''; position:fixed; inset:0; z-index:9999; pointer-events:none; opacity:.035;
    background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* ═══ LAYOUT ═══ */
  .shell { display:flex; min-height:100vh; }
  .main { margin-left:var(--sw); flex:1; min-width:0; }

  /* ═══ SIDEBAR ═══ */
  .sidebar {
    width:var(--sw); position:fixed; top:0; left:0; bottom:0; z-index:100;
    background:linear-gradient(180deg, #0a0c14 0%, #080a11 100%);
    border-right:1px solid var(--glass-border);
    display:flex; flex-direction:column; transition:transform .3s cubic-bezier(.4,0,.2,1);
  }
  .sb-top { padding:28px 24px 24px; }
  .sb-brand { display:flex; align-items:center; gap:14px; text-decoration:none; }
  .sb-icon {
    width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center;
    font-size:18px; background:linear-gradient(135deg, var(--accent), #d4782a);
    box-shadow:0 4px 20px var(--accent-glow);
  }
  .sb-name { font-family:var(--font-display); font-size:18px; font-weight:900; color:var(--text); letter-spacing:-.02em; }
  .sb-name small { display:block; font-family:var(--font-mono); font-size:9px; font-weight:400; color:var(--accent); letter-spacing:.15em; text-transform:uppercase; margin-top:2px; }

  .sb-divider { height:1px; background:var(--glass-border); margin:0 20px; }

  .sb-nav { flex:1; padding:20px 12px; overflow-y:auto; display:flex; flex-direction:column; gap:1px; }
  .sb-section { font-family:var(--font-mono); font-size:9px; font-weight:500; letter-spacing:.2em; text-transform:uppercase; color:var(--faint); padding:20px 14px 8px; }
  .sb-link {
    display:flex; align-items:center; gap:12px; padding:11px 16px; border-radius:var(--radius-sm);
    color:var(--dim); font-size:13px; font-weight:500; cursor:pointer;
    border:none; background:none; width:100%; text-align:left; font-family:var(--font-body);
    transition:all .2s ease; position:relative;
  }
  .sb-link:hover { background:var(--s1); color:var(--text); }
  .sb-link.active { background:var(--accent-dim); color:var(--accent); }
  .sb-link.active::before {
    content:''; position:absolute; left:0; top:8px; bottom:8px; width:3px;
    background:var(--accent); border-radius:0 3px 3px 0;
  }
  .sb-link-icon { font-size:16px; width:22px; text-align:center; flex-shrink:0; }
  .sb-badge { margin-left:auto; font-family:var(--font-mono); background:var(--s2); color:var(--faint); font-size:10px; font-weight:500; padding:2px 8px; border-radius:50px; }
  .sb-link.active .sb-badge { background:var(--accent-dim); color:var(--accent); }

  .sb-bottom { padding:16px 12px; border-top:1px solid var(--glass-border); }
  .sb-user { display:flex; align-items:center; gap:12px; padding:10px 14px; border-radius:var(--radius-sm); }
  .sb-avatar {
    width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-weight:700; font-size:14px; color:#fff;
    background:linear-gradient(135deg, var(--accent), #d4782a);
  }
  .sb-user-name { font-size:13px; font-weight:600; }
  .sb-user-role { font-family:var(--font-mono); font-size:10px; color:var(--faint); letter-spacing:.05em; }

  /* ═══ TOPBAR ═══ */
  .topbar {
    height:64px; border-bottom:1px solid var(--glass-border);
    background:rgba(6,8,14,.8); backdrop-filter:blur(24px) saturate(1.4);
    display:flex; align-items:center; justify-content:space-between;
    padding:0 32px; position:sticky; top:0; z-index:50;
  }
  .topbar-left { display:flex; align-items:center; gap:16px; }
  .hamburger { display:none; background:none; border:none; color:var(--text); font-size:22px; cursor:pointer; }
  .topbar-title { font-family:var(--font-display); font-size:24px; font-weight:900; letter-spacing:-.02em; }
  .topbar-right { display:flex; align-items:center; gap:10px; }
  .topbar-btn {
    background:var(--glass); border:1px solid var(--glass-border); border-radius:var(--radius-sm);
    padding:8px 18px; font-size:12px; font-weight:500; color:var(--dim); cursor:pointer;
    font-family:var(--font-body); transition:all .2s; text-decoration:none;
    backdrop-filter:blur(8px);
  }
  .topbar-btn:hover { border-color:rgba(255,255,255,.14); color:var(--text); background:var(--s2); }
  .topbar-btn.danger:hover { border-color:var(--red); color:var(--red); }

  /* ═══ CONTENT ═══ */
  .content { padding:32px; }
  .panel { display:none; }
  .panel.active { display:block; }
  .panel.active > * { animation:rise .4s cubic-bezier(.16,1,.3,1) both; }
  .panel.active > *:nth-child(2) { animation-delay:.06s; }
  .panel.active > *:nth-child(3) { animation-delay:.12s; }
  .panel.active > *:nth-child(4) { animation-delay:.18s; }
  @keyframes rise { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

  /* ═══ STAT CARDS ═══ */
  .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:18px; margin-bottom:32px; }
  .stat-card {
    background:var(--glass); border:1px solid var(--glass-border); border-radius:var(--radius);
    padding:24px 26px; backdrop-filter:blur(12px); position:relative; overflow:hidden;
  }
  .stat-card::before {
    content:''; position:absolute; top:-40px; right:-40px; width:100px; height:100px;
    background:radial-gradient(circle, var(--accent-glow), transparent 70%); opacity:.3;
  }
  .stat-card-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; position:relative; }
  .stat-icon { font-size:24px; }
  .stat-trend { font-family:var(--font-mono); font-size:11px; color:var(--green); font-weight:500; }
  .stat-num { font-family:var(--font-display); font-size:40px; font-weight:900; line-height:1; margin-bottom:6px; letter-spacing:-.02em; position:relative; }
  .stat-lbl { font-size:12px; color:var(--dim); font-weight:500; letter-spacing:.02em; position:relative; }

  /* ═══ TABLE CARDS ═══ */
  .table-card {
    background:var(--glass); border:1px solid var(--glass-border); border-radius:var(--radius);
    overflow:hidden; margin-bottom:24px; backdrop-filter:blur(12px);
  }
  .table-head {
    padding:20px 26px; border-bottom:1px solid var(--glass-border);
    display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap;
  }
  .table-title { font-family:var(--font-display); font-size:17px; font-weight:700; letter-spacing:-.01em; }
  .table-search {
    background:rgba(255,255,255,.04); border:1px solid var(--glass-border); border-radius:var(--radius-sm);
    padding:9px 16px; font-size:13px; color:var(--text); font-family:var(--font-body);
    outline:none; width:200px; transition:all .2s;
  }
  .table-search:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
  .table-search::placeholder { color:var(--faint); }

  table { width:100%; border-collapse:collapse; }
  th {
    padding:12px 24px; text-align:left; font-family:var(--font-mono); font-size:10px;
    letter-spacing:.15em; text-transform:uppercase; color:var(--faint); font-weight:500;
    background:rgba(255,255,255,.015); border-bottom:1px solid var(--glass-border);
  }
  td { padding:15px 24px; font-size:13px; border-bottom:1px solid rgba(255,255,255,.03); }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:rgba(255,255,255,.015); }
  .td-name { font-weight:600; color:var(--text); }
  .td-muted { color:var(--dim); }

  /* Badges */
  .badge { display:inline-flex; align-items:center; font-family:var(--font-mono); font-size:10px; font-weight:500; padding:4px 10px; border-radius:50px; letter-spacing:.02em; }
  .badge-green { background:rgba(74,222,128,.08); color:var(--green); }
  .badge-muted { background:rgba(255,255,255,.04); color:var(--faint); }
  .badge-accent { background:var(--accent-dim); color:var(--accent); }
  .badge-blue { background:rgba(96,165,250,.08); color:var(--blue); }

  /* Action buttons */
  .action-btn {
    background:none; border:1px solid var(--glass-border); border-radius:8px;
    padding:6px 13px; font-size:11px; font-weight:600; cursor:pointer;
    font-family:var(--font-body); color:var(--dim); transition:all .2s;
  }
  .action-btn:hover { border-color:var(--accent); color:var(--accent); transform:translateY(-1px); }
  .action-btn.del:hover { border-color:var(--red); color:var(--red); }

  /* ═══ SETTINGS ═══ */
  .settings-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
  .settings-card { background:var(--glass); border:1px solid var(--glass-border); border-radius:var(--radius); padding:28px; backdrop-filter:blur(12px); }
  .settings-card-title { font-family:var(--font-display); font-size:17px; font-weight:700; margin-bottom:4px; letter-spacing:-.01em; }
  .settings-card-sub { font-size:13px; color:var(--dim); margin-bottom:22px; line-height:1.6; }
  .settings-field { margin-bottom:18px; }
  .settings-label { display:block; font-family:var(--font-mono); font-size:9px; font-weight:500; letter-spacing:.15em; text-transform:uppercase; color:var(--faint); margin-bottom:8px; }
  .settings-input {
    width:100%; background:rgba(255,255,255,.03); border:1px solid var(--glass-border);
    border-radius:var(--radius-sm); padding:12px 16px; font-size:13px; color:var(--text);
    font-family:var(--font-body); outline:none; transition:all .2s;
  }
  .settings-input:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
  .settings-input::placeholder { color:var(--faint); }
  .settings-select { width:100%; background:rgba(255,255,255,.03); border:1px solid var(--glass-border); border-radius:var(--radius-sm); padding:12px 16px; font-size:13px; color:var(--text); font-family:var(--font-body); outline:none; cursor:pointer; }
  .settings-toggle { display:flex; align-items:center; justify-content:space-between; padding:15px 0; border-bottom:1px solid rgba(255,255,255,.04); }
  .settings-toggle:last-of-type { border-bottom:none; padding-bottom:0; }
  .settings-toggle-label { font-size:13px; font-weight:600; margin-bottom:3px; }
  .settings-toggle-desc { font-size:12px; color:var(--faint); }
  .toggle-switch { position:relative; width:44px; height:24px; flex-shrink:0; }
  .toggle-switch input { opacity:0; width:0; height:0; }
  .toggle-track {
    position:absolute; inset:0; background:var(--s2); border-radius:50px; cursor:pointer;
    transition:all .25s cubic-bezier(.4,0,.2,1); border:1px solid var(--glass-border);
  }
  .toggle-track::after {
    content:''; position:absolute; width:18px; height:18px; background:#fff;
    border-radius:50%; top:2px; left:2px; transition:all .25s cubic-bezier(.4,0,.2,1);
    box-shadow:0 1px 4px rgba(0,0,0,.3);
  }
  input:checked + .toggle-track { background:var(--accent); border-color:var(--accent); }
  input:checked + .toggle-track::after { transform:translateX(20px); }

  .save-btn {
    background:linear-gradient(135deg, var(--accent), #d4782a); color:#fff; border:none;
    border-radius:50px; padding:12px 28px; font-size:13px; font-weight:700; cursor:pointer;
    font-family:var(--font-body); transition:all .2s; margin-top:18px;
    box-shadow:0 4px 16px var(--accent-glow);
  }
  .save-btn:hover { transform:translateY(-1px); box-shadow:0 6px 24px var(--accent-glow); }
  .add-btn {
    background:linear-gradient(135deg, var(--accent), #d4782a); color:#fff; border:none;
    font-size:12px; font-weight:700; padding:9px 20px; border-radius:var(--radius-sm);
    cursor:pointer; font-family:var(--font-body); transition:all .2s;
    box-shadow:0 2px 12px var(--accent-glow);
  }
  .add-btn:hover { transform:translateY(-1px); }

  /* ═══ CREATE FORM ═══ */
  .create-form {
    background:var(--glass); border:1px solid var(--glass-border); border-radius:var(--radius);
    overflow:hidden; margin-bottom:24px; display:none; backdrop-filter:blur(12px);
  }
  .create-form.open { display:block; animation:rise .3s cubic-bezier(.16,1,.3,1); }
  .create-form-body { padding:24px; display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .span2 { grid-column:span 2; }

  /* ═══ EMPTY / TOAST ═══ */
  .empty { padding:56px; text-align:center; color:var(--faint); }
  .empty-icon { font-size:44px; margin-bottom:16px; opacity:.6; }
  .toast {
    position:fixed; bottom:32px; left:50%; transform:translateX(-50%) translateY(24px);
    background:rgba(12,14,22,.95); border:1px solid var(--glass-border); border-radius:var(--radius);
    padding:14px 28px; font-size:13px; font-weight:500; color:var(--text); z-index:9998;
    opacity:0; transition:all .35s cubic-bezier(.16,1,.3,1); pointer-events:none;
    backdrop-filter:blur(20px); box-shadow:0 8px 40px rgba(0,0,0,.5);
  }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
  .toast.error { border-color:var(--red); }

  .sb-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.65); z-index:99; backdrop-filter:blur(4px); }

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:900px) {
    .sidebar { transform:translateX(-100%); }
    .sidebar.open { transform:translateX(0); }
    .main { margin-left:0; }
    .hamburger { display:block; }
    .stats-row { grid-template-columns:1fr 1fr; }
    .settings-grid { grid-template-columns:1fr; }
    .content { padding:20px; }
    .create-form-body { grid-template-columns:1fr; }
    .span2 { grid-column:span 1; }
  }
  @media(max-width:480px) { .stats-row { grid-template-columns:1fr; } th,td { padding:10px 16px; } }
</style>

<div class="shell">
  <aside class="sidebar" id="sidebar">
    <div class="sb-top"><a href="/" class="sb-brand"><div class="sb-icon">🌆</div><div class="sb-name">Denver Social<small>admin panel</small></div></a></div>
    <div class="sb-divider"></div>
    <nav class="sb-nav">
      <div class="sb-section">Overview</div>
      <button class="sb-link active" data-panel="overview"><span class="sb-link-icon">📊</span> Dashboard</button>
      <div class="sb-section">Manage</div>
      <button class="sb-link" data-panel="members"><span class="sb-link-icon">👥</span> Members <span class="sb-badge">{members.length}</span></button>
      <button class="sb-link" data-panel="events"><span class="sb-link-icon">📅</span> Events <span class="sb-badge">{events.length}</span></button>
      <button class="sb-link" data-panel="suggestions"><span class="sb-link-icon">💡</span> Suggestions</button>
      <div class="sb-section">Config</div>
      <button class="sb-link" data-panel="settings"><span class="sb-link-icon">⚙️</span> Settings</button>
      <button class="sb-link" data-panel="content"><span class="sb-link-icon">✏️</span> Site Content</button>
    </nav>
    <div class="sb-bottom"><div class="sb-user"><div class="sb-avatar">S</div><div><div class="sb-user-name">Seth</div><div class="sb-user-role">administrator</div></div></div></div>
  </aside>
  <div class="sb-overlay" id="sbOverlay"></div>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left"><button class="hamburger" id="hamburger">☰</button><div class="topbar-title" id="topbarTitle">Dashboard</div></div>
      <div class="topbar-right"><a href="/" class="topbar-btn" target="_blank">← View Site</a><a href="/api/logout" class="topbar-btn danger">Log Out</a></div>
    </div>
    <div class="content">

      <!-- ═══ OVERVIEW ═══ -->
      <div class="panel active" id="panel-overview">
        <div class="stats-row">
          <div class="stat-card"><div class="stat-card-top"><span class="stat-icon">👥</span><span class="stat-trend">↑ growing</span></div><div class="stat-num">{members.length}</div><div class="stat-lbl">Total Members</div></div>
          <div class="stat-card"><div class="stat-card-top"><span class="stat-icon">✅</span><span class="stat-trend">{members.length > 0 ? Math.round(onboarded / members.length * 100) : 0}%</span></div><div class="stat-num">{onboarded}</div><div class="stat-lbl">Onboarded</div></div>
          <div class="stat-card"><div class="stat-card-top"><span class="stat-icon">📅</span><span class="stat-trend">active</span></div><div class="stat-num">{events.length}</div><div class="stat-lbl">Total Events</div></div>
          <div class="stat-card"><div class="stat-card-top"><span class="stat-icon">💡</span><span class="stat-trend">from crew</span></div><div class="stat-num">{suggestions.length}</div><div class="stat-lbl">Suggestions</div></div>
        </div>
        <div class="table-card">
          <div class="table-head"><div class="table-title">Recent Members</div><button class="action-btn" data-panel="members">View all →</button></div>
          {members.length===0?<div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>:(
            <table><thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Status</th></tr></thead><tbody>
              {members.slice(0,5).map((m:any)=><tr><td class="td-name">{m.name||'—'}</td><td class="td-muted">{m.email}</td><td class="td-muted">{m.neighborhood||'—'}</td><td><span class={`badge ${m.onboarding_done?'badge-green':'badge-muted'}`}>{m.onboarding_done?'✓ Active':'Pending'}</span></td></tr>)}
            </tbody></table>)}
        </div>
        <div class="table-card">
          <div class="table-head"><div class="table-title">Upcoming Events</div><button class="action-btn" data-panel="events">View all →</button></div>
          {events.length===0?<div class="empty"><div class="empty-icon">📅</div><p>No events yet.</p></div>:(
            <table><thead><tr><th>Event</th><th>Date</th><th>Location</th><th>Type</th></tr></thead><tbody>
              {events.slice(0,5).map((e:any)=><tr><td class="td-name">{typeEmoji[e.event_type]||'📅'} {e.title}</td><td class="td-muted">{e.event_month&&e.event_day?`${e.event_month} ${e.event_day}`:'TBD'}</td><td class="td-muted">{e.location||'—'}</td><td><span class={`badge ${e.featured?'badge-accent':'badge-muted'}`}>{e.featured?'⭐ Featured':(e.event_type||'event')}</span></td></tr>)}
            </tbody></table>)}
        </div>
      </div>

      <!-- ═══ MEMBERS ═══ -->
      <div class="panel" id="panel-members">
        <div class="table-card">
          <div class="table-head"><div class="table-title">All Members ({members.length})</div><input class="table-search" id="search-members" placeholder="Search members..." /></div>
          {members.length===0?<div class="empty"><div class="empty-icon">👥</div><p>No members yet.</p></div>:(
            <table id="members-table"><thead><tr><th>Name</th><th>Email</th><th>Neighborhood</th><th>Bio</th><th>Status</th><th></th></tr></thead><tbody>
