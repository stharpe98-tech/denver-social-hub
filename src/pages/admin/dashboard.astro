              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- EVENT MODAL -->
<div class="modal-backdrop" id="eventModal">
  <div class="modal">
    <div class="modal-head">
      <span class="modal-title" id="eventModalTitle">Add Event</span>
      <button class="modal-close" onclick="closeEventModal()">✕</button>
    </div>
    <div class="form-grid">
      <input type="hidden" id="eId"/>
      <div class="field span2"><label>Title</label><input type="text" id="eTitle" placeholder="e.g. Westminster Dinner Meetup"/></div>
      <div class="field"><label>Type</label>
        <select id="eType">
          <option value="dinner">🍽️ Dinner</option>
          <option value="game_night">🎲 Game Night</option>
          <option value="outdoor">🏔️ Outdoor</option>
          <option value="bowling">🎳 Bowling</option>
          <option value="arts">🎨 Arts</option>
          <option value="brewery">🍺 Brewery</option>
          <option value="coffee">☕ Coffee</option>
          <option value="music">🎵 Music</option>
          <option value="social">🎉 Social</option>
          <option value="group_tickets">🎫 Group Tickets</option>
          <option value="other">📅 Other</option>
        </select>
      </div>
      <div class="field"><label>Spots</label><input type="number" id="eSpots" placeholder="10" min="1"/></div>
      <div class="field"><label>Month</label><input type="text" id="eMonth" placeholder="APR"/></div>
      <div class="field"><label>Day</label><input type="text" id="eDay" placeholder="27"/></div>
      <div class="field span2"><label>Location</label><input type="text" id="eLocation" placeholder="venue name, neighborhood"/></div>
      <div class="field"><label>Zone / Neighborhood</label><input type="text" id="eZone" placeholder="RiNo, South, etc."/></div>
      <div class="field"><label>Price Cap</label><input type="text" id="ePriceCap" placeholder="$30/person cap or Free"/></div>
      <div class="field span2"><label>Description</label><textarea id="eDesc" placeholder="Short description..."></textarea></div>
      <div class="field span2">
        <div class="toggle-wrap">
          <label class="toggle"><input type="checkbox" id="eFeatured"><span class="toggle-slider"></span></label>
          <span style="font-size:13px;color:var(--text)">Featured event (shown at top)</span>
        </div>
      </div>
    </div>
    <div class="form-footer">
      <button class="btn btn-ghost" onclick="closeEventModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveEvent()">Save Event</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // ── SIDEBAR ──
  function openSidebar() {
    document.getElementById('sidebar')!.classList.add('open');
    document.getElementById('mobOverlay')!.classList.add('open');
  }
  function closeSidebar() {
    document.getElementById('sidebar')!.classList.remove('open');
    document.getElementById('mobOverlay')!.classList.remove('open');
  }

  // ── TABS ──
  const tabTitles: Record<string,string> = { overview:'Overview', events:'Events', members:'Members', settings:'Settings' };
  function switchTab(name: string, btn: HTMLElement) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
    document.getElementById(`tab-${name}`)!.classList.add('active');
    btn.classList.add('active');
    (document.getElementById('topbarTitle') as HTMLElement).textContent = tabTitles[name] || name;
    closeSidebar();
  }

  // ── SETTINGS TABS ──
  function switchSettings(name: string, el: HTMLElement) {
    document.querySelectorAll('.settings-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.settings-nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById(`settings-${name}`)!.classList.add('active');
    el.classList.add('active');
  }

  // ── EVENT MODAL ──
  function openEventModal() {
    (document.getElementById('eventModalTitle') as HTMLElement).textContent = 'Add Event';
    (document.getElementById('eId') as HTMLInputElement).value = '';
    ['eTitle','eSpots','eMonth','eDay','eLocation','eZone','ePriceCap','eDesc'].forEach(id => {
      (document.getElementById(id) as HTMLInputElement).value = '';
    });
    (document.getElementById('eType') as HTMLSelectElement).value = 'social';
    (document.getElementById('eFeatured') as HTMLInputElement).checked = false;
    document.getElementById('eventModal')!.classList.add('open');
  }
  function closeEventModal() { document.getElementById('eventModal')!.classList.remove('open'); }
  function editEvent(e: any) {
    (document.getElementById('eventModalTitle') as HTMLElement).textContent = 'Edit Event';
    (document.getElementById('eId') as HTMLInputElement).value = e.id;
    (document.getElementById('eTitle') as HTMLInputElement).value = e.title || '';
    (document.getElementById('eType') as HTMLSelectElement).value = e.event_type || 'social';
    (document.getElementById('eSpots') as HTMLInputElement).value = e.spots || '';
    (document.getElementById('eMonth') as HTMLInputElement).value = e.event_month || '';
    (document.getElementById('eDay') as HTMLInputElement).value = e.event_day || '';
    (document.getElementById('eLocation') as HTMLInputElement).value = e.location || '';
    (document.getElementById('eZone') as HTMLInputElement).value = e.zone || '';
    (document.getElementById('ePriceCap') as HTMLInputElement).value = e.price_cap || '';
    (document.getElementById('eDesc') as HTMLTextAreaElement).value = e.description || '';
    (document.getElementById('eFeatured') as HTMLInputElement).checked = !!e.featured;
    document.getElementById('eventModal')!.classList.add('open');
  }
  async function saveEvent() {
    const id = (document.getElementById('eId') as HTMLInputElement).value;
    const body = {
      action: id ? 'update' : 'create', id: id ? parseInt(id) : undefined,
      title: (document.getElementById('eTitle') as HTMLInputElement).value.trim(),
      event_type: (document.getElementById('eType') as HTMLSelectElement).value,
      spots: (document.getElementById('eSpots') as HTMLInputElement).value,
      event_month: (document.getElementById('eMonth') as HTMLInputElement).value.trim(),
      event_day: (document.getElementById('eDay') as HTMLInputElement).value.trim(),
      location: (document.getElementById('eLocation') as HTMLInputElement).value.trim(),
      zone: (document.getElementById('eZone') as HTMLInputElement).value.trim(),
      price_cap: (document.getElementById('ePriceCap') as HTMLInputElement).value.trim(),
      description: (document.getElementById('eDesc') as HTMLTextAreaElement).value.trim(),
      featured: (document.getElementById('eFeatured') as HTMLInputElement).checked,
    };
    if (!body.title) { showToast('Title is required','error'); return; }
    try {
      const res = await fetch('/api/admin/event', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json() as any;
      if (!res.ok) throw new Error(data.error);
      closeEventModal();
      showToast(id ? 'Event updated ✓' : 'Event created ✓', 'success');
      setTimeout(() => location.reload(), 800);
    } catch(e:any) { showToast(e.message || 'Error saving event','error'); }
  }
  async function deleteEvent(id: number, title: string, rowId: string) {
    if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
    try {
      const res = await fetch('/api/admin/event', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ action:'delete', id }) });
      if (!res.ok) throw new Error();
      document.getElementById(rowId)?.remove();
      showToast('Event deleted','success');
    } catch { showToast('Error deleting event','error'); }
  }

  // ── MEMBERS ──
  function filterMembers(q: string) {
    const rows = document.querySelectorAll<HTMLElement>('#membersBody tr');
    rows.forEach(row => {
      const name = row.dataset.name || '';
      const email = row.dataset.email || '';
      row.style.display = (name.includes(q.toLowerCase()) || email.includes(q.toLowerCase())) ? '' : 'none';
    });
  }
  async function deleteMember(id: number, name: string, rowId: string) {
    if (!confirm(`Remove ${name} from the community? This cannot be undone.`)) return;
    try {
      const res = await fetch('/api/admin/member', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ action:'delete', id }) });
      if (!res.ok) throw new Error();
      document.getElementById(rowId)?.remove();
      showToast(`${name} removed`, 'success');
    } catch { showToast('Error removing member','error'); }
  }

  // ── TOAST ──
  function showToast(msg: string, type = 'success') {
    const t = document.getElementById('toast')!;
    t.textContent = (type === 'success' ? '✓ ' : '✕ ') + msg;
    t.className = `toast ${type} show`;
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeEventModal(); });
</script>
</AdminBase>
