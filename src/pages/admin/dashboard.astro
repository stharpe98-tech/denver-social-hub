        <div class="field"><label class="field-label">Footer tagline</label><input class="field-input" data-setting="footer_tagline" value="Real connections, real city." /></div>
        <div class="field"><label class="field-label">Contact email</label><input class="field-input" data-setting="footer_email" value="hello@denversocial.com" /></div>
        <div class="field"><label class="field-label">Instagram</label><input class="field-input" data-setting="instagram_handle" placeholder="@denversocialhub" /></div>
        <div class="field"><label class="field-label">SEO description</label><textarea class="field-input" data-setting="seo_description" rows="2" style="resize:vertical">Real small-group events across Denver.</textarea></div>
