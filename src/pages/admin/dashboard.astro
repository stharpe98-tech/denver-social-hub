        <div class="toggle-row"><div><div class="toggle-label">Require approval</div><div class="toggle-desc">Manually approve new members</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_require_approval"><span class="toggle-track"></span></label></div>
