          <table><thead><tr><th>Message</th><th>Posted</th><th>Actions</th></tr></thead><tbody>
            {announcements.map((a:any)=><tr><td class="td-name" style="max-width:400px;word-break:break-word">{a.text}</td><td class="td-muted">{a.created_at?.slice(0,10)||'--'}</td><td><button class="btn btn-sm del" data-action="delete-announcement" data-id={a.id}>Delete</button></td></tr>)}
          </tbody></table>)}
      </div>
    </div>

