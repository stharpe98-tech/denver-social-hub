        <div class="field" style="margin-top:14px"><label class="field-label">Max no-shows</label><select class="field-select" data-setting="max_no_shows"><option value="2">2</option><option value="3" selected>3</option><option value="5">5</option><option value="0">Disabled</option></select></div>
        <button class="btn-primary js-save" style="margin-top:12px">Save</button>
      </div>
      <div class="settings-card">
        <div class="settings-title">Event defaults</div><div class="settings-sub">Defaults for new events.</div>
        <div class="toggle-row"><div><div class="toggle-label">Discord RSVP</div><div class="toggle-desc">Require Discord to RSVP</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_discord_rsvp" checked><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">Plus-ones</div><div class="toggle-desc">Allow guests by default</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_plus_ones" checked><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">Deposits</div><div class="toggle-desc">Require deposit for RSVP</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_deposits"><span class="toggle-track"></span></label></div>
        <div class="field" style="margin-top:14px"><label class="field-label">Default group size</label><select class="field-select" data-setting="default_group_size"><option value="8">8</option><option value="10" selected>10</option><option value="12">12</option><option value="15">15</option><option value="20">20</option></select></div>
        <div class="field"><label class="field-label">Default price cap</label><input class="field-input" data-setting="default_price_cap" value="$30/person cap" /></div>
        <button class="btn-primary js-save" style="margin-top:12px">Save</button>
      </div>
      <div class="settings-card">
        <div class="settings-title">Notifications</div><div class="settings-sub">Admin email alerts.</div>
        <div class="toggle-row"><div><div class="toggle-label">New member</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_notif_member" checked><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">New suggestion</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_notif_suggestion"><span class="toggle-track"></span></label></div>
        <div class="toggle-row"><div><div class="toggle-label">RSVP full</div></div><label class="toggle"><input type="checkbox" data-setting="toggle_notif_rsvp" checked><span class="toggle-track"></span></label></div>
