        <div class="field"><label class="field-label">Site description</label><input class="field-input" data-setting="site_description" value="A community for Denver locals." /></div>
        <div class="field"><label class="field-label">Discord link</label><input class="field-input" data-setting="discord_url" value="https://discord.gg/S8SFNkdSgK" /></div>
