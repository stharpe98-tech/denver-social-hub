          <button class="btn del" style="width:100%;padding:10px;font-size:12px" id="clear-pending">Clear Pending Members</button>
          <button class="btn del" style="width:100%;padding:10px;font-size:12px" id="export-csv">Export Members CSV</button>
          <button class="btn del" style="width:100%;padding:10px;font-size:12px" id="clear-past-events">Archive Past Events</button>
