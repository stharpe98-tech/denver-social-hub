<script is:inline>
(function(){var $=function(s){return document.querySelector(s)},$$=function(s){return document.querySelectorAll(s)};function toast(m,e){var el=$('#toast');if(!el)return;el.textContent=m;el.className=e?'toast show error':'toast show';setTimeout(function(){el.className='toast'},3000)}function api(u,b){return fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(function(r){return r.json()}).then(function(d){if(d.error)throw new Error(d.error);return d})}var titles={overview:'Overview',members:'Members',events:'Events',suggestions:'Suggestions',settings:'Settings',content:'Content'};function showPanel(id){$$('.panel').forEach(function(p){p.classList.remove('active')});var t=$('#panel-'+id);if(t)t.classList.add('active');$$('.tab').forEach(function(b){b.classList.remove('active')});$$('.tab[data-panel="'+id+'"]').forEach(function(b){b.classList.add('active')});var mob=$('#mob-tabs');if(mob)mob.classList.remove('open')}$$('[data-panel]').forEach(function(b){b.addEventListener('click',function(){showPanel(this.getAttribute('data-panel'))})});var mobMenu=$('#mob-menu'),mobTabs=$('#mob-tabs');if(mobMenu)mobMenu.addEventListener('click',function(){mobTabs.classList.toggle('open')});function bindSearch(i,t){var inp=$('#'+i);if(!inp)return;inp.addEventListener('input',function(){var q=this.value.toLowerCase();$$('#'+t+' tr[data-search]').forEach(function(r){r.style.display=(r.getAttribute('data-search')||'').toLowerCase().indexOf(q)>=0?'':'none'})})}bindSearch('search-members','members-table');bindSearch('search-events','events-table');document.addEventListener('click',function(e){var btn=e.target.closest('[data-action]');if(!btn)return;var act=btn.getAttribute('data-action'),id=btn.getAttribute('data-id');if(act==='remove-member'){var nm=btn.getAttribute('data-name');if(!confirm('Remove '+nm+'?'))return;btn.disabled=true;btn.textContent='...';api('/api/admin/member',{action:'delete',id:parseInt(id)}).then(function(){toast(nm+' removed.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Remove'})}if(act==='delete-event'){var tt=btn.getAttribute('data-title');if(!confirm('Delete "'+tt+'"?'))return;btn.disabled=true;btn.textContent='...';api('/api/admin/event',{action:'delete',id:parseInt(id)}).then(function(){toast('"'+tt+'" deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Delete'})}if(act==='toggle-feature'){var f=btn.getAttribute('data-featured')==='1';api('/api/admin/event',{action:'feature',id:parseInt(id),featured:!f}).then(function(){toast(f?'Unfeatured':'Featured ⭐');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}if(act==='mark-suggestion'){var st=btn.getAttribute('data-status');api('/api/admin/suggestion',{action:'status',id:parseInt(id),status:st}).then(function(){toast('Marked '+st+' ✓');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}if(act==='delete-suggestion'){if(!confirm('Delete this suggestion?'))return;api('/api/admin/suggestion',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)})}});$('#toggle-create').addEventListener('click',function(){$('#create-event-form').classList.toggle('open')});$('#cancel-create').addEventListener('click',function(){$('#create-event-form').classList.remove('open')});

var typeHints={dinner:{title:'e.g. RiNo Ramen Night',location:'e.g. Uncle Ramen — RiNo',price:'e.g. $20-30/person',desc:'Where are we eating? Any dietary notes?'},brewery:{title:'e.g. Brewery Crawl — Sunnyside',location:'e.g. Sunnyside, Denver',price:'e.g. $15-25/person',desc:'How many stops? Any food trucks nearby?'},outdoor:{title:'e.g. Bear Creek Trail Hike',location:'e.g. Bear Creek Trail, Lakewood',price:'Free',desc:'Distance, terrain, what to bring?'},game_night:{title:'e.g. Game Night — RiNo',location:'e.g. Board game cafe or someone\'s place',price:'Free or $5',desc:'What games? BYOB?'},bowling:{title:'e.g. Cosmic Bowling — Highlands',location:'e.g. Punch Bowl Social',price:'e.g. $15-20',desc:'How many lanes? Shoes included?'},sports:{title:'e.g. Rockies Game — Group Tickets',location:'e.g. Coors Field — LoDo',price:'e.g. $25-40/ticket',desc:'Which game? Tailgate plans?'},music:{title:'e.g. Red Rocks Concert Night',location:'e.g. Red Rocks Amphitheatre',price:'e.g. $30-60/ticket',desc:'Who\'s playing? Carpool plans?'},arts:{title:'e.g. Paint & Sip Night',location:'e.g. Painting with a Twist',price:'e.g. $35/person',desc:'What are we making? Supplies included?'},coffee:{title:'e.g. Sunday Coffee — Crema',location:'e.g. Crema Coffee House — RiNo',price:'Buy your own',desc:'Casual hangout? Anything planned?'},casino:{title:'e.g. Blackhawk Casino Night',location:'e.g. Isle Casino — Blackhawk, CO',price:'e.g. Bring $50-100',desc:'Which casino? Carpool from Denver?'},social:{title:'e.g. Block Party — RiNo',location:'e.g. RiNo Art District',price:'Free',desc:'What\'s the vibe?'},other:{title:'e.g. Potluck at the Park',location:'e.g. Washington Park',price:'Free or varies',desc:'What\'s the plan?'}};

function showTypeFields(type){
  $$('.evt-field').forEach(function(f){
    var forTypes=f.getAttribute('data-for');
    f.classList.toggle('show',forTypes==='all'||forTypes.split(' ').indexOf(type)>=0);
  });
  var h=typeHints[type]||typeHints.other;
  $('#evt-title').placeholder=h.title;$('#evt-location').placeholder=h.location;$('#evt-price').placeholder=h.price;$('#evt-desc').placeholder=h.desc;
  $('#evt-core').style.display='';
  if(type==='outdoor')$('#price-label').textContent='Cost';else $('#price-label').textContent='Price cap';
}

