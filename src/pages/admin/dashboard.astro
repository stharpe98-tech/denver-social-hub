api('/api/admin/event',body).then(function(){toast('Event created! 🎉');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});function gatherAll(){var s={};$$('[data-setting]').forEach(function(el){var k=el.getAttribute('data-setting');s[k]=el.type==='checkbox'?(el.checked?'1':'0'):el.value});return s}function doSave(){api('/api/admin/settings',gatherAll()).then(function(){toast('Settings saved ✓')}).catch(function(err){toast('Failed: '+err.message,true)})}$$('.js-save').forEach(function(b){b.addEventListener('click',doSave)});fetch('/api/admin/settings').then(function(r){return r.json()}).then(function(d){if(d.error)return;$$('[data-setting]').forEach(function(el){var k=el.getAttribute('data-setting');if(d[k]===undefined)return;if(el.type==='checkbox')el.checked=d[k]==='1';else el.value=d[k]})}).catch(function(){});$('#clear-pending').addEventListener('click',function(){if(!confirm('Clear all pending members?'))return;api('/api/admin/member',{action:'clear_pending'}).then(function(){toast('Cleared.');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});$('#export-csv').addEventListener('click',function(){var rows=$$('#members-table tbody tr');if(!rows.length){toast('No members.',true);return}var csv='Name,Email,Neighborhood,Bio,Status\n';rows.forEach(function(row){var cells=row.querySelectorAll('td');var vals=[];for(var i=0;i<5;i++)vals.push('"'+(cells[i]?cells[i].textContent.trim().replace(/"/g,'""'):'')+'"');csv+=vals.join(',')+'\n'});var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='dsn-members-'+new Date().toISOString().slice(0,10)+'.csv';a.click();toast('CSV downloaded ✓')});$('#clear-past-events').addEventListener('click',function(){if(!confirm('Mark all past events as archived? This sets is_past=1 on all events.'))return;api('/api/admin/event',{action:'archive_past'}).then(function(){toast('Past events archived.');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});var themeBtn=$('#theme-toggle');function setTheme(dark){if(dark){document.documentElement.classList.add('dark');themeBtn.textContent='🌙'}else{document.documentElement.classList.remove('dark');themeBtn.textContent='☀️'}try{localStorage.setItem('dsn_admin_theme',dark?'dark':'light')}catch(e){}}var saved=null;try{saved=localStorage.getItem('dsn_admin_theme')}catch(e){}if(saved==='dark')setTheme(true);else setTheme(false);themeBtn.addEventListener('click',function(){var isDark=document.documentElement.classList.contains('dark');setTheme(!isDark)})})();
