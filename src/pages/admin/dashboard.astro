// ============ RESTAURANTS ============
function loadRestaurants(){
  apiGet('restaurants').then(function(data){
    var rests=data.results||data||[];
    window.__restaurants=rests;
    // Populate zone filter
    var zones={};rests.forEach(function(r){if(r.zone)zones[r.zone]=true});
    var sel=$('#restaurant-zone-filter');
    sel.innerHTML='<option value="all">All Zones ('+rests.length+')</option>';
    Object.keys(zones).sort().forEach(function(z){sel.innerHTML+='<option value="'+esc(z)+'">'+esc(z)+'</option>'});
    renderRestaurants(rests);
  }).catch(function(err){$('#restaurants-body').innerHTML='<div class="empty">Failed: '+esc(err.message)+'</div>'});
}
function renderRestaurants(rests){
  if(!rests.length){$('#restaurants-body').innerHTML='<div class="empty"><div class="empty-icon">🍽️</div><p>No restaurants found.</p></div>';return}
  var h='<table><thead><tr><th>Name</th><th>Zone</th><th>Category</th><th>Price</th><th>Rating</th><th>Actions</th></tr></thead><tbody>';
  rests.forEach(function(r){
    h+='<tr data-search="'+esc((r.name||'')+' '+(r.zone||'')+' '+(r.category||''))+'" data-rzone="'+esc(r.zone||'')+'">';
    h+='<td class="td-name">'+esc(r.name||'--')+'</td>';
    h+='<td class="td-muted">'+esc(r.zone||'--')+'</td>';
    h+='<td class="td-muted">'+esc(r.category||'--')+'</td>';
    h+='<td class="td-muted">'+esc(r.price_range||'--')+'</td>';
    h+='<td class="td-muted">'+(r.rating||'--')+'</td>';
    h+='<td class="td-actions"><button class="btn btn-sm" data-action="edit-restaurant" data-id="'+r.id+'">Edit</button><button class="btn btn-sm del" data-action="delete-restaurant" data-id="'+r.id+'">Delete</button></td></tr>';
  });
  h+='</tbody></table>';
  $('#restaurants-body').innerHTML=h;
}
$('#search-restaurants').addEventListener('input',function(){
  var q=this.value.toLowerCase();
  $('#restaurants-body').querySelectorAll('tr[data-search]').forEach(function(r){
    r.style.display=(r.getAttribute('data-search')||'').toLowerCase().indexOf(q)>=0?'':'none';
  });
});
$('#restaurant-zone-filter').addEventListener('change',function(){
  var v=this.value;
  $('#restaurants-body').querySelectorAll('tr[data-rzone]').forEach(function(r){
    if(v==='all')r.style.display='';
    else r.style.display=r.getAttribute('data-rzone')===v?'':'none';
  });
});
$('#add-restaurant-btn').addEventListener('click',function(){
  $('#rest-name').value='';$('#rest-zone').value='';$('#rest-category').value='';$('#rest-price').value='$$';
  $('#rest-address').value='';$('#rest-phone').value='';$('#rest-rating').value='';$('#rest-hours').value='';
  $('#rest-notes').value='';$('#rest-edit-id').value='';
  $('#restaurant-modal-title').textContent='Add Restaurant';
  $('#restaurant-modal').classList.add('open');
});
$('#save-restaurant').addEventListener('click',function(){
  var name=$('#rest-name').value.trim();if(!name){toast('Enter restaurant name.',true);return}
  var editId=$('#rest-edit-id').value;
  var payload={table:'restaurants',action:editId?'update':'create',name:name,zone:$('#rest-zone').value.trim(),category:$('#rest-category').value.trim(),price_range:$('#rest-price').value,address:$('#rest-address').value.trim(),phone:$('#rest-phone').value.trim(),rating:parseFloat($('#rest-rating').value)||null,hours:$('#rest-hours').value.trim(),notes:$('#rest-notes').value.trim()};
  if(editId)payload.id=parseInt(editId);
  apiPost(payload).then(function(){toast(editId?'Updated':'Added');$('#restaurant-modal').classList.remove('open');loadRestaurants()}).catch(function(err){toast('Failed: '+err.message,true)});
});

