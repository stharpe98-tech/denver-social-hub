<div class="toast" id="toast"></div>

<script>
  // Panel navigation
  function showPanel(id: string, btn: HTMLElement | null) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.getElementById(`panel-${id}`)?.classList.add('active');
    document.querySelectorAll('.sb-link').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    const titles: Record<string,string> = {
      overview:'Dashboard', members:'Members', events:'Events',
      suggestions:'Suggestions', settings:'Settings', content:'Site Content'
    };
    const titleEl = document.getElementById('topbarTitle');
    if (titleEl) titleEl.textContent = titles[id] || 'Dashboard';
    closeSidebar();
  }

  // Sidebar mobile
  function toggleSidebar() {
    document.getElementById('sidebar')?.classList.toggle('open');
    const overlay = document.getElementById('sbOverlay');
    if (overlay) overlay.style.display = document.getElementById('sidebar')?.classList.contains('open') ? 'block' : 'none';
  }
  function closeSidebar() {
    document.getElementById('sidebar')?.classList.remove('open');
    const overlay = document.getElementById('sbOverlay');
    if (overlay) overlay.style.display = 'none';
  }

  // Table search filter
  function filterTable(tableId: string, query: string) {
    const q = query.toLowerCase();
    document.querySelectorAll(`#${tableId} tr[data-search]`).forEach((row) => {
      const searchVal = row.getAttribute('data-search')?.toLowerCase() || '';
      (row as HTMLElement).style.display = searchVal.includes(q) ? '' : 'none';
    });
  }

  // Toast
  function toast(msg: string) {
    const el = document.getElementById('toast')!;
    el.textContent = msg; el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 3000);
  }

  // Settings toggles
  function saveSetting(key: string, val: boolean) {
    try { const s = JSON.parse(localStorage.getItem('dsn_admin_settings') || '{}'); s[key] = val; localStorage.setItem('dsn_admin_settings', JSON.stringify(s)); } catch {}
    toast(`${key.replace(/_/g,' ')} ${val ? 'enabled' : 'disabled'}`);
  }

  function saveSettings() {
    toast('Settings saved ✓');
  }

  function loadSettings() {
    try {
      const s = JSON.parse(localStorage.getItem('dsn_admin_settings') || '{}');
      Object.entries(s).forEach(([k, v]) => {
        const el = document.getElementById(`toggle-${k}`) as HTMLInputElement;
        if (el) el.checked = v as boolean;
      });
    } catch {}
  }

  // Member remove
  async function removeMember(id: string, name: string) {
    if (!confirm(`Remove ${name} from the community?`)) return;
    toast(`${name} removed.`);
  }

  // Event delete
  async function deleteEvent(id: string, title: string) {
    if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
    toast(`Event deleted.`);
  }

  // Suggestion actions
  function markSuggestion(id: string, status: string) {
    toast(`Marked as ${status} ✓`);
  }
  function deleteSuggestion(id: string) {
    if (!confirm('Delete this suggestion?')) return;
    toast('Suggestion deleted.');
  }

  // Danger zone
  function confirmAction(msg: string, action: string) {
    if (!confirm(msg)) return;
    if (action === 'exportMembers') {
      toast('Export started — check your email.');
    } else {
      toast('Done.');
    }
  }

  // Init
  loadSettings();
</script>
</AdminBase>
