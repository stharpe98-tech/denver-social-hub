<!-- Member Detail Modal -->
<div class="modal-overlay" id="member-modal">
  <div class="modal">
    <div class="modal-head"><h3 id="modal-member-name">Member</h3><button class="btn" id="close-modal">✕</button></div>
    <div class="modal-body" id="modal-member-body"></div>
    <div class="modal-actions" id="modal-member-actions"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script is:inline define:vars={{ membersJSON }}>
  window.__members = JSON.parse(membersJSON);
</script>

<script is:inline>
(function(){
var $=function(s){return document.querySelector(s)},$$=function(s){return document.querySelectorAll(s)};
function toast(m,e){var el=$('#toast');if(!el)return;el.textContent=m;el.className=e?'toast show error':'toast show';setTimeout(function(){el.className='toast'},3000)}
function api(u,b){return fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(function(r){return r.json()}).then(function(d){if(d.error)throw new Error(d.error);return d})}

// Panels
var titles={overview:'Overview',members:'Members',events:'Events',suggestions:'Suggestions',announcements:'Announcements',spotlights:'Spotlights',settings:'Settings',content:'Content'};
function showPanel(id){$$('.panel').forEach(function(p){p.classList.remove('active')});var t=$('#panel-'+id);if(t)t.classList.add('active');$$('.tab').forEach(function(b){b.classList.remove('active')});$$('.tab[data-panel="'+id+'"]').forEach(function(b){b.classList.add('active')});var mob=$('#mob-tabs');if(mob)mob.classList.remove('open')}
$$('[data-panel]').forEach(function(b){b.addEventListener('click',function(){showPanel(this.getAttribute('data-panel'))})});
$('#mob-menu').addEventListener('click',function(){$('#mob-tabs').classList.toggle('open')});

// Search + Filter
function bindSearch(i,t){var inp=$('#'+i);if(!inp)return;inp.addEventListener('input',function(){var q=this.value.toLowerCase();$$('#'+t+' tr[data-search]').forEach(function(r){r.style.display=(r.getAttribute('data-search')||'').toLowerCase().indexOf(q)>=0?'':'none'})})}
bindSearch('search-members','members-table');bindSearch('search-events','events-table');
var mf=$('#member-filter');if(mf)mf.addEventListener('change',function(){var v=this.value;$$('#members-table tbody tr').forEach(function(r){if(v==='all')r.style.display='';else r.style.display=r.getAttribute('data-status')===v?'':'none'})});

// Actions
document.addEventListener('click',function(e){
  var btn=e.target.closest('[data-action]');if(!btn)return;
  var act=btn.getAttribute('data-action'),id=btn.getAttribute('data-id');
  if(act==='remove-member'){var nm=btn.getAttribute('data-name');if(!confirm('Remove '+nm+'?'))return;btn.disabled=true;btn.textContent='...';api('/api/admin/member',{action:'delete',id:parseInt(id)}).then(function(){toast(nm+' removed.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Remove'})}
  if(act==='approve-member'){api('/api/admin/member',{action:'approve',id:parseInt(id)}).then(function(){toast('Approved ✓');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='suspend-member'){var nm2=btn.getAttribute('data-name');var reason=prompt('Reason for suspending '+nm2+'?','Policy violation');if(!reason)return;api('/api/admin/member',{action:'suspend',id:parseInt(id),reason:reason}).then(function(){toast(nm2+' suspended.');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='unsuspend-member'){api('/api/admin/member',{action:'unsuspend',id:parseInt(id)}).then(function(){toast('Unsuspended ✓');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='delete-event'){var tt=btn.getAttribute('data-title');if(!confirm('Delete "'+tt+'"?'))return;btn.disabled=true;btn.textContent='...';api('/api/admin/event',{action:'delete',id:parseInt(id)}).then(function(){toast('"'+tt+'" deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true);btn.disabled=false;btn.textContent='Delete'})}
  if(act==='toggle-feature'){var f=btn.getAttribute('data-featured')==='1';api('/api/admin/event',{action:'feature',id:parseInt(id),featured:!f}).then(function(){toast(f?'Unfeatured':'Featured ⭐');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='mark-suggestion'){var st=btn.getAttribute('data-status');api('/api/admin/suggestion',{action:'status',id:parseInt(id),status:st}).then(function(){toast('Marked '+st);setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='delete-suggestion'){if(!confirm('Delete?'))return;api('/api/admin/suggestion',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='delete-announcement'){if(!confirm('Delete?'))return;api('/api/admin/announcement',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='delete-spotlight'){if(!confirm('Delete?'))return;api('/api/admin/spotlight',{action:'delete',id:parseInt(id)}).then(function(){toast('Deleted.');var r=btn.closest('tr');if(r)r.remove()}).catch(function(err){toast('Failed: '+err.message,true)})}
  if(act==='view-member'){
    var mem=null;(window.__members||[]).forEach(function(m){if(String(m.id)===String(id))mem=m});
    if(!mem)return;
    $('#modal-member-name').textContent=mem.name||mem.email;
    var rows=[['Email',mem.email],['Neighborhood',mem.neighborhood||'—'],['Bio',mem.bio||'—'],['Role',mem.role||'member'],['Discord',mem.discord_username||'—'],['Age range',mem.age_range||'—'],['Interests',mem.interests||'—'],['Event types',mem.event_types||'—'],['Food prefs',mem.food_prefs||'—'],['Points',mem.points||0],['Events attended',mem.events_attended||0],['No-shows',mem.no_show_count||0],['Joined',mem.joined_at?.slice(0,10)||'—'],['Referral code',mem.referral_code||'—'],['Status',mem.suspended?'Suspended ('+mem.suspended_reason+')':mem.approved?'Active':'Pending approval']];
    var html='';rows.forEach(function(r){html+='<div class="detail-row"><span class="detail-key">'+r[0]+'</span><span class="detail-val">'+r[1]+'</span></div>'});
    $('#modal-member-body').innerHTML=html;
    var acts='<button class="btn btn-sm" onclick="document.getElementById(\'member-modal\').classList.remove(\'open\')">Close</button>';
    if(!mem.approved)acts+='<button class="btn btn-sm" data-action="approve-member" data-id="'+mem.id+'">✓ Approve</button>';
    if(mem.suspended)acts+='<button class="btn btn-sm" data-action="unsuspend-member" data-id="'+mem.id+'">Unsuspend</button>';
    else acts+='<button class="btn btn-sm del" data-action="suspend-member" data-id="'+mem.id+'" data-name="'+(mem.name||mem.email)+'">Suspend</button>';
    $('#modal-member-actions').innerHTML=acts;
    $('#member-modal').classList.add('open');
  }
});

// Close modal
$('#close-modal').addEventListener('click',function(){$('#member-modal').classList.remove('open')});
$('#member-modal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('open')});

// Announcements
$('#post-announcement').addEventListener('click',function(){var t=$('#new-announcement').value.trim();if(!t){toast('Write something.',true);return}api('/api/admin/announcement',{action:'create',text:t}).then(function(){toast('Posted ✓');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})});

// Spotlights
$('#post-spotlight').addEventListener('click',function(){var e=$('#spot-email').value.trim(),w=$('#spot-week').value.trim(),b=$('#spot-blurb').value.trim();if(!e||!w||!b){toast('Fill all fields.',true);return}api('/api/admin/spotlight',{action:'create',member_email:e,week_of:w,blurb:b}).then(function(){toast('Spotlight added ✓');setTimeout(function(){location.reload()},400)}).catch(function(err){toast('Failed: '+err.message,true)})});

// Create event
$('#toggle-create').addEventListener('click',function(){$('#create-event-form').classList.toggle('open')});
$('#cancel-create').addEventListener('click',function(){$('#create-event-form').classList.remove('open')});
var typeHints={dinner:{title:'e.g. RiNo Ramen Night',loc:'e.g. Uncle Ramen',price:'$20-30/person',desc:'Dietary notes?'},brewery:{title:'e.g. Brewery Crawl',loc:'e.g. Sunnyside',price:'$15-25',desc:'How many stops?'},outdoor:{title:'e.g. Bear Creek Hike',loc:'e.g. Bear Creek Trail',price:'Free',desc:'Distance? Terrain?'},game_night:{title:'e.g. Game Night — RiNo',loc:'e.g. Board game cafe',price:'Free/$5',desc:'What games?'},bowling:{title:'e.g. Cosmic Bowling',loc:'e.g. Punch Bowl Social',price:'$15-20',desc:'Lanes?'},sports:{title:'e.g. Rockies Game',loc:'e.g. Coors Field',price:'$25-40/ticket',desc:'Tailgate?'},music:{title:'e.g. Red Rocks Night',loc:'e.g. Red Rocks',price:'$30-60',desc:'Who\'s playing?'},arts:{title:'e.g. Paint & Sip',loc:'e.g. Painting w/ Twist',price:'$35',desc:'Supplies included?'},coffee:{title:'e.g. Sunday Coffee',loc:'e.g. Crema — RiNo',price:'Buy your own',desc:'Casual hangout?'},casino:{title:'e.g. Blackhawk Night',loc:'e.g. Isle Casino',price:'Bring $50-100',desc:'Carpool?'},potluck:{title:'e.g. Summer Potluck',loc:'e.g. Wash Park Pavilion',price:'Free — bring a dish',desc:'Theme?'},social:{title:'e.g. Block Party',loc:'e.g. RiNo Art District',price:'Free',desc:'Vibe?'},other:{title:'e.g. Custom Event',loc:'Location',price:'Varies',desc:'Details?'}};
function showTypeFields(type){$$('.evt-field').forEach(function(f){var ft=f.getAttribute('data-for');f.classList.toggle('show',ft==='all'||ft.split(' ').indexOf(type)>=0)});var h=typeHints[type]||typeHints.other;$('#evt-title').placeholder=h.title;$('#evt-location').placeholder=h.loc;$('#evt-price').placeholder=h.price;$('#evt-desc').placeholder=h.desc;$('#evt-core').style.display=''}
$$('.type-chip').forEach(function(c){c.addEventListener('click',function(){$$('.type-chip').forEach(function(x){x.classList.remove('selected')});this.classList.add('selected');$('#evt-type').value=this.getAttribute('data-type');showTypeFields(this.getAttribute('data-type'))})});
$('#submit-event').addEventListener('click',function(){var t=$('#evt-title').value.trim(),ty=$('#evt-type').value;if(!ty){toast('Pick a type.',true);return}if(!t){toast('Name it.',true);return}var b={action:'create',title:t,event_type:ty,location:$('#evt-location').value.trim(),zone:$('#evt-zone').value.trim(),event_month:$('#evt-month').value,event_day:$('#evt-day').value.trim(),spots:$('#evt-spots').value,price_cap:$('#evt-price').value.trim(),description:$('#evt-desc').value.trim(),featured:$('#evt-featured').checked,plus_one_allowed:$('#evt-plusone')?$('#evt-plusone').value:'1'};
function g(id){var el=$('#'+id);return el&&el.offsetParent?el.value:''}
if(g('evt-difficulty'))b.difficulty=g('evt-difficulty');if(g('evt-pet'))b.pet_friendly=parseInt(g('evt-pet'));if(g('evt-cell'))b.cell_service=g('evt-cell');if(g('evt-packing'))b.packing_list=g('evt-packing');if(g('evt-reservation'))b.reservation_by=g('evt-reservation');if(g('evt-ppp'))b.price_per_person=g('evt-ppp');if(g('evt-payment'))b.payment_link=g('evt-payment');if(g('evt-mingroup'))b.min_group_size=parseInt(g('evt-mingroup'));if(g('evt-deposit')){b.deposit_required=parseInt(g('evt-deposit'));b.deposit_amount=parseFloat(g('evt-depositamt'))||10}if(g('evt-deadline'))b.commit_deadline=g('evt-deadline');if(g('evt-potluck-cats'))b.potluck_categories=g('evt-potluck-cats');if(g('evt-potluck-host'))b.reservation_by=g('evt-potluck-host');if(g('evt-potluck-bring'))b.packing_list=g('evt-potluck-bring');
api('/api/admin/event',b).then(function(){toast('Created! 🎉');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});

// Settings
function gatherAll(){var s={};$$('[data-setting]').forEach(function(el){var k=el.getAttribute('data-setting');s[k]=el.type==='checkbox'?(el.checked?'1':'0'):el.value});return s}
function doSave(){api('/api/admin/settings',gatherAll()).then(function(){toast('Saved ✓')}).catch(function(err){toast('Failed: '+err.message,true)})}
$$('.js-save').forEach(function(b){b.addEventListener('click',doSave)});
fetch('/api/admin/settings').then(function(r){return r.json()}).then(function(d){if(d.error)return;$$('[data-setting]').forEach(function(el){var k=el.getAttribute('data-setting');if(d[k]===undefined)return;if(el.type==='checkbox')el.checked=d[k]==='1';else if(el.tagName==='TEXTAREA')el.textContent=d[k];else el.value=d[k]})}).catch(function(){});

// Danger
$('#clear-pending').addEventListener('click',function(){if(!confirm('Clear pending?'))return;api('/api/admin/member',{action:'clear_pending'}).then(function(){toast('Cleared.');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});
$('#export-csv').addEventListener('click',function(){var rows=$$('#members-table tbody tr');if(!rows.length){toast('No members.',true);return}var csv='Name,Email,Neighborhood,Bio,Status\n';rows.forEach(function(row){var cells=row.querySelectorAll('td');var vals=[];for(var i=0;i<5;i++)vals.push('"'+(cells[i]?cells[i].textContent.trim().replace(/"/g,'""'):'')+'"');csv+=vals.join(',')+'\n'});var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='dsn-members-'+new Date().toISOString().slice(0,10)+'.csv';a.click();toast('CSV downloaded ✓')});
$('#clear-past-events').addEventListener('click',function(){if(!confirm('Archive all events?'))return;api('/api/admin/event',{action:'archive_past'}).then(function(){toast('Archived.');setTimeout(function(){location.reload()},500)}).catch(function(err){toast('Failed: '+err.message,true)})});

// Theme
var themeBtn=$('#theme-toggle');function setTheme(dark){if(dark){document.documentElement.classList.add('dark');themeBtn.textContent='🌙'}else{document.documentElement.classList.remove('dark');themeBtn.textContent='☀️'}try{localStorage.setItem('dsn_admin_theme',dark?'dark':'light')}catch(e){}}var saved=null;try{saved=localStorage.getItem('dsn_admin_theme')}catch(e){}setTheme(saved==='dark');themeBtn.addEventListener('click',function(){setTheme(!document.documentElement.classList.contains('dark'))});
})();
</script>
