---
import { requireApprovedOrg, isSuperAdmin } from '../../lib/admin-auth';
import { getDB } from '../../lib/db';
const gate = await requireApprovedOrg(Astro);
if (gate instanceof Response) return gate;
const org = gate;
const showApprovalUI = isSuperAdmin(org);
const db = getDB();
let pendingOrgs: any[] = [];
let approvedOrgs: any[] = [];
if (showApprovalUI && db) {
  const all = await db.prepare("SELECT id, name, email, approved_for_potlucks FROM organizers ORDER BY id DESC").all();
  const rows = (all.results ?? []) as any[];
  pendingOrgs = rows.filter(r => !r.approved_for_potlucks);
  approvedOrgs = rows.filter(r => !!r.approved_for_potlucks);
}
let events: any[] = [];
let templates: any[] = [];
try {
  if (db) {
    const e = await db.prepare(`SELECT p.*, COUNT(DISTINCT r.id) as signups FROM potlucks p LEFT JOIN potluck_rsvp r ON r.potluck_id=p.id AND r.rsvp='yes' WHERE p.status != 'pending' GROUP BY p.id ORDER BY p.id DESC`).all();
    events = e?.results ?? [];
    const t = await db.prepare(`SELECT * FROM event_templates ORDER BY created_at DESC`).all();
    templates = t?.results ?? [];
  }
} catch(e) {}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Dashboard · {org.name}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{background:#f7f5f2;color:#1c1917;font-family:'DM Sans',sans-serif;min-height:100vh}
    body{padding-bottom:40px}
    .hero{background:#fff;border-bottom:1px solid #e4ddd4;padding:24px 20px}
    .hi{max-width:700px;margin:0 auto;display:flex;justify-content:space-between;align-items:center}
    .hero h1{font-family:'Playfair Display',serif;font-size:22px;color:#1c1917}
    .hero-sub{font-size:13px;color:#a09890;margin-top:2px}
    .page{max-width:700px;margin:0 auto;padding:24px 16px}
    .nav-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:28px}
    @media(min-width:500px){.nav-grid{grid-template-columns:repeat(4,1fr)}}
    .nav-card{background:#fff;border:1px solid #e4ddd4;border-radius:14px;padding:16px;text-align:center;text-decoration:none;transition:border-color 0.15s;-webkit-tap-highlight-color:transparent}
    .nav-card:active{border-color:#f77f00}
    .nav-icon{font-size:28px;display:block;margin-bottom:6px}
    .nav-label{font-size:13px;font-weight:600;color:#57524c}
    .sec-label{font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#a09890;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid #e4ddd4}
    .event-card{background:#fff;border:1px solid #e4ddd4;border-radius:12px;padding:14px 16px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;text-decoration:none;gap:12px;-webkit-tap-highlight-color:transparent}
    .event-card:active{border-color:#f77f00}
    .event-title{font-size:15px;font-weight:500;color:#1c1917}
    .event-meta{font-size:12px;color:#a09890;margin-top:2px}
    .event-stats{font-size:12px;color:#c2410c;font-weight:600;flex-shrink:0}
    .tmpl-card{background:#fff;border:1px solid #e4ddd4;border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center}
    .tmpl-name{font-size:14px;font-weight:500;color:#1c1917}
    .tmpl-meta{font-size:12px;color:#a09890}
    .tmpl-actions{display:flex;gap:8px}
    .use-btn{padding:6px 14px;border-radius:8px;border:none;background:linear-gradient(135deg,#c2410c,#f77f00);color:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif}
    .del-btn{padding:6px 12px;border-radius:8px;border:1px solid #e4ddd4;background:transparent;color:#a09890;font-size:13px;cursor:pointer}
    .logout-btn{font-size:13px;color:#a09890;background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}
    .empty{text-align:center;padding:24px;color:#a09890;font-style:italic;font-size:13px}
    .plan-badge{padding:3px 10px;border-radius:100px;font-size:11px;font-weight:700;background:linear-gradient(135deg,#c2410c,#f77f00);color:#fff}
    .profile-section{background:#fff;border:1px solid #e4ddd4;border-radius:14px;padding:18px;margin-bottom:24px}
    .pf-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
    @media(max-width:420px){.pf-row{grid-template-columns:1fr}}
    .pf-field label{display:block;font-size:11px;color:#a09890;margin-bottom:5px;font-weight:600;text-transform:uppercase;letter-spacing:0.3px}
    .pf-input{width:100%;padding:10px 12px;background:#f7f5f2;border:1.5px solid #e4ddd4;border-radius:8px;color:#1c1917;font-family:'DM Sans',sans-serif;font-size:13px;outline:none}
    .pf-input:focus{border-color:#f77f00}
    .save-btn{padding:10px 20px;border-radius:9px;border:none;background:linear-gradient(135deg,#c2410c,#f77f00);color:#fff;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer}
    .embed-section{background:#1c1917;border-radius:14px;padding:16px 18px;margin-top:10px}
    .embed-code{font-family:'JetBrains Mono',monospace;font-size:11px;color:#86efac;word-break:break-all;line-height:1.6}
    .copy-embed{margin-top:10px;padding:8px 16px;border-radius:8px;border:1px solid #3d3d3d;background:transparent;color:#a09890;font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif}
    .toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:#0d2e1a;border:1px solid #166534;color:#4ade80;padding:10px 20px;border-radius:8px;font-size:13px;display:none;z-index:999}
  </style>
</head>
<body>
  <div class="hero">
    <div class="hi">
      <div>
        <h1>👋 Welcome, {org.name}</h1>
        <div class="hero-sub">{org.email}</div>
      </div>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="plan-badge">{org.plan}</span>
        <button class="logout-btn" id="logout-btn">Sign out</button>
      </div>
    </div>
  </div>

  <div class="page">
    <!-- Quick nav -->
    <div class="nav-grid">
      <a href="/potlucks/manage" class="nav-card"><span class="nav-icon">🍽</span><span class="nav-label">Events</span></a>
      <a href="/admin/analytics" class="nav-card"><span class="nav-icon">📊</span><span class="nav-label">Analytics</span></a>
      <a href="/admin/links" class="nav-card"><span class="nav-icon">🔗</span><span class="nav-label">Short Links</span></a>
      <a href="/potlucks/1/poster" class="nav-card"><span class="nav-icon">🖼</span><span class="nav-label">Poster</span></a>
    </div>

    {showApprovalUI && (
      <div style="margin-bottom:28px">
        <div class="sec-label">Backup & Restore (super-admin)</div>
        <div class="profile-section">
          <div style="font-size:13px;color:#57524c;margin-bottom:12px;line-height:1.6">
            Download a single JSON file containing every table in the database
            (events, sign-ups, organizers, passkeys, config secrets, everything).
            Save it somewhere safe — anyone with this file can restore your full site.
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:center">
            <a href="/api/admin/backup" class="save-btn" style="text-decoration:none;display:inline-block">⬇ Download backup</a>
            <a href="https://github.com/stharpe98-tech/denver-social-hub/archive/refs/heads/main.zip" class="del-btn" style="text-decoration:none;display:inline-block">⬇ Download source code</a>
          </div>

          <div style="margin-top:18px;padding-top:18px;border-top:1px solid #f0ede8">
            <div style="font-size:13px;font-weight:700;color:#dc2626;margin-bottom:6px">⚠ Restore (destructive)</div>
            <div style="font-size:12px;color:#a09890;margin-bottom:10px;line-height:1.6">
              Choose a backup JSON file. Drops + recreates every table in the file.
              Tables not in the backup are kept (uncheck "wipe first" if you want to merge).
            </div>
            <input type="file" id="restore-file" accept="application/json" style="margin-bottom:10px"/>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:#57524c;margin-bottom:10px">
              <input type="checkbox" id="restore-wipe"/> Wipe all tables first (full reset)
            </label>
            <button class="del-btn" id="restore-btn" style="background:#fef2f2;color:#dc2626;border-color:#fca5a5">Restore from file</button>
            <div id="restore-status" style="font-size:13px;margin-top:10px;display:none"></div>
          </div>
        </div>
      </div>
    )}

    <!-- Passkeys -->
    <div style="margin-bottom:28px">
      <div class="sec-label">Passkeys (sign in with Face ID / Touch ID)</div>
      <div class="profile-section">
        <div id="passkey-list" style="font-size:13px;color:#57524c;margin-bottom:12px">Loading…</div>
        <button class="save-btn" id="add-passkey-btn">+ Add a passkey</button>
        <div class="settings-hint" style="font-size:12px;color:#a09890;margin-top:10px">Once enrolled, you can sign in from /admin without a password by tapping "Sign in with passkey".</div>
        <div id="passkey-err" style="font-size:13px;color:#dc2626;margin-top:10px;display:none"></div>
      </div>
    </div>

    <!-- Quick PIN -->
    <div style="margin-bottom:28px">
      <div class="sec-label">Quick PIN (for this device)</div>
      <div class="profile-section">
        <div style="font-size:13px;color:#57524c;margin-bottom:12px;line-height:1.6">
          Set a 4–8 digit PIN to sign in fast on this device. The PIN only works on devices you've trusted, so a stolen PIN alone can't log in. 5 wrong tries removes the device — you'd need to log in normally and re-enroll.
        </div>
        <div class="pf-row" style="grid-template-columns:1fr 1fr">
          <div class="pf-field"><label>New PIN</label><input type="password" inputmode="numeric" pattern="[0-9]*" maxlength="8" id="pin-new" class="pf-input" placeholder="1234" autocomplete="off"/></div>
          <div class="pf-field"><label>Device name (optional)</label><input type="text" id="pin-label" class="pf-input" placeholder="Seth's MacBook" autocomplete="off"/></div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="save-btn" id="pin-save-btn">Save PIN for this device</button>
          <button class="del-btn" id="pin-disable-all-btn" type="button">Remove all PINs</button>
        </div>
        <div id="pin-err" style="font-size:13px;color:#dc2626;margin-top:10px;display:none"></div>
        <div id="pin-list" style="font-size:13px;color:#57524c;margin-top:14px;border-top:1px solid #f0ede8;padding-top:14px">Loading trusted devices…</div>
      </div>
    </div>

    <!-- White label / profile -->
    <div style="margin-bottom:28px">
      <div class="sec-label">Your Profile & Branding</div>
      <div class="profile-section">
        <div class="pf-row">
          <div class="pf-field"><label>Display Name</label><input type="text" id="pf-name" class="pf-input" placeholder="Denver Social Community" value={org.name}/></div>
          <div class="pf-field"><label>Logo URL</label><input type="text" id="pf-logo" class="pf-input" placeholder="https://…/logo.png"/></div>
        </div>
        <div class="pf-row">
          <div class="pf-field"><label>Stripe Payment Link</label><input type="text" id="pf-stripe" class="pf-input" placeholder="https://buy.stripe.com/…"/></div>
          <div class="pf-field"><label>Twilio Phone (SMS)</label><input type="text" id="pf-twilio" class="pf-input" placeholder="+1720…"/></div>
        </div>
        <button class="save-btn" id="save-profile">Save</button>
      </div>
    </div>

    <!-- Embed widget -->
    <div style="margin-bottom:28px">
      <div class="sec-label">Embed on Any Website</div>
      <p style="font-size:13px;color:#57524c;margin-bottom:10px">Drop this on any website to embed the sign-up form directly.</p>
      <div class="embed-section">
        <div class="embed-code" id="embed-code">&lt;iframe src="https://denversocialhub.com/potlucks/1" width="100%" height="700" frameborder="0" style="border-radius:16px"&gt;&lt;/iframe&gt;</div>
        <button class="copy-embed" id="copy-embed">Copy embed code</button>
      </div>
    </div>

    <!-- Event templates -->
    <div style="margin-bottom:28px">
      <div class="sec-label">Saved Event Templates ({templates.length})</div>
      {templates.length === 0
        ? <div class="empty">No templates yet — save a potluck as a template from the manage page</div>
        : templates.map((t:any) => (
          <div class="tmpl-card">
            <div>
              <div class="tmpl-name">{t.name}</div>
              <div class="tmpl-meta">{t.location} · {t.template} theme</div>
            </div>
            <div class="tmpl-actions">
              <button class="use-btn" data-id={t.id}>Use</button>
              <button class="del-btn" data-tmpl-id={t.id}>Del</button>
            </div>
          </div>
        ))
      }
    </div>

    {showApprovalUI && (
      <div style="margin-bottom:28px">
        <div class="sec-label">Organizer Access ({pendingOrgs.length} pending · {approvedOrgs.length} approved)</div>
        {pendingOrgs.length > 0 && (
          <div style="margin-bottom:14px">
            <div style="font-size:12px;color:#a09890;margin-bottom:8px">Pending approval</div>
            {pendingOrgs.map((o:any) => (
              <div class="tmpl-card">
                <div>
                  <div class="tmpl-name">{o.name}</div>
                  <div class="tmpl-meta">{o.email}</div>
                </div>
                <div class="tmpl-actions">
                  <button class="use-btn" data-approve-id={o.id}>Approve</button>
                </div>
              </div>
            ))}
          </div>
        )}
        {approvedOrgs.length > 0 && (
          <div>
            <div style="font-size:12px;color:#a09890;margin-bottom:8px">Approved</div>
            {approvedOrgs.map((o:any) => (
              <div class="tmpl-card">
                <div>
                  <div class="tmpl-name">{o.name}</div>
                  <div class="tmpl-meta">{o.email}</div>
                </div>
                <div class="tmpl-actions">
                  {o.email.toLowerCase() === 'stharpe98@gmail.com'
                    ? <span style="font-size:11px;color:#a09890;padding:6px 10px">super</span>
                    : <button class="del-btn" data-revoke-id={o.id}>Revoke</button>}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Recent events -->
    <div>
      <div class="sec-label">Your Events</div>
      {events.slice(0,5).map((p:any) => (
        <a href={`/potlucks/manage/${p.id}`} class="event-card">
          <div>
            <div class="event-title">{p.title}</div>
            <div class="event-meta">{p.date_label} · {p.location}</div>
          </div>
          <div class="event-stats">{p.signups || 0} signed up</div>
        </a>
      ))}
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline>
    function showToast(msg) {
      var t = document.getElementById('toast');
      t.textContent = msg; t.style.display='block';
      setTimeout(function(){t.style.display='none';},2000);
    }

    document.getElementById('logout-btn').addEventListener('click', async function() {
      await fetch('/api/auth', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'logout'})});
      location.href = '/admin/login';
    });

    document.getElementById('save-profile').addEventListener('click', async function() {
      var res = await fetch('/api/auth', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        action:'update_profile',
        white_label_name: document.getElementById('pf-name').value,
        white_label_logo: document.getElementById('pf-logo').value,
        stripe_link: document.getElementById('pf-stripe').value,
      })});
      var data = await res.json();
      if (data.ok) showToast('Saved ✓');
    });

    document.getElementById('copy-embed').addEventListener('click', function() {
      navigator.clipboard.writeText(document.getElementById('embed-code').textContent);
      showToast('Copied ✓');
    });

    document.querySelectorAll('[data-approve-id]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var id = parseInt(btn.getAttribute('data-approve-id'));
        var res = await fetch('/api/admin/organizers', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'approve',id:id})});
        var data = await res.json();
        if (data.ok) location.reload();
      });
    });
    document.querySelectorAll('[data-revoke-id]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        if (!confirm('Revoke potluck admin access for this user?')) return;
        var id = parseInt(btn.getAttribute('data-revoke-id'));
        var res = await fetch('/api/admin/organizers', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'revoke',id:id})});
        var data = await res.json();
        if (data.ok) location.reload();
      });
    });

    document.querySelectorAll('.del-btn[data-tmpl-id]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        if (!confirm('Delete this template?')) return;
        await fetch('/api/event-templates', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'delete',id:parseInt(btn.dataset.tmplId)})});
        btn.closest('.tmpl-card').remove();
        showToast('Deleted');
      });
    });
  </script>

  <script>
    // Bundled by Astro (NOT is:inline) so we can import from npm.
    import { startRegistration } from '@simplewebauthn/browser';

    async function refreshPasskeyList() {
      const listEl = document.getElementById('passkey-list');
      if (!listEl) return;
      try {
        const res = await fetch('/api/passkey/manage');
        const data = await res.json();
        const passkeys = data.passkeys || [];
        if (passkeys.length === 0) {
          listEl.innerHTML = '<em style="color:#a09890">No passkeys yet — tap below to add one.</em>';
          return;
        }
        listEl.innerHTML = passkeys.map((pk) => {
          const label = pk.device_label || 'Unnamed device';
          const date = new Date(pk.created_at).toLocaleDateString();
          return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #f0ede8">
            <div><strong>🔑 ${label}</strong><div style="font-size:11px;color:#a09890">added ${date}</div></div>
            <button class="del-btn" data-pk-id="${pk.id}">Remove</button>
          </div>`;
        }).join('');
        listEl.querySelectorAll('[data-pk-id]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            if (!confirm('Remove this passkey?')) return;
            await fetch('/api/passkey/manage', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete', id: parseInt(btn.getAttribute('data-pk-id')) }) });
            refreshPasskeyList();
          });
        });
      } catch {
        listEl.textContent = 'Failed to load passkeys.';
      }
    }

    document.getElementById('add-passkey-btn')?.addEventListener('click', async () => {
      const errEl = document.getElementById('passkey-err');
      errEl.style.display = 'none';
      try {
        const optsRes = await fetch('/api/passkey/register-options', { method: 'POST' });
        if (!optsRes.ok) throw new Error('options_failed');
        const opts = await optsRes.json();

        const label = prompt('Name this device (e.g. "MacBook", "iPhone"):', '') || '';
        const attResp = await startRegistration({ optionsJSON: opts });

        const verifyRes = await fetch('/api/passkey/register-verify', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ response: attResp, deviceLabel: label }),
        });
        const data = await verifyRes.json();
        if (!data.ok) throw new Error(data.error || 'verify_failed');
        showToast('Passkey added ✓');
        refreshPasskeyList();
      } catch (e) {
        errEl.textContent = 'Couldn\'t add passkey: ' + (e.message || 'unknown error');
        errEl.style.display = 'block';
      }
    });

    refreshPasskeyList();

    // ── Quick PIN (trusted-device) ──
    async function refreshPinList() {
      const listEl = document.getElementById('pin-list');
      if (!listEl) return;
      try {
        const res = await fetch('/api/pin/manage');
        const data = await res.json();
        const devices = data.devices || [];
        if (devices.length === 0) {
          listEl.innerHTML = '<em style="color:#a09890">No PIN set on any device yet.</em>';
          return;
        }
        listEl.innerHTML = '<div style="font-size:11px;font-weight:700;color:#a09890;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px">Trusted devices</div>' + devices.map((d) => {
          const label = d.device_label || 'Unnamed device';
          const date = new Date(d.created_at).toLocaleDateString();
          const last = d.last_used_at ? new Date(d.last_used_at).toLocaleDateString() : 'never';
          const here = d.is_current ? ' <span style="background:#fef3c7;color:#92400e;font-size:10px;padding:2px 6px;border-radius:6px;margin-left:6px">this device</span>' : '';
          return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #f0ede8">
            <div><strong>📱 ${label}</strong>${here}<div style="font-size:11px;color:#a09890">added ${date} · last used ${last}</div></div>
            <button class="del-btn" data-trusted-id="${d.id}">Remove</button>
          </div>`;
        }).join('');
        listEl.querySelectorAll('[data-trusted-id]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            if (!confirm('Remove PIN access from this device?')) return;
            await fetch('/api/pin/manage', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete', id: parseInt(btn.getAttribute('data-trusted-id')) }) });
            refreshPinList();
          });
        });
      } catch {
        listEl.textContent = 'Failed to load trusted devices.';
      }
    }

    document.getElementById('pin-save-btn')?.addEventListener('click', async () => {
      const errEl = document.getElementById('pin-err');
      errEl.style.display = 'none';
      const pin = document.getElementById('pin-new').value.trim();
      const label = document.getElementById('pin-label').value.trim();
      if (!/^\d{4,8}$/.test(pin)) {
        errEl.textContent = 'PIN must be 4–8 digits.';
        errEl.style.display = 'block';
        return;
      }
      const res = await fetch('/api/pin/setup', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ pin, deviceLabel: label }) });
      const data = await res.json();
      if (!data.ok) {
        errEl.textContent = data.error || 'Could not save PIN.';
        errEl.style.display = 'block';
        return;
      }
      document.getElementById('pin-new').value = '';
      showToast('PIN saved ✓');
      refreshPinList();
    });

    document.getElementById('pin-disable-all-btn')?.addEventListener('click', async () => {
      if (!confirm('Remove PIN access from ALL devices?')) return;
      await fetch('/api/pin/manage', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete_all' }) });
      showToast('All PINs removed');
      refreshPinList();
    });

    refreshPinList();

    // ── Backup / Restore ──
    document.getElementById('restore-btn')?.addEventListener('click', async () => {
      const fileEl = document.getElementById('restore-file');
      const statusEl = document.getElementById('restore-status');
      const file = fileEl.files?.[0];
      if (!file) {
        statusEl.style.display = 'block';
        statusEl.style.color = '#dc2626';
        statusEl.textContent = 'Pick a backup file first.';
        return;
      }
      const wipe = document.getElementById('restore-wipe').checked;
      if (!confirm(`Restore from "${file.name}"? This will drop + recreate every table in the backup.${wipe ? ' Plus wipe ALL existing tables first.' : ''} There is no undo.`)) return;

      statusEl.style.display = 'block';
      statusEl.style.color = '#57524c';
      statusEl.textContent = 'Reading file…';
      const text = await file.text();
      let payload;
      try { payload = JSON.parse(text); } catch {
        statusEl.style.color = '#dc2626';
        statusEl.textContent = 'File isn\'t valid JSON.';
        return;
      }

      statusEl.textContent = 'Uploading…';
      const url = `/api/admin/restore?confirm=yes${wipe ? '&action=wipe_first' : ''}`;
      const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const data = await res.json();
      if (data.ok) {
        statusEl.style.color = '#16a34a';
        statusEl.textContent = `✓ Restored ${data.tables_recreated} tables, ${data.rows_inserted} rows.`;
      } else {
        statusEl.style.color = '#dc2626';
        statusEl.textContent = `Restore had errors: ${(data.errors || []).join('; ') || data.error || 'unknown'}`;
      }
    });
  </script>
</body>
</html>
