---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

const db = getDB();
const errorParam = Astro.url.searchParams.get("error");
const next = Astro.url.searchParams.get("next") || "/events";

let memberCount = 0;
let eventCount = 0;
try {
  if (db) {
    const mc: any = await db.prepare("SELECT COUNT(*) as c FROM members").first();
    memberCount = mc?.c || 0;
    const ec: any = await db.prepare("SELECT COUNT(*) as c FROM events WHERE is_past IS NULL OR is_past = 0").first();
    eventCount = ec?.c || 0;
  }
} catch {}

// Admin backdoor — kept tiny at the bottom of the page for the founder.
let adminError: string | null = null;
if (Astro.request.method === "POST") {
  try {
    const form = await Astro.request.formData();
    const action = form.get("action")?.toString();
    const email = form.get("email")?.toString().trim().toLowerCase();
    if (action === "admin_login" && db && email === "stharpe98@gmail.com") {
      let member: any = await db.prepare("SELECT * FROM members WHERE email=?").bind(email).first();
      if (!member) {
        await db.prepare("INSERT INTO members (email,name,bio,neighborhood,onboarding_done,role) VALUES (?,?,?,?,1,'admin') ON CONFLICT(email) DO NOTHING").bind(email, "Seth", "Founder", "RiNo").run();
        member = await db.prepare("SELECT * FROM members WHERE email=?").bind(email).first();
      }
      if (member) {
        const val = encodeURIComponent(JSON.stringify({ id: member.id, email: member.email, name: member.name, role: member.role || 'admin' }));
        return new Response(null, { status: 302, headers: { "Location": next, "Set-Cookie": `dsn_user=${val}; Path=/; Max-Age=604800; SameSite=Lax` } });
      }
    }
    adminError = "Invalid credentials.";
  } catch { adminError = "Something went wrong."; }
}

const errorMessages: Record<string, string> = {
  denied: "Reddit authorization was denied. Try again whenever you're ready.",
  invalid_state: "Sign-in expired. Please try again.",
  csrf: "Security check failed. Please try again.",
  token_failed: "Couldn't connect to Reddit. Try again.",
  no_token: "Couldn't get a token from Reddit. Try again.",
  fetch_failed: "Couldn't reach Reddit. Check your connection and try again.",
  db: "Our server's having a moment. Try again in a few seconds.",
};
const errorMsg = errorParam ? (errorMessages[errorParam] || "Something went wrong.") : adminError;
---
<Base title="Sign in" description="Sign in to RSVP for Denver Social events.">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-icon">🌆</div>
      <h1>Welcome back.</h1>
      <p class="auth-sub">Sign in with Reddit to RSVP, see who's coming, and join the community.</p>

      {errorMsg && (
        <div class="auth-error">
          <span class="auth-error-dot"></span>
          <span>{errorMsg}</span>
        </div>
      )}

      <a href={`/api/auth/reddit?next=${encodeURIComponent(next)}`} class="reddit-btn">
        <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path d="M10 0C4.478 0 0 4.478 0 10c0 5.522 4.478 10 10 10s10-4.478 10-10C20 4.478 15.522 0 10 0zm5.8 11.6c.04.2.06.4.06.6 0 2.94-3.42 5.32-7.64 5.32S.58 15.14.58 12.2c0-.22.02-.44.06-.64a1.44 1.44 0 01-.58-1.16c0-.8.64-1.44 1.44-1.44.38 0 .72.14.98.38 1.3-.92 3.1-1.52 5.1-1.58l.98-4.56c.02-.1.08-.18.16-.22.08-.04.18-.06.28-.04l3.24.68c.18-.38.56-.64 1-.64.62 0 1.12.5 1.12 1.12s-.5 1.12-1.12 1.12-1.12-.5-1.12-1.12l-2.9-.6-.86 4.06c1.94.08 3.68.68 4.94 1.56.26-.22.6-.36.96-.36.8 0 1.44.64 1.44 1.44 0 .48-.24.9-.6 1.16zM6.6 11.2c-.62 0-1.12.5-1.12 1.12s.5 1.12 1.12 1.12 1.12-.5 1.12-1.12-.5-1.12-1.12-1.12zm6.8 0c-.62 0-1.12.5-1.12 1.12s.5 1.12 1.12 1.12 1.12-.5 1.12-1.12-.5-1.12-1.12-1.12zm-6.34 3.56c-.12-.12-.12-.32 0-.44s.32-.12.44 0c.58.58 1.52.86 2.5.86s1.92-.28 2.5-.86c.12-.12.32-.12.44 0s.12.32 0 .44c-.7.7-1.78 1.04-2.94 1.04s-2.24-.34-2.94-1.04z"/>
        </svg>
        <span>Continue with Reddit</span>
      </a>

      <ul class="auth-perks">
        <li><span class="auth-perk-icon">✓</span> Takes about 10 seconds</li>
        <li><span class="auth-perk-icon">✓</span> Read-only — we never post for you</li>
        <li><span class="auth-perk-icon">✓</span> Your karma is your trust score</li>
      </ul>

      {(memberCount > 0 || eventCount > 0) && (
        <div class="auth-stats">
          {memberCount > 0 && <span><strong>{memberCount}</strong> locals</span>}
          {memberCount > 0 && eventCount > 0 && <span class="auth-dot"></span>}
          {eventCount > 0 && <span><strong>{eventCount}</strong> upcoming events</span>}
        </div>
      )}
    </div>

    <details class="admin-backdoor">
      <summary>Organizer? Sign in here</summary>
      <form method="POST" class="admin-form">
        <input type="hidden" name="action" value="admin_login" />
        <input type="email" name="email" placeholder="your@email.com" class="admin-input" />
        <button type="submit" class="admin-btn">Sign in</button>
      </form>
      <div class="admin-hint">Or go to <a href="/admin/login">/admin/login</a> for full organizer options.</div>
    </details>
  </div>

  <style>
    .auth-wrap { max-width: 440px; margin: 0 auto; padding: var(--space-7) var(--space-4) var(--space-8); }
    .auth-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--card-shadow-lg);
      padding: var(--space-6) var(--space-5);
      text-align: center;
    }
    .auth-icon { font-size: 48px; line-height: 1; margin-bottom: var(--space-3); }
    .auth-card h1 {
      font-family: var(--font-display);
      font-size: clamp(28px, 4vw, 34px);
      font-weight: 800;
      color: var(--text);
      margin-bottom: var(--space-2);
      letter-spacing: -0.02em;
    }
    .auth-sub {
      color: var(--text-sec);
      font-size: 15px;
      line-height: 1.55;
      margin-bottom: var(--space-5);
      max-width: 340px;
      margin-left: auto;
      margin-right: auto;
    }

    .auth-error {
      display: flex; align-items: center; gap: 10px;
      background: var(--red-dim);
      border: 1px solid rgba(220,38,38,0.25);
      border-radius: 10px;
      padding: 10px 14px;
      margin-bottom: var(--space-4);
      font-size: 13px;
      color: var(--red);
      text-align: left;
    }
    .auth-error-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--red); flex-shrink: 0;
    }

    .reddit-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      width: 100%;
      padding: 14px 22px;
      background: #FF4500; /* Reddit orange — kept on purpose */
      color: #fff;
      border-radius: var(--radius-pill);
      font-family: var(--font);
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      box-shadow: 0 1px 3px rgba(255,69,0,0.22);
      transition: all 0.15s;
    }
    .reddit-btn:hover { box-shadow: 0 6px 18px rgba(255,69,0,0.32); transform: translateY(-1px); }
    .reddit-btn:active { transform: translateY(0); box-shadow: 0 1px 3px rgba(255,69,0,0.22); }

    .auth-perks {
      list-style: none; padding: 0;
      margin: var(--space-5) 0 var(--space-4);
      text-align: left;
      display: flex; flex-direction: column; gap: 8px;
    }
    .auth-perks li {
      display: flex; align-items: center; gap: 10px;
      font-size: 14px; color: var(--text-sec);
    }
    .auth-perk-icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 22px; height: 22px;
      background: var(--tag-bg2); color: var(--tag-text2);
      border-radius: 50%;
      font-size: 12px; font-weight: 700;
      flex-shrink: 0;
    }

    .auth-stats {
      padding-top: var(--space-4);
      border-top: 1px solid var(--border);
      font-size: 13px; color: var(--text-faint);
      display: inline-flex; align-items: center; gap: 12px;
      flex-wrap: wrap; justify-content: center;
    }
    .auth-stats strong { color: var(--text); font-weight: 700; }
    .auth-dot { width: 3px; height: 3px; background: var(--border); border-radius: 50%; }

    .admin-backdoor { margin-top: var(--space-5); text-align: center; }
    .admin-backdoor summary {
      font-size: 13px; color: var(--text-faint);
      cursor: pointer; list-style: none;
      padding: 8px 16px; display: inline-block;
      border-radius: 999px;
      transition: color 0.15s, background 0.15s;
    }
    .admin-backdoor summary:hover { color: var(--text-sec); background: var(--surface); }
    .admin-backdoor summary::-webkit-details-marker { display: none; }
    .admin-form {
      display: flex; gap: 8px; margin-top: 12px;
      max-width: 380px; margin-left: auto; margin-right: auto;
    }
    .admin-input {
      flex: 1;
      padding: 11px 14px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; font-size: 14px; color: var(--text);
      font-family: var(--font); outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .admin-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
    .admin-btn {
      padding: 11px 18px; border-radius: 10px; border: 1px solid var(--border);
      background: var(--bg); color: var(--text-sec);
      font-size: 14px; font-weight: 600; cursor: pointer; font-family: var(--font);
      white-space: nowrap;
      transition: all 0.15s;
    }
    .admin-btn:hover { border-color: var(--border-hover); background: var(--surface); }
    .admin-hint { font-size: 12px; color: var(--text-faint); margin-top: 10px; }
    .admin-hint a { color: var(--accent); font-weight: 600; }
  </style>
</Base>
