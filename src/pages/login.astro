---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

const db = getDB();
const errorParam = Astro.url.searchParams.get("error");
const next = Astro.url.searchParams.get("next") || "/events";

// Get social proof
let memberCount = 0;
let eventCount = 0;
try {
  if (db) {
    const mc: any = await db.prepare("SELECT COUNT(*) as c FROM members").first();
    memberCount = mc?.c || 0;
    const ec: any = await db.prepare("SELECT COUNT(*) as c FROM events WHERE is_past IS NULL OR is_past = 0").first();
    eventCount = ec?.c || 0;
  }
} catch {}

// Admin backdoor: still allow email login for Seth
let adminError: string | null = null;
if (Astro.request.method === "POST") {
  try {
    const form = await Astro.request.formData();
    const action = form.get("action")?.toString();
    const email = form.get("email")?.toString().trim().toLowerCase();
    if (action === "admin_login" && db && email === "stharpe98@gmail.com") {
      let member: any = await db.prepare("SELECT * FROM members WHERE email=?").bind(email).first();
      if (!member) {
        await db.prepare("INSERT INTO members (email,name,bio,neighborhood,onboarding_done,role) VALUES (?,?,?,?,1,'admin') ON CONFLICT(email) DO NOTHING").bind(email,"Seth","Founder","RiNo").run();
        member = await db.prepare("SELECT * FROM members WHERE email=?").bind(email).first();
      }
      if (member) {
        const val = encodeURIComponent(JSON.stringify({ id: member.id, email: member.email, name: member.name, role: member.role || 'admin' }));
        return new Response(null, { status: 302, headers: { "Location": next, "Set-Cookie": `dsn_user=${val}; Path=/; Max-Age=604800; SameSite=Lax` } });
      }
    }
    adminError = "Invalid credentials.";
  } catch { adminError = "Something went wrong."; }
}

const errorMessages: Record<string, string> = {
  denied: "Reddit authorization was denied.",
  invalid_state: "Invalid auth state. Please try again.",
  csrf: "Security check failed. Please try again.",
  token_failed: "Reddit connection failed. Try again.",
  no_token: "Couldn't get Reddit token. Try again.",
  fetch_failed: "Couldn't reach Reddit. Try again.",
  db: "Server error. Please try later."
};
const errorMsg = errorParam ? (errorMessages[errorParam] || "Something went wrong.") : adminError;
---
<Base title="Sign in">
  <div class="login">
    <div class="login-terminal">
      <div class="term-bar">
        <span class="term-dot" style="background:#ff5f57"></span>
        <span class="term-dot" style="background:#febc2e"></span>
        <span class="term-dot" style="background:#28c840"></span>
        <span class="term-title">auth — /r/events.hub</span>
      </div>

      <div class="term-body">
        <div class="term-line"><span class="term-prompt">$</span> <span class="term-cmd">cat welcome.md</span></div>
        <div class="term-output">
          <h1 class="login-title">Real events.<br/><span class="login-accent">Real people.</span></h1>
          <p class="login-sub">Denver's community-run event hub. Sign in with Reddit — your karma is your trust score.</p>
        </div>

        <div class="term-line"><span class="term-prompt">$</span> <span class="term-cmd">./authenticate --provider reddit</span></div>

        {errorMsg && (
          <div class="login-error">
            <span class="login-error-icon">!</span>
            <span>ERROR: {errorMsg}</span>
          </div>
        )}

        <a href={`/api/auth/reddit?next=${encodeURIComponent(next)}`} class="reddit-btn">
          <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor">
            <path d="M10 0C4.478 0 0 4.478 0 10c0 5.522 4.478 10 10 10s10-4.478 10-10C20 4.478 15.522 0 10 0zm5.8 11.6c.04.2.06.4.06.6 0 2.94-3.42 5.32-7.64 5.32S.58 15.14.58 12.2c0-.22.02-.44.06-.64a1.44 1.44 0 01-.58-1.16c0-.8.64-1.44 1.44-1.44.38 0 .72.14.98.38 1.3-.92 3.1-1.52 5.1-1.58l.98-4.56c.02-.1.08-.18.16-.22.08-.04.18-.06.28-.04l3.24.68c.18-.38.56-.64 1-.64.62 0 1.12.5 1.12 1.12s-.5 1.12-1.12 1.12-1.12-.5-1.12-1.12l-2.9-.6-.86 4.06c1.94.08 3.68.68 4.94 1.56.26-.22.6-.36.96-.36.8 0 1.44.64 1.44 1.44 0 .48-.24.9-.6 1.16zM6.6 11.2c-.62 0-1.12.5-1.12 1.12s.5 1.12 1.12 1.12 1.12-.5 1.12-1.12-.5-1.12-1.12-1.12zm6.8 0c-.62 0-1.12.5-1.12 1.12s.5 1.12 1.12 1.12 1.12-.5 1.12-1.12-.5-1.12-1.12-1.12zm-6.34 3.56c-.12-.12-.12-.32 0-.44s.32-.12.44 0c.58.58 1.52.86 2.5.86s1.92-.28 2.5-.86c.12-.12.32-.12.44 0s.12.32 0 .44c-.7.7-1.78 1.04-2.94 1.04s-2.24-.34-2.94-1.04z"/>
          </svg>
          <span>Continue with Reddit</span>
        </a>

        <div class="login-meta">
          <div class="login-meta-row">
            <span class="login-meta-label">trust_model:</span>
            <span class="login-meta-value">"karma + account_age"</span>
          </div>
          <div class="login-meta-row">
            <span class="login-meta-label">scope:</span>
            <span class="login-meta-value">"identity" <span class="login-meta-note">// read-only, we never post</span></span>
          </div>
        </div>

        {(memberCount > 5 || eventCount > 0) && (
          <div class="login-stats">
            {memberCount > 5 && <span class="login-stat"><span class="login-stat-num">{memberCount}</span> redditors joined</span>}
            {eventCount > 0 && <span class="login-stat"><span class="login-stat-num">{eventCount}</span> events live</span>}
          </div>
        )}

        <div class="term-line term-line-last"><span class="term-prompt">$</span> <span class="term-cursor">_</span></div>
      </div>
    </div>

    <!-- Hidden admin backdoor -->
    <details class="admin-backdoor">
      <summary>admin access</summary>
      <form method="POST" class="admin-form">
        <input type="hidden" name="action" value="admin_login" />
        <input type="email" name="email" placeholder="admin email" class="input admin-input" />
        <button type="submit" class="btn btn-ghost admin-btn">login</button>
      </form>
    </details>
  </div>
</Base>

<style is:inline>
  .login {
    max-width: 520px;
    margin: 40px auto 0;
    padding: 0 20px 80px;
  }

  /* ── Terminal window ── */
  .login-terminal {
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
  }
  .term-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 12px 16px;
    background: var(--surface-raised);
    border-bottom: 1px solid var(--border);
  }
  .term-dot {
    width: 10px; height: 10px; border-radius: 50%;
  }
  .term-title {
    font-family: var(--mono); font-size: 11px; color: var(--text-faint);
    margin-left: 8px;
  }
  .term-body { padding: 24px; }
  .term-line {
    font-family: var(--mono); font-size: 13px;
    margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .term-prompt { color: var(--accent); font-weight: 700; }
  .term-cmd { color: var(--text-sec); }
  .term-output { margin-bottom: 24px; padding-left: 0; }
  .term-line-last { margin-top: 24px; margin-bottom: 0; }
  .term-cursor {
    color: var(--accent);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Title ── */
  .login-title {
    font-family: var(--heading); font-size: 32px; font-weight: 800;
    color: var(--text); line-height: 1.15; margin-bottom: 8px;
    letter-spacing: -0.03em;
  }
  .login-accent { color: var(--accent); }
  .login-sub {
    font-size: 14px; color: var(--text-sec); line-height: 1.6;
    margin-bottom: 0;
  }

  /* ── Error ── */
  .login-error {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,71,87,0.08);
    border: 1px solid rgba(255,71,87,0.2);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 16px;
    font-family: var(--mono); font-size: 12px; color: var(--red);
  }
  .login-error-icon {
    width: 18px; height: 18px; border-radius: 4px;
    background: var(--red); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; flex-shrink: 0;
  }

  /* ── Reddit button ── */
  .reddit-btn {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; padding: 14px;
    background: var(--accent); color: #fff;
    border-radius: 8px; border: none;
    font-family: var(--mono); font-size: 14px; font-weight: 700;
    text-decoration: none; cursor: pointer;
    transition: all .2s;
    margin-bottom: 20px;
  }
  .reddit-btn:hover {
    box-shadow: 0 0 24px var(--accent-glow), 0 4px 12px rgba(0,0,0,0.3);
    transform: translateY(-1px);
  }
  .reddit-btn svg { flex-shrink: 0; }

  /* ── Meta info ── */
  .login-meta {
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 14px;
    margin-bottom: 16px;
  }
  .login-meta-row {
    font-family: var(--mono); font-size: 11px;
    display: flex; gap: 6px; line-height: 1.8;
  }
  .login-meta-label { color: var(--blue); }
  .login-meta-value { color: var(--green); }
  .login-meta-note { color: var(--text-faint); }

  /* ── Stats ── */
  .login-stats {
    display: flex; gap: 16px; flex-wrap: wrap;
  }
  .login-stat {
    font-family: var(--mono); font-size: 12px; color: var(--text-faint);
    display: flex; align-items: center; gap: 4px;
  }
  .login-stat-num {
    color: var(--accent); font-weight: 700;
  }

  /* ── Admin backdoor ── */
  .admin-backdoor {
    margin-top: 40px;
    text-align: center;
  }
  .admin-backdoor summary {
    font-family: var(--mono); font-size: 11px; color: var(--text-faint);
    cursor: pointer; list-style: none; opacity: .3;
    transition: opacity .2s;
  }
  .admin-backdoor summary:hover { opacity: .6; }
  .admin-form {
    display: flex; gap: 8px; margin-top: 12px;
    max-width: 320px; margin-left: auto; margin-right: auto;
  }
  .admin-input { font-family: var(--mono); font-size: 12px; }
  .admin-btn { font-size: 12px; white-space: nowrap; }

  @media (max-width: 480px) {
    .login { padding: 0 16px 60px; margin-top: 24px; }
    .login-title { font-size: 26px; }
    .term-body { padding: 18px; }
    .login-stats { flex-direction: column; gap: 6px; }
  }
</style>
