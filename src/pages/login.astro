---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { env } from 'cloudflare:workers';

const db = getDB();
const redditAvailable = !!(env as any).REDDIT_CLIENT_ID;
let discordAvailable = !!(env as any).DISCORD_CLIENT_ID;
if (!discordAvailable && db) {
  try {
    const row: any = await db.prepare("SELECT value FROM config WHERE key='discord_client_id'").first();
    if (row?.value) discordAvailable = true;
  } catch {}
}
const next = Astro.url.searchParams.get("next") || "/events";
const errorParam = Astro.url.searchParams.get("error");

let memberCount = 0;
let eventCount = 0;
try {
  if (db) {
    const mc: any = await db.prepare("SELECT COUNT(*) as c FROM members").first();
    memberCount = mc?.c || 0;
    const ec: any = await db.prepare("SELECT COUNT(*) as c FROM events WHERE is_past IS NULL OR is_past = 0").first();
    eventCount = ec?.c || 0;
  }
} catch {}

const errorMessages: Record<string, string> = {
  denied: "Authorization was denied.",
  invalid_state: "Invalid auth state. Please try again.",
  csrf: "Security check failed. Please try again.",
  token_failed: "Connection failed. Try again.",
  no_token: "Couldn't authenticate. Try again.",
  fetch_failed: "Couldn't reach server. Try again.",
  db: "Server error. Please try later."
};
const errorMsg = errorParam ? (errorMessages[errorParam] || "Something went wrong.") : null;
---
<Base title="Sign in">
  <div class="login-page">
    <div class="login-card">
      <h1 class="login-title">Get in here.</h1>
      <p class="login-sub">Pick your favorite. Email gets a 6-digit code, no password to forget. No upsell, no data sale, no algorithm whispering in your ear.</p>

      {errorMsg && (
        <div class="login-error">{errorMsg}</div>
      )}

      <!-- Step 1: Email input -->
          <div id="step-email">
            <label class="input-label" for="email-input">Email address</label>
            <input type="email" id="email-input" class="input" placeholder="you@email.com" autocomplete="email" />
            <p class="input-hint">Only used for login codes — we'll never share or spam your email.</p>
            <button id="send-code-btn" class="btn btn-primary btn-full">Send me a code</button>
          </div>

          <!-- Step 2: Code verification (hidden initially) -->
          <div id="step-code" style="display:none;">
            <p class="code-sent-msg">Code sent to <strong id="sent-email"></strong></p>
            <label class="input-label" for="code-input">6-digit code</label>
            <input type="text" id="code-input" class="input input-code" placeholder="000000" maxlength="6" inputmode="numeric" autocomplete="one-time-code" />
            <button id="verify-btn" class="btn btn-primary btn-full">Verify & sign in</button>
            <button id="back-btn" class="btn btn-ghost btn-full">Use a different email</button>
          </div>

          <div id="login-status" class="login-status"></div>

      <div class="login-divider">
        <span>or</span>
      </div>

      {discordAvailable && (
        <a href={`/api/auth/discord?next=${encodeURIComponent(next)}`} class="btn btn-discord btn-full">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
          Continue with Discord
        </a>
      )}

      {redditAvailable && (
        <a href={`/api/auth/reddit?next=${encodeURIComponent(next)}`} class="btn btn-reddit btn-full">
          <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor">
            <path d="M10 0C4.478 0 0 4.478 0 10c0 5.522 4.478 10 10 10s10-4.478 10-10C20 4.478 15.522 0 10 0zm5.8 11.6c.04.2.06.4.06.6 0 2.94-3.42 5.32-7.64 5.32S.58 15.14.58 12.2c0-.22.02-.44.06-.64a1.44 1.44 0 01-.58-1.16c0-.8.64-1.44 1.44-1.44.38 0 .72.14.98.38 1.3-.92 3.1-1.52 5.1-1.58l.98-4.56c.02-.1.08-.18.16-.22.08-.04.18-.06.28-.04l3.24.68c.18-.38.56-.64 1-.64.62 0 1.12.5 1.12 1.12s-.5 1.12-1.12 1.12-1.12-.5-1.12-1.12l-2.9-.6-.86 4.06c1.94.08 3.68.68 4.94 1.56.26-.22.6-.36.96-.36.8 0 1.44.64 1.44 1.44 0 .48-.24.9-.6 1.16zM6.6 11.2c-.62 0-1.12.5-1.12 1.12s.5 1.12 1.12 1.12 1.12-.5 1.12-1.12-.5-1.12-1.12-1.12zm6.8 0c-.62 0-1.12.5-1.12 1.12s.5 1.12 1.12 1.12 1.12-.5 1.12-1.12-.5-1.12-1.12-1.12zm-6.34 3.56c-.12-.12-.12-.32 0-.44s.32-.12.44 0c.58.58 1.52.86 2.5.86s1.92-.28 2.5-.86c.12-.12.32-.12.44 0s.12.32 0 .44c-.7.7-1.78 1.04-2.94 1.04s-2.24-.34-2.94-1.04z"/>
          </svg>
          Continue with Reddit
        </a>
      )}

      {(memberCount > 5 || eventCount > 0) && (
        <div class="login-stats">
          {memberCount > 5 && <span class="login-stat">{memberCount} members</span>}
          {eventCount > 0 && <span class="login-stat">{eventCount} events</span>}
        </div>
      )}
    </div>
  </div>
</Base>

<style is:inline>
  .login-page {
    max-width: 440px;
    margin: 60px auto 0;
    padding: 0 20px 80px;
  }
  .login-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px 32px;
  }
  .login-title {
    font-size: 26px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .login-sub {
    font-size: 14px;
    color: var(--text-sec);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .login-error {
    background: rgba(255,71,87,0.08);
    border: 1px solid rgba(255,71,87,0.2);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 16px;
    font-size: 13px;
    color: var(--red, #ff4757);
  }
  .input-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-sec);
    margin-bottom: 6px;
  }
  .input {
    width: 100%;
    padding: 12px 14px;
    background: var(--bg, #0a0a0a);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 15px;
    outline: none;
    transition: border-color .2s;
    box-sizing: border-box;
  }
  .input:focus {
    border-color: var(--accent);
  }
  .input-code {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 8px;
    text-align: center;
    font-family: var(--mono);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all .2s;
  }
  .btn-full { width: 100%; margin-top: 12px; }
  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    opacity: .9;
    transform: translateY(-1px);
  }
  .btn-primary:disabled {
    opacity: .5;
    cursor: not-allowed;
    transform: none;
  }
  .btn-ghost {
    background: transparent;
    color: var(--text-sec);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface-raised, rgba(255,255,255,0.05)); }
  .btn-discord {
    background: #5865F2;
    color: #fff;
  }
  .btn-discord:hover {
    background: #4752C4;
    transform: translateY(-1px);
  }
  .btn-reddit {
    background: #ff4500;
    color: #fff;
  }
  .btn-reddit:hover {
    background: #e63e00;
    transform: translateY(-1px);
  }
  .input-hint {
    font-size: 12px;
    color: var(--text-faint, #888);
    margin-top: 6px;
    margin-bottom: 0;
    line-height: 1.4;
  }
  .code-sent-msg {
    font-size: 14px;
    color: var(--text-sec);
    margin-bottom: 16px;
    padding: 10px 14px;
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.2);
    border-radius: 8px;
  }
  .code-sent-msg strong { color: var(--text); }
  .login-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    color: var(--text-faint, #666);
    font-size: 12px;
  }
  .login-divider::before,
  .login-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .login-stats {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 20px;
  }
  .login-stat {
    font-size: 12px;
    color: var(--text-faint);
  }
  .login-status {
    font-size: 13px;
    margin-top: 8px;
    min-height: 20px;
  }
  .login-status.error { color: var(--red, #ff4757); }
  .login-status.loading { color: var(--text-faint); }

  @media (max-width: 480px) {
    .login-page { margin-top: 24px; }
    .login-card { padding: 28px 20px; }
    .login-title { font-size: 22px; }
  }
</style>

<script is:inline>
  const nextUrl = new URLSearchParams(window.location.search).get('next') || '/events';
  const stepEmail = document.getElementById('step-email');
  const stepCode = document.getElementById('step-code');
  const emailInput = document.getElementById('email-input');
  const codeInput = document.getElementById('code-input');
  const sendBtn = document.getElementById('send-code-btn');
  const verifyBtn = document.getElementById('verify-btn');
  const backBtn = document.getElementById('back-btn');
  const sentEmailEl = document.getElementById('sent-email');
  const statusEl = document.getElementById('login-status');

  let currentEmail = '';

  function setStatus(msg, type) {
    statusEl.textContent = msg;
    statusEl.className = 'login-status ' + (type || '');
  }

  sendBtn.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      setStatus('Please enter a valid email.', 'error');
      return;
    }
    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending...';
    setStatus('', '');

    try {
      const res = await fetch('/api/auth/email-send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (data.ok) {
        currentEmail = email;
        sentEmailEl.textContent = email;
        stepEmail.style.display = 'none';
        stepCode.style.display = 'block';
        setStatus('', '');
        codeInput.focus();
      } else if (data.error === 'email_not_configured') {
        setStatus("Email login isn't set up yet — try Discord or Reddit below.", 'error');
      } else {
        setStatus(data.error || 'Failed to send code.', 'error');
      }
    } catch {
      setStatus('Network error. Try again.', 'error');
    }
    sendBtn.disabled = false;
    sendBtn.textContent = 'Send me a code';
  });

  verifyBtn.addEventListener('click', async () => {
    const code = codeInput.value.trim();
    if (!code || code.length !== 6) {
      setStatus('Enter the 6-digit code from your email.', 'error');
      return;
    }
    verifyBtn.disabled = true;
    verifyBtn.textContent = 'Verifying...';
    setStatus('', '');

    try {
      const res = await fetch('/api/auth/email-verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: currentEmail, code, next: nextUrl })
      });
      const data = await res.json();
      if (data.ok) {
        window.location.href = data.redirect || nextUrl;
      } else if (data.error === 'wrong_code') {
        setStatus('Wrong code. Try again.', 'error');
      } else if (data.error === 'expired') {
        setStatus('Code expired — go back and request a new one.', 'error');
      } else {
        setStatus(data.error || 'Invalid code.', 'error');
      }
    } catch {
      setStatus('Network error. Try again.', 'error');
    }
    verifyBtn.disabled = false;
    verifyBtn.textContent = 'Verify & sign in';
  });

  backBtn.addEventListener('click', () => {
    stepCode.style.display = 'none';
    stepEmail.style.display = 'block';
    codeInput.value = '';
    setStatus('', '');
  });

  // Allow Enter key to submit
  emailInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendBtn.click(); });
  codeInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') verifyBtn.click(); });
</script>
