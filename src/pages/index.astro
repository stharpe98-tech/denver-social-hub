---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

const db = getDB();
let upcomingEvents: any[] = [];
let suggestions: any[] = [];
let memberCount = 0;
let eventCount = 0;
let upcomingPotluck: any = null;

try {
  if (db) {
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentDay = now.getDate();
    const monthOrder: Record<string, number> = { JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11 };
    const allEvts = (await db.prepare("SELECT * FROM events WHERE is_past IS NULL OR is_past=0 ORDER BY id DESC").all())?.results || [];
    upcomingEvents = allEvts.filter((e: any) => {
      const m = monthOrder[(e.event_month || '').toUpperCase()];
      const d = parseInt(e.event_day) || 99;
      if (m === undefined) return false;
      if (m < currentMonth) return false;
      if (m === currentMonth && d < currentDay) return false;
      return true;
    }).sort((a: any, b: any) => {
      const ma = monthOrder[(a.event_month || '').toUpperCase()] ?? 99;
      const mb = monthOrder[(b.event_month || '').toUpperCase()] ?? 99;
      if (ma !== mb) return ma - mb;
      return (parseInt(a.event_day) || 99) - (parseInt(b.event_day) || 99);
    }).slice(0, 4);
    const mc = await db.prepare("SELECT COUNT(*) as cnt FROM members").first();
    memberCount = mc?.cnt || 0;
    const ec = await db.prepare("SELECT COUNT(*) as cnt FROM events WHERE is_past IS NULL OR is_past=0").first();
    eventCount = ec?.cnt || 0;
    suggestions = (await db.prepare("SELECT * FROM event_suggestions ORDER BY votes DESC LIMIT 4").all())?.results || [];
    upcomingPotluck = await db.prepare("SELECT id, title, date_label, location FROM potlucks WHERE status='upcoming' ORDER BY id DESC LIMIT 1").first();
  }
} catch {}

const typeLabel: Record<string, string> = {
  dinner: '🍽 Dinner', game_night: '🎲 Games', outdoor: '🌲 Outdoors', brewery: '🍺 Brewery',
  coffee: '☕ Coffee', arts: '🎨 Arts', music: '🎵 Music', social: '🥂 Social',
  group_tickets: '🎟 Tickets', camping: '🏕 Camping', sports_outing: '⚾ Sports',
  bowling: '🎳 Bowling', active: '🏃 Active', casino: '🎰 Casino', food_trucks: '🌮 Food', other: '✨ Event',
};
---
<Base title="Real events, real people" description="Small-group events across Denver. No algorithms. Just locals getting together.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-photos">
      <img src="https://images.unsplash.com/photo-1619856699906-09e1f4ef578c?w=600&h=400&fit=crop&crop=center" alt="Denver skyline at sunset" class="hero-photo hp-1" loading="eager" />
      <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=600&h=400&fit=crop&crop=center" alt="Friends gathering at a restaurant" class="hero-photo hp-2" loading="eager" />
      <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&h=400&fit=crop&crop=center" alt="Colorado mountains" class="hero-photo hp-3" loading="eager" />
      <img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&h=400&fit=crop&crop=center" alt="Group of friends laughing outdoors" class="hero-photo hp-4" loading="eager" />
      <img src="https://images.unsplash.com/photo-1546793665-c74683f339c1?w=600&h=400&fit=crop&crop=center" alt="Denver Union Station" class="hero-photo hp-5" loading="eager" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <span class="hero-eyebrow">Denver · Community · Since 2026</span>
      <h1 class="hero-title">
        Your city. <span class="hero-italic">Your crew.</span><br/>
        One <span class="hero-em">RSVP</span> away.
      </h1>
      <p class="hero-sub">
        Small-group events across Denver — potlucks at Cheesman, game nights, coffee, hikes. No algorithms, no awkward ice-breakers. Just locals showing up for each other.
      </p>

      <div class="hero-ctas">
        <a href="/events" class="btn-cta">Browse events →</a>
        <a href="/potlucks" class="btn-sec">See potlucks</a>
      </div>

      <div class="hero-meta">
        <div class="hero-stat">
          <strong>{memberCount || 88}+</strong>
          <span>locals</span>
        </div>
        <span class="hero-dot"></span>
        <div class="hero-stat">
          <strong>{eventCount || 12}</strong>
          <span>upcoming</span>
        </div>
        <span class="hero-dot"></span>
        <div class="hero-stat">
          <strong>6–12</strong>
          <span>per event</span>
        </div>
      </div>
    </div>
  </section>

  <!-- UPCOMING POTLUCK SPOTLIGHT -->
  {upcomingPotluck && (
    <section class="page-wrap">
      <a href={`/potlucks/${upcomingPotluck.id}`} class="potluck-spotlight">
        <div>
          <span class="tag tag-green">🍽 Next Potluck</span>
          <h3>{upcomingPotluck.title}</h3>
          <p>{upcomingPotluck.date_label}{upcomingPotluck.location ? ` · ${upcomingPotluck.location}` : ''}</p>
        </div>
        <span class="potluck-spotlight-arrow">→</span>
      </a>
    </section>
  )}

  <!-- UPCOMING EVENTS -->
  {upcomingEvents.length > 0 && (
    <section class="page-wrap">
      <div class="sec-head">
        <span class="sec-tag tag tag-blue">Upcoming</span>
        <h2>Events</h2>
        <p class="sec-sub">Small groups. Real people. Show up and you'll know somebody by the end.</p>
      </div>
      <div class="event-grid">
        {upcomingEvents.map((ev: any) => (
          <a href={`/events/${ev.id}`} class="ev-card">
            <div class="ev-top">
              <span class="ev-type">{typeLabel[ev.event_type] || '✨ Event'}</span>
              <span class="ev-fill">
                <span class="ev-fill-bar"><span class="ev-fill-prog" style={`width:${Math.min(100, Math.round((ev.rsvp_count || 0) / (ev.spots || 12) * 100))}%`}></span></span>
                <span class="ev-fill-num">{ev.rsvp_count || 0}/{ev.spots || 12}</span>
              </span>
            </div>
            <h3 class="ev-title">{ev.title}</h3>
            <div class="ev-meta">
              <span>📅 {ev.event_month} {ev.event_day}</span>
              <span class="ev-meta-dot"></span>
              <span>📍 {ev.zone || ev.location || 'Denver'}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="sec-foot">
        <a href="/events" class="btn-sec">See all events</a>
      </div>
    </section>
  )}

  <!-- COMMUNITY VOTES -->
  <section class="page-wrap">
    <div class="sec-head">
      <span class="sec-tag tag tag-green">What people want</span>
      <h2>What's next</h2>
      <p class="sec-sub">Community suggests, community votes. Top picks become real events.</p>
    </div>

    <div class="vote-list">
      {(suggestions.length > 0 ? suggestions : [
        { id: 0, title: 'Korean BBQ Night', description: 'Cook-your-own meat, Federal Blvd', votes: 41 },
        { id: 0, title: 'Red Rocks Sunrise Yoga', description: 'Early morning yoga + coffee after', votes: 34 },
        { id: 0, title: 'Board Game Tournament', description: 'Catan bracket at Tabletop Tap', votes: 27 },
      ]).map((s: any, i: number) => (
        <div class="vi" style={`--tint: ${['#0EA5E9','#10B981','#F59E0B','#0284C7'][i % 4]}`}>
          <div class="vi-rank">{i + 1}</div>
          <div class="vi-info">
            <div class="vi-title">{s.title}</div>
            {s.description && <div class="vi-desc">{s.description}</div>}
          </div>
          <div class="vi-bar"><div class="vi-fill" style={`width:${Math.min(100, (s.votes || 0) * 3)}%`}></div></div>
          <div class="vi-count">{s.votes || 0}</div>
          <button class="vi-up" data-id={s.id}>▲</button>
        </div>
      ))}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="page-wrap">
    <div class="sec-head">
      <span class="sec-tag tag tag-blue">Three steps</span>
      <h2>How it works</h2>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h4>Sign in</h4>
        <p>Reddit account, 10 seconds. We read karma + age. We never post.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h4>Find your thing</h4>
        <p>Browse potlucks, dinners, hikes, game nights. RSVP to lock your spot.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h4>Show up</h4>
        <p>QR check-in at the door. Reliable shows = trust score = priority on the next one.</p>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="page-wrap">
    <div class="sec-head">
      <span class="sec-tag tag tag-green">Why it works</span>
      <h2>Built on trust</h2>
      <p class="sec-sub">Identity gates and reliability scores keep events safe and small.</p>
    </div>
    <div class="trust-grid">
      <div class="trust-card">
        <div class="tc-icon">⬆</div>
        <h4>Karma = trust</h4>
        <p>Events can require minimum karma to RSVP. Higher karma unlocks more events.</p>
      </div>
      <div class="trust-card">
        <div class="tc-icon">✓</div>
        <h4>Reliability badge</h4>
        <p>Check in via QR. Show up consistently and earn priority for the next one.</p>
      </div>
      <div class="trust-card">
        <div class="tc-icon">📍</div>
        <h4>Address hidden</h4>
        <p>Locations are revealed only to confirmed RSVPs who meet the gate.</p>
      </div>
      <div class="trust-card">
        <div class="tc-icon">⏳</div>
        <h4>Account age</h4>
        <p>Some events require older accounts. No throwaway signups.</p>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="page-wrap final-cta-inner">
      <h2>Your people are already here.</h2>
      <p>Pick an event. Show up. Make a friend.</p>
      <div class="hero-ctas" style="justify-content:center">
        <a href="/events" class="btn-cta">Browse events</a>
        <a href="/potlucks" class="btn-sec">See potlucks</a>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="site-footer-brand">Denver <span>Social</span></div>
    <div class="site-footer-text">No ads. No algorithms. Just locals. · <a href="/about" style="color:var(--text-sec)">About</a> · <a href="/conduct" style="color:var(--text-sec)">Conduct</a></div>
  </footer>

  <style>
    .page-wrap { max-width: 1100px; margin: 0 auto; padding: var(--space-7) var(--space-5); }
    @media(max-width: 700px) { .page-wrap { padding: var(--space-6) var(--space-4); } }

    /* HERO */
    .hero { position: relative; overflow: hidden; padding: var(--space-9) var(--space-5) var(--space-7); background: #0c1a2a; min-height: 520px; }

    /* Slideshow background */
    .hero-photos {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 0;
      overflow: hidden;
    }
    .hero-photo {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      opacity: 0;
      animation: heroFade 25s infinite;
      filter: saturate(0.85) brightness(0.9);
      transform: scale(1.05);
    }
    .hp-1 { animation-delay: 0s; }
    .hp-2 { animation-delay: 5s; }
    .hp-3 { animation-delay: 10s; }
    .hp-4 { animation-delay: 15s; }
    .hp-5 { animation-delay: 20s; }

    @keyframes heroFade {
      0%   { opacity: 0; transform: scale(1.05); }
      4%   { opacity: 1; transform: scale(1.02); }
      20%  { opacity: 1; transform: scale(1); }
      24%  { opacity: 0; transform: scale(1); }
      100% { opacity: 0; transform: scale(1.05); }
    }

    /* Gradient overlay for text readability */
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background:
        linear-gradient(180deg, rgba(12,26,42,0.35) 0%, rgba(12,26,42,0.7) 55%, rgba(12,26,42,0.92) 100%),
        radial-gradient(ellipse 80% 60% at 50% 30%, rgba(14,165,233,0.12), transparent 70%);
    }

    .hero-inner { position: relative; max-width: 820px; margin: 0 auto; text-align: center; z-index: 2; }

    @media(max-width: 700px) {
      .hero { padding: var(--space-7) var(--space-4) var(--space-6); min-height: 440px; }
    }
    .hero-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: #7DD3FC; margin-bottom: var(--space-4); padding: 6px 14px; background: rgba(14,165,233,0.15); border: 1px solid rgba(14,165,233,0.25); border-radius: 999px; }
    .hero-title { font-family: var(--font-display); font-size: clamp(40px, 7vw, 68px); line-height: 1.05; letter-spacing: -0.03em; color: #FFFFFF; margin-bottom: var(--space-4); font-weight: 800; text-shadow: 0 2px 20px rgba(0,0,0,0.3); }
    .hero-italic { font-style: italic; color: #7DD3FC; }
    .hero-em { background: linear-gradient(135deg, #38BDF8, #34D399); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent; }
    .hero-sub { font-size: clamp(16px, 1.6vw, 18px); color: rgba(255,255,255,0.75); line-height: 1.6; max-width: 580px; margin: 0 auto var(--space-5); }
    .hero-ctas { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; margin-bottom: var(--space-5); }
    .hero-ctas .btn-sec { background: rgba(255,255,255,0.1); color: #fff; border-color: rgba(255,255,255,0.2); }
    .hero-ctas .btn-sec:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.35); }
    .hero-meta { display: inline-flex; align-items: center; gap: var(--space-3); padding: 10px 18px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 999px; backdrop-filter: blur(12px); }
    .hero-stat { display: inline-flex; align-items: baseline; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.6); }
    .hero-stat strong { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: #FFFFFF; letter-spacing: -0.02em; }
    .hero-dot { width: 4px; height: 4px; background: rgba(255,255,255,0.25); border-radius: 50%; }

    /* SECTION HEAD */
    .sec-head { margin-bottom: var(--space-5); }
    .sec-head h2 { font-size: clamp(28px, 3.5vw, 36px); margin: var(--space-2) 0 var(--space-2); }
    .sec-tag { margin-bottom: var(--space-2); }
    .sec-sub { color: var(--text-sec); font-size: 15px; max-width: 620px; line-height: 1.55; }
    .sec-foot { margin-top: var(--space-5); display: flex; justify-content: center; }

    /* POTLUCK SPOTLIGHT */
    .potluck-spotlight { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5); border-radius: var(--radius-lg); background: linear-gradient(135deg, #D1FAE5, #E0F2FE); border: 1px solid #A7F3D0; box-shadow: var(--card-shadow); transition: transform 0.15s, box-shadow 0.15s; text-decoration: none; }
    .potluck-spotlight:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-lg); }
    .potluck-spotlight h3 { font-size: 22px; margin: 8px 0 4px; }
    .potluck-spotlight p { color: var(--text-sec); font-size: 14px; }
    .potluck-spotlight-arrow { font-size: 28px; color: var(--accent); flex-shrink: 0; }

    /* EVENT GRID */
    .event-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-3); }
    .ev-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4); box-shadow: var(--card-shadow); transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s; text-decoration: none; display: flex; flex-direction: column; gap: var(--space-3); }
    .ev-card:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-lg); border-color: var(--border-hover); }
    .ev-top { display: flex; justify-content: space-between; align-items: center; gap: var(--space-2); }
    .ev-type { font-size: 12px; font-weight: 600; color: var(--text-sec); }
    .ev-fill { display: inline-flex; align-items: center; gap: 6px; }
    .ev-fill-bar { display: inline-block; width: 50px; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
    .ev-fill-prog { display: block; height: 100%; background: var(--accent); border-radius: 2px; }
    .ev-fill-num { font-size: 11px; color: var(--text-faint); font-weight: 600; }
    .ev-title { font-size: 18px; font-weight: 700; line-height: 1.3; color: var(--text); }
    .ev-meta { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-sec); }
    .ev-meta-dot { width: 3px; height: 3px; background: var(--border); border-radius: 50%; }

    /* VOTE LIST */
    .vote-list { display: flex; flex-direction: column; gap: var(--space-2); }
    .vi { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4); background: color-mix(in srgb, var(--tint, var(--accent)) 6%, #fff); border: 1px solid var(--border); border-radius: var(--radius); transition: border-color 0.15s; }
    .vi:hover { border-color: var(--border-hover); }
    .vi-rank { width: 28px; height: 28px; background: var(--bg); color: var(--text-sec); font-weight: 700; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; border: 1px solid var(--border); }
    .vi-info { flex: 1; min-width: 0; }
    .vi-title { font-weight: 600; color: var(--text); font-size: 15px; }
    .vi-desc { font-size: 13px; color: var(--text-sec); margin-top: 2px; }
    .vi-bar { width: 80px; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; flex-shrink: 0; }
    .vi-fill { height: 100%; background: var(--tint, var(--accent)); border-radius: 3px; }
    .vi-count { font-weight: 700; color: var(--text); font-size: 14px; min-width: 30px; text-align: right; }
    .vi-up { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 8px 12px; cursor: pointer; color: var(--text-sec); font-size: 13px; transition: all 0.15s; }
    .vi-up:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
    @media(max-width: 580px) {
      .vi-bar { display: none; }
      .vi-desc { display: none; }
    }

    /* STEPS */
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--space-4); }
    .step { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-5); box-shadow: var(--card-shadow); }
    .step-num { width: 36px; height: 36px; background: var(--accent); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700; font-size: 18px; margin-bottom: var(--space-3); }
    .step h4 { font-family: var(--font-display); font-size: 17px; font-weight: 700; margin-bottom: 6px; }
    .step p { color: var(--text-sec); font-size: 14px; line-height: 1.55; }

    /* TRUST GRID */
    .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-3); }
    .trust-card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4); box-shadow: var(--card-shadow); }
    .tc-icon { width: 40px; height: 40px; background: var(--accent-dim); color: var(--accent); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: var(--space-3); }
    .trust-card h4 { font-family: var(--font-display); font-size: 16px; font-weight: 700; margin-bottom: 4px; }
    .trust-card p { color: var(--text-sec); font-size: 13px; line-height: 1.55; }

    /* FINAL CTA */
    .final-cta { background: linear-gradient(135deg, #E0F2FE, #D1FAE5); margin-top: var(--space-7); }
    .final-cta-inner { text-align: center; padding: var(--space-7) var(--space-5); }
    .final-cta h2 { font-size: clamp(28px, 4vw, 40px); margin-bottom: var(--space-2); }
    .final-cta p { color: var(--text-sec); font-size: 16px; margin-bottom: var(--space-5); }
  </style>

  <script>
    document.querySelectorAll('.vi-up').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        if (!id || id === '0') return;
        try {
          await fetch('/api/recs-vote', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: parseInt(id) }) });
          location.reload();
        } catch {}
      });
    });
  </script>
</Base>
