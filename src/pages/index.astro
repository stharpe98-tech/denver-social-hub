---
import { getDB } from '../lib/db';

const db = getDB();
let upcomingEvents: any[] = [];
try {
  if (db) upcomingEvents = (await db.prepare("SELECT * FROM events ORDER BY id DESC LIMIT 6").all())?.results || [];
} catch {}

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.email === "stharpe98@gmail.com";

const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",other:"📅" };
const typeTint: Record<string,string> = { dinner:"#F05A28",game_night:"#a855f7",outdoor:"#22c55e",brewery:"#fbbf24",coffee:"#FF8A65",arts:"#ec4899",music:"#a855f7",social:"#ec4899",group_tickets:"#3b82f6",camping:"#22c55e",sports_outing:"#3b82f6",bowling:"#fbbf24",active:"#22c55e",casino:"#a855f7",food_trucks:"#F05A28",other:"#6b7a8e" };

const categories = [
  { emoji:"🍽️", label:"Dinners",        sub:"Small tables, long nights", type:"dinner",       tint:"#F05A28" },
  { emoji:"🏔️", label:"Outdoors",       sub:"Hikes, sunrise, trails",    type:"outdoor",      tint:"#22c55e" },
  { emoji:"🎲", label:"Game nights",    sub:"Board games + trivia",      type:"game_night",   tint:"#a855f7" },
  { emoji:"🍺", label:"Brewery crawls", sub:"Denver's best taprooms",    type:"brewery",      tint:"#fbbf24" },
  { emoji:"🎨", label:"Arts + pottery", sub:"Get your hands dirty",      type:"arts",         tint:"#ec4899" },
  { emoji:"🎳", label:"Bowling",        sub:"Strikes + gutters",         type:"bowling",      tint:"#FF8A65" },
  { emoji:"☕", label:"Coffee meets",   sub:"Low-key + local",           type:"coffee",       tint:"#3b82f6" },
  { emoji:"🎉", label:"Just social",    sub:"Turn-up, turn-out",         type:"social",       tint:"#ec4899" },
];

const slides = [
  { img:"https://images.unsplash.com/photo-1546156929-a4c0ac411f47?w=1800&q=80", alt:"Denver skyline at dusk" },
  { img:"https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=1800&q=80", alt:"Pottery studio" },
  { img:"https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=1800&q=80", alt:"Friends at dinner" },
  { img:"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1800&q=80", alt:"Colorado mountains" },
  { img:"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1800&q=80", alt:"Mountain sunset" },
];

const activities = [
  { emoji:"🍽️", title:"Dinner hangs", desc:"Small tables, real conversation. Friends by dessert.", img:"https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=600&q=70", color:"#F05A28" },
  { emoji:"🏔️", title:"Outdoor adventures", desc:"Hikes, sunrise treks, park days across Colorado.", img:"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&q=70", color:"#22c55e" },
  { emoji:"🏺", title:"Pottery nights", desc:"Get your hands dirty. No skill needed.", img:"https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600&q=70", color:"#3b82f6" },
  { emoji:"🎲", title:"Game evenings", desc:"Board games, trivia, zero experience required.", img:"https://images.unsplash.com/photo-1632501641765-e568d28b0015?w=600&q=70", color:"#a855f7" },
  { emoji:"🧶", title:"Fiber arts", desc:"Knitting, crochet — bring your project or start one.", img:"https://images.unsplash.com/photo-1582738411706-bfc8e691d1c2?w=600&q=70", color:"#ec4899" },
  { emoji:"🎳", title:"Bowling nights", desc:"Strikes, gutters, and a whole lot of laughing.", img:"https://images.unsplash.com/photo-1545232979-8bf68ee9b1af?w=600&q=70", color:"#f59e0b" },
];

const crew = [
  { initial:"S", name:"Sarah M.",  zone:"Capitol Hill", fav:"Dinner hangs",     quote:"Moved here knowing nobody. Now I have a group text.",    tint:"#F05A28" },
  { initial:"M", name:"Marco D.",  zone:"Highlands",    fav:"Brewery crawls",   quote:"Tuesdays are now the best night of my week.",             tint:"#fbbf24" },
  { initial:"P", name:"Priya L.",  zone:"RiNo",         fav:"Pottery nights",   quote:"I came for the clay, stayed for the dumpling crawl.",     tint:"#ec4899" },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Denver Social — Show up. See what happens.</title>
  <meta name="description" content="Small-group hangouts across Denver. Dinners, hikes, game nights, brewery crawls. No fees. No awkwardness. Just show up." />
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ═══ NAV — fades in on scroll ═══ -->
<nav id="nav" class="nav">
  <a href="/" class="nav-logo">Denver <em>Social</em></a>
  <div class="nav-links">
    <a href="/events">Events</a>
    <a href="/discover">Discover</a>
    <a href="/members">The Crew</a>
    <a href="/about">About</a>
  </div>
  <div class="nav-auth">
    {user
      ? <a href="/profile" class="nav-btn nav-btn-ghost">My Profile</a>
      : <a href="/login?mode=join" class="nav-btn nav-btn-primary">Join Free</a>
    }
  </div>
</nav>


<!-- ═══ HERO — fullscreen slideshow with Ken Burns ═══ -->
<section class="hero" id="hero">
  {slides.map((s, i) => (
    <div class={`hero-slide ${i === 0 ? 'active' : ''}`} aria-label={s.alt}>
      <div class="hero-slide-img" style={`background-image:url(${s.img})`}></div>
    </div>
  ))}

  <div class="hero-overlay"></div>

  <div class="hero-stickers" aria-hidden="true">
    <span class="sticker s1">🍕</span>
    <span class="sticker s2">🏔️</span>
    <span class="sticker s3">🎲</span>
    <span class="sticker s4">🍻</span>
    <span class="sticker s5">🎨</span>
  </div>

  <div class="hero-content">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      88 Denverites. One group chat. Lots of plans.
    </div>
    <h1 class="hero-h1">
      Your next Denver<br>friends are <em>planning dinner.</em>
    </h1>
    <p class="hero-sub">
      Small-group dinners, hikes, pottery, game nights. First hang is always free. Warm welcome, no awkwardness.
    </p>
    <div class="hero-btns">
      <a href="/login?mode=join" class="btn-party">Join Free →</a>
      <a href="#activities" class="btn-ghost-lg">See What We Do</a>
    </div>
  </div>

  <div class="hero-dots" id="heroDots">
    {slides.map((_, i) => (
      <button class={`hero-dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Slide ${i + 1}`}></button>
    ))}
  </div>

  <div class="hero-scroll" id="scrollHint">
    <div class="hero-scroll-line"></div>
  </div>
</section>


<!-- ═══ CATEGORY SCROLLER — Meetup-style pills ═══ -->
<section class="categories" aria-label="Browse by category">
  <div class="categories-scroll">
    {categories.map((c) => (
      <a href={`/events?type=${c.type}`} class="cat-pill" style={`--tint:${c.tint}`}>
        <span class="cat-emoji">{c.emoji}</span>
        <span class="cat-text">
          <strong>{c.label}</strong>
          <small>{c.sub}</small>
        </span>
      </a>
    ))}
  </div>
</section>


<!-- ═══ ACTIVITY CARDS — photo-backed grid ═══ -->
<section id="activities" class="section">
  <div class="section-head">
    <span class="section-tag">What we do</span>
    <h2 class="section-h2">Pick your thing. <em>Show up.</em></h2>
    <p class="section-sub">No experience needed for any of these. Seriously.</p>
  </div>
  <div class="activity-grid">
    {activities.map((a) => (
      <div class="activity-card fade-up" style={`--tint:${a.color}`}>
        <img src={a.img} alt={a.title} class="activity-img" loading="lazy" />
        <div class="activity-overlay"></div>
        <div class="activity-sticker">{a.emoji}</div>
        <div class="activity-content">
          <h3 class="activity-title">{a.title}</h3>
          <p class="activity-desc">{a.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>


<!-- ═══ MEET THE CREW — humanize the landing ═══ -->
<section class="section crew-section">
  <div class="section-head">
    <span class="section-tag">Meet the crew</span>
    <h2 class="section-h2">A few <em>Denverites</em> you'll meet.</h2>
    <p class="section-sub">Real people, real neighborhoods, real plans.</p>
  </div>
  <div class="crew-grid">
    {crew.map((m) => (
      <div class="crew-card fade-up" style={`--tint:${m.tint}`}>
        <div class="crew-avatar">{m.initial}</div>
        <div class="crew-meta">
          <strong>{m.name}</strong>
          <span>{m.zone}</span>
        </div>
        <span class="crew-fav">{m.fav}</span>
        <p class="crew-quote">"{m.quote}"</p>
      </div>
    ))}
  </div>
</section>


<!-- ═══ HOW IT WORKS — with numbered visual steps ═══ -->
<section class="how-section">
  <div class="how-inner">
    <div class="section-head">
      <span class="section-tag">How it works</span>
      <h2 class="section-h2">Three steps, <em>that's it.</em></h2>
    </div>
    <div class="steps">
      <div class="step fade-up">
        <div class="step-number s-coral">1</div>
        <div class="step-body">
          <h3>Join free</h3>
          <p>60 seconds — name, email, done. No credit card, no subscription.</p>
        </div>
      </div>
      <div class="step-divider fade-up"></div>
      <div class="step fade-up">
        <div class="step-number s-pink">2</div>
        <div class="step-body">
          <h3>Pick something</h3>
          <p>Pottery, dinner, hike, game night. Whatever sounds like you.</p>
        </div>
      </div>
      <div class="step-divider fade-up"></div>
      <div class="step fade-up">
        <div class="step-number s-purple">3</div>
        <div class="step-body">
          <h3>Show up</h3>
          <p>Small group, real people. Walk-ins welcome. No icebreakers, we promise.</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══ UPCOMING EVENTS ═══ -->
{upcomingEvents.length > 0 && (
  <section class="section">
    <div class="section-head">
      <span class="section-tag">Coming up</span>
      <h2 class="section-h2">Happening in <em>Denver</em></h2>
    </div>
    <div class="events-grid">
      {upcomingEvents.slice(0, 4).map((ev: any) => (
        <a href={`/events/${ev.id}`} class="event-card fade-up" style={`--ev-tint:${typeTint[ev.event_type] || '#F05A28'}`}>
          <div class="event-strip"></div>
          <div class="event-body">
            <div class="event-date-badge">
              <span class="event-month">{ev.event_month || 'TBD'}</span>
              <span class="event-day">{ev.event_day || '—'}</span>
            </div>
            <div class="event-info">
              <div class="event-type-row">
                <span class="event-type-emoji">{typeEmoji[ev.event_type] || '📅'}</span>
                <span class="event-type-label">{(ev.event_type || '').replace('_', ' ')}</span>
              </div>
              <h3 class="event-title">{ev.title}</h3>
              <p class="event-meta">{ev.zone || ev.location} · up to {ev.spots} people</p>
            </div>
            <span class="event-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
    <div style="text-align:center;margin-top:32px">
      <a href="/events" class="btn-ghost-lg">All events →</a>
    </div>
  </section>
)}


<!-- ═══ DISCORD CTA — full-width band ═══ -->
<section class="discord-section fade-up">
  <div class="discord-inner">
    <div class="discord-icon">💬</div>
    <div class="discord-text">
      <h3><strong>88</strong> in the group chat. Come say hi.</h3>
      <p>This is where plans actually happen — polls, last-minute hangs, hot takes on Denver's best dumplings.</p>
    </div>
    <a href="https://discord.gg/S8SFNkdSgK" class="discord-btn" target="_blank" rel="noopener">Join the Discord →</a>
  </div>
</section>


<!-- ═══ TRUST / SOCIAL PROOF ═══ -->
<section class="section">
  <div class="trust-grid">
    <div class="trust-quote fade-up">
      <div class="trust-quote-mark">"</div>
      <p>I moved to Denver knowing nobody. Three dinners later, I had a group text with 8 new friends.</p>
      <footer>
        <div class="trust-avatar">S</div>
        <div>
          <strong>Sarah M.</strong>
          <span>Member since Jan 2026</span>
        </div>
      </footer>
    </div>
    <div class="trust-facts fade-up">
      <h3>How we keep hangs cozy.</h3>
      <div class="trust-list">
        <div class="trust-item"><div class="trust-check">✓</div><span>Small groups only — 6 to 12 people, always</span></div>
        <div class="trust-item"><div class="trust-check">✓</div><span>Hosts reply within a day, usually same-night</span></div>
        <div class="trust-item"><div class="trust-check">✓</div><span>Locations stay private until you RSVP</span></div>
        <div class="trust-item"><div class="trust-check">✓</div><span>One hang free. No subscription, no catch.</span></div>
      </div>
    </div>
  </div>
</section>


<!-- ═══ FINAL CTA — gradient mesh ═══ -->
<section class="final-cta">
  <div class="final-cta-mesh" aria-hidden="true"></div>
  <div class="final-cta-stickers" aria-hidden="true">
    <span class="sticker s1">🌮</span>
    <span class="sticker s2">⛺</span>
    <span class="sticker s3">🪩</span>
    <span class="sticker s4">🎟️</span>
  </div>
  <div class="final-cta-content fade-up">
    <h2>See you <em>Thursday?</em></h2>
    <p>Pick a hang. Show up. We handle the rest.</p>
    <a href="/login?mode=join" class="btn-party btn-party-lg">Join Free →</a>
  </div>
</section>


<!-- ═══ FOOTER ═══ -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Denver <em>Social</em></span>
      <p>Real connections, real city.</p>
    </div>
    <div class="footer-links">
      <a href="/events">Events</a>
      <a href="/discover">Discover</a>
      <a href="/members">The Crew</a>
      <a href="/about">About</a>
      <a href="/conduct">Code of Conduct</a>
    </div>
    <div class="footer-links">
      <a href="https://discord.gg/S8SFNkdSgK" target="_blank" rel="noopener">Discord</a>
      <a href="/login?mode=join">Join Free</a>
    </div>
  </div>
</footer>


<!-- ═══ MOBILE NAV ═══ -->
<div class="mob-nav">
  <div class="mob-nav-inner">
    <a href="/" class="active"><span>🏠</span>Home</a>
    <a href="/events"><span>📅</span>Events</a>
    <a href="/discover"><span>🔍</span>Explore</a>
    <a href="/members"><span>👥</span>Crew</a>
    <a href="/about"><span>💬</span>About</a>
    {isAdmin && <a href="/admin"><span>⚙️</span>Admin</a>}
  </div>
</div>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-family: 'DM Sans', sans-serif; background: #05070d; color: #e8ecf4; scroll-behavior: smooth; }
  body { min-height: 100vh; overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  img { display: block; }

  /* ─── NAV ─── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 40px;
    background: rgba(5,7,13,.92); backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,.06);
    transform: translateY(-100%); opacity: 0;
    transition: transform .45s cubic-bezier(.22,1,.36,1), opacity .4s ease;
    pointer-events: none;
  }
  .nav.visible { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .nav-logo { font-family: 'Instrument Serif', serif; font-size: 20px; color: #fff; }
  .nav-logo em { color: #4ade80; font-style: italic; }
  .nav-links { display: flex; gap: 28px; position: absolute; left: 50%; transform: translateX(-50%); }
  .nav-links a { font-size: 14px; font-weight: 500; color: rgba(255,255,255,.45); transition: color .2s; }
  .nav-links a:hover { color: #fff; }
  .nav-auth { display: flex; gap: 8px; }
  .nav-btn { font-size: 13px; font-weight: 700; padding: 8px 20px; border-radius: 50px; transition: transform .2s, box-shadow .3s, background .2s, border-color .2s; }
  .nav-btn-primary {
    color: #fff;
    background: linear-gradient(135deg, #F05A28 0%, #ec4899 55%, #a855f7 100%);
    box-shadow: 0 6px 16px rgba(240,90,40,.28);
  }
  .nav-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 10px 22px rgba(236,72,153,.4); }
  .nav-btn-primary:active { transform: translateY(0); }
  .nav-btn-ghost { color: #fff; border: 1px solid rgba(255,255,255,.15); }
  .nav-btn-ghost:hover { border-color: rgba(255,255,255,.35); background: rgba(255,255,255,.04); }
  .nav-btn-ghost:active { background: rgba(255,255,255,.08); }
  .nav-links a:active { color: #fff; }

  /* ─── HERO ─── */
  .hero { position: relative; width: 100%; height: 100svh; min-height: 640px; overflow: hidden; background: #000; }
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 1.6s ease;
  }
  .hero-slide.active { opacity: 1; }
  .hero-slide.active .hero-slide-img { animation: kenBurns 12s ease forwards; }
  .hero-slide-img {
    position: absolute; inset: -20px;
    background-size: cover; background-position: center;
    will-change: transform;
  }
  @keyframes kenBurns {
    0% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }

  .hero-overlay {
    position: absolute; inset: 0; z-index: 2;
    background:
      linear-gradient(to bottom, rgba(5,7,13,.25) 0%, rgba(5,7,13,.05) 25%, rgba(5,7,13,.3) 55%, rgba(5,7,13,.95) 82%, #05070d 100%),
      radial-gradient(ellipse at 15% 90%, rgba(240,90,40,.18), transparent 55%),
      radial-gradient(ellipse at 85% 85%, rgba(251,191,36,.08), transparent 60%),
      radial-gradient(ellipse at 20% 50%, rgba(59,130,246,.06), transparent 60%);
  }

  .hero-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0 48px 56px; z-index: 10; max-width: 760px;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 16px; border-radius: 50px;
    background: rgba(255,255,255,.08); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.1);
    font-size: 12px; color: rgba(255,255,255,.7); margin-bottom: 22px;
    font-weight: 500;
  }
  .hero-badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,.5); }
  .hero-h1 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(36px, 6vw, 66px);
    font-weight: 400; color: #fff; line-height: 1.04; margin-bottom: 16px;
  }
  .hero-h1 em { font-style: italic; color: #4ade80; }
  .hero-sub {
    font-size: clamp(14px, 1.6vw, 17px); color: rgba(255,255,255,.45);
    line-height: 1.7; max-width: 500px; margin-bottom: 28px;
  }
  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-party {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 15px 34px; color: #fff;
    border-radius: 999px; font-size: 15px; font-weight: 700; letter-spacing: .2px;
    background: linear-gradient(135deg, #F05A28 0%, #ec4899 55%, #a855f7 100%);
    background-size: 200% 100%; background-position: 0% 50%;
    box-shadow: 0 10px 28px rgba(240,90,40,.35), 0 0 0 1px rgba(255,255,255,.06) inset;
    transition: transform .2s cubic-bezier(.22,1,.36,1), box-shadow .3s, background-position .6s;
  }
  .btn-party:hover { transform: translateY(-2px) scale(1.02); background-position: 100% 50%; box-shadow: 0 16px 40px rgba(236,72,153,.45); }
  .btn-party:active { transform: translateY(0) scale(.99); }
  .btn-party-lg { padding: 18px 44px; font-size: 16px; }
  .btn-primary-lg {
    display: inline-block; padding: 14px 32px; background: #fff; color: #05070d;
    border-radius: 14px; font-size: 15px; font-weight: 700;
    transition: transform .2s, box-shadow .3s;
  }
  .btn-primary-lg:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(255,255,255,.12); }
  .btn-ghost-lg {
    display: inline-block; padding: 14px 32px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    color: #fff; border-radius: 14px; font-size: 15px; font-weight: 500;
    transition: background .2s, border-color .2s, transform .2s;
  }
  .btn-ghost-lg:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.2); transform: translateY(-1px); }
  .btn-ghost-lg:active { transform: translateY(0); }

  /* ─── HERO STICKERS ─── */
  .hero-stickers { position: absolute; inset: 0; z-index: 3; pointer-events: none; }
  .hero-stickers .sticker {
    position: absolute; font-size: clamp(34px, 5vw, 52px);
    filter: drop-shadow(0 8px 18px rgba(0,0,0,.35));
    animation: bob 6s ease-in-out infinite;
  }
  .hero-stickers .s1 { top: 12%;  left: 8%;   animation-delay: 0s;   transform: rotate(-12deg); }
  .hero-stickers .s2 { top: 22%;  right: 12%; animation-delay: .6s;  transform: rotate(8deg); }
  .hero-stickers .s3 { top: 54%;  right: 18%; animation-delay: 1.2s; transform: rotate(-6deg); }
  .hero-stickers .s4 { top: 40%;  left: 14%;  animation-delay: 1.8s; transform: rotate(14deg); }
  .hero-stickers .s5 { top: 68%;  right: 8%;  animation-delay: 2.4s; transform: rotate(-10deg); }
  @keyframes bob {
    0%, 100% { translate: 0 0; }
    50%      { translate: 0 -10px; }
  }
  @media (max-width: 768px) {
    .hero-stickers .s3, .hero-stickers .s4 { display: none; }
    .hero-stickers .s1 { top: 8%; left: 6%; }
    .hero-stickers .s2 { top: 14%; right: 6%; }
    .hero-stickers .s5 { top: 44%; right: 6%; }
  }

  .hero-dots { position: absolute; bottom: 40px; right: 48px; z-index: 12; display: flex; gap: 6px; align-items: center; }
  .hero-dot {
    width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,.25);
    border: none; padding: 0; cursor: pointer; transition: all .4s cubic-bezier(.22,1,.36,1);
  }
  .hero-dot.active { width: 22px; border-radius: 3px; background: #fff; }

  .hero-scroll {
    position: absolute; bottom: 32px; left: 48px; z-index: 12; height: 36px;
    opacity: 1; transition: opacity .5s;
  }
  .hero-scroll.hidden { opacity: 0; }
  .hero-scroll-line {
    width: 1px; height: 100%; background: rgba(255,255,255,.2);
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    30% { opacity: 1; }
    60% { transform: scaleY(1); transform-origin: top; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ─── SECTION HEADS ─── */
  .section { max-width: 1040px; margin: 0 auto; padding: 72px 40px; }
  .section-head { margin-bottom: 36px; }
  .section-tag {
    display: inline-block; font-size: 10px; text-transform: uppercase; letter-spacing: .2em;
    color: #3b82f6; font-weight: 700; margin-bottom: 10px;
    padding: 5px 12px; background: rgba(59,130,246,.08); border-radius: 6px;
  }
  .section-h2 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(28px, 4vw, 42px); color: #fff; line-height: 1.1; margin-bottom: 8px;
  }
  .section-h2 em { font-style: italic; color: #4ade80; }
  .section-sub { font-size: 14px; color: rgba(255,255,255,.4); }

  /* ─── CATEGORY SCROLLER (Meetup-style) ─── */
  .categories {
    max-width: 1200px; margin: 0 auto;
    padding: 32px 0 8px;
  }
  .categories-scroll {
    display: flex; gap: 12px;
    padding: 8px 40px 24px;
    overflow-x: auto; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .categories-scroll::-webkit-scrollbar { display: none; }
  .cat-pill {
    scroll-snap-align: start; flex: 0 0 auto;
    display: flex; align-items: center; gap: 12px;
    padding: 14px 20px 14px 16px;
    background: color-mix(in srgb, var(--tint) 10%, rgba(255,255,255,.02));
    border: 1px solid color-mix(in srgb, var(--tint) 28%, transparent);
    border-radius: 999px;
    text-decoration: none;
    transition: transform .25s cubic-bezier(.22,1,.36,1), background .25s, border-color .25s, box-shadow .25s;
  }
  .cat-pill:hover {
    transform: translateY(-3px) rotate(-.6deg);
    background: color-mix(in srgb, var(--tint) 18%, rgba(255,255,255,.04));
    border-color: color-mix(in srgb, var(--tint) 55%, transparent);
    box-shadow: 0 12px 28px color-mix(in srgb, var(--tint) 25%, transparent);
  }
  .cat-pill:active { transform: translateY(-1px) rotate(0); }
  .cat-emoji {
    font-size: 26px; line-height: 1;
    width: 44px; height: 44px; border-radius: 50%;
    background: color-mix(in srgb, var(--tint) 22%, rgba(255,255,255,.04));
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .cat-text { display: flex; flex-direction: column; line-height: 1.2; }
  .cat-text strong { font-size: 14px; color: #fff; font-weight: 700; }
  .cat-text small { font-size: 11px; color: rgba(255,255,255,.45); margin-top: 2px; }
  @media (max-width: 768px) {
    .categories-scroll { padding: 8px 20px 20px; }
  }

  /* ─── ACTIVITY CARDS ─── */
  .activity-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .activity-card {
    position: relative; border-radius: 22px; overflow: hidden;
    height: 240px; display: flex;
    border: 1px solid color-mix(in srgb, var(--tint, #fff) 15%, transparent);
    transition: transform .35s cubic-bezier(.22,1,.36,1), box-shadow .35s, border-color .3s;
  }
  .activity-card:hover {
    transform: translateY(-4px) rotate(-.4deg);
    border-color: color-mix(in srgb, var(--tint, #fff) 50%, transparent);
    box-shadow: 0 18px 40px color-mix(in srgb, var(--tint, #000) 35%, rgba(0,0,0,.4));
  }
  .activity-card:hover .activity-img { transform: scale(1.06); }
  .activity-img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform .6s cubic-bezier(.22,1,.36,1);
  }
  .activity-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(0,0,0,.78) 0%, rgba(0,0,0,.15) 55%, transparent 100%),
      linear-gradient(135deg, color-mix(in srgb, var(--tint, transparent) 55%, transparent) 0%, transparent 55%);
  }
  .activity-sticker {
    position: absolute; top: 14px; left: 14px; z-index: 3;
    width: 44px; height: 44px; border-radius: 50%;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    box-shadow: 0 6px 14px rgba(0,0,0,.35), 0 0 0 3px color-mix(in srgb, var(--tint, #fff) 60%, transparent);
    transform: rotate(-8deg);
    transition: transform .3s cubic-bezier(.22,1,.36,1);
  }
  .activity-card:hover .activity-sticker { transform: rotate(6deg) scale(1.08); }
  .activity-content {
    position: relative; z-index: 2; margin-top: auto; padding: 20px;
  }
  .activity-title { font-size: 17px; color: #fff; font-weight: 700; margin-bottom: 4px; letter-spacing: -.2px; }
  .activity-desc { font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.5; }

  /* ─── CREW CARDS ─── */
  .crew-section {
    background:
      radial-gradient(ellipse at 90% 0%, rgba(236,72,153,.06), transparent 55%),
      radial-gradient(ellipse at 10% 100%, rgba(240,90,40,.06), transparent 55%);
    border-radius: 28px;
    max-width: 1040px; margin: 0 auto;
  }
  .crew-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .crew-card {
    position: relative;
    padding: 28px 22px 24px;
    border-radius: 22px;
    background: color-mix(in srgb, var(--tint, #fff) 5%, rgba(255,255,255,.025));
    border: 1px solid color-mix(in srgb, var(--tint, #fff) 18%, rgba(255,255,255,.05));
    transition: transform .3s cubic-bezier(.22,1,.36,1), border-color .3s, box-shadow .3s;
  }
  .crew-card:hover {
    transform: translateY(-4px) rotate(-.3deg);
    border-color: color-mix(in srgb, var(--tint, #fff) 45%, transparent);
    box-shadow: 0 16px 36px color-mix(in srgb, var(--tint, #000) 22%, rgba(0,0,0,.3));
  }
  .crew-avatar {
    width: 52px; height: 52px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Instrument Serif', serif; font-size: 26px; color: #fff;
    font-weight: 500; letter-spacing: -.5px;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--tint, #F05A28) 100%, transparent) 0%,
      color-mix(in srgb, var(--tint, #ec4899) 65%, #ec4899) 100%);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--tint, #000) 30%, rgba(0,0,0,.35)), inset 0 0 0 2px rgba(255,255,255,.14);
    margin-bottom: 14px;
    transform: rotate(-4deg);
    transition: transform .3s cubic-bezier(.22,1,.36,1);
  }
  .crew-card:hover .crew-avatar { transform: rotate(4deg) scale(1.05); }
  .crew-meta { display: flex; align-items: baseline; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
  .crew-meta strong { font-size: 16px; color: #fff; font-weight: 700; letter-spacing: -.2px; }
  .crew-meta span { font-size: 12px; color: rgba(255,255,255,.45); }
  .crew-fav {
    display: inline-block;
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
    padding: 4px 10px; border-radius: 999px;
    background: color-mix(in srgb, var(--tint, #F05A28) 16%, transparent);
    color: color-mix(in srgb, var(--tint, #fff) 75%, #fff);
    margin-bottom: 14px;
  }
  .crew-quote {
    font-family: 'Instrument Serif', serif;
    font-size: 17px; line-height: 1.35; color: rgba(255,255,255,.88);
    font-style: italic;
  }
  @media (max-width: 768px) {
    .crew-grid { grid-template-columns: 1fr; gap: 12px; }
  }

  /* ─── HOW IT WORKS ─── */
  .how-section {
    background:
      radial-gradient(ellipse at 15% 0%, rgba(240,90,40,.08), transparent 55%),
      radial-gradient(ellipse at 85% 100%, rgba(168,85,247,.07), transparent 55%);
    border-top: 1px solid rgba(255,255,255,.04);
    border-bottom: 1px solid rgba(255,255,255,.04);
    padding: 72px 0;
  }
  .how-inner { max-width: 1040px; margin: 0 auto; padding: 0 40px; }
  .steps { display: flex; align-items: flex-start; gap: 0; margin-top: 12px; }
  .step { flex: 1; display: flex; align-items: flex-start; gap: 16px; }
  .step-number {
    width: 56px; height: 56px; flex-shrink: 0;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Instrument Serif', serif; font-size: 26px; color: #fff;
    font-style: italic; font-weight: 500;
    box-shadow: 0 10px 24px rgba(0,0,0,.35), inset 0 0 0 2px rgba(255,255,255,.12);
    transform: rotate(-6deg);
    transition: transform .3s cubic-bezier(.22,1,.36,1);
  }
  .step:hover .step-number { transform: rotate(6deg) scale(1.06); }
  .step-number.s-coral  { background: linear-gradient(135deg, #F05A28 0%, #fbbf24 100%); }
  .step-number.s-pink   { background: linear-gradient(135deg, #ec4899 0%, #F05A28 100%); }
  .step-number.s-purple { background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%); }
  .step-body h3 { font-size: 17px; color: #fff; margin-bottom: 6px; font-weight: 700; }
  .step-body p { font-size: 13px; color: rgba(255,255,255,.5); line-height: 1.6; }
  .step-divider {
    width: 1px; min-height: 60px; align-self: stretch;
    background: linear-gradient(to bottom, rgba(236,72,153,.3), transparent);
    margin: 0 20px; flex-shrink: 0;
  }

  /* ─── EVENT CARDS ─── */
  .events-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .event-card {
    position: relative; display: flex; flex-direction: column;
    border-radius: 20px; overflow: hidden; text-decoration: none;
    background: rgba(255,255,255,.03);
    border: 1px solid color-mix(in srgb, var(--ev-tint, #fff) 14%, rgba(255,255,255,.06));
    transition: transform .3s cubic-bezier(.22,1,.36,1), border-color .3s, box-shadow .3s;
  }
  .event-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--ev-tint, #fff) 50%, transparent);
    box-shadow: 0 18px 38px color-mix(in srgb, var(--ev-tint, #000) 25%, rgba(0,0,0,.35));
  }
  .event-strip {
    height: 8px;
    background: linear-gradient(90deg,
      color-mix(in srgb, var(--ev-tint, #F05A28) 100%, transparent) 0%,
      color-mix(in srgb, var(--ev-tint, #F05A28) 60%, #ec4899) 100%);
  }
  .event-body {
    display: flex; align-items: center; gap: 16px;
    padding: 20px 22px;
  }
  .event-date-badge {
    text-align: center; padding: 10px 12px; min-width: 58px;
    background: color-mix(in srgb, var(--ev-tint, #F05A28) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--ev-tint, #F05A28) 28%, transparent);
    border-radius: 14px;
  }
  .event-month { display: block; font-size: 10px; font-weight: 700; color: color-mix(in srgb, var(--ev-tint, #fff) 80%, #fff); text-transform: uppercase; letter-spacing: .08em; }
  .event-day { display: block; font-family: 'Instrument Serif', serif; font-size: 26px; color: #fff; line-height: 1.05; }
  .event-info { flex: 1; min-width: 0; }
  .event-type-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .event-type-emoji { font-size: 16px; }
  .event-type-label {
    font-size: 10px; color: color-mix(in srgb, var(--ev-tint, #fff) 75%, #fff);
    font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
    padding: 3px 10px; border-radius: 999px;
    background: color-mix(in srgb, var(--ev-tint, #F05A28) 14%, transparent);
  }
  .event-title { font-size: 16px; color: #fff; font-weight: 700; margin-bottom: 4px; letter-spacing: -.2px; }
  .event-meta { font-size: 12px; color: rgba(255,255,255,.5); }
  .event-arrow {
    font-size: 18px; color: rgba(255,255,255,.35);
    flex-shrink: 0; transition: transform .3s cubic-bezier(.22,1,.36,1), color .2s;
  }
  .event-card:hover .event-arrow { transform: translateX(4px); color: color-mix(in srgb, var(--ev-tint, #fff) 85%, #fff); }
  @media (max-width: 680px) {
    .events-grid { grid-template-columns: 1fr; }
  }

  /* ─── DISCORD ─── */
  .discord-section {
    margin: 0 40px; border-radius: 24px; overflow: hidden;
    background: linear-gradient(135deg, #5865F2 0%, #4752c4 100%);
    position: relative;
  }
  .discord-section::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(255,255,255,.12), transparent 50%);
  }
  .discord-inner {
    position: relative; z-index: 2;
    max-width: 1040px; margin: 0 auto;
    padding: 40px 48px; display: flex; align-items: center; gap: 24px;
  }
  .discord-icon { font-size: 36px; flex-shrink: 0; }
  .discord-text { flex: 1; }
  .discord-text h3 { font-size: 18px; color: #fff; margin-bottom: 4px; }
  .discord-text h3 strong { font-family: 'Instrument Serif', serif; font-size: 24px; }
  .discord-text p { font-size: 13px; color: rgba(255,255,255,.65); line-height: 1.5; }
  .discord-btn {
    padding: 12px 28px; background: #fff; color: #5865F2;
    border-radius: 12px; font-size: 14px; font-weight: 700;
    flex-shrink: 0; transition: transform .2s, box-shadow .2s;
  }
  .discord-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.2); }

  /* ─── TRUST ─── */
  .trust-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .trust-quote {
    background: linear-gradient(135deg, rgba(74,222,128,.06) 0%, rgba(59,130,246,.04) 100%);
    border: 1px solid rgba(74,222,128,.1);
    border-radius: 20px; padding: 36px; position: relative;
  }
  .trust-quote-mark {
    font-family: 'Instrument Serif', serif; font-size: 72px;
    color: rgba(74,222,128,.15); line-height: 0.5; margin-bottom: 16px; display: block;
  }
  .trust-quote p { font-family: 'Instrument Serif', serif; font-size: 20px; color: #fff; line-height: 1.5; margin-bottom: 20px; }
  .trust-quote footer { display: flex; align-items: center; gap: 12px; }
  .trust-avatar {
    width: 36px; height: 36px; border-radius: 50%; background: rgba(74,222,128,.15);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: #4ade80; flex-shrink: 0;
  }
  .trust-quote footer strong { display: block; font-size: 13px; color: #fff; }
  .trust-quote footer span { font-size: 11px; color: rgba(255,255,255,.35); }
  .trust-facts {
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.06);
    border-radius: 20px; padding: 36px;
  }
  .trust-facts h3 { font-size: 18px; color: #fff; margin-bottom: 22px; }
  .trust-list { display: flex; flex-direction: column; gap: 14px; }
  .trust-item { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; color: rgba(255,255,255,.5); line-height: 1.5; }
  .trust-check {
    width: 24px; height: 24px; flex-shrink: 0;
    background: rgba(74,222,128,.1); border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #4ade80; font-size: 12px; font-weight: 700;
  }

  /* ─── FINAL CTA ─── */
  .final-cta {
    position: relative; min-height: 460px; overflow: hidden;
    display: flex; align-items: center; justify-content: center; text-align: center;
    margin-top: 40px;
    background: #05070d;
  }
  .final-cta-mesh {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 55% at 18% 30%, rgba(240,90,40,.55), transparent 65%),
      radial-gradient(ellipse 55% 50% at 82% 25%, rgba(236,72,153,.5), transparent 60%),
      radial-gradient(ellipse 70% 60% at 50% 110%, rgba(168,85,247,.55), transparent 55%),
      radial-gradient(ellipse 40% 40% at 20% 95%, rgba(251,191,36,.28), transparent 60%),
      linear-gradient(180deg, #0a0712 0%, #05070d 100%);
    filter: saturate(1.1);
  }
  .final-cta-mesh::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(5,7,13,.55) 100%);
  }
  .final-cta-stickers { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .final-cta-stickers .sticker {
    position: absolute; font-size: clamp(32px, 4.5vw, 48px);
    filter: drop-shadow(0 8px 18px rgba(0,0,0,.4));
    animation: bob 7s ease-in-out infinite;
  }
  .final-cta-stickers .s1 { top: 18%; left: 10%;  animation-delay: 0s;   transform: rotate(-12deg); }
  .final-cta-stickers .s2 { top: 22%; right: 12%; animation-delay: .8s;  transform: rotate(10deg); }
  .final-cta-stickers .s3 { bottom: 18%; left: 16%; animation-delay: 1.6s; transform: rotate(14deg); }
  .final-cta-stickers .s4 { bottom: 22%; right: 14%; animation-delay: 2.4s; transform: rotate(-8deg); }
  @media (max-width: 768px) {
    .final-cta-stickers .s2, .final-cta-stickers .s4 { display: none; }
  }
  .final-cta-content { position: relative; z-index: 2; padding: 72px 24px; }
  .final-cta-content h2 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(34px, 5.5vw, 56px); color: #fff; line-height: 1.08; margin-bottom: 14px;
    letter-spacing: -.5px;
  }
  .final-cta-content h2 em {
    font-style: italic;
    background: linear-gradient(135deg, #fbbf24 0%, #F05A28 50%, #ec4899 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .final-cta-content p { font-size: 15px; color: rgba(255,255,255,.7); margin-bottom: 32px; }

  /* ─── FOOTER ─── */
  .footer { border-top: 1px solid rgba(255,255,255,.06); padding: 48px 40px; }
  .footer-inner { max-width: 1040px; margin: 0 auto; display: flex; gap: 48px; align-items: flex-start; }
  .footer-brand { flex: 1; }
  .footer-logo { font-family: 'Instrument Serif', serif; font-size: 20px; color: #fff; display: block; margin-bottom: 6px; }
  .footer-logo em { color: #4ade80; font-style: italic; }
  .footer-brand p { font-size: 12px; color: rgba(255,255,255,.3); }
  .footer-links { display: flex; flex-direction: column; gap: 10px; }
  .footer-links a { font-size: 13px; color: rgba(255,255,255,.35); transition: color .2s; }
  .footer-links a:hover { color: #fff; }

  /* ─── MOBILE NAV ─── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: rgba(5,7,13,.95); backdrop-filter: blur(24px);
    border-top: 1px solid rgba(255,255,255,.08);
    padding: 10px 0 max(10px, env(safe-area-inset-bottom));
  }
  .mob-nav-inner {
    display: flex; justify-content: space-around; align-items: center;
    max-width: 540px; margin: 0 auto; padding: 0 8px;
  }
  .mob-nav a {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 8px 6px; font-size: 11px; color: rgba(255,255,255,.35); font-weight: 700; border-radius: 12px;
  }
  .mob-nav a span { font-size: 22px; }
  .mob-nav a.active { color: #fff; background: rgba(96,165,250,.12); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav { padding: 14px 20px; }
    .discord-section { margin: 0 20px; }
    .discord-inner { flex-direction: column; text-align: center; padding: 32px 24px; }
  }
  @media (min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }
  @media (max-width: 768px) {
    body { padding-bottom: 76px; }
    .hero-content { padding: 0 24px 40px; }
    .hero-dots { right: 24px; bottom: 28px; }
    .hero-scroll { left: 24px; }
    .activity-grid { grid-template-columns: 1fr 1fr; }
    .activity-card { height: 180px; }
    .steps { flex-direction: column; gap: 0; }
    .step-divider { width: 40px; min-height: 1px; height: 1px; margin: 16px 0 16px 22px;
      background: linear-gradient(to right, rgba(59,130,246,.2), transparent); }
    .trust-grid { grid-template-columns: 1fr; }
    .events-grid { gap: 8px; }
    .section { padding: 48px 20px; }
    .how-inner { padding: 0 20px; }
    .footer-inner { flex-direction: column; gap: 24px; }
    .footer { padding: 32px 20px; }
    .final-cta { height: 340px; }
  }
  @media (max-width: 480px) {
    .activity-grid { grid-template-columns: 1fr; }
    .activity-card { height: 160px; }
  }

  /* ─── ANIMATIONS ─── */
  .fade-up { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s cubic-bezier(.22,1,.36,1); }
  .fade-up.in { opacity: 1; transform: translateY(0); }
</style>


<script is:inline>
  // ── Slideshow with Ken Burns ──
  var slides = document.querySelectorAll('.hero-slide');
  var dots = document.querySelectorAll('.hero-dot');
  var current = 0;
  var interval;

  function goToSlide(i) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = i;
    // Reset Ken Burns by cloning the img div
    var img = slides[current].querySelector('.hero-slide-img');
    if (img) { img.style.animation = 'none'; img.offsetHeight; img.style.animation = ''; }
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  function nextSlide() { goToSlide((current + 1) % slides.length); }

  function startSlideshow() { interval = setInterval(nextSlide, 5000); }

  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() {
      clearInterval(interval); goToSlide(i); startSlideshow();
    });
  });
  startSlideshow();

  // ── Nav reveal ──
  var nav = document.getElementById('nav');
  var hero = document.getElementById('hero');
  var scrollHint = document.getElementById('scrollHint');
  var navShown = false;

  function onScroll() {
    var y = window.scrollY || window.pageYOffset;
    var t = hero.offsetHeight * 0.55;
    if (y > t && !navShown) { nav.classList.add('visible'); navShown = true; }
    else if (y <= t && navShown) { nav.classList.remove('visible'); navShown = false; }
    if (y > 60) scrollHint.classList.add('hidden');
    else scrollHint.classList.remove('hidden');
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Fade-up on scroll ──
  var fadeEls = document.querySelectorAll('.fade-up');
  if (fadeEls.length && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    fadeEls.forEach(function(el) { obs.observe(el); });
  }
</script>

</body>
