---
import { getDB } from '../lib/db';
import { getContent } from '../lib/content';

const db = getDB();
let upcomingEvents: any[] = [];
let suggestions: any[] = [];
let memberCount = 0;
let eventCount = 0;

try {
  if (db) {
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentDay = now.getDate();
    const monthOrder: Record<string,number> = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};
    const allEvts = (await db.prepare("SELECT * FROM events WHERE is_past IS NULL OR is_past=0 ORDER BY id DESC").all())?.results || [];
    upcomingEvents = allEvts.filter((e: any) => {
      const m = monthOrder[(e.event_month || '').toUpperCase()];
      const d = parseInt(e.event_day) || 99;
      if (m === undefined) return false;
      if (m < currentMonth) return false;
      if (m === currentMonth && d < currentDay) return false;
      return true;
    }).sort((a: any, b: any) => {
      const ma = monthOrder[(a.event_month || '').toUpperCase()] ?? 99;
      const mb = monthOrder[(b.event_month || '').toUpperCase()] ?? 99;
      if (ma !== mb) return ma - mb;
      return (parseInt(a.event_day) || 99) - (parseInt(b.event_day) || 99);
    }).slice(0, 4);
    const mc = await db.prepare("SELECT COUNT(*) as cnt FROM members").first();
    memberCount = mc?.cnt || 0;
    const ec = await db.prepare("SELECT COUNT(*) as cnt FROM events WHERE is_past IS NULL OR is_past=0").first();
    eventCount = ec?.cnt || 0;
    suggestions = (await db.prepare("SELECT * FROM event_suggestions ORDER BY votes DESC LIMIT 4").all())?.results || [];
  }
} catch {}

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
const isAdmin = user?.role === 'admin' || user?.email === "stharpe98@gmail.com";
const redditName = user?.reddit_username || user?.name;

const typeLabel: Record<string,string> = { dinner:"dinner",game_night:"game_night",outdoor:"outdoor",brewery:"brewery",coffee:"coffee",arts:"arts",music:"music",social:"social",group_tickets:"tickets",camping:"camping",sports_outing:"sports",bowling:"bowling",active:"active",casino:"casino",food_trucks:"food",other:"event" };
const content = await getContent();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>/r/events.hub — Denver's Reddit Event Hub</title>
  <meta name="description" content="Real small-group events in Denver. Sign in with Reddit. Your karma is your trust score." />
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <a href="/" class="nav-logo">/r/<span class="nav-accent">events.hub</span></a>
  <div class="nav-links">
    <a href="/events"><span class="nl-icon">~</span>browse</a>
    <a href="/recs"><span class="nl-icon">*</span>recs</a>
    <a href="/about"><span class="nl-icon">?</span>about</a>
  </div>
  <div class="nav-auth">
    {user ? (
      <>
        <a href="/profile" class="nav-user">
          <span class="nav-karma">{user.karma || 0} karma</span>
          <span class="nav-uname">u/{redditName}</span>
        </a>
        <a href="/api/logout" class="nav-out">[logout]</a>
      </>
    ) : (
      <a href="/login" class="nav-cta">Sign in with Reddit</a>
    )}
  </div>
</nav>


<!-- HERO -->
<section class="hero">
  <div class="hero-terminal">
    <div class="hero-line"><span class="hl-prompt">$</span> <span class="hl-cmd">grep</span> <span class="hl-flag">--city</span> <span class="hl-str">"denver"</span> <span class="hl-flag">--type</span> <span class="hl-str">"real_events"</span></div>
    <div class="hero-output">
      <span class="ho-found">Found <strong>{eventCount || 12}</strong> events matching criteria</span>
    </div>
  </div>

  <h1 class="hero-title">Real events.<br/><span class="hero-accent">Real people.</span></h1>
  <p class="hero-sub">Denver's community-run event hub. Sign in with Reddit — your karma is your trust score. No algorithms. Just locals showing up.</p>

  <div class="hero-stats">
    <div class="hs"><span class="hs-num">{memberCount || 88}</span><span class="hs-label">redditors</span></div>
    <div class="hs-dot"></div>
    <div class="hs"><span class="hs-num">{eventCount || 12}</span><span class="hs-label">events</span></div>
    <div class="hs-dot"></div>
    <div class="hs"><span class="hs-num">6-12</span><span class="hs-label">per group</span></div>
  </div>

  <div class="hero-ctas">
    {user ? (
      <a href="/events" class="btn-primary">browse events</a>
    ) : (
      <a href="/login" class="btn-primary">
        <svg viewBox="0 0 20 20" width="16" height="16" fill="currentColor"><path d="M10 0C4.478 0 0 4.478 0 10c0 5.522 4.478 10 10 10s10-4.478 10-10C20 4.478 15.522 0 10 0zm5.8 11.6c.04.2.06.4.06.6 0 2.94-3.42 5.32-7.64 5.32S.58 15.14.58 12.2c0-.22.02-.44.06-.64a1.44 1.44 0 01-.58-1.16c0-.8.64-1.44 1.44-1.44.38 0 .72.14.98.38 1.3-.92 3.1-1.52 5.1-1.58l.98-4.56c.02-.1.08-.18.16-.22.08-.04.18-.06.28-.04l3.24.68c.18-.38.56-.64 1-.64.62 0 1.12.5 1.12 1.12s-.5 1.12-1.12 1.12-1.12-.5-1.12-1.12l-2.9-.6-.86 4.06c1.94.08 3.68.68 4.94 1.56.26-.22.6-.36.96-.36.8 0 1.44.64 1.44 1.44 0 .48-.24.9-.6 1.16z"/></svg>
        sign in with reddit
      </a>
    )}
    <a href="#events" class="btn-ghost">see what's next</a>
  </div>
</section>


<!-- UPCOMING EVENTS -->
{upcomingEvents.length > 0 && (
<section class="section" id="events">
  <div class="sec-head">
    <span class="sec-tag tag tag-orange"># upcoming</span>
    <h2 class="sec-title">live events</h2>
  </div>
  <div class="event-grid">
    {upcomingEvents.map((ev: any) => (
      <a href={`/events/${ev.id}`} class="ev-card">
        <div class="ev-top">
          <span class="ev-type tag tag-blue">{typeLabel[ev.event_type] || 'event'}</span>
          <span class="ev-fill-wrap">
            <span class="ev-fill-bar"><span class="ev-fill" style={`width:${Math.min(100, Math.round((ev.rsvp_count || 0) / (ev.spots || 12) * 100))}%`}></span></span>
            <span class="ev-fill-text">{ev.rsvp_count || 0}/{ev.spots}</span>
          </span>
        </div>
        <h3 class="ev-title">{ev.title}</h3>
        <div class="ev-meta">
          <span>{ev.event_month} {ev.event_day}</span>
          <span class="ev-meta-dot"></span>
          <span>{ev.zone || ev.location || 'Denver'}</span>
        </div>
        {ev.karma_min > 0 && <span class="ev-karma tag tag-yellow">requires {ev.karma_min}+ karma</span>}
      </a>
    ))}
  </div>
  <div style="text-align:center;margin-top:24px">
    <a href="/events" class="btn-ghost">all events →</a>
  </div>
</section>
)}


<!-- COMMUNITY VOTES -->
<section class="section" id="vote">
  <div class="sec-head">
    <span class="sec-tag tag tag-green"># voting</span>
    <h2 class="sec-title">what's next</h2>
    <p class="sec-sub">Community suggests. Community votes. Top picks become real events.</p>
  </div>

  {suggestions.length > 0 ? (
    <div class="vote-list">
      {suggestions.map((s: any, i: number) => (
        <div class="vi">
          <div class="vi-rank">{i + 1}</div>
          <div class="vi-info">
            <div class="vi-title">{s.title}</div>
            {s.description && <div class="vi-desc">{s.description}</div>}
          </div>
          <div class="vi-bar"><div class="vi-fill" style={`width:${Math.min(100, (s.votes || 0) * 3)}%`}></div></div>
          <div class="vi-count">{s.votes || 0}</div>
          <button class="vi-up" data-id={s.id}>▲</button>
        </div>
      ))}
    </div>
  ) : (
    <div class="vote-list">
      <div class="vi"><div class="vi-rank">1</div><div class="vi-info"><div class="vi-title">Korean BBQ Night</div><div class="vi-desc">Cook-your-own meat, Federal Blvd</div></div><div class="vi-bar"><div class="vi-fill" style="width:82%"></div></div><div class="vi-count">41</div><button class="vi-up">▲</button></div>
      <div class="vi"><div class="vi-rank">2</div><div class="vi-info"><div class="vi-title">Red Rocks Sunrise Yoga</div><div class="vi-desc">Early morning yoga + coffee after</div></div><div class="vi-bar"><div class="vi-fill" style="width:68%"></div></div><div class="vi-count">34</div><button class="vi-up">▲</button></div>
      <div class="vi"><div class="vi-rank">3</div><div class="vi-info"><div class="vi-title">Board Game Tournament</div><div class="vi-desc">Catan bracket at Tabletop Tap</div></div><div class="vi-bar"><div class="vi-fill" style="width:55%"></div></div><div class="vi-count">27</div><button class="vi-up">▲</button></div>
    </div>
  )}
</section>


<!-- HOW IT WORKS -->
<section class="how-section">
  <div class="how-inner">
    <div class="sec-head">
      <span class="sec-tag tag tag-orange"># readme</span>
      <h2 class="sec-title">how it works</h2>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-num">01</div>
        <div class="step-body">
          <h3>authenticate</h3>
          <p>Sign in with Reddit. We read your karma and account age — that's it. We never post.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <div class="step-body">
          <h3>browse + rsvp</h3>
          <p>Find an event. Some require minimum karma — keeps things legit. RSVP to lock your spot.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <div class="step-body">
          <h3>show up</h3>
          <p>QR check-in at the door. Show up reliably = build your trust score. Flake = lose it.</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- TRUST -->
<section class="section">
  <div class="sec-head">
    <span class="sec-tag tag tag-green"># trust</span>
    <h2 class="sec-title">the karma gate</h2>
    <p class="sec-sub">Reddit identity as the trust layer. No burner accounts. No strangers.</p>
  </div>
  <div class="trust-grid">
    <div class="trust-card">
      <div class="tc-icon" style="color:var(--accent)">⬆</div>
      <h4>Karma = Trust</h4>
      <p>Events can require minimum karma to RSVP. Higher karma = access to more events.</p>
    </div>
    <div class="trust-card">
      <div class="tc-icon" style="color:var(--green)">✓</div>
      <h4>Reliability Badge</h4>
      <p>Check in via QR. Show up consistently and earn a badge that unlocks priority RSVPs.</p>
    </div>
    <div class="trust-card">
      <div class="tc-icon" style="color:var(--blue)">🔒</div>
      <h4>Address Hidden</h4>
      <p>Event locations are revealed only to confirmed RSVPs who meet the karma gate.</p>
    </div>
    <div class="trust-card">
      <div class="tc-icon" style="color:var(--yellow)">⏳</div>
      <h4>Account Age</h4>
      <p>Some events require accounts older than 30 days. No throwaway signups.</p>
    </div>
  </div>
</section>


<!-- FINAL CTA -->
<section class="final-cta">
  <div class="fc-terminal">
    <span class="fc-prompt">$</span> <span class="fc-cmd">./join</span> <span class="fc-flag">--city</span> <span class="fc-str">"denver"</span>
  </div>
  <h2>Your people are already here.</h2>
  <p>Sign in with Reddit. Takes 10 seconds.</p>
  {user ? (
    <a href="/events" class="btn-primary">browse events →</a>
  ) : (
    <a href="/login" class="btn-primary">
      <svg viewBox="0 0 20 20" width="16" height="16" fill="currentColor"><path d="M10 0C4.478 0 0 4.478 0 10c0 5.522 4.478 10 10 10s10-4.478 10-10C20 4.478 15.522 0 10 0zm5.8 11.6c.04.2.06.4.06.6 0 2.94-3.42 5.32-7.64 5.32S.58 15.14.58 12.2c0-.22.02-.44.06-.64a1.44 1.44 0 01-.58-1.16c0-.8.64-1.44 1.44-1.44.38 0 .72.14.98.38 1.3-.92 3.1-1.52 5.1-1.58l.98-4.56c.02-.1.08-.18.16-.22.08-.04.18-.06.28-.04l3.24.68c.18-.38.56-.64 1-.64.62 0 1.12.5 1.12 1.12s-.5 1.12-1.12 1.12-1.12-.5-1.12-1.12l-2.9-.6-.86 4.06c1.94.08 3.68.68 4.94 1.56.26-.22.6-.36.96-.36.8 0 1.44.64 1.44 1.44 0 .48-.24.9-.6 1.16z"/></svg>
      sign in with reddit →
    </a>
  )}
</section>


<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">/r/<span>events.hub</span></span>
      <p>Denver's Reddit event hub</p>
    </div>
    <div class="footer-links">
      <a href="/events">events</a>
      <a href="/recs">recs</a>
      <a href="/about">about</a>
      <a href="/conduct">conduct</a>
    </div>
  </div>
</footer>


<!-- MOBILE NAV -->
<div class="mob-nav">
  <div class="mob-nav-inner">
    <a href="/" class="active"><span class="mn-icon">~</span>home</a>
    <a href="/events"><span class="mn-icon">#</span>events</a>
    <a href="/recs"><span class="mn-icon">*</span>recs</a>
    <a href="/about"><span class="mn-icon">?</span>about</a>
    {isAdmin && <a href="/admin"><span class="mn-icon">&gt;</span>admin</a>}
  </div>
</div>


<style is:inline>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0e0e10;
    --surface: #1a1a1f;
    --surface-hover: #222228;
    --surface-raised: #26262c;
    --border: #2a2a30;
    --border-hover: #3a3a42;
    --text: #e4e4e7;
    --text-sec: #8b8b94;
    --text-faint: #55555e;
    --accent: #ff4500;
    --accent-dim: rgba(255,69,0,0.15);
    --accent-glow: rgba(255,69,0,0.3);
    --green: #00d26a;
    --green-dim: rgba(0,210,106,0.12);
    --blue: #4a9eff;
    --blue-dim: rgba(74,158,255,0.12);
    --yellow: #ffd93d;
    --yellow-dim: rgba(255,217,61,0.1);
    --red: #ff4757;
    --mono: 'JetBrains Mono', 'Fira Code', monospace;
    --body: 'Inter', system-ui, sans-serif;
  }
  html { font-family: var(--body); background: var(--bg); color: var(--text); scroll-behavior: smooth; }
  body { min-height: 100vh; overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  img { display: block; }
  ::selection { background: var(--accent-dim); color: var(--accent); }

  /* Tags */
  .tag { font-family: var(--mono); font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 4px; display: inline-flex; align-items: center; }
  .tag-orange { background: var(--accent-dim); color: var(--accent); }
  .tag-green { background: var(--green-dim); color: var(--green); }
  .tag-blue { background: var(--blue-dim); color: var(--blue); }
  .tag-yellow { background: var(--yellow-dim); color: var(--yellow); }

  /* Buttons */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; border-radius: 8px;
    font-family: var(--mono); font-size: 13px; font-weight: 700;
    background: var(--accent); color: #fff;
    transition: all .2s;
  }
  .btn-primary:hover { box-shadow: 0 0 24px var(--accent-glow); transform: translateY(-1px); }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; border-radius: 8px;
    font-family: var(--mono); font-size: 13px; font-weight: 600;
    background: var(--surface); color: var(--text-sec);
    border: 1px solid var(--border); transition: all .2s;
  }
  .btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }

  /* NAV */
  .nav {
    position: sticky; top: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 52px;
    background: rgba(14,14,16,.92); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo { font-family: var(--mono); font-weight: 700; font-size: 15px; color: var(--text-sec); }
  .nav-accent { color: var(--accent); }
  .nav-links { display: flex; gap: 2px; position: absolute; left: 50%; transform: translateX(-50%); }
  .nav-links a { font-family: var(--mono); font-size: 13px; font-weight: 500; color: var(--text-faint); padding: 6px 14px; border-radius: 6px; transition: all .2s; display: flex; align-items: center; gap: 4px; }
  .nl-icon { opacity: .5; font-size: 14px; }
  .nav-links a:hover { color: var(--text-sec); background: var(--surface); }
  .nav-auth { display: flex; gap: 8px; align-items: center; }
  .nav-user { display: flex; align-items: center; gap: 8px; padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border); transition: all .2s; }
  .nav-user:hover { border-color: var(--border-hover); background: var(--surface); }
  .nav-karma { font-family: var(--mono); font-size: 11px; font-weight: 600; color: var(--accent); background: var(--accent-dim); padding: 2px 6px; border-radius: 4px; }
  .nav-uname { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--text); }
  .nav-out { font-family: var(--mono); font-size: 11px; color: var(--text-faint); padding: 5px 8px; border-radius: 4px; transition: all .2s; }
  .nav-out:hover { color: var(--red); }
  .nav-cta { font-family: var(--mono); font-size: 12px; font-weight: 600; background: var(--accent); color: #fff; padding: 7px 16px; border-radius: 6px; transition: all .2s; }
  .nav-cta:hover { box-shadow: 0 0 12px var(--accent-glow); }

  /* HERO */
  .hero {
    padding: 60px 32px 48px; text-align: center; position: relative;
    border-bottom: 1px solid var(--border);
  }
  .hero::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, var(--accent-dim), transparent 70%);
    pointer-events: none; opacity: .4;
  }
  .hero-terminal {
    display: inline-block;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 20px;
    margin-bottom: 28px; text-align: left;
  }
  .hero-line { font-family: var(--mono); font-size: 13px; margin-bottom: 6px; }
  .hl-prompt { color: var(--accent); font-weight: 700; }
  .hl-cmd { color: var(--text); }
  .hl-flag { color: var(--blue); }
  .hl-str { color: var(--green); }
  .hero-output { font-family: var(--mono); font-size: 12px; }
  .ho-found { color: var(--text-sec); }
  .ho-found strong { color: var(--accent); }

  .hero-title {
    font-family: var(--body); font-size: clamp(36px, 5vw, 56px);
    font-weight: 800; line-height: 1.05; letter-spacing: -0.04em;
    margin-bottom: 14px; position: relative;
  }
  .hero-accent { color: var(--accent); }
  .hero-sub {
    font-size: 15px; color: var(--text-sec); max-width: 500px;
    margin: 0 auto 24px; line-height: 1.7;
  }
  .hero-stats {
    display: flex; align-items: center; justify-content: center; gap: 20px;
    margin-bottom: 28px;
  }
  .hs { text-align: center; }
  .hs-num { font-family: var(--mono); font-weight: 700; font-size: 22px; color: var(--text); display: block; }
  .hs-label { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }
  .hs-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--border); }
  .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* SECTIONS */
  .section { padding: 56px 32px; max-width: 900px; margin: 0 auto; }
  .sec-head { margin-bottom: 24px; }
  .sec-tag { margin-bottom: 8px; }
  .sec-title { font-family: var(--body); font-size: 28px; font-weight: 800; letter-spacing: -0.03em; color: var(--text); }
  .sec-sub { font-size: 14px; color: var(--text-sec); margin-top: 6px; line-height: 1.6; }

  /* EVENT GRID */
  .event-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .ev-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 18px; transition: all .25s;
    display: flex; flex-direction: column; gap: 10px;
  }
  .ev-card:hover { border-color: var(--border-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .ev-top { display: flex; align-items: center; justify-content: space-between; }
  .ev-fill-wrap { display: flex; align-items: center; gap: 6px; }
  .ev-fill-bar { width: 48px; height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; }
  .ev-fill { height: 100%; border-radius: 2px; background: var(--green); }
  .ev-fill-text { font-family: var(--mono); font-size: 10px; color: var(--text-faint); }
  .ev-title { font-weight: 700; font-size: 15px; color: var(--text); }
  .ev-meta { font-family: var(--mono); font-size: 12px; color: var(--text-faint); display: flex; align-items: center; gap: 6px; }
  .ev-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-faint); }
  .ev-karma { margin-top: 2px; }

  /* VOTE LIST */
  .vote-list { display: flex; flex-direction: column; gap: 8px; }
  .vi {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 16px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; transition: all .2s;
  }
  .vi:hover { border-color: var(--border-hover); }
  .vi-rank { font-family: var(--mono); font-weight: 700; font-size: 16px; color: var(--text-faint); min-width: 20px; text-align: center; }
  .vi-info { flex: 1; }
  .vi-title { font-weight: 600; font-size: 14px; color: var(--text); }
  .vi-desc { font-size: 12px; color: var(--text-sec); margin-top: 2px; }
  .vi-bar { width: 80px; height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; }
  .vi-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--accent), var(--yellow)); }
  .vi-count { font-family: var(--mono); font-weight: 700; font-size: 15px; color: var(--accent); min-width: 28px; text-align: right; }
  .vi-up {
    width: 28px; height: 28px; border-radius: 6px; background: var(--accent-dim);
    border: 1px solid transparent; color: var(--accent); font-size: 12px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all .15s; flex-shrink: 0; font-family: var(--mono);
  }
  .vi-up:hover { background: var(--accent); color: #fff; }

  /* HOW IT WORKS */
  .how-section {
    padding: 56px 0; border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border); background: var(--surface);
  }
  .how-inner { max-width: 900px; margin: 0 auto; padding: 0 32px; }
  .steps { display: flex; gap: 20px; margin-top: 0; }
  .step {
    flex: 1; display: flex; flex-direction: column; gap: 10px;
    padding: 20px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px;
  }
  .step-num {
    font-family: var(--mono); font-size: 24px; font-weight: 700;
    color: var(--accent); opacity: .4;
  }
  .step-body h3 { font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
  .step-body p { font-size: 13px; color: var(--text-sec); line-height: 1.6; }

  /* TRUST GRID */
  .trust-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .trust-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px;
  }
  .tc-icon { font-size: 20px; margin-bottom: 10px; display: block; }
  .trust-card h4 { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .trust-card p { font-size: 13px; color: var(--text-sec); line-height: 1.6; }

  /* FINAL CTA */
  .final-cta {
    padding: 64px 32px; text-align: center;
    border-top: 1px solid var(--border);
    position: relative;
  }
  .final-cta::before {
    content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 400px; height: 200px;
    background: radial-gradient(ellipse, var(--accent-dim), transparent 70%);
    pointer-events: none; opacity: .3;
  }
  .fc-terminal {
    font-family: var(--mono); font-size: 14px; margin-bottom: 20px;
    display: inline-block; padding: 8px 16px;
    background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
  }
  .fc-prompt { color: var(--accent); font-weight: 700; }
  .fc-cmd { color: var(--text); }
  .fc-flag { color: var(--blue); }
  .fc-str { color: var(--green); }
  .final-cta h2 {
    font-size: 32px; font-weight: 800; letter-spacing: -0.03em;
    margin-bottom: 8px; position: relative;
  }
  .final-cta p { font-size: 14px; color: var(--text-sec); margin-bottom: 24px; }

  /* FOOTER */
  .footer { border-top: 1px solid var(--border); padding: 32px; }
  .footer-inner { max-width: 900px; margin: 0 auto; display: flex; gap: 48px; align-items: flex-start; }
  .footer-brand { flex: 1; }
  .footer-logo { font-family: var(--mono); font-weight: 700; font-size: 14px; color: var(--text-sec); display: block; margin-bottom: 4px; }
  .footer-logo span { color: var(--accent); }
  .footer-brand p { font-size: 12px; color: var(--text-faint); }
  .footer-links { display: flex; flex-direction: column; gap: 8px; }
  .footer-links a { font-family: var(--mono); font-size: 12px; color: var(--text-faint); transition: color .2s; }
  .footer-links a:hover { color: var(--text); }

  /* MOBILE NAV */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: rgba(14,14,16,.95); backdrop-filter: blur(24px);
    border-top: 1px solid var(--border);
    padding: 4px 0 max(4px, env(safe-area-inset-bottom));
  }
  .mob-nav-inner { display: flex; justify-content: space-around; align-items: center; max-width: 540px; margin: 0 auto; }
  .mob-nav a {
    display: flex; flex-direction: column; align-items: center; gap: 1px;
    padding: 6px 10px; font-size: 10px; color: var(--text-faint);
    font-family: var(--mono); font-weight: 500; border-radius: 6px; transition: all .2s;
  }
  .mn-icon { font-size: 16px; font-weight: 700; line-height: 1.2; }
  .mob-nav a.active { color: var(--accent); background: var(--accent-dim); }

  /* RESPONSIVE */
  @media (min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }
  @media (max-width: 900px) { .nav-links { display: none; } .nav { padding: 0 16px; } }
  @media (max-width: 768px) {
    body { padding-bottom: 72px; }
    .hero { padding: 40px 20px 36px; }
    .hero-stats { gap: 12px; }
    .hs-num { font-size: 18px; }
    .event-grid { grid-template-columns: 1fr; }
    .steps { flex-direction: column; }
    .trust-grid { grid-template-columns: 1fr; }
    .section { padding: 40px 20px; }
    .how-inner { padding: 0 20px; }
    .footer-inner { flex-direction: column; gap: 20px; }
    .footer { padding: 24px 20px; }
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--border-hover); }
</style>

<script is:inline>
  // Vote buttons
  document.querySelectorAll('.vi-up').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var vi = this.closest('.vi');
      var c = vi.querySelector('.vi-count');
      var f = vi.querySelector('.vi-fill');
      c.textContent = parseInt(c.textContent) + 1;
      var w = parseInt(f.style.width) || 0;
      f.style.width = Math.min(100, w + 2) + '%';
      this.style.background = 'var(--accent)';
      this.style.color = '#fff';
      this.textContent = '✓';
      this.disabled = true;
    });
  });
</script>

</body>
</html>
