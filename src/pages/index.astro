---
import { getDB } from '../lib/db';

const db = getDB();
let upcomingEvents: any[] = [];
try {
  if (db) upcomingEvents = (await db.prepare("SELECT * FROM events ORDER BY id DESC LIMIT 6").all())?.results || [];
} catch {}

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",other:"📅" };
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DSN Denver — Real small-group events</title>
  <meta name="description" content="We organize small-group hangouts across Denver. Dinners, hikes, game nights, brewery crawls. No fees. No awkwardness. Just show up." />
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="margin:0;background:#05070d;color:#e8ecf4;font-family:'DM Sans',sans-serif;padding-bottom:80px">

  <!-- NAV -->
  <nav id="hp-nav" style="position:fixed;top:0;left:0;right:0;z-index:100;padding:16px 40px;display:flex;align-items:center;justify-content:space-between;transition:all .35s">
    <a href="/" style="font-family:'Instrument Serif',serif;font-size:20px;color:#fff;text-decoration:none;flex-shrink:0">DSN <em style="color:#4ade80;font-style:italic">Denver</em></a>
    <div class="hp-nav-links" style="display:flex;gap:28px" class="hp-nav-links">
      <a href="/discover" style="font-size:13px;color:rgba(255,255,255,.6);text-decoration:none;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'">Explore</a>
      <a href="/members"  style="font-size:13px;color:rgba(255,255,255,.6);text-decoration:none;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'">The Crew</a>
      <a href="/fund"     style="font-size:13px;color:rgba(255,255,255,.6);text-decoration:none;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'">🤝 Fund</a>
      <a href="/about"    style="font-size:13px;color:rgba(255,255,255,.6);text-decoration:none;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'">About</a>
    </div>
    <div class="hp-nav-auth">
      {user
        ? <a href="/profile" style="padding:8px 22px;background:rgba(255,255,255,.08);color:#fff;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,.1)">My Profile</a>
        : <a href="/login"   style="padding:8px 22px;background:rgba(255,255,255,.08);color:#fff;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,.1)">Join the Fun</a>
      }
    </div>
  </nav>

  <!-- HERO -->
  <div style="position:relative;min-height:100svh;display:flex;align-items:center;justify-content:center;overflow:hidden">
    <div style="position:absolute;inset:0">
      <img src="https://images.unsplash.com/photo-1546156929-a4c0ac411f47?w=1400&q=75" alt="Denver" style="width:100%;height:100%;object-fit:cover;filter:brightness(.28) saturate(1.15)" />
    </div>
    <div style="position:absolute;inset:0;z-index:1;background:radial-gradient(ellipse at 25% 35%,rgba(96,165,250,.14),transparent 50%)"></div>
    <div style="position:absolute;bottom:0;left:0;right:0;height:35%;z-index:5;background:linear-gradient(transparent,#05070d)"></div>
    <div style="position:relative;z-index:10;text-align:center;padding:0 24px;max-width:660px">
      <p style="font-size:12px;color:rgba(255,255,255,.35);margin-bottom:16px;letter-spacing:.06em">📍 Denver, Colorado</p>
      <h1 style="font-family:'Instrument Serif',serif;font-size:clamp(34px,6vw,64px);font-weight:400;color:#fff;line-height:1.06;margin-bottom:16px">
        Tired of not knowing<br>anyone in <em style="font-style:italic;color:#4ade80">Denver?</em>
      </h1>
      <p style="font-size:clamp(13px,1.6vw,16px);color:rgba(255,255,255,.4);line-height:1.7;max-width:440px;margin:0 auto 28px">
        We organize small-group hangouts across Denver. Dinners, hikes, game nights, brewery crawls. No fees. No awkwardness. Just show up.
      </p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:32px">
        <a href="/login?mode=join" style="padding:14px 32px;background:#fff;color:#000;border-radius:14px;font-size:14px;font-weight:700;text-decoration:none">Join Free →</a>
        <a href="#how" style="padding:14px 32px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:#fff;border-radius:14px;font-size:14px;font-weight:500;text-decoration:none">How it works</a>
      </div>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <div style="padding:10px 18px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);border-radius:12px;text-align:center">
          <b style="font-family:'Instrument Serif',serif;font-size:18px;color:#fff;display:block">88+</b>
          <span style="font-size:9px;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em">In Discord</span>
        </div>
        <div style="padding:10px 18px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);border-radius:12px;text-align:center">
          <b style="font-family:'Instrument Serif',serif;font-size:18px;color:#fff;display:block">{upcomingEvents.length}</b>
          <span style="font-size:9px;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em">Events</span>
        </div>
        <div style="padding:10px 18px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);border-radius:12px;text-align:center">
          <b style="font-family:'Instrument Serif',serif;font-size:18px;color:#fff;display:block">Free</b>
          <span style="font-size:9px;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em">Always</span>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div id="how" style="max-width:960px;margin:0 auto;padding:56px 40px" class="hp-section">
    <div style="font-size:10px;text-transform:uppercase;letter-spacing:.2em;color:#3b82f6;font-weight:600;margin-bottom:18px;display:flex;align-items:center;gap:10px">
      How it works<span style="flex:1;height:1px;background:rgba(255,255,255,.06)"></span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:52px" class="hp-steps">
      {[
        { emoji:"📋", title:"Join for free", desc:"60 seconds. Just your name and email." },
        { emoji:"🎯", title:"Pick an event",  desc:"Dinners, hikes, games — whatever sounds fun." },
        { emoji:"🤝", title:"Show up",        desc:"Small group, real people. No icebreakers." },
      ].map(s => (
        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:24px">
          <div style="font-size:28px;margin-bottom:12px">{s.emoji}</div>
          <h3 style="font-size:16px;color:#fff;margin-bottom:6px">{s.title}</h3>
          <p style="font-size:13px;color:#6b7a8e;line-height:1.6">{s.desc}</p>
        </div>
      ))}
    </div>

    <!-- EVENTS PREVIEW -->
    {upcomingEvents.length > 0 && (
      <div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.2em;color:#3b82f6;font-weight:600;margin-bottom:18px;display:flex;align-items:center;gap:10px">
          This week in Denver<span style="flex:1;height:1px;background:rgba(255,255,255,.06)"></span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:40px" class="hp-grid-2">
          {upcomingEvents.slice(0,4).map((ev:any) => (
            <a href={`/events/${ev.id}`} style="display:block;padding:18px;border-radius:14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);text-decoration:none;color:#e8ecf4">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
                <span style="font-size:14px">{typeEmoji[ev.event_type]||'📅'}</span>
                <span style="font-size:10px;color:#4a5568">{ev.zone}</span>
              </div>
              <h3 style="font-size:14px;color:#fff;margin-bottom:4px">{ev.title}</h3>
              <div style="font-size:11px;color:#4a5568">{ev.event_month} {ev.event_day} · {ev.spots} spots</div>
            </a>
          ))}
        </div>
        <div style="text-align:center">
          <a href="/discover" style="padding:14px 32px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:#fff;border-radius:14px;font-size:14px;font-weight:500;text-decoration:none">See All Events →</a>
        </div>
      </div>
    )}

    <!-- TRUST -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:56px" class="hp-trust">
      <blockquote style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:28px;font-family:'Instrument Serif',serif;font-size:18px;color:#fff;line-height:1.5;margin:0">
        "I moved to Denver knowing nobody. Three dinners later, I had a group text with 8 new friends."
        <footer style="font-size:12px;color:#4a5568;font-family:'DM Sans',sans-serif;margin-top:12px;font-style:normal">— Member since January 2026</footer>
      </blockquote>
      <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:28px">
        <h3 style="font-size:16px;color:#fff;margin-bottom:16px">Built for trust.</h3>
        {[
          "Every member is approved before RSVP",
          "Locations are private until you RSVP",
          "Small groups only — 6 to 12 people",
          "One-strike policy for bad behavior",
        ].map(item => (
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px;color:#6b7a8e">
            <span style="color:#4ade80">✓</span>{item}
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div style="text-align:center;margin-top:64px">
      <h2 style="font-family:'Instrument Serif',serif;font-size:36px;color:#fff;margin-bottom:8px">Ready to <em style="color:#4ade80;font-style:italic">show up?</em></h2>
      <p style="font-size:14px;color:#6b7a8e;margin-bottom:24px">Free forever. Takes 60 seconds to join.</p>
      <a href="/login?mode=join" style="padding:16px 40px;background:#fff;color:#000;border-radius:14px;font-size:15px;font-weight:700;text-decoration:none">Join Free →</a>
    </div>
  </div>

  <!-- MOBILE NAV -->
  <div class="hp-mob-nav" style="position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#05070df2;backdrop-filter:blur(24px);border-top:1px solid rgba(255,255,255,.08);padding:10px 0">
    <div style="display:flex;justify-content:space-around;align-items:center;max-width:540px;margin:0 auto;padding:0 8px">
      {[
        { href:"/",        emoji:"🏠", label:"Home"    },
        { href:"/discover",emoji:"🔍", label:"Explore"  },
        { href:"/members", emoji:"👥", label:"Crew"     },
        { href:"/fund",    emoji:"🤝", label:"Fund"     },
        { href:"/about",   emoji:"💬", label:"About"    },
      ].map(l => (
        <a href={l.href} style="display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:8px 6px;font-size:11px;color:rgba(255,255,255,.4);font-weight:700;border-radius:12px">
          <span style="font-size:22px">{l.emoji}</span>{l.label}
        </a>
      ))}
      {!user && <a href="/login" style="display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;padding:8px 6px;font-size:11px;color:#60a5fa;font-weight:700;border-radius:12px"><span style="font-size:22px">✨</span>Join</a>}
    </div>
  </div>

<style>
  /* Hide desktop nav links + auth button on mobile */
  @media (max-width: 900px) {
    .hp-nav-links { display: none !important; }
    .hp-nav-auth  { display: none !important; }
    #hp-nav { padding: 16px 20px; }
  }
  /* Hide mobile bottom nav on desktop */
  @media (min-width: 901px) {
    .hp-mob-nav { display: none !important; }
    body { padding-bottom: 0; }
  }
  /* Mobile layout fixes */
  @media (max-width: 768px) {
    .hp-steps { grid-template-columns: 1fr !important; }
    .hp-grid-2 { grid-template-columns: 1fr !important; }
    .hp-trust { grid-template-columns: 1fr !important; }
    .hp-section { padding: 40px 20px !important; }
    #hp-nav { padding: 14px 20px !important; }
    body { padding-bottom: 70px; }
  }
</style>
</body>
</html>
