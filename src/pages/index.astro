---
import { getDB } from '../lib/db';

const db = getDB();
let upcomingEvents: any[] = [];
try {
  if (db) upcomingEvents = (await db.prepare("SELECT * FROM events ORDER BY id DESC LIMIT 6").all())?.results || [];
} catch {}

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.email === "stharpe98@gmail.com";

const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",other:"📅" };

const slides = [
  { img:"https://images.unsplash.com/photo-1546156929-a4c0ac411f47?w=1600&q=80", alt:"Denver skyline at dusk" },
  { img:"https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=1600&q=80", alt:"Pottery studio" },
  { img:"https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=1600&q=80", alt:"Friends at dinner" },
  { img:"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=80", alt:"Colorado mountains" },
  { img:"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=80", alt:"Mountain sunset" },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Denver Social — Show up. See what happens.</title>
  <meta name="description" content="We organize small-group hangouts across Denver. Dinners, hikes, game nights, brewery crawls. No fees. No awkwardness. Just show up." />
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ═══════════════════════════════════════════
     NAV — hidden by default, fades in on scroll
     ═══════════════════════════════════════════ -->
<nav id="nav" class="nav">
  <a href="/" class="nav-logo">Denver <em>Social</em></a>
  <div class="nav-links">
    <a href="/events">Events</a>
    <a href="/members">The Crew</a>
    <a href="/about">About</a>
  </div>
  <div class="nav-auth">
    {user
      ? <a href="/profile" class="nav-btn nav-btn-ghost">My Profile</a>
      : <a href="/login?mode=join" class="nav-btn nav-btn-primary">Join Free</a>
    }
  </div>
</nav>


<!-- ═══════════════════════════════════════════
     HERO — fullscreen slideshow, no chrome
     ═══════════════════════════════════════════ -->
<section class="hero" id="hero">
  {slides.map((s, i) => (
    <div class={`hero-slide ${i === 0 ? 'active' : ''}`} style={`background-image:url(${s.img})`} aria-label={s.alt}></div>
  ))}

  <div class="hero-gradient"></div>

  <div class="hero-content">
    <p class="hero-loc">📍 Denver, Colorado</p>
    <h1 class="hero-h1">
      Tired of not knowing<br>anyone in <em>Denver?</em>
    </h1>
    <p class="hero-sub">
      Small-group hangouts across Denver — dinners, hikes, game nights, brewery crawls. No fees. No awkwardness. Just show up.
    </p>
    <div class="hero-btns">
      <a href="/login?mode=join" class="btn-hero-primary">Join Free →</a>
      <a href="#how" class="btn-hero-ghost">How it works</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <strong>88+</strong>
        <span>In Discord</span>
      </div>
      <div class="hero-stat">
        <strong>{upcomingEvents.length}</strong>
        <span>Events</span>
      </div>
      <div class="hero-stat">
        <strong>Free</strong>
        <span>Always</span>
      </div>
    </div>
  </div>

  <div class="hero-dots" id="heroDots">
    {slides.map((_, i) => (
      <button class={`hero-dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Slide ${i + 1}`}></button>
    ))}
  </div>

  <div class="scroll-hint" id="scrollHint">
    <span>Scroll</span>
    <div class="scroll-arrow"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     HOW IT WORKS
     ═══════════════════════════════════════════ -->
<section id="how" class="section">
  <div class="section-label">
    How it works<span class="section-line"></span>
  </div>
  <div class="steps">
    <div class="step fade-up">
      <div class="step-num">01</div>
      <h3 class="step-title">Join for free</h3>
      <p class="step-desc">60 seconds. Connect with Discord and tell us what you're into.</p>
    </div>
    <div class="step fade-up">
      <div class="step-num">02</div>
      <h3 class="step-title">Pick an event</h3>
      <p class="step-desc">Dinners, hikes, pottery, game nights — whatever sounds fun.</p>
    </div>
    <div class="step fade-up">
      <div class="step-num">03</div>
      <h3 class="step-title">Show up</h3>
      <p class="step-desc">Small group, real people. No icebreakers. Walk-ins welcome.</p>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     UPCOMING EVENTS
     ═══════════════════════════════════════════ -->
{upcomingEvents.length > 0 && (
  <section class="section">
    <div class="section-label">
      Coming up in Denver<span class="section-line"></span>
    </div>
    <div class="events-grid">
      {upcomingEvents.slice(0, 4).map((ev: any) => (
        <a href={`/events/${ev.id}`} class="event-card fade-up">
          <div class="event-card-top">
            <span class="event-emoji">{typeEmoji[ev.event_type] || '📅'}</span>
            <span class="event-zone">{ev.zone}</span>
          </div>
          <h3 class="event-title">{ev.title}</h3>
          <div class="event-meta">{ev.event_month} {ev.event_day} · {ev.spots} spots</div>
        </a>
      ))}
    </div>
    <div class="section-cta">
      <a href="/events" class="btn-ghost-lg">See All Events →</a>
    </div>
  </section>
)}


<!-- ═══════════════════════════════════════════
     TRUST / SOCIAL PROOF
     ═══════════════════════════════════════════ -->
<section class="section">
  <div class="trust-grid">
    <blockquote class="testimonial fade-up">
      <p>"I moved to Denver knowing nobody. Three dinners later, I had a group text with 8 new friends."</p>
      <footer>— Member since January 2026</footer>
    </blockquote>
    <div class="trust-card fade-up">
      <h3>Built for trust.</h3>
      <div class="trust-items">
        <div class="trust-item"><span class="check">✓</span> Every member is approved before RSVP</div>
        <div class="trust-item"><span class="check">✓</span> Locations are private until you RSVP</div>
        <div class="trust-item"><span class="check">✓</span> Small groups only — 6 to 12 people</div>
        <div class="trust-item"><span class="check">✓</span> One-strike policy for bad behavior</div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     FINAL CTA
     ═══════════════════════════════════════════ -->
<section class="section" style="text-align:center;padding-bottom:80px">
  <h2 class="cta-h2 fade-up">Ready to <em>show up?</em></h2>
  <p class="cta-sub fade-up">Free forever. Takes 60 seconds to join.</p>
  <a href="/login?mode=join" class="btn-hero-primary fade-up" style="font-size:15px;padding:16px 40px">Join Free →</a>
</section>


<!-- ═══════════════════════════════════════════
     MOBILE BOTTOM NAV
     ═══════════════════════════════════════════ -->
<div class="mob-nav">
  <div class="mob-nav-inner">
    <a href="/" class="active"><span>🏠</span>Home</a>
    <a href="/events"><span>📅</span>Events</a>
    <a href="/members"><span>👥</span>Crew</a>
    <a href="/about"><span>💬</span>About</a>
    {isAdmin && <a href="/admin"><span>⚙️</span>Admin</a>}
  </div>
</div>


<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-family: 'DM Sans', sans-serif; background: #05070d; color: #e8ecf4; scroll-behavior: smooth; }
  body { min-height: 100vh; }
  a { color: inherit; text-decoration: none; }

  /* ─── NAV (hidden until scroll) ─── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 40px;
    background: rgba(5,7,13,.92); backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,.06);
    transform: translateY(-100%); opacity: 0;
    transition: transform .4s cubic-bezier(.22,1,.36,1), opacity .4s ease;
    pointer-events: none;
  }
  .nav.visible { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .nav-logo { font-family: 'Instrument Serif', serif; font-size: 20px; color: #fff; }
  .nav-logo em { color: #4ade80; font-style: italic; }
  .nav-links { display: flex; gap: 28px; position: absolute; left: 50%; transform: translateX(-50%); }
  .nav-links a { font-size: 14px; font-weight: 500; color: rgba(255,255,255,.45); transition: color .2s; }
  .nav-links a:hover { color: #fff; }
  .nav-auth { display: flex; gap: 8px; }
  .nav-btn { font-size: 13px; font-weight: 600; padding: 7px 18px; border-radius: 50px; transition: all .2s; }
  .nav-btn-primary { background: #3b82f6; color: #fff; }
  .nav-btn-primary:hover { background: #2563eb; }
  .nav-btn-ghost { color: #fff; border: 1px solid rgba(255,255,255,.15); }
  .nav-btn-ghost:hover { border-color: rgba(255,255,255,.3); }

  /* ─── HERO ─── */
  .hero { position: relative; width: 100%; height: 100svh; min-height: 600px; overflow: hidden; background: #05070d; }
  .hero-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0; transition: opacity 1.4s ease; will-change: opacity;
  }
  .hero-slide::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(5,7,13,.15) 0%, rgba(5,7,13,.1) 30%,
      rgba(5,7,13,.4) 60%, rgba(5,7,13,.92) 85%, #05070d 100%);
  }
  .hero-slide.active { opacity: 1; }
  .hero-gradient {
    position: absolute; bottom: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(transparent, #05070d); z-index: 5; pointer-events: none;
  }
  .hero-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0 40px 48px; z-index: 10; max-width: 720px;
  }
  .hero-loc { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: rgba(255,255,255,.3); margin-bottom: 16px; }
  .hero-h1 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(32px, 5.5vw, 60px);
    font-weight: 400; color: #fff; line-height: 1.06; margin-bottom: 14px;
  }
  .hero-h1 em { font-style: italic; color: #4ade80; }
  .hero-sub { font-size: clamp(13px, 1.5vw, 16px); color: rgba(255,255,255,.4); line-height: 1.7; max-width: 480px; margin-bottom: 24px; }
  .hero-btns { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
  .btn-hero-primary {
    display: inline-block; padding: 13px 30px; background: #fff; color: #05070d;
    border-radius: 12px; font-size: 14px; font-weight: 700;
    transition: transform .15s, box-shadow .2s;
  }
  .btn-hero-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(255,255,255,.1); }
  .btn-hero-ghost {
    display: inline-block; padding: 13px 30px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    color: #fff; border-radius: 12px; font-size: 14px; font-weight: 500; transition: background .2s;
  }
  .btn-hero-ghost:hover { background: rgba(255,255,255,.1); }
  .hero-stats { display: flex; gap: 10px; flex-wrap: wrap; }
  .hero-stat {
    padding: 8px 16px; background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.07); border-radius: 10px; text-align: center;
  }
  .hero-stat strong { font-family: 'Instrument Serif', serif; font-size: 17px; color: #fff; display: block; }
  .hero-stat span { font-size: 9px; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.3); }

  /* Dots */
  .hero-dots { position: absolute; bottom: 32px; right: 40px; z-index: 12; display: flex; gap: 6px; align-items: center; }
  .hero-dot {
    width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,.25);
    border: none; padding: 0; cursor: pointer; transition: all .4s cubic-bezier(.22,1,.36,1);
  }
  .hero-dot.active { width: 20px; border-radius: 3px; background: #fff; }

  /* Scroll hint */
  .scroll-hint {
    position: absolute; bottom: 100px; left: 50%; transform: translateX(-50%);
    z-index: 12; display: flex; flex-direction: column; align-items: center; gap: 6px;
    opacity: 1; transition: opacity .5s;
    animation: scrollPulse 2.5s ease-in-out infinite;
  }
  .scroll-hint.hidden { opacity: 0; pointer-events: none; }
  .scroll-hint span { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.25); }
  .scroll-arrow {
    width: 10px; height: 10px;
    border-right: 1.5px solid rgba(255,255,255,.25);
    border-bottom: 1.5px solid rgba(255,255,255,.25);
    transform: rotate(45deg);
  }
  @keyframes scrollPulse {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ─── SECTIONS ─── */
  .section { max-width: 960px; margin: 0 auto; padding: 56px 40px; }
  .section-label {
    font-size: 10px; text-transform: uppercase; letter-spacing: .2em;
    color: #3b82f6; font-weight: 600; margin-bottom: 22px;
    display: flex; align-items: center; gap: 12px;
  }
  .section-line { flex: 1; height: 1px; background: rgba(255,255,255,.06); }
  .section-cta { text-align: center; margin-top: 32px; }

  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .step {
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.05);
    border-radius: 16px; padding: 28px 24px; transition: border-color .25s, transform .25s;
  }
  .step:hover { border-color: rgba(255,255,255,.12); transform: translateY(-2px); }
  .step-num { font-family: 'Instrument Serif', serif; font-size: 28px; color: rgba(255,255,255,.08); margin-bottom: 10px; }
  .step-title { font-size: 16px; color: #fff; font-weight: 600; margin-bottom: 6px; }
  .step-desc { font-size: 13px; color: rgba(255,255,255,.4); line-height: 1.6; }

  .events-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .event-card {
    display: block; padding: 20px; border-radius: 14px;
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.05);
    transition: border-color .2s, transform .2s;
  }
  .event-card:hover { border-color: rgba(255,255,255,.12); transform: translateY(-2px); }
  .event-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
  .event-emoji { font-size: 16px; }
  .event-zone { font-size: 10px; color: rgba(255,255,255,.25); }
  .event-title { font-size: 14px; color: #fff; font-weight: 600; margin-bottom: 4px; }
  .event-meta { font-size: 11px; color: rgba(255,255,255,.3); }
  .btn-ghost-lg {
    display: inline-block; padding: 14px 32px;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px; font-size: 14px; font-weight: 500; color: #fff; transition: background .2s;
  }
  .btn-ghost-lg:hover { background: rgba(255,255,255,.08); }

  .trust-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .testimonial {
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.05);
    border-radius: 18px; padding: 32px;
  }
  .testimonial p { font-family: 'Instrument Serif', serif; font-size: 19px; color: #fff; line-height: 1.5; margin-bottom: 14px; }
  .testimonial footer { font-size: 12px; color: rgba(255,255,255,.3); font-family: 'DM Sans', sans-serif; }
  .trust-card {
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.05);
    border-radius: 18px; padding: 32px;
  }
  .trust-card h3 { font-size: 16px; color: #fff; margin-bottom: 18px; }
  .trust-item { display: flex; align-items: center; gap: 10px; font-size: 13px; color: rgba(255,255,255,.45); margin-bottom: 10px; }
  .check { color: #4ade80; flex-shrink: 0; }

  .cta-h2 { font-family: 'Instrument Serif', serif; font-size: clamp(28px, 4vw, 40px); color: #fff; margin-bottom: 8px; }
  .cta-h2 em { color: #4ade80; font-style: italic; }
  .cta-sub { font-size: 14px; color: rgba(255,255,255,.4); margin-bottom: 24px; }

  /* ─── MOBILE NAV ─── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: rgba(5,7,13,.95); backdrop-filter: blur(24px);
    border-top: 1px solid rgba(255,255,255,.08);
    padding: 10px 0 max(10px, env(safe-area-inset-bottom));
  }
  .mob-nav-inner {
    display: flex; justify-content: space-around; align-items: center;
    max-width: 540px; margin: 0 auto; padding: 0 8px;
  }
  .mob-nav a {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 8px 6px; font-size: 11px; color: rgba(255,255,255,.35); font-weight: 700; border-radius: 12px;
  }
  .mob-nav a span { font-size: 22px; }
  .mob-nav a.active { color: #fff; background: rgba(96,165,250,.12); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav { padding: 14px 20px; }
  }
  @media (min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }
  @media (max-width: 768px) {
    body { padding-bottom: 76px; }
    .hero-content { padding: 0 20px 36px; }
    .hero-dots { right: 20px; bottom: 24px; }
    .steps { grid-template-columns: 1fr; }
    .events-grid { grid-template-columns: 1fr; }
    .trust-grid { grid-template-columns: 1fr; }
    .section { padding: 40px 20px; }
    .scroll-hint { bottom: 80px; }
  }

  /* ─── SCROLL ANIMATIONS ─── */
  .fade-up { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
  .fade-up.in { opacity: 1; transform: translateY(0); }
</style>


<script is:inline>
  // ── Slideshow ──
  var slides = document.querySelectorAll('.hero-slide');
  var dots = document.querySelectorAll('.hero-dot');
  var current = 0;
  var interval;

  function goToSlide(i) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = i;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  function nextSlide() {
    goToSlide((current + 1) % slides.length);
  }

  function startSlideshow() {
    interval = setInterval(nextSlide, 4500);
  }

  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() {
      clearInterval(interval);
      goToSlide(i);
      startSlideshow();
    });
  });

  startSlideshow();

  // ── Nav reveal on scroll ──
  var nav = document.getElementById('nav');
  var hero = document.getElementById('hero');
  var scrollHint = document.getElementById('scrollHint');
  var navVisible = false;

  function checkScroll() {
    var scrollY = window.scrollY || window.pageYOffset;
    var threshold = hero.offsetHeight * 0.6;

    if (scrollY > threshold && !navVisible) {
      nav.classList.add('visible');
      navVisible = true;
    } else if (scrollY <= threshold && navVisible) {
      nav.classList.remove('visible');
      navVisible = false;
    }

    if (scrollY > 80) {
      scrollHint.classList.add('hidden');
    } else {
      scrollHint.classList.remove('hidden');
    }
  }

  window.addEventListener('scroll', checkScroll, { passive: true });
  checkScroll();

  // ── Fade-up on scroll ──
  var fadeEls = document.querySelectorAll('.fade-up');
  if (fadeEls.length && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    fadeEls.forEach(function(el) { observer.observe(el); });
  }
</script>

</body>
</html>
