---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

const db = getDB();
let upcomingEvents: any[] = [];
let memberCount = 0;
let eventCount = 0;
let upcomingPotluck: any = null;
let suggestions: any[] = []; // FIX: was undeclared

// Pull Discord guild_id from event-sync config and fetch the live online count.
// Cached at the worker fetch layer so we don't hammer Discord on every render.
let discordOnline: number | null = null;
let discordInvite: string | null = null;
let discordName: string = '';
if (db) {
  try {
    const src: any = await db.prepare(
      "SELECT config FROM event_sources WHERE kind='discord' AND enabled=1 ORDER BY id LIMIT 1"
    ).first();
    const guildId = src?.config ? (() => { try { return (JSON.parse(src.config).guild_id || '').toString() || null; } catch { return null; } })() : null;
    if (guildId) {
      const r = await fetch(`https://discord.com/api/guilds/${encodeURIComponent(guildId)}/widget.json`, {
        headers: { 'User-Agent': 'DenverSocialHub/1.0' },
        cf: { cacheTtl: 60, cacheEverything: true } as any,
      });
      if (r.ok) {
        const w: any = await r.json();
        if (typeof w?.presence_count === 'number') discordOnline = w.presence_count;
        discordInvite = w?.instant_invite || null;
        discordName = w?.name || '';
      }
    }
  } catch {}
}

try {
  if (db) {
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentDay = now.getDate();
    const monthOrder: Record<string, number> = { JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11 };
    const allEvts = (await db.prepare(
      "SELECT * FROM events WHERE is_past IS NULL OR is_past = 0 ORDER BY id DESC LIMIT 12"
    ).all())?.results || [];

    // Trust is_past for visibility; sort by month/day for chronological order.
    upcomingEvents = allEvts.sort((a: any, b: any) => {
      const ma = monthOrder[(a.event_month || '').toUpperCase()] ?? 99;
      const mb = monthOrder[(b.event_month || '').toUpperCase()] ?? 99;
      if (ma !== mb) return ma - mb;
      return (parseInt(a.event_day) || 99) - (parseInt(b.event_day) || 99);
    }).slice(0, 4);
    const mc = await db.prepare("SELECT COUNT(*) as cnt FROM members").first();
    memberCount = mc?.cnt || 0;
    const ec = await db.prepare("SELECT COUNT(*) as cnt FROM events WHERE is_past IS NULL OR is_past=0").first();
    eventCount = ec?.cnt || 0;
    suggestions = (await db.prepare("SELECT * FROM event_suggestions ORDER BY votes DESC LIMIT 4").all())?.results || [];
    upcomingPotluck = await db.prepare("SELECT id, slug, title, date_label, location FROM potlucks WHERE status='upcoming' ORDER BY id DESC LIMIT 1").first();
  }
} catch {}

const typeLabel: Record<string, string> = {
  dinner: '🍽 Dinner', game_night: '🎲 Games', outdoor: '🌲 Outdoors', brewery: '🍺 Brewery',
  coffee: '☕ Coffee', arts: '🎨 Arts', music: '🎵 Music', social: '🥂 Social',
  group_tickets: '🎟 Tickets', camping: '🏕 Camping', sports_outing: '⚾ Sports',
  bowling: '🎳 Bowling', active: '🏃 Active', casino: '🎰 Casino', food_trucks: '🌮 Food', other: '✨ Event',
};

// Aspirational chips — what people host (no counts)
const eventTypeChips = [
  { emoji: '🥾', label: 'Hikes' },
  { emoji: '🍽', label: 'Potlucks' },
  { emoji: '🏺', label: 'Pottery & making' },
  { emoji: '🎲', label: 'Game nights' },
  { emoji: '☕', label: 'Coffee meetups' },
  { emoji: '🧊', label: 'Cold plunges' },
  { emoji: '🖼', label: 'Art walks' },
];
---
<Base title="Real events, real people" description="Small-group hangouts across Denver. Pick one, RSVP, show up.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-photos">
      <img src="/hero/red-rocks.jpg" alt="Red Rocks Amphitheatre at night" class="hero-photo hp-1" loading="eager" />
      <img src="/hero/skyline.jpg" alt="Denver skyline with the Rockies behind" class="hero-photo hp-2" loading="eager" />
      <img src="/hero/foothills.jpg" alt="Snowy Colorado foothills trail" class="hero-photo hp-3" loading="eager" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <span class="hero-eyebrow">Denver · Community · Since 2026</span>
      <h1 class="hero-title">
        Post your event. <span class="hero-italic">Find one.</span><br/>
        Or <span class="hero-em">pin a flyer</span> on the board.
      </h1>
      <p class="hero-sub">
        Pick something on the calendar, RSVP, and show up. Dinners, art, outdoors, game nights, big potlucks at Cheesman, and more — something for everyone.
      </p>

      <div class="hero-ctas">
        <a href="/events" class="btn-cta">Browse events →</a>
        <a href="/events#potlucks" class="hero-link">or jump to potlucks</a>
      </div>

      <div class="hero-meta">
        <div class="hero-stat">
          <strong>{memberCount}+</strong>
          <span>locals</span>
        </div>
        <span class="hero-dot"></span>
        <div class="hero-stat">
          <strong>{eventCount}</strong>
          <span>upcoming</span>
        </div>
        <span class="hero-dot"></span>
        <div class="hero-stat">
          <strong>6–12</strong>
          <span>per event</span>
        </div>
      </div>
    </div>
  </section>

  {/* DISCORD LIVE CHIP — just the count, no avatars */}
  {discordOnline !== null && (
    <section class="page-wrap discord-chip-wrap">
      <a href="/discord" class="discord-chip">
        <span class="discord-pulse"></span>
        <span class="discord-text">
          <strong>{discordOnline}</strong> online in the Discord{discordName ? ` · ${discordName}` : ''}
        </span>
        <span class="discord-arrow">→</span>
      </a>
    </section>
  )}

  <!-- UPCOMING POTLUCK SPOTLIGHT -->
  {upcomingPotluck && (
    <section class="page-wrap">
      <a href={upcomingPotluck.slug ? `/${upcomingPotluck.slug}` : `/potlucks/${upcomingPotluck.id}`} class="potluck-spotlight">
        <div>
          <span class="tag tag-green">🍽 Next Potluck</span>
          <h3>{upcomingPotluck.title}</h3>
          <p>{upcomingPotluck.date_label}{upcomingPotluck.location ? ` · ${upcomingPotluck.location}` : ''}</p>
        </div>
        <span class="potluck-spotlight-arrow">→</span>
      </a>
    </section>
  )}

  <!-- FEATURED EVENT (the next one coming up) -->
  {upcomingEvents.length > 0 && (
    <section class="page-wrap">
      <a href={`/events/${upcomingEvents[0].id}`} class="featured-event">
        <div class="featured-event-bg"></div>
        <div class="featured-event-inner">
          <div class="featured-event-tag">
            <span>🎉</span> Next up
          </div>
          <h2 class="featured-event-title">{upcomingEvents[0].title}</h2>
          <div class="featured-event-meta">
            <span class="featured-event-chip">📅 {upcomingEvents[0].event_month} {upcomingEvents[0].event_day}</span>
            <span class="featured-event-chip">📍 {upcomingEvents[0].zone || upcomingEvents[0].location || 'Denver'}</span>
            <span class="featured-event-chip">{typeLabel[upcomingEvents[0].event_type] || '✨ Event'}</span>
            <span class="featured-event-chip">👥 {upcomingEvents[0].rsvp_count || 0}/{upcomingEvents[0].spots || 12}</span>
          </div>
          <span class="featured-event-cta">RSVP →</span>
        </div>
      </a>
    </section>
  )}

  <!-- MORE UPCOMING EVENTS -->
  {upcomingEvents.length > 1 && (
    <section class="page-wrap">
      <div class="sec-head">
        <span class="sec-tag tag tag-blue">Also coming up</span>
        <h2>More events</h2>
        <p class="sec-sub">Pick one, RSVP, and you'll probably know somebody by the time you leave.</p>
      </div>
      <div class="event-grid">
        {upcomingEvents.slice(1).map((ev: any) => (
          <a href={`/events/${ev.id}`} class="ev-card">
            <div class="ev-top">
              <span class="ev-type">{typeLabel[ev.event_type] || '✨ Event'}</span>
              <span class="ev-fill">
                <span class="ev-fill-bar"><span class="ev-fill-prog" style={`width:${Math.min(100, Math.round((ev.rsvp_count || 0) / (ev.spots || 12) * 100))}%`}></span></span>
                <span class="ev-fill-num">{ev.rsvp_count || 0}/{ev.spots || 12}</span>
              </span>
            </div>
            <h3 class="ev-title">{ev.title}</h3>
            <div class="ev-meta">
              <span>📅 {ev.event_month} {ev.event_day}</span>
              <span class="ev-meta-dot"></span>
              <span>📍 {ev.zone || ev.location || 'Denver'}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="sec-foot">
        <a href="/events" class="btn-sec">See all events</a>
      </div>
    </section>
  )}

  {/* PERSONAL PAGES CTA — moved below event content (different audience than hero) */}
  <section class="page-wrap personal-page-band">
    <div class="pp-card">
      <div class="pp-card-left">
        <div class="pp-avatars">
          <span class="pp-av pp-av-1">👨🏽‍💼</span>
          <span class="pp-av pp-av-2">🧘🏻‍♀️</span>
          <span class="pp-av pp-av-3">👨‍🍳</span>
        </div>
        <div class="pp-card-text">
          <h3 class="pp-h">Have something you offer Denver?</h3>
          <p class="pp-p">Free landing page for realtors, instructors, makers, dog-walkers — anyone with skills, services, or a side hustle. Your own URL, your contact info, your face on the neighborhood map.</p>
          <ul class="pp-bullets">
            <li>✓ Pick your own URL — <span class="mono">denversocialhub.com/u/yourname</span></li>
            <li>✓ Free forever — no credit card, no account</li>
            <li>✓ Live in 2 minutes — email yourself a code, edit, publish</li>
          </ul>
        </div>
      </div>
      <a href="/u/new" class="pp-card-cta">Make my page →</a>
    </div>
  </section>


  <!-- WHAT WE GET UP TO + HOST THE NEXT ONE -->
  <section class="page-wrap">
    <div class="get-up-to">
      <span class="get-up-label">What we get up to</span>
      <div class="chip-row">
        {eventTypeChips.map(c => (
          <span class="chip-pill">
            <span class="chip-emoji">{c.emoji}</span> {c.label}
          </span>
        ))}
      </div>
    </div>

    <a href="/events/new" class="host-slot">
      <div class="host-slot-icon">+</div>
      <div class="host-slot-text">
        <span class="host-slot-eyebrow">Open slot · this week</span>
        <h3 class="host-slot-title">Host the next one</h3>
        <p>A board game evening. A long walk. A potluck. Whatever you'd want to show up to — chances are someone else would too.</p>
      </div>
      <span class="host-slot-arrow">→</span>
    </a>
  </section>

  <style>
    .page-wrap { max-width: 1100px; margin: 0 auto; padding: var(--space-7) var(--space-5); }
    @media(max-width: 700px) { .page-wrap { padding: var(--space-6) var(--space-4); } }

    /* HERO */
    .hero { position: relative; overflow: hidden; padding: var(--space-9) var(--space-5) var(--space-7); background: #0c1a2a; min-height: 520px; }

    /* Slideshow background */
    .hero-photos {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 0;
      overflow: hidden;
    }
    .hero-photo {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      opacity: 0;
      animation: heroFade 21s infinite;
      filter: saturate(0.85) brightness(0.9);
      transform: scale(1.05);
    }
    .hp-1 { animation-delay: 0s; }
    .hp-2 { animation-delay: 7s; }
    .hp-3 { animation-delay: 14s; }

    @keyframes heroFade {
      0%   { opacity: 0; transform: scale(1.05); }
      5%   { opacity: 1; transform: scale(1.02); }
      30%  { opacity: 1; transform: scale(1); }
      38%  { opacity: 0; transform: scale(1); }
      100% { opacity: 0; transform: scale(1.05); }
    }

    /* Gradient overlay for text readability */
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background:
        linear-gradient(180deg, rgba(12,26,42,0.35) 0%, rgba(12,26,42,0.7) 55%, rgba(12,26,42,0.92) 100%),
        radial-gradient(ellipse 80% 60% at 50% 30%, rgba(14,165,233,0.12), transparent 70%);
    }

    .hero-inner { position: relative; max-width: 820px; margin: 0 auto; text-align: center; z-index: 2; }

    @media(max-width: 700px) {
      .hero { padding: var(--space-7) var(--space-4) var(--space-6); min-height: 440px; }
    }
    .hero-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: #7DD3FC; margin-bottom: var(--space-4); padding: 6px 14px; background: rgba(14,165,233,0.15); border: 1px solid rgba(14,165,233,0.25); border-radius: 999px; }
    .hero-title { font-family: var(--font-display); font-size: clamp(40px, 7vw, 68px); line-height: 1.05; letter-spacing: -0.03em; color: #FFFFFF; margin-bottom: var(--space-4); font-weight: 800; text-shadow: 0 2px 20px rgba(0,0,0,0.3); }
    .hero-italic { font-style: italic; color: #7DD3FC; }
    .hero-em { background: linear-gradient(135deg, #38BDF8, #34D399); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent; }
    .hero-sub { font-size: clamp(16px, 1.6vw, 18px); color: rgba(255,255,255,0.75); line-height: 1.6; max-width: 580px; margin: 0 auto var(--space-5); }
    .hero-ctas { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; align-items: center; margin-bottom: var(--space-5); }
    .hero-ctas .btn-sec { background: rgba(255,255,255,0.2); color: #fff; border: 2px solid rgba(255,255,255,0.5); font-weight: 700; }
    .hero-ctas .btn-sec:hover { background: rgba(255,255,255,0.3); border-color: rgba(255,255,255,0.7); }
    .hero-link { color: rgba(255,255,255,0.78); font-size: 14px; text-decoration: underline; text-underline-offset: 4px; transition: color 0.15s; }
    .hero-link:hover { color: #fff; }
    .hero-meta { display: inline-flex; align-items: center; gap: var(--space-3); padding: 10px 18px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 999px; backdrop-filter: blur(12px); }
    .hero-stat { display: inline-flex; align-items: baseline; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.6); }
    .hero-stat strong { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: #FFFFFF; letter-spacing: -0.02em; }
    .hero-dot { width: 4px; height: 4px; background: rgba(255,255,255,0.25); border-radius: 50%; }

    /* SECTION HEAD */
    .sec-head { margin-bottom: var(--space-5); }
    .sec-head h2 { font-size: clamp(28px, 3.5vw, 36px); margin: var(--space-2) 0 var(--space-2); }
    .sec-tag { margin-bottom: var(--space-2); }
    .sec-sub { color: var(--text-sec); font-size: 15px; max-width: 620px; line-height: 1.55; }
    .sec-foot { margin-top: var(--space-5); display: flex; justify-content: center; }

    /* POTLUCK SPOTLIGHT */
    .potluck-spotlight { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5); border-radius: var(--radius-lg); background: linear-gradient(135deg, #D1FAE5, #E0F2FE); border: 1px solid #A7F3D0; box-shadow: var(--card-shadow); transition: transform 0.15s, box-shadow 0.15s; text-decoration: none; }
    .potluck-spotlight:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-lg); }
    .potluck-spotlight h3 { font-size: 22px; margin: 8px 0 4px; }
    .potluck-spotlight p { color: var(--text-sec); font-size: 14px; }
    .potluck-spotlight-arrow { font-size: 28px; color: var(--accent); flex-shrink: 0; }
    @media (max-width: 639px) {
      .potluck-spotlight { padding: var(--space-4); gap: var(--space-3); }
      .potluck-spotlight h3 { font-size: 18px; }
    }

    /* EVENT GRID */
    .event-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(260px, 100%), 1fr)); gap: var(--space-3); }

    /* Featured event */
    /* Personal pages card */
    .personal-page-band { padding-top: var(--space-5); padding-bottom: var(--space-3); }
    .pp-card { display: grid; grid-template-columns: 1fr auto; gap: var(--space-4); align-items: center; padding: var(--space-5); background: linear-gradient(135deg, #FAF5FF 0%, #ECFDF5 50%, #EFF6FF 100%); border: 1.5px solid #DDD6FE; border-radius: 20px; }
    .pp-card-left { display: flex; gap: var(--space-3); align-items: flex-start; }
    .pp-avatars { display: flex; flex-shrink: 0; }
    .pp-av { width: 48px; height: 48px; border-radius: 50%; background: #fff; border: 3px solid #fff; display: flex; align-items: center; justify-content: center; font-size: 24px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
    .pp-av-1 { z-index: 3; }
    .pp-av-2 { z-index: 2; margin-left: -14px; }
    .pp-av-3 { z-index: 1; margin-left: -14px; }
    .pp-card-text { flex: 1; }
    .pp-h { font-family: var(--font-display, 'Playfair Display', serif); font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 6px; line-height: 1.2; }
    .pp-p { font-size: 14px; color: var(--text-sec, #4B5563); line-height: 1.5; margin-bottom: 10px; }
    .pp-bullets { list-style: none; padding: 0; margin: 0; font-size: 13px; color: var(--text); line-height: 1.7; }
    .pp-bullets li { margin-bottom: 2px; }
    .pp-bullets .mono { font-family: 'SF Mono', Menlo, monospace; background: rgba(124,58,237,0.08); padding: 1px 6px; border-radius: 4px; font-size: 12px; color: var(--accent, #7C3AED); }
    .pp-card-cta { display: inline-block; padding: 14px 24px; background: var(--accent, #7C3AED); color: #fff; border-radius: 999px; font-weight: 700; font-size: 15px; text-decoration: none; box-shadow: 0 4px 14px rgba(124,58,237,0.25); transition: transform 0.15s, box-shadow 0.15s; white-space: nowrap; }
    .pp-card-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(124,58,237,0.35); }
    @media (max-width: 700px) {
      .pp-card { grid-template-columns: 1fr; text-align: center; gap: var(--space-3); }
      .pp-card-left { flex-direction: column; align-items: center; gap: var(--space-2); }
      .pp-avatars { justify-content: center; }
      .pp-card-text { text-align: center; }
      .pp-bullets { text-align: left; max-width: 320px; margin: 0 auto; }
      .pp-card-cta { width: 100%; text-align: center; box-sizing: border-box; }
    }
    @media (max-width: 480px) {
      .pp-h { font-size: 19px; }
      .pp-card { padding: var(--space-4); }
      .pp-p { font-size: 13.5px; }
      .pp-bullets li { line-height: 1.5; margin-bottom: 4px; }
      .pp-bullets .mono { font-size: 11px; word-break: break-all; }
      .pp-av { width: 44px; height: 44px; font-size: 22px; }
    }
    /* Discord live chip */
    .discord-chip-wrap { padding-top: var(--space-5); padding-bottom: 0; }
    .discord-chip {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 10px 18px 10px 14px; border-radius: 999px;
      background: linear-gradient(135deg, rgba(88,101,242,0.10), rgba(88,101,242,0.04));
      border: 1px solid rgba(88,101,242,0.25);
      color: var(--text); text-decoration: none;
      font-size: 14px; font-family: var(--font);
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    }
    .discord-chip:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(88,101,242,0.18); border-color: rgba(88,101,242,0.4); }
    .discord-pulse {
      width: 9px; height: 9px; border-radius: 50%;
      background: #57F287;
      box-shadow: 0 0 0 0 rgba(87,242,135,0.6);
      animation: discord-pulse 1.8s ease-out infinite;
      flex-shrink: 0;
    }
    @keyframes discord-pulse {
      0% { box-shadow: 0 0 0 0 rgba(87,242,135,0.6); }
      100% { box-shadow: 0 0 0 10px rgba(87,242,135,0); }
    }
    .discord-text strong { font-family: var(--font-display); font-weight: 800; color: #5865F2; }
    .discord-arrow { color: #5865F2; font-weight: 700; }

    .featured-event {
      position: relative; display: block;
      border-radius: 24px; overflow: hidden;
      padding: 32px clamp(20px, 4vw, 40px);
      color: #fff; text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 8px 32px rgba(249,115,22,0.25);
    }
    .featured-event:hover { transform: translateY(-2px); box-shadow: 0 16px 48px rgba(249,115,22,0.35); }
    .featured-event-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(255,255,255,0.18), transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(255,255,255,0.12), transparent 50%),
        linear-gradient(135deg, #F97316 0%, #EC4899 60%, #8B5CF6 100%);
    }
    .featured-event-inner { position: relative; z-index: 1; }
    .featured-event-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-display); font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.08em;
      background: rgba(255,255,255,0.22); color: #fff;
      padding: 6px 14px; border-radius: 999px; margin-bottom: 16px;
      backdrop-filter: blur(6px);
    }
    .featured-event-title {
      font-family: var(--font-display); font-size: clamp(26px, 4vw, 38px); font-weight: 900;
      letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 16px; color: #fff;
    }
    .featured-event-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
    .featured-event-chip {
      font-size: 13px; padding: 6px 14px; border-radius: 999px;
      background: rgba(255,255,255,0.18); color: #fff; font-weight: 500;
