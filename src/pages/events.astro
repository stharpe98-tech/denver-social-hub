  }
  .mag-sub {
    font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5;
    margin-bottom: 14px; max-width: 340px;
  }
  .mag-week-pill {
    display: inline-flex; align-items: center; gap: 8px;
