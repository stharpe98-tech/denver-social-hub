---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getContent } from '../lib/content';

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const db = getDB();
const now = new Date();
const currentMonth = now.getMonth();
const currentDay = now.getDate();
const monthOrder: Record<string,number> = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};
const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const monthAbbrs = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const potluckMonthMap: Record<string,number> = {jan:0,feb:1,mar:2,apr:3,may:4,jun:5,jul:6,aug:7,sep:8,oct:9,nov:10,dec:11,january:0,february:1,march:2,april:3,june:5,july:6,august:7,september:8,october:9,november:10,december:11};

// -- Unified card type --
type Card = {
  kind: 'event' | 'potluck';
  id: number;
  href: string;
  title: string;
  description: string;
  type: string;
  dateStr: string;
  timeStr: string;
  sortMonth: number;
  sortDay: number;
  location: string;
  fillPct: number;
  goingCount: number;
  spotsLeft: number;
  hostName: string;
  karmaMin: number;
  attendeeCount: number;
  dishCount: number;
  externalSource?: string;
  externalUrl?: string;
};

let cards: Card[] = [];
let rsvpCounts: Record<number, number> = {};

try {
  if (db) {
    // -- Query events --
    const allEvents = (await db.prepare("SELECT * FROM events WHERE is_past IS NULL OR is_past=0 ORDER BY id DESC").all())?.results || [];
    const counts = (await db.prepare("SELECT event_id, COUNT(*) as cnt FROM event_rsvps GROUP BY event_id").all())?.results || [];
    counts.forEach((c: any) => { rsvpCounts[c.event_id] = c.cnt; });

    const futureEvents = allEvents.filter((e: any) => {
      const m = monthOrder[(e.event_month || '').toUpperCase()];
      const d = parseInt(e.event_day) || 99;
      if (m === undefined) return true;
      if (m < currentMonth) return false;
      if (m === currentMonth && d < currentDay) return false;
      return true;
    });

    for (const ev of futureEvents) {
      const sm = monthOrder[(ev.event_month || '').toUpperCase()] ?? 99;
      const sd = parseInt(ev.event_day) || 99;
      const total = parseInt(ev.spots) || 10;
      const taken = rsvpCounts[ev.id] || 0;
      const left = Math.max(0, total - taken);
      const pct = Math.min(100, Math.round(taken / total * 100));
      let ds = `${ev.event_month} ${ev.event_day}`;
      if (sm !== 99) {
        const dt = new Date(2026, sm, sd);
        ds = `${dayNames[dt.getDay()]}, ${ev.event_month} ${ev.event_day}`;
      }
      cards.push({
        kind: 'event', id: ev.id, href: `/events/${ev.id}`,
        title: ev.title, description: ev.description || '',
        type: ev.event_type || 'other',
        dateStr: ds, timeStr: '',
        sortMonth: sm, sortDay: sd,
        location: ev.zone || ev.location || 'Denver',
        fillPct: pct, goingCount: taken, spotsLeft: left,
        hostName: ev.host_name || '', karmaMin: ev.karma_min || 0,
        attendeeCount: 0, dishCount: 0,
        externalSource: ev.external_source || '',
        externalUrl: ev.external_url || '',
      });
    }

    // -- Query potlucks --
    const potluckRows = (await db.prepare(`
      SELECT p.*, COUNT(DISTINCT CASE WHEN r.rsvp='yes' THEN r.id END) as attendee_count,
        COUNT(DISTINCT CASE WHEN r.rsvp='yes' AND r.dish!='' THEN LOWER(r.dish) END) as dish_count
      FROM potlucks p LEFT JOIN potluck_rsvp r ON r.potluck_id=p.id
      WHERE p.status = 'upcoming' GROUP BY p.id
    `).all())?.results || [];

    for (const p of potluckRows) {
      const parts = (p.date_label || '').trim().split(/\s+/);
      const monthStr = (parts[0] || '').toLowerCase().replace(/[^a-z]/g, '');
      const dayStr = (parts[1] || '').replace(/\D/g, '');
      const sm = potluckMonthMap[monthStr] ?? potluckMonthMap[monthStr.slice(0,3)] ?? 99;
      const sd = parseInt(dayStr) || 99;
      // Skip past potlucks
      if (sm < currentMonth || (sm === currentMonth && sd < currentDay)) continue;
      let ds = p.date_label || 'TBD';
      if (sm !== 99 && sd !== 99) {
        const dt = new Date(2026, sm, sd);
        ds = `${dayNames[dt.getDay()]}, ${monthAbbrs[sm]} ${sd}`;
      }
      cards.push({
        kind: 'potluck', id: p.id, href: `/potlucks/${p.id}`,
        title: p.title, description: p.description || '',
        type: 'potluck',
        dateStr: ds, timeStr: p.time_label || '',
        sortMonth: sm, sortDay: sd,
        location: p.location || 'Denver',
        fillPct: 0, goingCount: p.attendee_count || 0, spotsLeft: -1,
        hostName: '', karmaMin: 0,
        attendeeCount: p.attendee_count || 0, dishCount: p.dish_count || 0,
      });
    }
  }
} catch (err) { console.error('Events page query error:', err); }

// Sort chronologically
cards.sort((a, b) => {
  if (a.sortMonth !== b.sortMonth) return a.sortMonth - b.sortMonth;
  return a.sortDay - b.sortDay;
});

const typeLabel: Record<string,string> = { dinner:"dinner",game_night:"game_night",outdoor:"outdoor",brewery:"brewery",coffee:"coffee",arts:"arts",music:"music",social:"social",group_tickets:"tickets",camping:"camping",sports_outing:"sports",bowling:"bowling",active:"active",casino:"casino",food_trucks:"food",potluck:"potluck",other:"event" };
const typeSet = new Set(cards.map(c => c.type).filter(Boolean));
const allTypes = Array.from(typeSet);
const content = await getContent();
---
<Base title="Browse Events">
<div class="ev-page">

  <!-- Header -->
  <div class="ev-header">
    <div class="ev-header-left">
      <span class="tag tag-orange">Events</span>
      <h1 class="ev-h1">{cards.length} events live</h1>
      <p class="ev-sub">{content.events_subtitle || 'Small groups, real plans, no flakes.'}</p>
    </div>
    {user && (
      <a href="/events/new" class="btn btn-primary" id="createBtn">Post an event</a>
    )}
  </div>

  <!-- Search + filter strip -->
  <div class="ev-search-row">
    <input type="search" id="eventSearch" class="ev-search-input" placeholder="Search events…" autocomplete="off"/>
  </div>
  <div class="ev-filters" id="filterStrip">
    <button class="fpill active" data-type="all">all</button>
    {allTypes.map(t => (
      <button class="fpill" data-type={t}>{typeLabel[t] || t}</button>
    ))}
  </div>

  <style is:inline>
    .ev-search-row { margin: 0 0 12px; }
    .ev-search-input {
      width: 100%; padding: 12px 16px;
      background: var(--bg, #fff);
      border: 1px solid var(--border, #e5e7eb);
      border-radius: 999px;
      font-size: 14px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
      -webkit-appearance: none;
    }
    .ev-search-input:focus {
      border-color: var(--accent, #0EA5E9);
      box-shadow: 0 0 0 3px var(--accent-dim, rgba(14,165,233,0.10));
    }
    .ec.hidden { display: none !important; }
  </style>

  <script is:inline>
    (function() {
      var input = document.getElementById('eventSearch');
      if (!input) return;
      function applyFilter() {
        var q = input.value.trim().toLowerCase();
        var activePill = document.querySelector('.fpill.active');
        var activeType = activePill ? activePill.getAttribute('data-type') : 'all';
        document.querySelectorAll('#eventGrid .ec').forEach(function(card) {
          var matchesType = (activeType === 'all' || card.getAttribute('data-type') === activeType);
          var matchesQuery = !q || (card.textContent || '').toLowerCase().indexOf(q) !== -1;
          card.classList.toggle('hidden', !(matchesType && matchesQuery));
        });
      }
      input.addEventListener('input', applyFilter);
      // Re-run after pill clicks too (the existing pill JS may not know about search)
      document.querySelectorAll('.fpill').forEach(function(btn) {
        btn.addEventListener('click', function() { setTimeout(applyFilter, 0); });
      });
    })();
  </script>

  <!-- Event grid -->
  {cards.length > 0 ? (
    <div class="ev-grid" id="eventGrid">
      {cards.map((c) => (
          <a href={c.href} class="ec" data-type={c.type}>
            <div class="ec-top">
              {c.kind === 'potluck' ? (
                <span class="ec-type tag tag-green">🍽 potluck</span>
              ) : (
                <span class="ec-type tag tag-blue">{typeLabel[c.type] || 'event'}</span>
              )}
              {c.externalSource && (
                <span class="tag tag-purple">via {c.externalSource}</span>
              )}
              {c.karmaMin >= 1 && <span class="tag tag-yellow">{c.karmaMin}+ karma</span>}
              {(c.kind === 'event' && c.spotsLeft !== 0 && c.spotsLeft !== -1 && 4 > c.spotsLeft) && <span class="tag tag-orange">last {c.spotsLeft} spots</span>}
              {c.kind === 'event' && c.spotsLeft === 0 && <span class="tag" style="background:rgba(255,71,87,0.12);color:#ff4757">Full</span>}
            </div>
            <h3 class="ec-title">{c.title}</h3>
            {c.description && <p class="ec-desc">{c.description.slice(0, 80)}</p>}
            <div class="ec-meta">
              <span class="ec-date">{c.dateStr}{c.timeStr ? ` · ${c.timeStr}` : ''}</span>
              <span class="ec-dot"></span>
              <span>{c.location}</span>
            </div>
            <div class="ec-footer">
              {c.kind === 'potluck' ? (
                <div class="ec-fill-wrap">
                  <span class="ec-fill-text">👥 {c.attendeeCount} signed up · 🍽 {c.dishCount} dishes</span>
                </div>
              ) : (
                <div class="ec-footer-inner">
                  <div class="ec-fill-wrap">
                    <div class="ec-fill-bar"><div class="ec-fill" style={`width:${c.fillPct}%`}></div></div>
                    <span class="ec-fill-text">{c.goingCount} going</span>
                  </div>
                  {c.hostName && <span class="ec-host">by {c.hostName}</span>}
                </div>
              )}
            </div>
          </a>
      ))}
    </div>
  ) : (
    <div class="ev-empty">
      <div class="ev-empty-term">
        <span class="term-prompt">$</span> <span class="term-cmd">What's happening</span><br/>
        <span class="term-output">No events right now — check back soon.</span>
      </div>
      <p>{content.events_empty || 'Check back soon or post your own event.'}</p>
      {!user && <a href="/login" class="btn btn-primary">sign in to post</a>}
    </div>
  )}


  <!-- Create event panel (logged-in, inline) -->
  <div class="create-panel" id="createPanel" style="display:none">
    <div class="cp-header">
      <h3>Post an event</h3>
      <button class="cp-close" id="createClose">&times;</button>
    </div>

    <!-- Template picker -->
    <div class="cp-templates" id="templatePicker">
      <p class="cp-templates-label">Start from a template</p>
      <div class="cp-tpl-grid">
        <button class="cp-tpl" data-tpl="dinner">
          <span class="cp-tpl-icon">🍽️</span>
          <span class="cp-tpl-name">Dinner</span>
        </button>
        <button class="cp-tpl" data-tpl="game_night">
          <span class="cp-tpl-icon">🎲</span>
          <span class="cp-tpl-name">Game Night</span>
        </button>
        <button class="cp-tpl" data-tpl="arts">
          <span class="cp-tpl-icon">🎨</span>
          <span class="cp-tpl-name">Arts / Pottery</span>
        </button>
        <button class="cp-tpl" data-tpl="brewery">
          <span class="cp-tpl-icon">🍺</span>
          <span class="cp-tpl-name">Brewery</span>
        </button>
        <button class="cp-tpl" data-tpl="outdoor">
          <span class="cp-tpl-icon">🥾</span>
          <span class="cp-tpl-name">Outdoor</span>
        </button>
        <button class="cp-tpl" data-tpl="coffee">
          <span class="cp-tpl-icon">☕</span>
          <span class="cp-tpl-name">Coffee</span>
        </button>
        <button class="cp-tpl" data-tpl="bowling">
          <span class="cp-tpl-icon">🎳</span>
          <span class="cp-tpl-name">Bowling</span>
        </button>
        <button class="cp-tpl" data-tpl="social">
          <span class="cp-tpl-icon">🎉</span>
          <span class="cp-tpl-name">Social</span>
        </button>
        <button class="cp-tpl" data-tpl="blank">
          <span class="cp-tpl-icon">✏️</span>
          <span class="cp-tpl-name">Blank</span>
        </button>
      </div>
    </div>

    <!-- Form (hidden until template picked) -->
    <form method="POST" action="/api/create-event" class="cp-form" id="createForm" style="display:none">
      <button type="button" class="cp-back" id="backToTemplates">← pick a different template</button>
      <div class="cp-row">
        <label class="cp-label">title</label>
        <input type="text" name="title" id="cpTitle" required placeholder="Korean BBQ Night" class="input" />
      </div>
      <div class="cp-row">
        <label class="cp-label">type</label>
        <select name="event_type" id="cpType" class="input">
          <option value="dinner">dinner</option>
          <option value="outdoor">outdoor</option>
          <option value="game_night">game night</option>
          <option value="arts">arts / pottery</option>
          <option value="brewery">brewery</option>
          <option value="coffee">coffee</option>
          <option value="bowling">bowling</option>
          <option value="social">social</option>
          <option value="other">other</option>
        </select>
      </div>
      <div class="cp-row-half">
        <div class="cp-row">
          <label class="cp-label">month</label>
          <input type="text" name="event_month" id="cpMonth" placeholder="MAY" class="input" />
        </div>
        <div class="cp-row">
          <label class="cp-label">day</label>
          <input type="text" name="event_day" id="cpDay" placeholder="15" class="input" />
        </div>
      </div>
      <div class="cp-row">
        <label class="cp-label">neighborhood</label>
        <input type="text" name="zone" id="cpZone" placeholder="RiNo, LoHi, etc." class="input" />
      </div>
      <div class="cp-row">
        <label class="cp-label">spots</label>
        <input type="number" name="spots" id="cpSpots" placeholder="leave blank for unlimited" class="input" />
      </div>
      <div class="cp-row">
        <label class="cp-label">description</label>
        <textarea name="description" id="cpDesc" rows="3" placeholder="What's the plan?" class="input" style="border-radius:8px;resize:vertical"></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%">Post event</button>
    </form>
  </div>

</div>
</Base>

<style is:inline>
  .ev-page { max-width: 960px; margin: 0 auto; padding: 24px 24px 80px; }

  /* Header */
  .ev-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; }
  .ev-h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; margin-top: 6px; }
  .ev-sub { font-size: 14px; color: var(--text-sec); margin-top: 4px; }

  /* Filters */
  .ev-filters {
    display: flex; gap: 6px; overflow-x: auto; padding-bottom: 16px;
    border-bottom: 1px solid var(--border); margin-bottom: 20px;
    scrollbar-width: none;
  }
  .ev-filters::-webkit-scrollbar { display: none; }
  .fpill {
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    padding: 6px 14px; border-radius: 6px; border: 1px solid var(--border);
    background: var(--surface); color: var(--text-faint);
    cursor: pointer; white-space: nowrap; transition: all .2s;
  }
  .fpill:hover { color: var(--text-sec); border-color: var(--border-hover); }
  .fpill.active { background: var(--accent-dim); color: var(--accent); border-color: var(--accent); }

  /* Event grid */
  .ev-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

  .ec {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 18px; text-decoration: none;
    display: flex; flex-direction: column; gap: 8px;
    transition: all .25s;
  }
  .ec:hover { border-color: var(--border-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .ec[data-hidden="true"] { display: none; }

  .ec-top { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .ec-title { font-weight: 700; font-size: 16px; color: var(--text); line-height: 1.3; }
  .ec-desc { font-size: 13px; color: var(--text-sec); line-height: 1.5; }
  .ec-meta {
    font-family: var(--mono); font-size: 12px; color: var(--text-faint);
    display: flex; align-items: center; gap: 6px;
  }
  .ec-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-faint); }
  .ec-date { color: var(--text-sec); }

  .ec-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 6px; }
  .ec-fill-wrap { display: flex; align-items: center; gap: 8px; }
  .ec-fill-bar { width: 56px; height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; }
  .ec-fill { height: 100%; border-radius: 2px; background: var(--green); transition: width .3s; }
  .ec-fill-text { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }
  .ec-host { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }
  .ec-footer-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; }

  /* Empty state */
  .ev-empty { text-align: center; padding: 48px 24px; }
  .ev-empty-term {
    display: inline-block; text-align: left;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px 20px;
    font-family: var(--mono); font-size: 13px;
    margin-bottom: 16px;
  }
  .term-prompt { color: var(--accent); font-weight: 700; }
  .term-cmd { color: var(--text); }
  .term-output { color: var(--text-faint); }
  .ev-empty p { color: var(--text-sec); font-size: 14px; margin-bottom: 16px; }

  /* Create panel */
  .create-panel {
    position: fixed; bottom: 80px; right: 24px; z-index: 1000;
    width: 380px; max-height: 80vh; overflow-y: auto;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; box-shadow: 0 16px 48px rgba(0,0,0,0.4);
    padding: 20px;
  }
  .cp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .cp-header h3 { font-family: var(--mono); font-size: 15px; font-weight: 700; }
  .cp-close {
    width: 28px; height: 28px; border-radius: 6px; border: 1px solid var(--border);
    background: var(--surface); color: var(--text-faint); font-size: 16px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
  }
  .cp-close:hover { color: var(--text); }
  .cp-form { display: flex; flex-direction: column; gap: 12px; }
  .cp-label { font-family: var(--mono); font-size: 11px; color: var(--text-faint); font-weight: 600; display: block; margin-bottom: 4px; }
  .cp-row-half { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  /* Templates */
  .cp-templates-label {
    font-family: var(--mono); font-size: 11px; color: var(--text-faint);
    font-weight: 600; margin-bottom: 10px;
  }
  .cp-tpl-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
  }
  .cp-tpl {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 14px 8px; border-radius: 10px;
    border: 1px solid var(--border); background: var(--bg, #0a0a0a);
    cursor: pointer; transition: all .2s;
  }
  .cp-tpl:hover {
    border-color: var(--accent); background: var(--surface);
    transform: translateY(-1px);
  }
  .cp-tpl-icon { font-size: 22px; }
  .cp-tpl-name { font-family: var(--mono); font-size: 10px; color: var(--text-sec); font-weight: 600; }
  .cp-back {
    background: none; border: none; color: var(--text-faint); font-family: var(--mono);
    font-size: 11px; cursor: pointer; padding: 0; margin-bottom: 12px;
    transition: color .2s;
  }
  .cp-back:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .ev-grid { grid-template-columns: 1fr; }
    .ev-header { flex-direction: column; gap: 12px; }
    .create-panel { left: 12px; right: 12px; width: auto; bottom: 72px; }
    .cp-tpl-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<script is:inline>
  // Filter logic
  var filterBtns = document.querySelectorAll('.fpill');
  var cards = document.querySelectorAll('.ec');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var type = btn.getAttribute('data-type');
      cards.forEach(function(card) {
        if (type === 'all' || card.getAttribute('data-type') === type) {
          card.removeAttribute('data-hidden');
          card.style.display = '';
        } else {
          card.setAttribute('data-hidden', 'true');
          card.style.display = 'none';
        }
      });
    });
  });

  // Create panel toggle
  var createBtn = document.getElementById('createBtn');
  var createPanel = document.getElementById('createPanel');
  var createClose = document.getElementById('createClose');
  if (createBtn && createPanel) {
    createBtn.addEventListener('click', function(e) {
      e.preventDefault();
      createPanel.style.display = createPanel.style.display === 'none' ? 'block' : 'none';
      // Reset to template picker
      document.getElementById('templatePicker').style.display = 'block';
      document.getElementById('createForm').style.display = 'none';
    });
  }
  if (createClose && createPanel) {
    createClose.addEventListener('click', function() { createPanel.style.display = 'none'; });
  }

  // Event templates
  var templates = {
    dinner: { title: '', type: 'dinner', desc: 'Trying a new spot — come hungry.', spots: 8, zone: '' },
    game_night: { title: 'Board Game Night', type: 'game_night', desc: 'Bring your favorites or play ours. All skill levels welcome.', spots: 10, zone: '' },
    arts: { title: 'Pottery / Paint Night', type: 'arts', desc: 'Guided session — no experience needed. Materials included.', spots: 8, zone: '' },
    brewery: { title: 'Brewery Hang', type: 'brewery', desc: 'Casual drinks and conversation. No agenda, just vibes.', spots: '', zone: '' },
    outdoor: { title: '', type: 'outdoor', desc: 'Getting outside. Details on meetup point coming soon.', spots: '', zone: '' },
    coffee: { title: 'Coffee & Conversation', type: 'coffee', desc: 'Low-key morning meetup. Grab a drink, meet new people.', spots: 6, zone: '' },
    bowling: { title: 'Bowling Night', type: 'bowling', desc: 'Lanes reserved. Beginners and pros welcome.', spots: 12, zone: '' },
    social: { title: '', type: 'social', desc: '', spots: '', zone: '' },
    blank: { title: '', type: 'other', desc: '', spots: '', zone: '' }
  };

  var tplButtons = document.querySelectorAll('.cp-tpl');
  var tplPicker = document.getElementById('templatePicker');
  var createForm = document.getElementById('createForm');
  var backToTpl = document.getElementById('backToTemplates');

  tplButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = btn.getAttribute('data-tpl');
      var tpl = templates[key] || templates.blank;
      document.getElementById('cpTitle').value = tpl.title;
      document.getElementById('cpType').value = tpl.type;
      document.getElementById('cpDesc').value = tpl.desc;
      document.getElementById('cpSpots').value = tpl.spots;
      document.getElementById('cpZone').value = tpl.zone;
      tplPicker.style.display = 'none';
      createForm.style.display = 'flex';
      if (!tpl.title) document.getElementById('cpTitle').focus();
    });
  });

  if (backToTpl) {
    backToTpl.addEventListener('click', function() {
      createForm.style.display = 'none';
      tplPicker.style.display = 'block';
    });
  }

  // Form submit via JSON
  if (createForm) {
    createForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var submitBtn = createForm.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Posting...';
      try {
        var res = await fetch('/api/create-event', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: document.getElementById('cpTitle').value,
            type: document.getElementById('cpType').value,
            description: document.getElementById('cpDesc').value,
            spots: document.getElementById('cpSpots').value || '',
            location: document.getElementById('cpZone').value,
            event_month: document.getElementById('cpMonth').value || '',
            event_day: document.getElementById('cpDay').value || '',
          })
        });
        var data = await res.json();
        if (data.ok) {
          window.location.reload();
        } else {
          alert(data.error || 'Something went wrong');
        }
      } catch {
        alert('Network error — try again');
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Post event';
    });
  }
</script>

