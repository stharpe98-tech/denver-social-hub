  .fpill[data-type="all"] { --pill-accent: #7C3AED; --pill-bg: rgba(124,58,237,0.08); --pill-text: #7C3AED; }
  .fpill-foryou {
    background: linear-gradient(135deg, #FCE7F3 0%, #EEF2FF 50%, #ECFDF5 100%);
    border-color: #D8B4FE;
  }
  .fpill-foryou .fpill-label { background: linear-gradient(135deg, #EC4899, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .fpill-foryou.active { border-color: #7C3AED; }

  /* ═══ POST BANNER ═══ */
  .post-banner {
