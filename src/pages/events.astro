---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getContent } from '../lib/content';

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const db = getDB();
let events: any[] = [];
let rsvpCounts: Record<number, number> = {};
try {
  if (db) {
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentDay = now.getDate();
    const monthOrder: Record<string,number> = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};
    const allEvents = (await db.prepare("SELECT * FROM events WHERE is_past IS NULL OR is_past=0 ORDER BY id DESC").all())?.results || [];
    events = allEvents.filter((e: any) => {
      const m = monthOrder[(e.event_month || '').toUpperCase()];
      const d = parseInt(e.event_day) || 99;
      if (m === undefined) return true;
      if (m < currentMonth) return false;
      if (m === currentMonth && d < currentDay) return false;
      return true;
    }).sort((a: any, b: any) => {
      const ma = monthOrder[(a.event_month || '').toUpperCase()] ?? 99;
      const mb = monthOrder[(b.event_month || '').toUpperCase()] ?? 99;
      if (ma !== mb) return ma - mb;
      return (parseInt(a.event_day) || 99) - (parseInt(b.event_day) || 99);
    });
    const counts = (await db.prepare("SELECT event_id, COUNT(*) as cnt FROM event_rsvps GROUP BY event_id").all())?.results || [];
    counts.forEach((c: any) => { rsvpCounts[c.event_id] = c.cnt; });
  }
} catch {}

const typeLabel: Record<string,string> = { dinner:"dinner",game_night:"game_night",outdoor:"outdoor",brewery:"brewery",coffee:"coffee",arts:"arts",music:"music",social:"social",group_tickets:"tickets",camping:"camping",sports_outing:"sports",bowling:"bowling",active:"active",casino:"casino",food_trucks:"food",potluck:"potluck",other:"event" };
const typeSet = new Set(events.map((e: any) => e.event_type).filter(Boolean));
const allTypes = Array.from(typeSet);
const content = await getContent();

function spotsLeft(ev: any): number {
  const total = parseInt(ev.spots) || 10;
  const taken = rsvpCounts[ev.id] || 0;
  return Math.max(0, total - taken);
}
function fillPct(ev: any): number {
  const total = parseInt(ev.spots) || 10;
  const taken = rsvpCounts[ev.id] || 0;
  return Math.min(100, Math.round(taken / total * 100));
}
---
<Base title="Browse Events">
<div class="ev-page">

  <!-- Header -->
  <div class="ev-header">
    <div class="ev-header-left">
      <span class="tag tag-orange">Events</span>
      <h1 class="ev-h1">{events.length} events live</h1>
      <p class="ev-sub">{content.events_subtitle || 'Small groups, real plans, no flakes.'}</p>
    </div>
    {user && (
      <a href="/events/new" class="btn btn-primary" id="createBtn">Post an event</a>
    )}
  </div>

  <!-- Filter strip -->
  <div class="ev-filters" id="filterStrip">
    <button class="fpill active" data-type="all">all</button>
    {allTypes.map(t => (
      <button class="fpill" data-type={t}>{typeLabel[t] || t}</button>
    ))}
  </div>

  <!-- Event grid -->
  {events.length > 0 ? (
    <div class="ev-grid" id="eventGrid">
      {events.map((ev: any) => (
          <a href={`/events/${ev.id}`} class="ec" data-type={ev.event_type}>
            <div class="ec-top">
              <span class="ec-type tag tag-blue">{typeLabel[ev.event_type] || 'event'}</span>
              {ev.karma_min > 0 && <span class="tag tag-yellow">{ev.karma_min}+ karma</span>}
              {spotsLeft(ev) <= 3 && spotsLeft(ev) > 0 && <span class="tag tag-orange">last {spotsLeft(ev)} spots</span>}
              {spotsLeft(ev) === 0 && <span class="tag" style="background:rgba(255,71,87,0.12);color:#ff4757">Full</span>}
            </div>
            <h3 class="ec-title">{ev.title}</h3>
            {ev.description && <p class="ec-desc">{ev.description.slice(0, 80)}</p>}
            <div class="ec-meta">
              <span class="ec-date">{ev.event_month} {ev.event_day}</span>
              <span class="ec-dot"></span>
              <span>{ev.zone || ev.location || 'Denver'}</span>
            </div>
            <div class="ec-footer">
              <div class="ec-fill-wrap">
                <div class="ec-fill-bar"><div class="ec-fill" style={`width:${fillPct(ev)}%`}></div></div>
                <span class="ec-fill-text">{rsvpCounts[ev.id] || 0}/{ev.spots || 12}</span>
              </div>
              {ev.host_name && <span class="ec-host">by {ev.host_name}</span>}
            </div>
          </a>
      ))}
    </div>
  ) : (
    <div class="ev-empty">
      <div class="ev-empty-term">
        <span class="term-prompt">$</span> <span class="term-cmd">What's happening</span><br/>
        <span class="term-output">No events right now — check back soon.</span>
      </div>
      <p>{content.events_empty || 'Check back soon or post your own event.'}</p>
      {!user && <a href="/login" class="btn btn-primary">sign in to post</a>}
    </div>
  )}

  <!-- Create event panel (logged-in, inline) -->
  <div class="create-panel" id="createPanel" style="display:none">
    <div class="cp-header">
      <h3>Post an event</h3>
      <button class="cp-close" id="createClose">&times;</button>
    </div>
    <form method="POST" action="/api/create-event" class="cp-form">
      <div class="cp-row">
        <label class="cp-label">title</label>
        <input type="text" name="title" required placeholder="Korean BBQ Night" class="input" />
      </div>
      <div class="cp-row">
        <label class="cp-label">type</label>
        <select name="event_type" class="input">
          <option value="dinner">dinner</option>
          <option value="outdoor">outdoor</option>
          <option value="game_night">game night</option>
          <option value="arts">arts / pottery</option>
          <option value="brewery">brewery</option>
          <option value="coffee">coffee</option>
          <option value="bowling">bowling</option>
          <option value="social">social</option>
          <option value="other">other</option>
        </select>
      </div>
      <div class="cp-row-half">
        <div class="cp-row">
          <label class="cp-label">month</label>
          <input type="text" name="event_month" placeholder="MAY" class="input" />
        </div>
        <div class="cp-row">
          <label class="cp-label">day</label>
          <input type="text" name="event_day" placeholder="15" class="input" />
        </div>
      </div>
      <div class="cp-row">
        <label class="cp-label">neighborhood</label>
        <input type="text" name="zone" placeholder="RiNo, LoHi, etc." class="input" />
      </div>
      <div class="cp-row">
        <label class="cp-label">spots</label>
        <input type="number" name="spots" value="12" class="input" />
      </div>
      <div class="cp-row">
        <label class="cp-label">description</label>
        <textarea name="description" rows="3" placeholder="What's the plan?" class="input" style="border-radius:8px;resize:vertical"></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%">Submit for review</button>
    </form>
  </div>

</div>
</Base>

<style is:inline>
  .ev-page { max-width: 960px; margin: 0 auto; padding: 24px 24px 80px; }

  /* Header */
  .ev-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; }
  .ev-h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; margin-top: 6px; }
  .ev-sub { font-size: 14px; color: var(--text-sec); margin-top: 4px; }

  /* Filters */
  .ev-filters {
    display: flex; gap: 6px; overflow-x: auto; padding-bottom: 16px;
    border-bottom: 1px solid var(--border); margin-bottom: 20px;
    scrollbar-width: none;
  }
  .ev-filters::-webkit-scrollbar { display: none; }
  .fpill {
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    padding: 6px 14px; border-radius: 6px; border: 1px solid var(--border);
    background: var(--surface); color: var(--text-faint);
    cursor: pointer; white-space: nowrap; transition: all .2s;
  }
  .fpill:hover { color: var(--text-sec); border-color: var(--border-hover); }
  .fpill.active { background: var(--accent-dim); color: var(--accent); border-color: var(--accent); }

  /* Event grid */
  .ev-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

  .ec {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 18px; text-decoration: none;
    display: flex; flex-direction: column; gap: 8px;
    transition: all .25s;
  }
  .ec:hover { border-color: var(--border-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .ec[data-hidden="true"] { display: none; }

  .ec-top { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .ec-title { font-weight: 700; font-size: 16px; color: var(--text); line-height: 1.3; }
  .ec-desc { font-size: 13px; color: var(--text-sec); line-height: 1.5; }
  .ec-meta {
    font-family: var(--mono); font-size: 12px; color: var(--text-faint);
    display: flex; align-items: center; gap: 6px;
  }
  .ec-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-faint); }
  .ec-date { color: var(--text-sec); }

  .ec-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 6px; }
  .ec-fill-wrap { display: flex; align-items: center; gap: 8px; }
  .ec-fill-bar { width: 56px; height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; }
  .ec-fill { height: 100%; border-radius: 2px; background: var(--green); transition: width .3s; }
  .ec-fill-text { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }
  .ec-host { font-family: var(--mono); font-size: 11px; color: var(--text-faint); }

  /* Empty state */
  .ev-empty { text-align: center; padding: 48px 24px; }
  .ev-empty-term {
    display: inline-block; text-align: left;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px 20px;
    font-family: var(--mono); font-size: 13px;
    margin-bottom: 16px;
  }
  .term-prompt { color: var(--accent); font-weight: 700; }
  .term-cmd { color: var(--text); }
  .term-output { color: var(--text-faint); }
  .ev-empty p { color: var(--text-sec); font-size: 14px; margin-bottom: 16px; }

  /* Create panel */
  .create-panel {
    position: fixed; bottom: 80px; right: 24px; z-index: 1000;
    width: 380px; max-height: 80vh; overflow-y: auto;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; box-shadow: 0 16px 48px rgba(0,0,0,0.4);
    padding: 20px;
  }
  .cp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .cp-header h3 { font-family: var(--mono); font-size: 15px; font-weight: 700; }
  .cp-close {
    width: 28px; height: 28px; border-radius: 6px; border: 1px solid var(--border);
    background: var(--surface); color: var(--text-faint); font-size: 16px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
  }
  .cp-close:hover { color: var(--text); }
  .cp-form { display: flex; flex-direction: column; gap: 12px; }
  .cp-label { font-family: var(--mono); font-size: 11px; color: var(--text-faint); font-weight: 600; display: block; margin-bottom: 4px; }
  .cp-row-half { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  @media (max-width: 640px) {
    .ev-grid { grid-template-columns: 1fr; }
    .ev-header { flex-direction: column; gap: 12px; }
    .create-panel { left: 12px; right: 12px; width: auto; bottom: 72px; }
  }
</style>

<script is:inline>
  // Filter logic
  var filterBtns = document.querySelectorAll('.fpill');
  var cards = document.querySelectorAll('.ec');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var type = btn.getAttribute('data-type');
      cards.forEach(function(card) {
        if (type === 'all' || card.getAttribute('data-type') === type) {
          card.removeAttribute('data-hidden');
          card.style.display = '';
        } else {
          card.setAttribute('data-hidden', 'true');
          card.style.display = 'none';
        }
      });
    });
  });

  // Create panel toggle
  var createBtn = document.getElementById('createBtn');
  var createPanel = document.getElementById('createPanel');
  var createClose = document.getElementById('createClose');
  if (createBtn && createPanel) {
    createBtn.addEventListener('click', function(e) {
      e.preventDefault();
      createPanel.style.display = createPanel.style.display === 'none' ? 'block' : 'none';
    });
  }
  if (createClose && createPanel) {
    createClose.addEventListener('click', function() { createPanel.style.display = 'none'; });
  }
</script>

