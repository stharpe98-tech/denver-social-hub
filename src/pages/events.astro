  }
  .wiz-sug-chip:hover { border-color: #7C3AED; color: #7C3AED; background: rgba(124,58,237,0.04); transform: translateY(-1px); }
  .wiz-sug-chip.selected { border-color: #7C3AED; background: rgba(124,58,237,0.08); color: #7C3AED; }
  .wiz-sug-other { border-style: dashed; color: #9CA3AF; }
  .wiz-sug-other:hover { border-color: #7C3AED; color: #7C3AED; border-style: dashed; }
  .wiz-sug-other.selected { border-style: dashed; }
  .wiz-input {
    width: 100%; padding: 16px 20px; background: #F8F9FB; border: 2px solid #E5E7EB;
    border-radius: 14px; font-size: 16px; color: #111827; font-family: 'Inter', sans-serif;
    outline: none; transition: border-color .2s;
  }
  .wiz-input:focus { border-color: #7C3AED; background: #fff; }
  .wiz-input::placeholder { color: #D1D5DB; }
  .wiz-textarea {
    width: 100%; padding: 16px 20px; background: #F8F9FB; border: 2px solid #E5E7EB;
    border-radius: 14px; font-size: 15px; color: #111827; font-family: 'Inter', sans-serif;
    outline: none; resize: vertical; transition: border-color .2s;
  }
  .wiz-textarea:focus { border-color: #7C3AED; background: #fff; }
  .wiz-textarea::placeholder { color: #D1D5DB; }
  .wiz-next, .wiz-submit {
    margin-top: 18px; padding: 14px 32px; background: #7C3AED; color: #fff;
    border: none; border-radius: 50px; font-size: 15px; font-weight: 700;
    font-family: 'Outfit', sans-serif; cursor: pointer; transition: all .2s;
    width: 100%;
  }
  .wiz-next:hover, .wiz-submit:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 6px 18px rgba(124,58,237,0.25); }
  .wiz-next:disabled, .wiz-submit:disabled { opacity: .5; cursor: not-allowed; transform: none; box-shadow: none; }
  .wiz-ghost {
    margin-top: 10px; padding: 14px 32px; background: #F8F9FB; color: #6B7280;
    border: 1px solid #E5E7EB; border-radius: 50px; font-size: 15px; font-weight: 700;
    font-family: 'Outfit', sans-serif; cursor: pointer; transition: all .2s; width: 100%;
  }
  .wiz-ghost:hover { color: #111827; border-color: #D1D5DB; }
  .wiz-err { font-size: 12px; font-weight: 600; color: #DC2626; margin-top: 8px; min-height: 18px; font-family: 'Outfit', sans-serif; }

  /* Type grid */
  .wiz-type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
  .wiz-type-btn {
    padding: 14px 12px; background: #F8F9FB; border: 2px solid #E5E7EB;
    border-radius: 14px; font-size: 13px; font-weight: 600; color: #374151;
    font-family: 'Outfit', sans-serif; cursor: pointer; transition: all .15s;
    text-align: center;
  }
  .wiz-type-btn:hover { border-color: #D1D5DB; background: #fff; transform: translateY(-1px); }
  .wiz-type-btn.selected { border-color: #7C3AED; background: rgba(124,58,237,0.06); color: #7C3AED; box-shadow: 0 2px 8px rgba(124,58,237,0.12); }

  /* Pill select buttons (when/where/budget/size) */
  .wiz-label {
    display: block; font-size: 12px; font-weight: 700; color: #6B7280;
    font-family: 'Outfit', sans-serif; text-transform: uppercase;
    letter-spacing: .06em; margin-bottom: 10px;
  }
  .wiz-pill-btn {
    padding: 11px 16px; background: #F8F9FB; border: 2px solid #E5E7EB;
    border-radius: 50px; font-size: 13px; font-weight: 600; color: #374151;
    font-family: 'Outfit', sans-serif; cursor: pointer; transition: all .15s;
    text-align: center;
  }
  .wiz-pill-btn:hover { border-color: #D1D5DB; background: #fff; }
  .wiz-pill-btn.selected { border-color: #7C3AED; background: rgba(124,58,237,0.06); color: #7C3AED; }
  .wiz-when-grid, .wiz-budget-grid, .wiz-size-grid { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }
  .wiz-where-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }

  /* Mode toggle */
  .wiz-mode-toggle {
    display: flex; gap: 8px; margin: 16px 0 4px;
  }
  .wiz-mode-btn {
    flex: 1; padding: 12px 10px; border-radius: 12px;
    background: #F8F9FB; border: 2px solid #E5E7EB;
    font-size: 13px; font-weight: 700; color: #6B7280;
    font-family: 'Outfit', sans-serif; cursor: pointer; transition: all .15s;
    text-align: center;
  }
  .wiz-mode-btn:hover { border-color: #D1D5DB; color: #374151; }
  .wiz-mode-btn.selected[data-mode="live"] { border-color: #10B981; background: rgba(16,185,129,0.06); color: #059669; }
  .wiz-mode-btn.selected[data-mode="suggest"] { border-color: #7C3AED; background: rgba(124,58,237,0.06); color: #7C3AED; }

  /* Done step */
  .wiz-done { text-align: center; padding: 32px 32px 28px; }
  .wiz-done-icon { font-size: 52px; margin-bottom: 12px; }
  .wiz-done-btns { display: flex; flex-direction: column; gap: 0; }

  @media (max-width: 768px) {
    .ev-page { padding: 0 20px 40px; }
    .ev-grid { grid-template-columns: 1fr; }
    .chooser-cards { grid-template-columns: 1fr; max-width: 320px; }
    .wiz-type-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
  }
</style>

<script is:inline define:vars={{ isLoggedIn }}>
(function() {
  var chooser = document.getElementById('chooser');
  var browsePath = document.getElementById('browsePath');
  var suggestPath = document.getElementById('suggestPath');

  function showView(view) {
    chooser.style.display = 'none';
    browsePath.style.display = 'none';
    suggestPath.style.display = 'none';
    if (view === 'chooser') chooser.style.display = '';
    if (view === 'browse') browsePath.style.display = '';
    if (view === 'suggest') suggestPath.style.display = '';
    window.scrollTo(0, 0);
  }

  document.getElementById('pickBrowse').addEventListener('click', function() { showView('browse'); });
  document.getElementById('pickSuggest').addEventListener('click', function() { showView('suggest'); });
  document.getElementById('browseBack').addEventListener('click', function() { showView('chooser'); });
  document.getElementById('suggestBack').addEventListener('click', function() { showView('chooser'); resetWizard(); });

  // ── Filter pills ──
  document.querySelectorAll('.fpill').forEach(function(pill) {
    pill.addEventListener('click', function() {
      document.querySelectorAll('.fpill').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      var type = this.getAttribute('data-type');
      document.querySelectorAll('.ec').forEach(function(card) {
        card.style.display = (type === 'all' || card.getAttribute('data-type') === type) ? '' : 'none';
      });
    });
  });

  // ── Wizard ──
  var TOTAL_STEPS = 4;
  var wizMode = isLoggedIn ? 'live' : 'suggest'; // 'live' = create event, 'suggest' = suggestion
  var wizData = { title: '', type: 'social', suggested_date: '', location: '', venue: '', link: '', budget: '', group_size: '', description: '' };

  // Auto-suggestion names by type
  var suggestions = {
    dinner:        ['Taco Tuesday', 'Ramen Night', 'Sushi Hangout', 'Pizza Party', 'BBQ Cookout'],
    brewery:       ['Brewery Crawl', 'Taproom Hangout', 'Craft Beer Night', 'New Brewery Tour'],
    outdoor:       ['Group Hike', 'Park Hangout', 'Bike Ride', 'Sunrise Hike', 'Trail Run'],
    game_night:    ['Board Game Night', 'Trivia Night', 'Card Games', 'Video Game Tourney'],
    coffee:        ['Coffee & Chat', 'Café Hop', 'Morning Meetup', 'Latte Walk'],
    arts:          ['Gallery Walk', 'Paint Night', 'Pottery Class', 'Art Museum Trip'],
    music:         ['Live Music Night', 'Concert Outing', 'Open Mic', 'Jazz Night'],
    social:        ['Happy Hour', 'Karaoke Night', 'Rooftop Hangout', 'New Friends Mixer'],
    sports:        ['Pickup Basketball', 'Flag Football', 'Volleyball', 'Soccer Match'],
    group_tickets: ['Comedy Show', 'Rockies Game', 'Nuggets Game', 'Avs Game', 'Rapids Match'],
    camping:       ['Weekend Camping', 'Overnight Trip', 'Car Camping', 'Backpacking'],
    bowling:       ['Bowling Night', 'Cosmic Bowling', 'Bowling + Beers'],
    active:        ['Rock Climbing', 'Yoga in the Park', 'Kayaking', 'Ice Skating'],
    casino:        ['Casino Night', 'Poker Night', 'Blackhawk Trip'],
    food_trucks:   ['Food Truck Rally', 'Street Eats Tour', 'Food Truck Friday'],
    potluck:       ['Potluck Dinner', 'Dish Swap', 'Themed Potluck', 'Cook-Off'],
    other:         ['Hangout', 'Meetup', 'Get-Together', 'Group Outing']
  };

  // Venue suggestions by type
  var venueSuggestions = {
    dinner:        ['Guard & Grace', 'Uncle', 'Tavernetta', 'El Five', 'Hop Alley', 'Safta'],
    brewery:       ['Ratio Beerworks', 'Great Divide', 'Odell Brewing', 'Cerebral Brewing', 'Our Mutual Friend'],
    outdoor:       ['Red Rocks', 'Sloan\'s Lake', 'Wash Park', 'Chatfield', 'Bear Creek Trail', 'South Table Mountain'],
    game_night:    ['Board Game Republic', 'Grandma\'s House', 'Punch Bowl Social', 'Dave & Buster\'s'],
    coffee:        ['Crema', 'Huckleberry', 'Thump Coffee', 'Little Owl', 'Novo Coffee'],
    arts:          ['Denver Art Museum', 'Meow Wolf', 'RINO Art District', 'Artwork Network'],
    music:         ['Red Rocks', 'Dazzle', 'Globe Hall', 'Cervantes', 'Mission Ballroom'],
    social:        ['Punch Bowl Social', 'Topgolf', 'ViewHouse', 'Finn\'s Manor', 'Lustre Pearl'],
    sports:        ['City Park', 'Sloans Lake', 'Ruby Hill', 'Coors Field area'],
    group_tickets: ['Ball Arena', 'Coors Field', 'Empower Field', 'Dick\'s Sporting Goods Park'],
    camping:       ['Mueller State Park', 'Golden Gate Canyon', 'Chatfield', 'Cherry Creek State Park'],
    bowling:       ['Lucky Strike', 'Elitch Lanes', 'AMF', 'Bowlero'],
    active:        ['Movement RiNo', 'Earth Treks', 'Confluence Kayaks', 'Denver Bouldering Club'],
    casino:        ['Ameristar (Blackhawk)', 'Monarch (Blackhawk)', 'Johnny Z\'s (Central City)', 'The Lodge (Blackhawk)'],
    food_trucks:   ['Civic Center Eats', 'Stanley Marketplace', 'Union Station', 'RiNo Food Truck Park'],
    potluck:       ['Someone\'s place', 'Community center', 'Park pavilion'],
    other:         []
  };

  // Venue label by type
  var venueLabels = {
    dinner: 'Which restaurant?', brewery: 'Which brewery?', casino: 'Which casino?',
    coffee: 'Which café?', music: 'Which venue?', bowling: 'Which alley?',
    arts: 'Which gallery/museum?', active: 'Which gym/spot?'
  };

  function renderSuggestions(type) {
    var container = document.getElementById('wizSuggestions');
    var items = suggestions[type] || suggestions.other;
    container.innerHTML = '';
    items.forEach(function(name) {
      var chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'wiz-sug-chip';
      chip.textContent = name;
      chip.addEventListener('click', function() {
        container.querySelectorAll('.wiz-sug-chip').forEach(function(c) { c.classList.remove('selected'); });
        chip.classList.add('selected');
        document.getElementById('wizTitle').value = name;
      });
      container.appendChild(chip);
    });
    // "Other" chip — clears input and focuses it
    var other = document.createElement('button');
    other.type = 'button';
    other.className = 'wiz-sug-chip wiz-sug-other';
    other.textContent = '✏️ Other';
    other.addEventListener('click', function() {
      container.querySelectorAll('.wiz-sug-chip').forEach(function(c) { c.classList.remove('selected'); });
      other.classList.add('selected');
      document.getElementById('wizTitle').value = '';
      document.getElementById('wizTitle').focus();
    });
    container.appendChild(other);
  }

  function renderVenueSuggestions(type) {
    var container = document.getElementById('wizVenueSuggestions');
    var items = venueSuggestions[type] || [];
    var label = document.getElementById('wizVenueLabel');
    label.textContent = venueLabels[type] || 'Specific spot?';
    container.innerHTML = '';
    items.forEach(function(name) {
      var chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'wiz-sug-chip';
      chip.textContent = name;
      chip.addEventListener('click', function() {
        container.querySelectorAll('.wiz-sug-chip').forEach(function(c) { c.classList.remove('selected'); });
        chip.classList.add('selected');
        document.getElementById('wizVenue').value = name;
      });
      container.appendChild(chip);
    });
    // "Other" chip — clears input and focuses it
    var other = document.createElement('button');
    other.type = 'button';
    other.className = 'wiz-sug-chip wiz-sug-other';
    other.textContent = '✏️ Other';
    other.addEventListener('click', function() {
      container.querySelectorAll('.wiz-sug-chip').forEach(function(c) { c.classList.remove('selected'); });
      other.classList.add('selected');
      document.getElementById('wizVenue').value = '';
      document.getElementById('wizVenue').focus();
    });
    container.appendChild(other);
  }

  function showStep(n) {
    for (var i = 1; i <= 5; i++) {
      var el = document.getElementById('wizStep' + i);
      if (el) el.style.display = (i === n) ? '' : 'none';
    }
    var pct = n >= 5 ? 100 : Math.round((n / TOTAL_STEPS) * 100);
    document.getElementById('wizProgress').style.width = pct + '%';
  }

  function resetWizard() {
    wizData = { title: '', type: 'social', suggested_date: '', location: '', venue: '', link: '', budget: '', group_size: '', description: '' };
    wizMode = isLoggedIn ? 'live' : 'suggest';
    document.getElementById('wizTitle').value = '';
    document.getElementById('wizType').value = 'social';
    document.getElementById('wizDesc').value = '';
    document.getElementById('wizVenue').value = '';
    document.getElementById('wizLink').value = '';
    document.querySelectorAll('.wiz-pill-btn, .wiz-sug-chip').forEach(function(b) { b.classList.remove('selected'); });
    document.querySelectorAll('.wiz-err').forEach(function(e) { e.textContent = ''; });
    // Reset mode toggle
    if (isLoggedIn) {
      document.getElementById('wizModeLive').classList.add('selected');
      document.getElementById('wizModeSuggest').classList.remove('selected');
      document.getElementById('wizSubmit').textContent = 'Create Event';
    }
    renderSuggestions('social');
    renderVenueSuggestions('social');
    showStep(1);
  }

  // Render initial suggestions
  renderSuggestions('social');
  renderVenueSuggestions('social');

  // Dropdown change → update suggestions + venue suggestions
  document.getElementById('wizType').addEventListener('change', function() {
    wizData.type = this.value;
    document.getElementById('wizTitle').value = '';
    renderSuggestions(this.value);
    renderVenueSuggestions(this.value);
  });

  // Clear suggestion selection when user types manually
  document.getElementById('wizTitle').addEventListener('input', function() {
    document.querySelectorAll('#wizSuggestions .wiz-sug-chip').forEach(function(c) { c.classList.remove('selected'); });
  });
  document.getElementById('wizVenue').addEventListener('input', function() {
    document.querySelectorAll('#wizVenueSuggestions .wiz-sug-chip').forEach(function(c) { c.classList.remove('selected'); });
  });

  // Step 1 → 2 (also update venue suggestions for selected type)
  document.getElementById('wizNext1').addEventListener('click', function() {
    var val = document.getElementById('wizTitle').value.trim();
    if (!val) { document.getElementById('wizErr1').textContent = 'Pick a suggestion or type a name.'; return; }
    wizData.title = val;
    wizData.type = document.getElementById('wizType').value;
    document.getElementById('wizErr1').textContent = '';
    renderVenueSuggestions(wizData.type);
    showStep(2);
  });

  document.getElementById('wizTitle').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('wizNext1').click(); }
  });

  // Pill buttons (date, location, budget, group_size)
  document.querySelectorAll('.wiz-pill-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var field = btn.getAttribute('data-field');
      document.querySelectorAll('.wiz-pill-btn[data-field="' + field + '"]').forEach(function(b) { b.classList.remove('selected'); });
      btn.classList.add('selected');
      wizData[field] = btn.getAttribute('data-val');
    });
  });

  // Step 2 → 3 (capture venue + link)
  document.getElementById('wizNext2').addEventListener('click', function() {
    wizData.venue = document.getElementById('wizVenue').value.trim();
    wizData.link = document.getElementById('wizLink').value.trim();
    showStep(3);
  });

  // Step 3 → 4
  document.getElementById('wizNext3').addEventListener('click', function() { showStep(4); });

  // Mode toggle (live vs suggest) — only exists for logged-in users
  if (isLoggedIn) {
    document.querySelectorAll('.wiz-mode-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.wiz-mode-btn').forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        wizMode = btn.getAttribute('data-mode');
        document.getElementById('wizSubmit').textContent = wizMode === 'live' ? 'Create Event' : 'Submit Suggestion';
      });
    });
  }

  // Step 4 → submit
  document.getElementById('wizSubmit').addEventListener('click', function() {
    var btn = this;
    wizData.description = document.getElementById('wizDesc').value.trim();
    btn.disabled = true;
    btn.textContent = wizMode === 'live' ? 'Creating...' : 'Submitting...';
    document.getElementById('wizErr4').textContent = '';

    var endpoint = wizMode === 'live' ? '/api/create-event' : '/api/suggest';

    fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(wizData)
    }).then(function(r) { return r.json(); }).then(function(data) {
      btn.disabled = false;
      btn.textContent = wizMode === 'live' ? 'Create Event' : 'Submit Suggestion';
      if (data.ok) {
        // Update done screen messaging
        var doneTitle = document.getElementById('wizDoneTitle');
        var doneHint = document.getElementById('wizDoneHint');
        if (wizMode === 'live') {
          doneTitle.textContent = 'Event Created!';
          doneHint.textContent = 'Your event is live — people can RSVP now.';
        } else {
          doneTitle.textContent = 'Suggestion Submitted!';
          doneHint.textContent = 'The community will vote on your idea. Thanks for making Denver more fun.';
        }
        showStep(5);
      } else {
        document.getElementById('wizErr4').textContent = data.error || 'Something went wrong.';
      }
    }).catch(function() {
      btn.disabled = false;
      btn.textContent = wizMode === 'live' ? 'Create Event' : 'Submit Suggestion';
      document.getElementById('wizErr4').textContent = 'Network error. Try again.';
    });
  });

  // Done → another / browse
  document.getElementById('wizAnother').addEventListener('click', function() { resetWizard(); });
  document.getElementById('wizBrowse').addEventListener('click', function() { resetWizard(); showView('browse'); });
})();
</script>

</Base>
