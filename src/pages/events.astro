---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
const isLoggedIn = !!user;
const isAdmin = user?.role === 'admin';

const db = getDB();
let events: any[] = [];
let rsvpCounts: Record<number, number> = {};
try {
  if (db) {
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentDay = now.getDate();
    const monthOrder: Record<string,number> = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};

    const allEvents = (await db.prepare("SELECT * FROM events WHERE is_past IS NULL OR is_past=0 ORDER BY id DESC").all())?.results || [];

    events = allEvents.filter((e: any) => {
      const m = monthOrder[(e.event_month || '').toUpperCase()];
      const d = parseInt(e.event_day) || 99;
      if (m === undefined) return true;
      if (m < currentMonth) return false;
      if (m === currentMonth && d < currentDay) return false;
      return true;
    }).sort((a: any, b: any) => {
      const ma = monthOrder[(a.event_month || '').toUpperCase()] ?? 99;
      const mb = monthOrder[(b.event_month || '').toUpperCase()] ?? 99;
      if (ma !== mb) return ma - mb;
      const da = parseInt(a.event_day) || 99;
      const db2 = parseInt(b.event_day) || 99;
      return da - db2;
    });
    const counts = (await db.prepare("SELECT event_id, COUNT(*) as cnt FROM event_rsvps GROUP BY event_id").all())?.results || [];
    counts.forEach((c: any) => { rsvpCounts[c.event_id] = c.cnt; });
  }
} catch {}

const typeEmoji: Record<string,string> = { dinner:"🍽️",game_night:"🎳",outdoor:"🏔️",brewery:"🍺",coffee:"☕",arts:"🎨",music:"🎵",social:"🎉",group_tickets:"🎫",camping:"🏕️",sports_outing:"🏒",sports:"🏒",bowling:"🎳",active:"🧗",casino:"🎰",food_trucks:"🌮",potluck:"🍲",other:"📅" };

const typeColors: Record<string, { accent: string; tagBg: string; tagText: string }> = {
  dinner:        { accent:"#F05A28", tagBg:"#FFF7ED", tagText:"#C2410C" },
  game_night:    { accent:"#7C3AED", tagBg:"#EEF2FF", tagText:"#5B21B6" },
  outdoor:       { accent:"#059669", tagBg:"#F0FDF4", tagText:"#047857" },
  brewery:       { accent:"#D97706", tagBg:"#FFFBEB", tagText:"#92400E" },
  coffee:        { accent:"#92400E", tagBg:"#FEF3C7", tagText:"#78350F" },
  arts:          { accent:"#DB2777", tagBg:"#FDF2F8", tagText:"#9D174D" },
  music:         { accent:"#7C3AED", tagBg:"#F5F3FF", tagText:"#6D28D9" },
  social:        { accent:"#EC4899", tagBg:"#FCE7F3", tagText:"#BE185D" },
  group_tickets: { accent:"#2563EB", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  camping:       { accent:"#059669", tagBg:"#ECFDF5", tagText:"#065F46" },
  sports_outing: { accent:"#2563EB", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  bowling:       { accent:"#3B82F6", tagBg:"#EFF6FF", tagText:"#1D4ED8" },
  active:        { accent:"#059669", tagBg:"#ECFDF5", tagText:"#065F46" },
  casino:        { accent:"#DC2626", tagBg:"#FEF2F2", tagText:"#991B1B" },
  food_trucks:   { accent:"#EA580C", tagBg:"#FFF7ED", tagText:"#C2410C" },
  potluck:       { accent:"#F05A28", tagBg:"#FFF7ED", tagText:"#C2410C" },
  sports:        { accent:"#2563EB", tagBg:"#EFF6FF", tagText:"#1E40AF" },
  other:         { accent:"#7C3AED", tagBg:"#EEF2FF", tagText:"#4338CA" },
};

function getTypeColor(type: string) {
  return typeColors[type] || typeColors.other;
}

const typeImages: Record<string, string> = {
  dinner:        "https://images.unsplash.com/photo-1529543544282-ea669407fca3?w=600&q=70",
  game_night:    "https://images.unsplash.com/photo-1632501641765-e568d28b0015?w=600&q=70",
  outdoor:       "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&q=70",
  brewery:       "https://images.unsplash.com/photo-1535958636474-b021ee887b13?w=600&q=70",
  coffee:        "https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=600&q=70",
  arts:          "https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600&q=70",
  music:         "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=600&q=70",
  social:        "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&q=70",
  group_tickets: "https://images.unsplash.com/photo-1540039155733-5bb30b53aa14?w=600&q=70",
  camping:       "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=600&q=70",
  sports_outing: "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=600&q=70",
  bowling:       "https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=600&q=70",
  active:        "https://images.unsplash.com/photo-1522163182402-834f871fd851?w=600&q=70",
  casino:        "https://images.unsplash.com/photo-1596838132731-3301c3fd4317?w=600&q=70",
  food_trucks:   "https://images.unsplash.com/photo-1565123409695-7b5ef63a2efb?w=600&q=70",
  potluck:       "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=600&q=70",
  sports:        "https://images.unsplash.com/photo-1461896836934-bd45ba8fcbf5?w=600&q=70",
  other:         "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&q=70",
};

function spotsLeft(ev: any): number {
  const total = parseInt(ev.spots) || 10;
  const taken = rsvpCounts[ev.id] || 0;
  return Math.max(0, total - taken);
}

function priceLabel(ev: any): string {
  if (!ev.price_cap || ev.price_cap === 'Free' || ev.price_cap === '$0') return 'Free';
  return ev.price_cap;
}

function isHotEvent(ev: any): boolean {
  const left = spotsLeft(ev);
  return left >= 1 && left <= 4;
}

const typeToInterests: Record<string, string[]> = {
  dinner: ["Food & Dining","Craft Beer"], brewery: ["Craft Beer","Food & Dining"],
  coffee: ["Coffee & Cafes"], outdoor: ["Hiking","Outdoors"], camping: ["Hiking","Outdoors"],
  active: ["Fitness","Hiking","Outdoors"], music: ["Live Music"], arts: ["Art & Culture"],
  game_night: ["Board Games","Trivia"], bowling: ["Bowling"], casino: ["Casino Trips"],
  sports: ["Sports"], sports_outing: ["Sports"], food_trucks: ["Food & Dining"],
  potluck: ["Food & Dining"], social: ["Food & Dining","Craft Beer","Live Music"],
  group_tickets: ["Live Music","Art & Culture","Sports"],
};

let userInterests: string[] = [];
if (user && db) {
  try {
    const m: any = await db.prepare("SELECT interests FROM members WHERE email=?").bind(user.email).first();
    if (m?.interests) userInterests = m.interests.split(",").map((s: string) => s.replace(/^[^\w\s]+\s*/, '').trim());
  } catch {}
}

function eventMatchesUser(eventType: string): boolean {
  if (!userInterests.length) return false;
  const keywords = typeToInterests[eventType] || [];
  return keywords.some(k => userInterests.some(ui => k.includes(ui) || ui.includes(k)));
}

// ── Group events by timeframe ──
const monthOrder: Record<string,number> = {JAN:0,FEB:1,MAR:2,APR:3,MAY:4,JUN:5,JUL:6,AUG:7,SEP:8,OCT:9,NOV:10,DEC:11};
const now = new Date();

function daysUntilEvent(ev: any): number {
  const m = monthOrder[(ev.event_month || '').toUpperCase()];
  const d = parseInt(ev.event_day) || 99;
  if (m === undefined) return 999;
  const target = new Date(now.getFullYear(), m, d);
  return Math.ceil((target.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
}

const thisWeekEvents = events.filter(e => daysUntilEvent(e) <= 7 && daysUntilEvent(e) >= 0);
const laterEvents = events.filter(e => daysUntilEvent(e) > 7 || daysUntilEvent(e) < 0);
const featured = thisWeekEvents[0] || events[0];
const alsoSoon = thisWeekEvents.slice(featured && thisWeekEvents.includes(featured) ? 1 : 0);
const comingUp = thisWeekEvents.includes(featured) ? laterEvents : events.slice(1);

// Day name helper
const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
function eventDayName(ev: any): string {
  const m = monthOrder[(ev.event_month || '').toUpperCase()];
  const d = parseInt(ev.event_day);
  if (m === undefined || isNaN(d)) return '';
  const date = new Date(now.getFullYear(), m, d);
  return dayNames[date.getDay()] || '';
}

// Dynamic headline
const weekendCount = thisWeekEvents.length;
const headline = weekendCount > 0
  ? `${weekendCount} thing${weekendCount > 1 ? 's' : ''} happening this week`
  : 'New events drop every week';

const typeSet = new Set(events.map((e: any) => e.event_type).filter(Boolean));
---
<Base title="Events">

<div class="ev-page">

  <!-- ═══ BROWSE — Weekend Magazine Layout ═══ -->
  <div id="browsePath" class="path">

    <!-- HERO -->
    <div class="mag-hero">
      <div class="mag-hero-glow"></div>
      <div class="mag-hero-content">
        {isLoggedIn && user?.name && (
          <p class="mag-greeting">Hey {user.name.split(' ')[0]} 👋</p>
        )}
        <h1 class="mag-headline">{headline}</h1>
        <p class="mag-sub">Free to join. Free to host. No fees, no catch — just people making plans.</p>
        <div class="mag-week-pill">
          <span class="mag-week-dot"></span>
          Denver · {events.length} upcoming
        </div>
      </div>
    </div>

    <!-- POST AN EVENT BANNER -->
    <div class="post-banner" id="postBanner">
      <div class="post-banner-left">
        <span class="post-banner-icon">✍️</span>
        <div>
          <strong class="post-banner-title">Want to do something?</strong>
          <span class="post-banner-sub">Post an event for free — no account needed</span>
        </div>
      </div>
      <button class="post-banner-btn" id="postBannerBtn">Post an event</button>
    </div>

    <!-- FILTER CHIPS -->
    <div class="filters-wrap">
      <div class="filters" id="filterStrip">
        <button class="fpill active" data-type="all">
          <span class="fpill-emoji">🔥</span>
          <span class="fpill-label">All</span>
        </button>
        {userInterests.length > 0 && (
          <button class="fpill fpill-foryou" data-type="foryou">
            <span class="fpill-emoji">✨</span>
            <span class="fpill-label">For You</span>
          </button>
        )}
        {Array.from(typeSet).map((t: any) => {
          const tc = getTypeColor(t as string);
          return (
            <button class="fpill" data-type={t} style={`--pill-accent: ${tc.accent}; --pill-bg: ${tc.tagBg}; --pill-text: ${tc.tagText};`}>
              <span class="fpill-emoji">{typeEmoji[t as string] || '📅'}</span>
              <span class="fpill-label">{((t as string) || '').replace('_', ' ')}</span>
            </button>
          );
        })}
      </div>
      <div class="filter-fade-r"></div>
    </div>

    {events.length === 0 ? (
      <!-- EMPTY STATE -->
      <div class="mag-empty">
        <div class="mag-empty-icon">🗓️</div>
        <h2 class="mag-empty-title">Nothing on the calendar yet</h2>
        <p class="mag-empty-sub">New events drop every week — mostly weekends. Join the Discord so you don't miss one.</p>
        <div class="mag-empty-actions">
          <button class="mag-empty-btn" id="emptyCreate">Post an event — it's free</button>
          <a href="https://discord.gg/S8SFNkdSgK" class="mag-empty-btn mag-empty-btn-alt" target="_blank" rel="noopener">Join the Discord</a>
        </div>
      </div>
    ) : (
      <div class="mag-content" id="magContent">

        <!-- FEATURED EVENT (big card) -->
        {featured && (
          <a href={`/events/${featured.id}`} class="feat" data-type={featured.event_type}>
            <div class="feat-img" style={`background-image: url(${typeImages[featured.event_type] || typeImages.other});`}>
              <div class="feat-img-overlay"></div>
              <span class="feat-badge">
                {isHotEvent(featured) ? '🔥 Filling up' : `${typeEmoji[featured.event_type] || '📅'} Featured`}
              </span>
              {eventMatchesUser(featured.event_type) && <span class="feat-match">✨ Matches your interests</span>}
            </div>
            <div class="feat-body">
              <div class="feat-tag" style={`background: ${getTypeColor(featured.event_type).tagBg}; color: ${getTypeColor(featured.event_type).tagText};`}>
                {typeEmoji[featured.event_type] || '📅'} {(featured.event_type || '').replace('_', ' ')}
              </div>
              <h2 class="feat-title">{featured.title}</h2>
              <div class="feat-meta">
                <span>📅 {eventDayName(featured)}, {(featured.event_month || 'TBD').slice(0,3)} {featured.event_day || ''}</span>
                <span>📍 {featured.zone || featured.location || 'Denver'}</span>
                {priceLabel(featured) !== 'Free' && <span>💰 {priceLabel(featured)}</span>}
              </div>
              {featured.description && (
                <p class="feat-desc">{featured.description.length > 100 ? featured.description.slice(0, 100) + '...' : featured.description}</p>
              )}
              <div class="feat-footer">
                <div class="feat-going">
                  <div class="feat-faces">
                    {Array.from({length: Math.min(rsvpCounts[featured.id] || 0, 5)}).map((_, i) => (
                      <div class="feat-face" style={`background: hsl(${260 + i * 30}, 60%, 60%); z-index: ${5 - i};`}>
                        {String.fromCharCode(65 + i)}
                      </div>
                    ))}
                  </div>
                  <span class="feat-going-text">
                    <strong>{rsvpCounts[featured.id] || 0} going</strong> · {spotsLeft(featured)} spots left
                  </span>
                </div>
                <span class="feat-rsvp-btn">RSVP →</span>
              </div>
            </div>
          </a>
        )}

        <!-- ALSO THIS WEEK -->
        {alsoSoon.length > 0 && (
          <div class="also-section">
            <h3 class="also-label">Also this week</h3>
            {alsoSoon.map((ev: any) => {
              const tc = getTypeColor(ev.event_type);
              const going = rsvpCounts[ev.id] || 0;
              return (
                <a href={`/events/${ev.id}`} class="mini" data-type={ev.event_type}>
                  <div class="mini-date">
                    <div class="mini-day-name" style={`color: ${tc.accent};`}>{eventDayName(ev).slice(0,3)}</div>
                    <div class="mini-day-num">{ev.event_day || '—'}</div>
                  </div>
                  <div class="mini-info">
                    <div class="mini-title">{ev.title}</div>
                    <div class="mini-sub">
                      {ev.zone || ev.location || 'Denver'} · {going} going · {priceLabel(ev)}
                    </div>
                    {eventMatchesUser(ev.event_type) && <span class="mini-match">✨ For you</span>}
                    {isHotEvent(ev) && <span class="mini-hot">🔥 Filling up</span>}
                  </div>
                  <div class="mini-emoji">{typeEmoji[ev.event_type] || '📅'}</div>
                </a>
              );
            })}
          </div>
        )}

        <!-- COMING UP (further out) -->
        {comingUp.length > 0 && (
          <div class="also-section">
            <h3 class="also-label">Coming up</h3>
            {comingUp.map((ev: any) => {
              const tc = getTypeColor(ev.event_type);
              const going = rsvpCounts[ev.id] || 0;
              return (
                <a href={`/events/${ev.id}`} class="mini" data-type={ev.event_type}>
                  <div class="mini-date">
                    <div class="mini-day-name" style={`color: ${tc.accent};`}>{(ev.event_month || 'TBD').slice(0,3)}</div>
                    <div class="mini-day-num">{ev.event_day || '—'}</div>
                  </div>
                  <div class="mini-info">
                    <div class="mini-title">{ev.title}</div>
                    <div class="mini-sub">
                      {ev.zone || ev.location || 'Denver'} · {going} going · {priceLabel(ev)}
                    </div>
                    {eventMatchesUser(ev.event_type) && <span class="mini-match">✨ For you</span>}
                    {isHotEvent(ev) && <span class="mini-hot">🔥 Filling up</span>}
                  </div>
                  <div class="mini-emoji">{typeEmoji[ev.event_type] || '📅'}</div>
                </a>
              );
            })}
          </div>
        )}

        <!-- SUGGEST CTA -->
        <div class="mag-suggest">
          <div class="mag-suggest-icon">💡</div>
          <div class="mag-suggest-text">
            <strong>Don't see what you want?</strong>
            <span>Post your own — takes 30 seconds, no account required.</span>
          </div>
          <button class="mag-suggest-btn" id="suggestCta">Post one →</button>
        </div>
      </div>
    )}

    <!-- DISCORD CTA -->
    <div class="mag-discord">
      <span class="mag-discord-icon">💬</span>
      <div class="mag-discord-text">
        <strong>Plans happen in Discord first</strong>
        <span>88 locals and growing</span>
      </div>
      <a href="https://discord.gg/S8SFNkdSgK" class="mag-discord-btn" target="_blank" rel="noopener">Join →</a>
    </div>
  </div>

  <!-- FAB — floating button to create an event (everyone) -->
  <button class="ev-fab" id="fabCreate" title="Post an Event">
    <span class="ev-fab-icon">+</span>
    <span class="ev-fab-label">Post Event</span>
  </button>

  <!-- ═══ SUGGEST PATH — one-box-at-a-time wizard ═══ -->
  <div id="suggestPath" class="path" style="display:none;">
    <button class="path-back" id="suggestBack">← Back to events</button>

    <div class="wiz-container">
      <div class="wiz-card">
        <div class="wiz-progress">
          <div class="wiz-progress-fill" id="wizProgress" style="width:20%;"></div>
        </div>

        <div class="wiz-step" id="wizStep1">
          <div class="wiz-step-icon">💡</div>
          <div class="wiz-num">Step 1 of 4</div>
          <h2 class="wiz-q">What do you want to do?</h2>
          <p class="wiz-hint">Pick a vibe, then name it. No account needed.</p>
          <select id="wizType" class="wiz-select">
            <option value="dinner">🍽️ Dinner</option>
            <option value="brewery">🍺 Brewery</option>
            <option value="outdoor">🏔️ Outdoor</option>
            <option value="game_night">🎳 Game Night</option>
            <option value="coffee">☕ Coffee</option>
            <option value="arts">🎨 Arts</option>
            <option value="music">🎵 Music</option>
            <option value="social" selected>🎉 Social</option>
            <option value="sports">🏒 Sports</option>
            <option value="group_tickets">🎫 Group Tickets</option>
            <option value="camping">🏕️ Camping</option>
            <option value="bowling">🎳 Bowling</option>
            <option value="active">🧗 Active</option>
            <option value="casino">🎰 Casino</option>
            <option value="food_trucks">🌮 Food Trucks</option>
            <option value="potluck">🍲 Potluck</option>
            <option value="other">📅 Other</option>
          </select>
          <div class="wiz-subcats" id="wizSubcats"></div>
          <div class="wiz-suggestions" id="wizSuggestions"></div>
          <input type="text" id="wizTitle" class="wiz-input" placeholder="or type your own name..." maxlength="100" />
          <button class="wiz-next" id="wizNext1">Next →</button>
          <div class="wiz-err" id="wizErr1"></div>
        </div>

        <div class="wiz-step" id="wizStep2" style="display:none;">
          <div class="wiz-step-icon">📍</div>
          <div class="wiz-num">Step 2 of 4</div>
          <h2 class="wiz-q">When & where?</h2>
          <p class="wiz-hint">Doesn't need to be exact — a rough idea helps.</p>
          <label class="wiz-label">When should it happen?</label>
          <div class="wiz-type-grid wiz-when-grid">
            <button class="wiz-pill-btn" data-field="date" data-val="weeknight">Weeknight</button>
            <button class="wiz-pill-btn" data-field="date" data-val="friday">Friday</button>
            <button class="wiz-pill-btn" data-field="date" data-val="saturday">Saturday</button>
            <button class="wiz-pill-btn" data-field="date" data-val="sunday">Sunday</button>
            <button class="wiz-pill-btn" data-field="date" data-val="flexible">Flexible</button>
          </div>
          <label class="wiz-label" style="margin-top:18px;">Where in Denver?</label>
          <div class="wiz-type-grid wiz-where-grid">
            <button class="wiz-pill-btn" data-field="location" data-val="RiNo">RiNo</button>
            <button class="wiz-pill-btn" data-field="location" data-val="Cap Hill">Cap Hill</button>
            <button class="wiz-pill-btn" data-field="location" data-val="Highlands">Highlands</button>
            <button class="wiz-pill-btn" data-field="location" data-val="LoDo">LoDo</button>
            <button class="wiz-pill-btn" data-field="location" data-val="South Denver">South Denver</button>
            <button class="wiz-pill-btn" data-field="location" data-val="Aurora">Aurora</button>
            <button class="wiz-pill-btn" data-field="location" data-val="Lakewood">Lakewood</button>
            <button class="wiz-pill-btn" data-field="location" data-val="Anywhere">Anywhere</button>
          </div>
          <label class="wiz-label" style="margin-top:18px;" id="wizVenueLabel">Specific spot?</label>
          <div class="wiz-suggestions" id="wizVenueSuggestions"></div>
          <input type="text" id="wizVenue" class="wiz-input" placeholder="e.g. Uncle, Guard & Grace, Punch Bowl Social..." maxlength="120" style="border-radius:14px;" />
          <label class="wiz-label" style="margin-top:14px;">Link <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:11px;color:#9CA3AF;">(optional)</span></label>
          <input type="url" id="wizLink" class="wiz-input" placeholder="https://..." maxlength="300" style="border-radius:14px;" />
          <button class="wiz-next" id="wizNext2">Next →</button>
        </div>

        <div class="wiz-step" id="wizStep3" style="display:none;">
          <div class="wiz-step-icon">👥</div>
          <div class="wiz-num">Step 3 of 4</div>
          <h2 class="wiz-q">Budget & group size</h2>
          <p class="wiz-hint">Helps people know what to expect.</p>
          <label class="wiz-label">Price per person</label>
          <div class="wiz-type-grid wiz-budget-grid">
            <button class="wiz-pill-btn" data-field="budget" data-val="Free">Free</button>
            <button class="wiz-pill-btn" data-field="budget" data-val="$1–10">$1–10</button>
            <button class="wiz-pill-btn" data-field="budget" data-val="$10–25">$10–25</button>
            <button class="wiz-pill-btn" data-field="budget" data-val="$25–50">$25–50</button>
            <button class="wiz-pill-btn" data-field="budget" data-val="$50+">$50+</button>
          </div>
          <label class="wiz-label" style="margin-top:18px;">Ideal group size</label>
          <div class="wiz-type-grid wiz-size-grid">
            <button class="wiz-pill-btn" data-field="group_size" data-val="Small (4–6)">Small (4–6)</button>
            <button class="wiz-pill-btn" data-field="group_size" data-val="Medium (8–12)">Medium (8–12)</button>
            <button class="wiz-pill-btn" data-field="group_size" data-val="Large (15+)">Large (15+)</button>
            <button class="wiz-pill-btn" data-field="group_size" data-val="Any size">Any size</button>
          </div>
          <button class="wiz-next" id="wizNext3">Next →</button>
        </div>

        <div class="wiz-step" id="wizStep4" style="display:none;">
          <div class="wiz-step-icon">✍️</div>
          <div class="wiz-num">Step 4 of 4</div>
          <h2 class="wiz-q">Almost done!</h2>
          <p class="wiz-hint">Add a quick description so people know what to expect.</p>
          <textarea id="wizDesc" class="wiz-textarea" placeholder="e.g. Meet at Sloan's Lake, bring a frisbee, we'll grab beers after..." rows="3" maxlength="300"></textarea>
          {!isLoggedIn && (
            <div class="wiz-identity">
              <div class="wiz-identity-header">
                <span class="wiz-identity-wave">👋</span>
                <div>
                  <strong class="wiz-identity-title">Join the crew</strong>
                  <span class="wiz-identity-sub">Drop your name and you're in. That's it.</span>
                </div>
              </div>
              <input type="text" id="wizName" class="wiz-input" placeholder="First name" maxlength="60" style="margin-bottom:10px;" />
              <input type="email" id="wizEmail" class="wiz-input" placeholder="Email (keeps your spot)" maxlength="120" />
              <p class="wiz-identity-note">No passwords, no spam. You'll be part of Denver Social.</p>
            </div>
          )}
          {isAdmin && (
            <div class="wiz-mode-toggle">
              <button type="button" class="wiz-mode-btn selected" id="wizModeLive" data-mode="live">🚀 Make it live</button>
              <button type="button" class="wiz-mode-btn" id="wizModeSuggest" data-mode="suggest">💡 Suggest for voting</button>
            </div>
          )}
          <button class="wiz-submit" id="wizSubmit">{isAdmin ? 'Create Event' : 'Post Event'}</button>
          <div class="wiz-err" id="wizErr4"></div>
        </div>

        <div class="wiz-step wiz-done" id="wizStep5" style="display:none;">
          <div class="wiz-done-icon" id="wizDoneIcon">🎉</div>
          <h2 class="wiz-q" id="wizDoneTitle">Submitted!</h2>
          <p class="wiz-hint" id="wizDoneHint">Thanks for making Denver more fun.</p>
          <div class="wiz-welcome-card" id="wizWelcome" style="display:none;">
            <span class="wiz-welcome-badge">You're in</span>
            <p class="wiz-welcome-text">You're now part of Denver Social. Browse events, RSVP, and suggest more ideas anytime.</p>
          </div>
          <div class="wiz-done-btns">
            <button class="wiz-next" id="wizAnother">Post Another</button>
            <button class="wiz-ghost" id="wizBrowse">Browse Events →</button>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<style is:inline>
  /* ═══ PAGE ═══ */
  .ev-page { max-width: 640px; margin: 0 auto; padding: 0 20px 40px; }

  .path { animation: fadeUp .3s ease; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .path-back {
    display: inline-flex; align-items: center; gap: 4px;
