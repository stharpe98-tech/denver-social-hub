---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getLevel } from '../lib/levels';

const db = getDB();
let members: any[] = [];
try {
  if (db) {
    const r = await db.prepare("SELECT m.id,m.name,m.email,m.neighborhood,m.points,m.role,s.current_streak,s.total_events FROM members m LEFT JOIN member_streaks s ON m.email=s.email WHERE m.name IS NOT NULL AND m.name!='' ORDER BY m.points DESC LIMIT 50").all();
    members = r?.results || [];
  }
} catch {}
const tab = Astro.url.searchParams.get("tab") || "members";
const colors = ["#3b82f6","#8b5cf6","#ec4899","#f59e0b","#10b981","#ef4444","#6366f1"];
---
<Base title="The Crew">
  <div style="max-width:600px;margin:0 auto;padding:24px 20px">
    <div style="text-align:center;margin-bottom:16px">
      <div style="font-size:36px">👥</div>
      <h1 style="font-size:28px;color:#fff;margin-bottom:4px">The Crew</h1>
      <p class="muted" style="font-size:13px">Denver locals building something real together.</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:center;margin-bottom:20px">
      <a href="/members" style={`padding:10px 16px;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;${tab==='members'?'background:#3b82f6;color:#fff':'background:rgba(255,255,255,.04);color:#6b7a8e'}`}>👥 Members</a>
      <a href="/members?tab=regulars" style={`padding:10px 16px;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;${tab==='regulars'?'background:#3b82f6;color:#fff':'background:rgba(255,255,255,.04);color:#6b7a8e'}`}>🏆 Regulars</a>
    </div>
    <div style="display:flex;flex-direction:column;gap:8px">
      {members.map((m, i) => {
        const lvl = getLevel(m.total_events||0);
        return (
          <div style="display:flex;gap:12px;align-items:center;padding:14px 16px;border-radius:14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06)">
            <div style={`width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;background:${colors[i%colors.length]};flex-shrink:0`}>{(m.name||'?')[0]}</div>
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                <b style="font-family:'Instrument Serif',serif;font-size:16px;color:#fff;font-weight:400">{m.name}</b>
                {m.role==='admin' && <span style="font-size:10px;padding:2px 8px;border-radius:6px;background:rgba(74,222,128,.1);color:#4ade80;font-weight:700">Organizer</span>}
                {lvl.number>1 && <span style={`font-size:10px;padding:2px 8px;border-radius:6px;background:${lvl.color}22;color:${lvl.color};font-weight:700`}>{lvl.emoji} {lvl.name}</span>}
                {(m.current_streak||0)>=3 && <span style="font-size:10px;padding:2px 8px;border-radius:6px;background:rgba(251,191,36,.1);color:#fbbf24;font-weight:700">🔥{m.current_streak}</span>}
              </div>
              <div style="font-size:12px;color:#4a5568">{m.neighborhood||'Denver'}</div>
            </div>
            <div style="font-size:14px;color:#fbbf24;font-family:'Instrument Serif',serif">{m.points||0}pts</div>
          </div>
        );
      })}
      {members.length===0 && <p style="text-align:center;color:#4a5568;padding:40px">No members yet. Be the first!</p>}
    </div>
  </div>
</Base>
