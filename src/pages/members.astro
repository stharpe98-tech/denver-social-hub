---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';
import { getLevel } from '../lib/levels';
import { getContent } from '../lib/content';

const db = getDB();
let members: any[] = [];
let totalCount = 0;

try {
  if (db) {
    const result = await db.prepare(
      "SELECT id, name, neighborhood, interests, looking_for, bio, events_attended, joined_at, role FROM members WHERE suspended=0 ORDER BY events_attended DESC, joined_at ASC LIMIT 100"
    ).all();
    members = result.results || [];
    const countResult = await db.prepare("SELECT COUNT(*) as cnt FROM members WHERE suspended=0").first();
    totalCount = (countResult as any)?.cnt || members.length;
  }
} catch {}

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }
const isLoggedIn = !!user;
const content = await getContent();
---
<Base title="The Crew">
  <div style="max-width:680px;margin:0 auto;padding:24px 20px 60px">

    <div style="text-align:center;margin-bottom:32px">
      <h1 style="font-family:var(--heading);font-size:28px;font-weight:800;color:var(--text);margin-bottom:8px" set:html={content.members_title}>
      </h1>
      <p style="font-size:14px;color:var(--text-sec);line-height:1.6">
        {content.members_subtitle}
      </p>
    </div>

    {members.length === 0 ? (
      <div class="card" style="text-align:center;padding:48px 24px">
        <div style="font-size:48px;margin-bottom:12px">👋</div>
        <h3 style="font-family:var(--heading);font-size:18px;color:var(--text);margin-bottom:8px">Be the first to join!</h3>
        <p style="font-size:13px;color:var(--text-sec);margin-bottom:20px">Sign up and start suggesting events for the community.</p>
        <a href="/login?mode=join" class="btn btn-primary">Join Free →</a>
      </div>
    ) : (
      <div class="member-grid">
        {members.map((m: any) => {
          const level = getLevel(m.events_attended || 0);
          const interests = (m.interests || '').split(',').filter(Boolean).slice(0, 3);
          const joinDate = m.joined_at ? new Date(m.joined_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : '';
          const initial = (m.name || '?')[0].toUpperCase();
          return (
            <div class="member-card card">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
                <div class="member-avatar" style={`background:${level.color}15;border-color:${level.color}40`}>
                  <span>{level.emoji}</span>
                </div>
                <div style="flex:1;min-width:0">
                  <div style="display:flex;align-items:center;gap:6px">
                    <span style="font-family:var(--heading);font-size:15px;font-weight:700;color:var(--text)">{m.name}</span>
                    {m.role === 'admin' && <span class="member-badge-admin">Admin</span>}
                  </div>
                  <div style="font-size:12px;color:var(--text-faint)">
                    {m.neighborhood && <span>{m.neighborhood}</span>}
                    {m.neighborhood && joinDate && <span> · </span>}
                    {joinDate && <span>Joined {joinDate}</span>}
                  </div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px">
                <span style={`font-size:11px;font-weight:600;color:${level.color}`}>{level.name}</span>
                <span style="font-size:11px;color:var(--text-faint)">· {m.events_attended || 0} events</span>
              </div>
              {interests.length > 0 && (
                <div style="display:flex;flex-wrap:wrap;gap:4px">
                  {interests.map((tag: string) => (
                    <span class="member-tag">{tag.replace(/^[^\w\s]+\s*/, '')}</span>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}

    {!isLoggedIn && members.length > 0 && (
      <div style="text-align:center;margin-top:32px">
        <a href="/login?mode=join" class="btn btn-primary">Join the Crew →</a>
      </div>
    )}

  </div>
</Base>

<style is:inline>
  .member-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 520px) {
    .member-grid { grid-template-columns: 1fr 1fr; }
  }
  .member-card {
    padding: 16px !important;
  }
  .member-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; border: 2px solid;
    flex-shrink: 0;
  }
  .member-badge-admin {
    font-size: 10px; font-weight: 700; font-family: var(--heading);
    background: var(--accent-bg); color: var(--accent);
    padding: 2px 8px; border-radius: 50px;
  }
  .member-tag {
    font-size: 11px; padding: 3px 10px; border-radius: 50px;
    background: var(--tag-bg); color: var(--tag-text);
    font-weight: 500; white-space: nowrap;
  }
</style>
