---
import ActionRow from './ActionRow.astro';
export interface Props { profile: any; hostedEvents: any[]; templateData: Record<string, any>; links?: any[]; }
const { profile, templateData = {}, links = [] } = Astro.props;
const pups: any[] = Array.isArray(templateData.pups) ? templateData.pups : [];
const parks: string[] = Array.isArray(templateData.favorite_parks) ? templateData.favorite_parks.filter(Boolean) : [];
---
<div class="t11">
  <span class="pill">OFF-LEASH · SUNDAY MORNINGS</span>
  <h1>{profile.display_name}</h1>
  {profile.headline && <div class="caveat">~ {profile.headline} ~</div>}
  <ActionRow profile={profile} links={links} />
  {pups.length > 0 && (
    <div class="pups">
      <div class="h">— The regulars</div>
      <div class="pup-list">
        {pups.map(p => (
          <div class="pup">
            <div class="pup-av">{p.emoji || '🐶'}</div>
            <div class="pup-n">{p.name || ''}</div>
            <div class="pup-b">{p.breed || ''}</div>
          </div>
        ))}
      </div>
    </div>
  )}
  {profile.bio && <p class="bio">{profile.bio}</p>}
  {parks.length > 0 && (
    <div class="parks">
      <div class="h">— Favorite spots</div>
      <div class="parks-list">{parks.map((p, i) => <><strong>{p}</strong>{i < parks.length - 1 ? ' · ' : ''}</>)}</div>
    </div>
  )}
</div>
<style>
  .t11 { padding: 44px 32px; background: linear-gradient(160deg, #FDF4E1, #FFE7B5); color: #3D2918; border-radius: 18px; }
  .t11 .pill { display: inline-block; padding: 5px 12px; border-radius: 999px; font-size: 11px; font-weight: 800; letter-spacing: 1px; transform: rotate(-2deg); margin-bottom: 14px; background: #C97A45; color: #fff; }
  .t11 h1 { font-family: 'Playfair Display', serif; font-size: 34px; font-weight: 800; line-height: 1; margin-bottom: 6px; }
  .t11 .caveat { font-family: 'Caveat', cursive; color: #6B4D2E; font-size: 22px; display: inline-block; transform: rotate(-1deg); margin-bottom: 18px; }
  .t11 .pups { background: #fff; border-radius: 14px; padding: 18px; margin-bottom: 16px; }
  .t11 .h { font-size: 11px; letter-spacing: 2px; font-weight: 700; color: #C97A45; text-transform: uppercase; margin-bottom: 12px; }
  .t11 .pup-list { display: flex; gap: 16px; flex-wrap: wrap; }
  .t11 .pup { text-align: center; }
  .t11 .pup-av { width: 60px; height: 60px; border-radius: 50%; background: #FDF4E1; border: 2px solid #C97A45; display: flex; align-items: center; justify-content: center; font-size: 30px; margin-bottom: 6px; }
  .t11 .pup-n { font-weight: 800; font-size: 13px; color: #3D2918; }
  .t11 .pup-b { font-family: 'Caveat', cursive; font-size: 16px; color: #8B6B3E; }
  .t11 .bio { font-size: 15px; line-height: 1.6; margin-bottom: 16px; }
  .t11 .parks { background: rgba(255,255,255,0.5); padding: 12px 16px; border-radius: 10px; }
  .t11 .parks-list { font-size: 13px; }
  .t11 .parks-list strong { color: #C97A45; }
</style>
