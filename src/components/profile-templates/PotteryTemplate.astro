---
import ActionRow from './ActionRow.astro';
export interface Props { profile: any; hostedEvents: any[]; templateData: Record<string, any>; links?: any[]; }
const { profile, templateData = {}, links = [] } = Astro.props;
const gallery: any[] = Array.isArray(templateData.gallery) ? templateData.gallery.slice(0, 3) : [];
const classes: any[] = Array.isArray(templateData.classes) ? templateData.classes : [];
---
<div class="t4">
  {gallery.length > 0 && (
    <div class="gallery">
      {gallery.map((g, i) => (
        <div class={`tile tile-${i+1}`}>{g.emoji || '🏺'}<span class="cap">{g.caption || ''}</span></div>
      ))}
    </div>
  )}
  <div class="body">
    {(profile.neighborhood || templateData.studio_hours) && (
      <div class="eb">{[profile.neighborhood, templateData.studio_hours].filter(Boolean).join(' · ').toUpperCase()}</div>
    )}
    <h1>{profile.display_name}</h1>
    {profile.headline && <div class="caveat">~ {profile.headline} ~</div>}
    <ActionRow profile={profile} links={links} />
    {profile.bio && <p class="bio">{profile.bio}</p>}
    {classes.length > 0 && (
      <>
        <div class="h">— Classes & open studio</div>
        {classes.map(c => (
          <div class="class">
            <div><div class="class-t">{c.title}</div><div class="class-w">{c.when || ''}</div></div>
            {c.price_usd != null && <div class="class-p">${c.price_usd}</div>}
          </div>
        ))}
      </>
    )}
  </div>
</div>
<style>
  .t4 { background: #FBF4E5; border-radius: 18px; overflow: hidden; color: #2C2416; }
  .t4 .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .t4 .tile { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 56px; position: relative; }
  .t4 .tile-1 { background: linear-gradient(135deg, #D4A574, #B8895C); }
  .t4 .tile-2 { background: linear-gradient(135deg, #C9B89A, #A89878); }
  .t4 .tile-3 { background: linear-gradient(135deg, #E8D9C0, #C9B89A); color: #6B4423; }
  .t4 .cap { position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); font-family: 'Caveat', cursive; font-size: 16px; color: #fff; background: rgba(0,0,0,0.4); padding: 2px 10px; border-radius: 999px; white-space: nowrap; }
  .t4 .tile-3 .cap { color: #6B4423; background: rgba(255,255,255,0.7); }
  .t4 .body { padding: 36px 32px; }
  .t4 .eb { font-size: 11px; letter-spacing: 2px; font-weight: 700; text-transform: uppercase; margin-bottom: 8px; color: #C97A45; }
  .t4 h1 { font-family: 'Playfair Display', serif; font-size: 40px; font-weight: 800; line-height: 1; margin-bottom: 6px; }
  .t4 .caveat { font-family: 'Caveat', cursive; font-size: 22px; color: #8B6B2F; display: inline-block; transform: rotate(-1deg); margin-bottom: 22px; }
  .t4 .bio { font-size: 15px; line-height: 1.7; margin-bottom: 22px; max-width: 600px; }
  .t4 .h { font-size: 11px; letter-spacing: 2px; font-weight: 700; color: #C97A45; text-transform: uppercase; margin-bottom: 12px; }
  .t4 .class { display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 14px 18px; border-radius: 12px; margin-bottom: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); border-left: 4px solid #C97A45; }
  .t4 .class:nth-child(even) { border-left-color: #FF6B9D; }
  .t4 .class-t { font-weight: 700; font-size: 15px; }
  .t4 .class-w { font-family: 'Caveat', cursive; font-size: 17px; color: #8B6B2F; margin-top: 2px; }
  .t4 .class-p { background: #2C2416; color: #FFD93D; font-weight: 800; font-size: 15px; padding: 6px 14px; border-radius: 999px; transform: rotate(-2deg); }
  @media (max-width: 600px) { .t4 .gallery { grid-template-columns: 1fr 1fr; } .t4 .tile:nth-child(3) { display: none; } }
</style>
