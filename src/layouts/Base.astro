---
const { title = "Denver Social", description = "Real small-group events across the Denver metro." } = Astro.props;

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.email === "stharpe98@gmail.com";
const currentPath = Astro.url.pathname;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Denver Social</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-logo">DSN <span>Denver</span></a>

    <div class="nav-links">
      <a href="/discover"  class:list={["nav-link", { active: currentPath.startsWith("/discover")  }]}>Explore</a>
      <a href="/members"   class:list={["nav-link", { active: currentPath.startsWith("/members")   }]}>The Crew</a>
      <a href="/fund"      class:list={["nav-link", { active: currentPath.startsWith("/fund")      }]}>🤝 Fund</a>
      <a href="/about"     class:list={["nav-link", { active: currentPath.startsWith("/about")     }]}>About</a>
    </div>

    <div class="nav-auth">
      {user ? (
        <>
          <a href="/profile" class="nav-profile">My Profile</a>
          <a href="/api/logout" class="nav-cta" style="background:rgba(248,113,113,.15);color:#f87171;font-size:12px">Sign Out</a>
        </>
      ) : (
        <a href="/login" class="nav-cta">Join the Fun</a>
      )}
    </div>
  </nav>

  <slot />

  <div class="mob-nav">
    <div class="mob-nav-inner">
      <a href="/"         class:list={[{ active: currentPath === "/"                          }]}><span>🏠</span>Home</a>
      <a href="/discover" class:list={[{ active: currentPath.startsWith("/discover")          }]}><span>🔍</span>Explore</a>
      <a href="/members"  class:list={[{ active: currentPath.startsWith("/members")           }]}><span>👥</span>Crew</a>
      <a href="/fund"     class:list={[{ active: currentPath.startsWith("/fund")              }]}><span>🤝</span>Fund</a>
      <a href="/about"    class:list={[{ active: currentPath.startsWith("/about")             }]}><span>💬</span>About</a>
      {isAdmin && <a href="/admin" class:list={[{ active: currentPath.startsWith("/admin") }]}><span>⚙️</span>Admin</a>}

    </div>
  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-family: 'DM Sans', sans-serif; background: #05070d; color: #e8ecf4; }
  body { min-height: 100vh; padding-bottom: 80px; }

  /* ── Nav ── */
  .nav {
    padding: 14px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,.06);
    position: sticky; top: 0; z-index: 100;
    background: #05070deb;
    backdrop-filter: blur(20px);
  }
  .nav-logo { font-family: 'Instrument Serif', serif; font-size: 20px; color: #fff; text-decoration: none; }
  .nav-logo span { color: #4ade80; font-style: italic; }

  .nav-links {
    display: flex; gap: 28px; align-items: center;
    position: absolute; left: 50%; transform: translateX(-50%);
  }
  .nav-link { font-size: 14px; font-weight: 500; text-decoration: none; color: #6b7a8e; transition: color .2s; }
  .nav-link:hover, .nav-link.active { color: #fff; }
  @media (max-width: 900px) { .nav-links { display: none; } }

  .nav-auth { display: flex; gap: 8px; align-items: center; }
  .nav-auth a { font-size: 13px; font-weight: 600; text-decoration: none; padding: 7px 14px; border-radius: 50px; }
  .nav-profile { color: #fff; border: 1.5px solid rgba(255,255,255,.2); }
  .nav-cta { background: #3b82f6; color: #fff; }

  /* ── Mobile nav ── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: #05070df2; backdrop-filter: blur(24px);
    border-top: 1px solid rgba(255,255,255,.08);
    padding: 10px 0 max(10px, env(safe-area-inset-bottom));
  }
  .mob-nav-inner { display: flex; justify-content: space-around; align-items: center; max-width: 540px; margin: 0 auto; padding: 0 8px; }
  .mob-nav a { display: flex; flex-direction: column; align-items: center; gap: 3px; text-decoration: none; padding: 8px 6px; font-size: 11px; color: rgba(255,255,255,.4); font-weight: 700; border-radius: 12px; }
  .mob-nav a span { font-size: 22px; }
  .mob-nav a.active { color: #fff; background: rgba(96,165,250,.15); }
  @media (min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }

  /* ── Shared components ── */
  .card   { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.06); border-radius: 18px; padding: 24px; }
  .btn    { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 24px; border-radius: 12px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: 'DM Sans', sans-serif; text-decoration: none; border: none; }
  .btn-primary { background: #3b82f6; color: #fff; }
  .btn-ghost   { background: rgba(255,255,255,.04); color: #6b7a8e; border: 1px solid rgba(255,255,255,.08); }
  .input { width: 100%; padding: 14px 16px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; font-size: 15px; color: #e8ecf4; font-family: 'DM Sans', sans-serif; }
  .input::placeholder { color: #4a5568; }
  .input:focus { border-color: #3b82f6; outline: none; }
  .chip { display: inline-flex; align-items: center; gap: 6px; padding: 10px 16px; background: rgba(255,255,255,.04); border: 1.5px solid rgba(255,255,255,.06); border-radius: 14px; font-size: 13px; color: #e8ecf4; cursor: pointer; transition: border-color .2s; }
  .chip:hover  { border-color: rgba(255,255,255,.2); }
  .chip.selected { border-color: #3b82f6; background: rgba(59,130,246,.1); color: #60a5fa; }
  .muted { color: #6b7a8e; }
  a { color: inherit; }
  select, textarea { color: #e8ecf4; }
</style>
