---
const { title = "Denver Social", description = "Real small-group events across Denver. Show up, meet people." } = Astro.props;

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.role === 'admin' || user?.email === "stharpe98@gmail.com";
const currentPath = Astro.url.pathname;
const redditName = user?.reddit_username || user?.name;
// Tour is rendered only for signed-out visitors who haven't already
// dismissed it. The cookie is the source of truth — localStorage is a
// client-side fallback. Skipping the markup server-side means no
// flash-of-tour on subsequent visits and zero JS cost.
const tourSeen = Astro.cookies.get('dsn_tour_seen')?.value === '1';
const showWelcomeTour = !user && !tourSeen;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · Denver Social</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,700&family=Work+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Top nav -->
  <header class="site-header">
    <div class="site-header-inner">
      <button class="mob-hamburger" id="mob-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mob-drawer">
        <span></span><span></span><span></span>
      </button>

      <nav class="site-nav site-nav-left">
        <a href="/events" class:list={["site-nav-link", { active: currentPath.startsWith("/events") || currentPath.startsWith("/potlucks") }]}>Events</a>
        <a href="/neighborhoods" class:list={["site-nav-link", { active: currentPath.startsWith("/neighborhoods") }]}>Neighborhoods</a>
        <a href="/perks" class:list={["site-nav-link", { active: currentPath.startsWith("/perks") }]}>Perks</a>
      </nav>

      <a href="/" class="site-logo" aria-label="Denver Social home">
        <img src="/logo-light.svg" alt="Denver Social" class="site-logo-img" />
      </a>

      <nav class="site-nav site-nav-right">
        <a href="/about" class:list={["site-nav-link", { active: currentPath.startsWith("/about") }]}>About</a>
        <a href="/help"  class:list={["site-nav-link", { active: currentPath.startsWith("/help") }]}>Help</a>
        {isAdmin && (
          <a href="/admin/dashboard" class:list={["site-nav-link site-nav-admin", { active: currentPath.startsWith("/admin") }]}>⚙ Admin</a>
        )}
      </nav>

      <div class="site-auth">
        {user ? (
          <>
            <a href="/profile" class="site-user">
              <span class="site-user-name">{redditName ? `u/${redditName}` : 'Profile'}</span>
              {typeof user.karma === 'number' && <span class="site-user-karma">{user.karma} karma</span>}
            </a>
            <a href="/api/logout" class="site-logout">Sign out</a>
          </>
        ) : (
          <a href="/login" class="site-cta">Sign in</a>
        )}
      </div>
    </div>
  </header>

  <!-- Mobile drawer -->
  <div class="mob-backdrop" id="mob-backdrop" hidden></div>
  <aside class="mob-drawer" id="mob-drawer" hidden aria-label="Site menu">
    <div class="mob-drawer-head">
      <a href="/" class="mob-drawer-brand">
        <span>🌆</span><strong>Denver Social</strong>
      </a>
      <button class="mob-drawer-close" id="mob-drawer-close" aria-label="Close menu">×</button>
    </div>

    {user && (
      <a href="/profile" class="mob-drawer-user">
        <div class="mob-drawer-avatar">{(user.name || user.email || '?')[0]?.toUpperCase()}</div>
        <div>
          <strong>{user.name || (redditName ? `u/${redditName}` : 'Profile')}</strong>
          <span>View profile</span>
        </div>
      </a>
    )}

    <nav class="mob-drawer-nav">
      <a href="/" class:list={["mob-drawer-link", { active: currentPath === "/" }]}><span class="mob-drawer-icon">🏠</span>Home</a>
      <a href="/events" class:list={["mob-drawer-link", { active: currentPath.startsWith("/events") || currentPath.startsWith("/potlucks") || currentPath.startsWith("/calendar") }]}><span class="mob-drawer-icon">📅</span>Events</a>
      <a href="/neighborhoods" class:list={["mob-drawer-link", { active: currentPath.startsWith("/neighborhoods") }]}><span class="mob-drawer-icon">📍</span>Neighborhoods</a>
      <a href="/perks" class:list={["mob-drawer-link", { active: currentPath.startsWith("/perks") }]}><span class="mob-drawer-icon">🏪</span>Perks</a>
      {isAdmin && (
        <a href="/admin/dashboard" class:list={["mob-drawer-link mob-drawer-link-admin", { active: currentPath.startsWith("/admin") }]}><span class="mob-drawer-icon">⚙️</span>Admin</a>
      )}
    </nav>

    <div class="mob-drawer-foot">
      {user
        ? <a href="/api/logout" class="mob-drawer-cta mob-drawer-cta-ghost">Sign out</a>
        : <a href="/login" class="mob-drawer-cta">Sign in / sign up</a>}
    </div>
  </aside>

  <slot />

  <!-- Site footer -->
  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="footer-col footer-brand-col">
        <a href="/" class="footer-brand">
          <span class="footer-brand-icon" aria-hidden="true">🌆</span>
          <span class="footer-brand-name">Denver <span>Social</span></span>
        </a>
        <p class="footer-tagline">Show up. Meet people. That's it.</p>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Explore</div>
        <a href="/events">Events</a>
        <a href="/neighborhoods">Neighborhoods</a>
        <a href="/calendar">Shared calendar</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Community</div>
        <a href="/welcome">Say hi</a>
        <a href="/help-out">Help out / favors</a>
        <a href="/perks">Perks</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">About</div>
        <a href="/about">About</a>
        <a href="/help">Help & Safety</a>
        <a href="/contact">Contact us</a>
        {isAdmin && <a href="/admin/dashboard">Admin dashboard</a>}
      </div>
    </div>
    <div class="site-footer-bottom">
      <span>© {new Date().getFullYear()} Denver Social</span>
      <span class="footer-dot">·</span>
      <span>Made in Denver, CO 🏔</span>
    </div>
  </footer>

  {showWelcomeTour && (
    <div id="welcome-tour" class="wt-overlay" hidden>
      <div class="wt-modal" role="dialog" aria-modal="true" aria-labelledby="wt-title">
        <button class="wt-close" id="wt-close" aria-label="Close">×</button>

        <div class="wt-slide wt-slide-intro" data-step="0">
          <div class="wt-emoji">👋</div>
          <h2 id="wt-title">Hey. You new here?</h2>
          <p>This is where Denver people meet other Denver people. Hikes, dinners, game nights, brewery hops, whatever. You show up, you meet people, you go home. We promise it's less awkward than it sounds.</p>
          <div class="wt-actions">
            <button class="wt-btn wt-btn-primary" data-action="start">Show me around</button>
            <button class="wt-btn wt-btn-ghost" data-action="skip">I'm good, let me explore</button>
          </div>
        </div>

        <div class="wt-slide" data-step="1" hidden>
          <div class="wt-emoji">📅</div>
          <h2>Browse events</h2>
          <p>Head to <strong>Events</strong> to see what's happening this week. Filter by type (dinner, hike, brewery…) and pick something that fits your vibe.</p>
          <div class="wt-tip"><strong>Tip:</strong> "Vibe tags" like 🥤 Sober-friendly or 🤫 Introvert-friendly help you find the right room.</div>
        </div>

        <div class="wt-slide" data-step="2" hidden>
          <div class="wt-emoji">🎉</div>
          <h2>RSVP in one tap</h2>
          <p>Click any event and pick <strong>Going</strong>, <strong>Maybe</strong>, or <strong>Can't make it</strong>. Spots are limited — when an event fills up, you'll be auto-added to a waitlist if you still want in.</p>
          <div class="wt-tip"><strong>Add to calendar:</strong> RSVPed events give you Google and .ics one-click adds.</div>
        </div>

        <div class="wt-slide" data-step="3" hidden>
          <div class="wt-emoji">👥</div>
          <h2>Build your own circle</h2>
          <p>Make a <strong>Group</strong> for your trivia crew, hiking buddies, or dinner club. Invite-only or public — your call. Post events scoped just to that group.</p>
          <div class="wt-tip"><strong>Single-use invite links</strong> let you share carefully without random people slipping in.</div>
        </div>

        <div class="wt-slide" data-step="4" hidden>
          <div class="wt-emoji">🏆</div>
          <h2>Level up</h2>
          <p>Your <strong>profile</strong> tracks every hangout you've gone to. The more you show up, the higher you level — and Denver starts knowing your name.</p>
          <div class="wt-tip"><strong>Reliability score:</strong> show up to events you RSVPed for and your score climbs. Skip and it drops.</div>
        </div>

        <div class="wt-slide" data-step="5" hidden>
          <div class="wt-emoji">🚀</div>
          <h2>You're set</h2>
          <p>Sign up free with Discord and you can RSVP, host, and start your own groups. Or just keep browsing — no pressure.</p>
          <div class="wt-actions">
            <button class="wt-btn wt-btn-primary" data-action="signin">Sign in / sign up</button>
            <button class="wt-btn wt-btn-ghost" data-action="skip">Keep browsing</button>
          </div>
        </div>

        <div class="wt-footer" id="wt-footer" hidden>
          <button class="wt-step-btn" id="wt-prev" data-action="prev">← Back</button>
          <div class="wt-dots">
            <span class="wt-dot" data-dot="1"></span>
            <span class="wt-dot" data-dot="2"></span>
            <span class="wt-dot" data-dot="3"></span>
            <span class="wt-dot" data-dot="4"></span>
            <span class="wt-dot" data-dot="5"></span>
          </div>
          <button class="wt-step-btn wt-step-btn-primary" id="wt-next" data-action="next">Next →</button>
        </div>
      </div>
    </div>
  )}

  <script is:inline>
    (function() {
      var burger = document.getElementById('mob-hamburger');
      var drawer = document.getElementById('mob-drawer');
      var backdrop = document.getElementById('mob-backdrop');
      var closeBtn = document.getElementById('mob-drawer-close');
      if (!burger || !drawer || !backdrop) return;

      function open() {
        drawer.removeAttribute('hidden');
        backdrop.removeAttribute('hidden');
        burger.setAttribute('aria-expanded', 'true');
        document.body.classList.add('drawer-open');
        requestAnimationFrame(function() { drawer.classList.add('open'); backdrop.classList.add('open'); });
      }
      function close() {
        drawer.classList.remove('open');
        backdrop.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('drawer-open');
        setTimeout(function() {
          drawer.setAttribute('hidden', '');
          backdrop.setAttribute('hidden', '');
        }, 220);
      }
      burger.addEventListener('click', open);
      closeBtn && closeBtn.addEventListener('click', close);
      backdrop.addEventListener('click', close);
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });
    })();
  </script>

  {user && (
    <div id="mc-overlay" class="mc-overlay" hidden>
      <div class="mc-card" role="dialog" aria-modal="true">
        <button class="mc-close" id="mc-close" aria-label="Close">×</button>
        <div id="mc-body" class="mc-body">
          <div class="mc-loading">Loading…</div>
        </div>
      </div>
    </div>
  )}

  <script is:inline>
    (function() {
      var overlay = document.getElementById('mc-overlay');
      if (!overlay) return;
      var body = document.getElementById('mc-body');
      var closeBtn = document.getElementById('mc-close');

      function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
          return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
        });
      }

      function close() {
        overlay.setAttribute('hidden', '');
      }
      function open() {
        overlay.removeAttribute('hidden');
      }

      function fmtDate(iso) {
        if (!iso) return '';
        try {
          var d = new Date(iso);
          return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
        } catch (e) { return iso; }
      }

      function renderCard(data) {
        var m = data.member;
        var initial = (m.name || '?').charAt(0).toUpperCase();
        var html = '';
        html += '<div class="mc-avatar">' + escapeHtml(initial) + '</div>';
        html += '<h2 class="mc-name">' + escapeHtml(m.name) + '</h2>';
        var meta = [];
        if (m.extra_role) meta.push('<span class="mc-role">' + escapeHtml(m.extra_role) + '</span>');
        if (m.neighborhood) meta.push('📍 ' + escapeHtml(m.neighborhood));
        if (m.joined_at) meta.push('Member since ' + escapeHtml(fmtDate(m.joined_at)));
        if (meta.length) html += '<p class="mc-meta">' + meta.join(' · ') + '</p>';

        if (m.bio) {
          html += '<p class="mc-bio">"' + escapeHtml(m.bio) + '"</p>';
        }

        if (data.mutualGroups && data.mutualGroups.length) {
          html += '<div class="mc-mutuals"><span class="mc-label">Mutual groups</span><div class="mc-mutual-list">';
          data.mutualGroups.forEach(function(g) {
            html += '<a href="/groups/' + escapeHtml(g.slug) + '" class="mc-mutual">' + escapeHtml(g.name) + '</a>';
          });
          html += '</div></div>';
        }

        html += '<div class="mc-contact"><span class="mc-label">Email</span><span class="mc-email">' + escapeHtml(m.email) + '</span></div>';

        if (!data.isSelf) {
          html += '<div class="mc-actions">';
          html += '<button class="mc-btn mc-btn-primary" id="mc-msg" data-email="' + escapeHtml(m.email) + '">💬 Message</button>';

          var sent = data.phoneRequest && data.phoneRequest.sent;
          if (sent && sent.status === 'approved' && sent.shared_phone) {
            html += '<div class="mc-phone-ok">📱 ' + escapeHtml(sent.shared_phone) + '</div>';
          } else if (sent && sent.status === 'pending') {
            html += '<button class="mc-btn mc-btn-sec" disabled>📱 Phone requested</button>';
          } else if (sent && sent.status === 'declined') {
            html += '<button class="mc-btn mc-btn-sec" disabled>📱 Phone request declined</button>';
          } else {
            html += '<button class="mc-btn mc-btn-sec" id="mc-phone" data-email="' + escapeHtml(m.email) + '">📱 Request phone</button>';
          }
          html += '</div>';
        }

        body.innerHTML = html;

        var msgBtn = document.getElementById('mc-msg');
        msgBtn && msgBtn.addEventListener('click', async function() {
          var email = msgBtn.getAttribute('data-email');
          var r = await fetch('/api/dm', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ action: 'start', with: email }),
          });
          var d = await r.json();
          if (d.ok && d.id) window.location.href = '/messages/' + d.id;
          else alert('Failed: ' + (d.error || 'unknown'));
        });

        var phBtn = document.getElementById('mc-phone');
        phBtn && phBtn.addEventListener('click', async function() {
          var email = phBtn.getAttribute('data-email');
          var note = prompt('Optional note (e.g. "for the hike Saturday"):') || '';
          var r = await fetch('/api/phone-requests', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ action: 'request', to: email, note: note }),
          });
          var d = await r.json();
          if (d.ok) {
            alert('Sent. They can approve or decline from their profile.');
            close();
          } else {
            alert('Failed: ' + d.error);
          }
        });
      }

      async function showCard(email) {
        body.innerHTML = '<div class="mc-loading">Loading…</div>';
        open();
        try {
          var r = await fetch('/api/member-card?email=' + encodeURIComponent(email));
          var d = await r.json();
          if (d.ok) renderCard(d);
          else body.innerHTML = '<p class="mc-loading">Could not load member.</p>';
        } catch (e) {
          body.innerHTML = '<p class="mc-loading">Network error.</p>';
        }
      }

      // Delegate clicks on anything with [data-member-card]
      document.body.addEventListener('click', function(e) {
        var t = e.target;
        while (t && t !== document.body) {
          if (t.getAttribute && t.getAttribute('data-member-card')) {
            e.preventDefault();
            showCard(t.getAttribute('data-member-card'));
            return;
          }
          t = t.parentNode;
        }
      });

      closeBtn.addEventListener('click', close);
      overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });
    })();
  </script>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* Design tokens — Earth Studio: parchment surface, sage + terracotta
     accents, Cormorant Garamond display + Work Sans body. Quiet,
     ceramic-studio energy. */
  :root {
    /* Surface — parchment */
    --bg: #F5EFE3;
    --surface: #EDE6D6;
    --surface-hover: #E4DBC7;
    --border: #DDD2BB;
    --border-hover: #C9BCA0;

    /* Text — warm charcoal */
    --text: #2D2A24;
    --text-sec: #5C574E;
    --text-faint: #8A8478;

    /* Accents — sage primary, clay secondary */
    --accent: #6B8E5A;       /* sage green — primary identity */
    --accent-dim: rgba(107, 142, 90, 0.14);
    --accent-glow: rgba(107, 142, 90, 0.28);
    --accent2: #C66B3D;      /* terracotta */
    --accent2-dim: rgba(198, 107, 61, 0.14);
    --sunset: #C66B3D;       /* terracotta (legacy name kept for callouts) */
    --sunset-dim: rgba(198, 107, 61, 0.14);
    --pink: #B8553D;         /* deeper clay (legacy "pink" slot) */
    --pink-dim: rgba(184, 85, 61, 0.14);
    --mint: #6B8E5A;

    /* CTA — terracotta */
    --cta-bg: linear-gradient(135deg, #C66B3D, #B8553D);
    --cta-bg-solid: #C66B3D;
    --cta-text: #F5EFE3;
    --cta-glow: rgba(198, 107, 61, 0.32);

    /* Tags — earthy palette */
    --tag-bg: #E8D5A8;       /* cream */
    --tag-text: #6B5828;
    --tag-bg2: #E5D4C2;      /* sand */
    --tag-text2: #8B4A2B;
    --tag-bg3: #DDE6CC;      /* moss */
    --tag-text3: #4A6B3A;
    --tag-bg4: #E8D5A8;
    --tag-text4: #6B5828;

    /* Status */
    --green: #10B981;
    --green-dim: rgba(16, 185, 129, 0.10);
    --red: #DC2626;
    --red-dim: rgba(220, 38, 38, 0.10);
    --yellow: #D97706;
    --yellow-dim: rgba(217, 119, 6, 0.10);

    /* Type */
    --font: 'Work Sans', system-ui, sans-serif;
    --font-display: 'Cormorant Garamond', 'Work Sans', system-ui, serif;

    /* Shape */
    --radius: 14px;
    --radius-lg: 20px;
    --radius-pill: 50px;

    /* Shadow */
    --card-shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --card-shadow-lg: 0 4px 16px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);

    /* 4px spacing scale */
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;
    --space-6: 32px;
    --space-7: 48px;
    --space-8: 64px;
    --space-9: 96px;
  }

  html { font-family: var(--font); background: var(--bg); color: var(--text); scroll-behavior: smooth; }
  body { min-height: 100vh; -webkit-font-smoothing: antialiased; -webkit-overflow-scrolling: touch; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  button { font-family: var(--font); }
  h1, h2, h3 { font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; color: var(--text); }

  /* ── Site Header — dark slate, centered logo, nav split L/R ── */
  .site-header {
    position: sticky; top: 0; z-index: 200;
    background: rgba(15, 23, 42, 0.94); /* slate-900 */
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    height: 72px; display: flex; align-items: center;
  }
  .site-header-inner {
    width: 100%; max-width: 1200px; margin: 0 auto;
    padding: 0 var(--space-5);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
  }

  .site-nav { display: flex; gap: var(--space-1); align-items: center; }
  .site-nav-left { justify-self: end; }
  .site-nav-right { justify-self: start; }
  .site-nav-link {
    font-size: 14px; font-weight: 500;
    color: rgba(255,255,255,0.72);
    padding: 8px 14px; border-radius: 999px;
    transition: color 0.15s, background 0.15s; text-decoration: none;
    white-space: nowrap;
  }
  .site-nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }
  .site-nav-link:active { background: rgba(255,255,255,0.10); }
  .site-nav-link.active { color: var(--accent); background: rgba(14, 165, 233, 0.14); }
  .site-nav-admin {
    color: #c4b5fd; background: rgba(124,58,237,0.18);
    border: 1px solid rgba(124,58,237,0.35);
  }
  .site-nav-admin:hover { color: #fff; background: rgba(124,58,237,0.30); }

  .site-logo {
    display: inline-flex; align-items: center; gap: var(--space-2);
    text-decoration: none; flex-shrink: 0;
    justify-self: center;
    transition: opacity 0.15s, transform 0.15s;
  }
  .site-logo:hover { opacity: 0.92; transform: translateY(-1px); }
  .site-logo:active { opacity: 0.8; transform: none; }
  .site-logo-img {
    height: 44px; width: auto;
    display: block;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.35));
  }

  .site-auth { display: flex; align-items: center; gap: var(--space-2); justify-self: end; }
  .site-user {
    display: flex; flex-direction: column; align-items: flex-end;
    text-decoration: none; padding: 6px 12px; border-radius: 10px;
    transition: background 0.15s;
  }
  .site-user:hover { background: rgba(255,255,255,0.06); }
  .site-user-name { font-size: 13px; font-weight: 600; color: #fff; }
