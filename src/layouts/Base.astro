---
const { title = "Denver Social", description = "Real small-group events across the Denver metro." } = Astro.props;

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.email === "stharpe98@gmail.com";
const currentPath = Astro.url.pathname;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Denver Social</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-logo">Denver <em>Social</em></a>

    <div class="nav-links">
      <a href="/events"   class:list={["nav-link", { active: currentPath.startsWith("/events") && !currentPath.startsWith("/events/new") }]}>Events</a>
      <a href="/discover" class:list={["nav-link", { active: currentPath.startsWith("/discover") }]}>Discover</a>
      <a href="/members"  class:list={["nav-link", { active: currentPath.startsWith("/members")  }]}>The Crew</a>
      <a href="/about"    class:list={["nav-link", { active: currentPath.startsWith("/about")    }]}>About</a>
    </div>

    <div class="nav-auth">
      {user ? (
        <>
          <a href="/profile" class="nav-profile">My Profile</a>
          <a href="/api/logout" class="nav-logout">Sign Out</a>
        </>
      ) : (
        <a href="/login?mode=join" class="nav-cta">Join Free</a>
      )}
    </div>
  </nav>

  <slot />

  <!-- Bottom tab bar for mobile -->
  <div class="mob-nav">
    <div class="mob-nav-inner">
      <a href="/"        class:list={[{ active: currentPath === "/" }]}><span>🏠</span>Home</a>
      <a href="/events"  class:list={[{ active: currentPath.startsWith("/events") }]}><span>📅</span>Events</a>
      <a href="/discover" class:list={[{ active: currentPath.startsWith("/discover") }]}><span>🔍</span>Explore</a>
      <a href="/members" class:list={[{ active: currentPath.startsWith("/members") }]}><span>👥</span>Crew</a>
      <a href="/about"   class:list={[{ active: currentPath.startsWith("/about") }]}><span>💬</span>About</a>
      {isAdmin && <a href="/admin" class:list={[{ active: currentPath.startsWith("/admin") }]}><span>⚙️</span>Admin</a>}
    </div>
  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #FFFFFF;
    --surface: #F8F9FB;
    --surface-hover: #F0F2F5;
    --border: #E5E7EB;
    --border-hover: #D1D5DB;
    --text: #111827;
    --text-sec: #6B7280;
    --text-faint: #9CA3AF;
    --accent: #7C3AED;
    --accent-bg: rgba(124,58,237,0.06);
    --accent2: #3B82F6;
    --mint: #10B981;
    --card-shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --cta-bg: #7C3AED;
    --cta-text: #FFF;
    --tag-bg: #EEF2FF;
    --tag-text: #4338CA;
    --tag-bg2: #F0FDF4;
    --tag-text2: #047857;
    --vote-fill: linear-gradient(90deg, #7C3AED, #3B82F6);
    --badge-hot-bg: #FEF2F2;
    --badge-hot-text: #DC2626;
    --heading: 'Outfit', system-ui, sans-serif;
    --body: 'Inter', system-ui, sans-serif;
    --radius: 14px;
    --radius-lg: 20px;
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;
    --space-6: 32px;
    --space-7: 48px;
    --space-8: 64px;
    --space-9: 96px;
  }

  html { font-family: var(--body); background: var(--bg); color: var(--text); }
  body { min-height: 100vh; padding-bottom: 80px; -webkit-font-smoothing: antialiased; }
  a { color: inherit; }
  img { display: block; }

  /* ── Nav (light, top for desktop/tablet) ── */
  .nav {
    padding: 0 var(--space-6); height: 56px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,.92); backdrop-filter: blur(20px) saturate(1.4);
  }
  .nav-logo {
    font-family: var(--heading); font-weight: 800; font-size: 18px;
    color: var(--text); text-decoration: none; letter-spacing: -0.02em;
  }
  .nav-logo em { font-style: normal; color: var(--accent); }

  .nav-links {
    display: flex; gap: var(--space-1); align-items: center;
    position: absolute; left: 50%; transform: translateX(-50%);
  }
  .nav-link {
    font-family: var(--heading); font-size: 13px; font-weight: 500;
    text-decoration: none; color: var(--text-sec);
    padding: 6px 14px; border-radius: 8px; transition: all .2s;
  }
  .nav-link:hover { color: var(--text); background: var(--surface); }
  .nav-link.active { color: var(--accent); background: var(--accent-bg); }
  @media (max-width: 900px) { .nav-links { display: none; } .nav { padding: 0 20px; } }

  .nav-auth { display: flex; gap: var(--space-2); align-items: center; }
  .nav-auth a {
    font-family: var(--heading); font-size: 12px; font-weight: 600;
    text-decoration: none; padding: 7px 16px; border-radius: 50px; transition: all .2s;
  }
  .nav-profile { color: var(--text); border: 1px solid var(--border); }
  .nav-profile:hover { border-color: var(--border-hover); background: var(--surface); }
  .nav-logout { color: var(--text-faint); }
  .nav-logout:hover { color: #DC2626; }
  .nav-cta { background: var(--cta-bg); color: var(--cta-text) !important; }
  .nav-cta:hover { opacity: .9; }

  /* ── Bottom tab bar (mobile only) ── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: rgba(255,255,255,.95); backdrop-filter: blur(24px);
    border-top: 1px solid var(--border);
    padding: 6px 0 max(6px, env(safe-area-inset-bottom));
  }
  .mob-nav-inner {
    display: flex; justify-content: space-around; align-items: center;
    max-width: 540px; margin: 0 auto; padding: 0 var(--space-1);
  }
  .mob-nav a {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none; padding: 6px 10px; font-size: 10px;
    color: var(--text-faint); font-family: var(--heading); font-weight: 600;
    border-radius: 10px; transition: all .2s;
  }
  .mob-nav a span { font-size: 20px; }
  .mob-nav a.active { color: var(--accent); background: var(--accent-bg); }
  @media (min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }

  /* ── Shared components ── */
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: var(--space-5);
    box-shadow: var(--card-shadow); transition: all .2s;
  }
  .card:hover { border-color: var(--border-hover); }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
    padding: 11px 24px; border-radius: 50px; font-size: 13px; font-weight: 700;
    cursor: pointer; font-family: var(--heading); text-decoration: none; border: none;
    transition: all .2s;
  }
  .btn-primary { background: var(--cta-bg); color: var(--cta-text); }
  .btn-primary:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(124,58,237,0.2); }
  .btn-ghost { background: var(--surface); color: var(--text-sec); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }
  .input {
    width: 100%; padding: 11px 16px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 50px; font-size: 13px; color: var(--text); font-family: var(--body);
    transition: border-color .2s; outline: none;
  }
  .input::placeholder { color: var(--text-faint); }
  .input:focus { border-color: var(--accent); }

  /* ── Footer ── */
  .site-footer {
    padding: var(--space-6); border-top: 1px solid var(--border); text-align: center;
    margin-bottom: 60px;
  }
  .footer-brand { font-family: var(--heading); font-weight: 800; font-size: 16px; margin-bottom: var(--space-1); }
  .footer-brand em { font-style: normal; color: var(--accent); }
  .footer-text { font-size: 11px; color: var(--text-faint); }
</style>
