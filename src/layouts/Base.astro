---
const { title = "Denver Social", description = "Real small-group events across Denver. Show up, meet people." } = Astro.props;

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.role === 'admin' || user?.email === "stharpe98@gmail.com";
const currentPath = Astro.url.pathname;
const redditName = user?.reddit_username || user?.name;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · Denver Social</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Top nav -->
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">
        <span class="site-logo-icon">🏔</span>
        <span class="site-logo-text">Denver Social</span>
      </a>

      <nav class="site-nav">
        <a href="/events"   class:list={["site-nav-link", { active: currentPath.startsWith("/events") }]}>Events</a>
        <a href="/potlucks" class:list={["site-nav-link", { active: currentPath.startsWith("/potlucks") }]}>Potlucks</a>
        <a href="/recs"     class:list={["site-nav-link", { active: currentPath === "/recs" }]}>Recs</a>
        <a href="/about"    class:list={["site-nav-link", { active: currentPath.startsWith("/about") }]}>About</a>
      </nav>

      <div class="site-auth">
        {user ? (
          <>
            <a href="/profile" class="site-user">
              <span class="site-user-name">u/{redditName}</span>
              <span class="site-user-karma">{user.karma || 0} karma</span>
            </a>
            <a href="/api/logout" class="site-logout">Sign out</a>
          </>
        ) : (
          <a href="/login" class="site-cta">Sign in with Reddit</a>
        )}
      </div>
    </div>
  </header>

  <slot />

  <!-- Mobile bottom nav -->
  <nav class="mob-nav">
    <a href="/"        class:list={["mob-link", { active: currentPath === "/" }]}>
      <span class="mob-icon">🏠</span><span class="mob-label">Home</span>
    </a>
    <a href="/events"  class:list={["mob-link", { active: currentPath.startsWith("/events") }]}>
      <span class="mob-icon">📅</span><span class="mob-label">Events</span>
    </a>
    <a href="/potlucks" class:list={["mob-link", { active: currentPath.startsWith("/potlucks") }]}>
      <span class="mob-icon">🍽</span><span class="mob-label">Potlucks</span>
    </a>
    <a href="/recs"    class:list={["mob-link", { active: currentPath === "/recs" }]}>
      <span class="mob-icon">⭐</span><span class="mob-label">Recs</span>
    </a>
    {isAdmin && (
      <a href="/admin/dashboard" class:list={["mob-link", { active: currentPath.startsWith("/admin") }]}>
        <span class="mob-icon">⚙</span><span class="mob-label">Admin</span>
      </a>
    )}
  </nav>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f7f5f2;
    --surface: #ffffff;
    --surface-hover: #f0ede8;
    --border: #e4ddd4;
    --border-hover: #cec5b8;
    --text: #1c1917;
    --text-sec: #57524c;
    --text-faint: #a09890;
    --accent: #f77f00;
    --accent-dim: rgba(247,127,0,0.10);
    --accent-glow: rgba(247,127,0,0.22);
    --green: #16a34a;
    --green-dim: rgba(22,163,74,0.10);
    --red: #dc2626;
    --red-dim: rgba(220,38,38,0.10);
    --yellow: #d97706;
    --yellow-dim: rgba(217,119,6,0.10);
    --font: 'Inter', system-ui, sans-serif;
    --font-display: 'Playfair Display', Georgia, serif;
    --radius: 10px;
    --radius-lg: 16px;
    --radius-xl: 20px;
  }

  html { font-family: var(--font); background: var(--bg); color: var(--text); scroll-behavior: smooth; }
  body { min-height: 100vh; padding-bottom: 72px; -webkit-font-smoothing: antialiased; -webkit-overflow-scrolling: touch; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  button { font-family: var(--font); }

  /* ── Site Header ── */
  .site-header {
    position: sticky; top: 0; z-index: 200;
    background: rgba(247,245,242,0.94); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    height: 56px; display: flex; align-items: center;
  }
  .site-header-inner {
    width: 100%; max-width: 1100px; margin: 0 auto;
    padding: 0 20px; display: flex; align-items: center; gap: 16px;
  }

  .site-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; flex-shrink: 0; }
  .site-logo-icon { font-size: 22px; }
  .site-logo-text { font-size: 16px; font-weight: 700; color: var(--text); letter-spacing: -0.3px; }

  .site-nav { display: flex; gap: 4px; align-items: center; margin-left: 8px; }
  .site-nav-link {
    font-size: 14px; font-weight: 500; color: var(--text-faint);
    padding: 6px 12px; border-radius: var(--radius);
    transition: all 0.15s; text-decoration: none;
  }
  .site-nav-link:hover { color: var(--text-sec); background: var(--surface); }
  .site-nav-link.active { color: var(--accent); background: var(--accent-dim); }
  @media(max-width: 700px) { .site-nav { display: none; } }

  .site-auth { display: flex; align-items: center; gap: 10px; margin-left: auto; }
  .site-user { display: flex; flex-direction: column; align-items: flex-end; text-decoration: none; padding: 6px 10px; border-radius: var(--radius); transition: background 0.15s; }
  .site-user:hover { background: var(--surface); }
  .site-user-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .site-user-karma { font-size: 11px; color: var(--accent); font-weight: 500; }
  .site-logout { font-size: 12px; color: var(--text-faint); padding: 6px 10px; border-radius: var(--radius); transition: color 0.15s; }
  .site-logout:hover { color: var(--red); }
  .site-cta {
    font-size: 13px; font-weight: 600;
    background: var(--accent); color: #fff;
    padding: 8px 16px; border-radius: var(--radius);
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .site-cta:hover { opacity: 0.88; }
  @media(max-width: 500px) {
    .site-user-karma { display: none; }
    .site-cta { font-size: 12px; padding: 7px 12px; }
  }

  /* ── Mobile bottom nav ── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    background: rgba(247,245,242,0.97); backdrop-filter: blur(24px);
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-around; align-items: center;
    padding: 6px 0 max(6px, env(safe-area-inset-bottom));
    height: 56px;
  }
  .mob-link {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none; padding: 4px 10px;
    color: var(--text-faint); transition: color 0.15s;
    -webkit-tap-highlight-color: transparent;
    min-width: 48px;
  }
  .mob-link.active { color: var(--accent); }
  .mob-icon { font-size: 22px; line-height: 1; }
  .mob-label { font-size: 10px; font-weight: 500; }
  @media(min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }

  /* ── Shared components ── */
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 20px;
    transition: border-color 0.15s;
  }
  .card:hover { border-color: var(--border-hover); }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 20px; border-radius: var(--radius); font-size: 14px; font-weight: 600;
    cursor: pointer; text-decoration: none; border: none; transition: all 0.15s;
    font-family: var(--font); -webkit-tap-highlight-color: transparent;
  }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { opacity: 0.9; box-shadow: 0 4px 16px var(--accent-glow); }
  .btn-ghost { background: var(--surface); color: var(--text-sec); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }

  .input {
    width: 100%; padding: 11px 14px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); font-size: 14px; color: var(--text);
    font-family: var(--font); outline: none; transition: border-color 0.15s;
    -webkit-appearance: none; appearance: none;
  }
  .input::placeholder { color: var(--text-faint); }
  .input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }

  /* Tags */
  .tag {
    font-size: 11px; font-weight: 600;
    padding: 3px 8px; border-radius: 6px;
    display: inline-flex; align-items: center;
  }
  .tag-orange { background: var(--accent-dim); color: var(--accent); }
  .tag-green  { background: var(--green-dim);  color: var(--green);  }
  .tag-red    { background: var(--red-dim);    color: var(--red);    }
  .tag-yellow { background: var(--yellow-dim); color: var(--yellow); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--border-hover); }
  ::selection { background: var(--accent-dim); color: var(--accent); }

  /* Footer */
  .site-footer {
    padding: 32px 20px; border-top: 1px solid var(--border);
    text-align: center; margin-bottom: 72px;
  }
  .site-footer-brand { font-size: 14px; font-weight: 700; color: var(--text-sec); margin-bottom: 4px; }
  .site-footer-brand span { color: var(--accent); }
  .site-footer-text { font-size: 12px; color: var(--text-faint); }
</style>

