---
const { title = "Denver Social", description = "Real small-group events across Denver. Show up, meet people." } = Astro.props;

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.role === 'admin' || user?.email === "stharpe98@gmail.com";
const currentPath = Astro.url.pathname;
const redditName = user?.reddit_username || user?.name;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · Denver Social</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Top nav -->
  <header class="site-header">
    <div class="site-header-inner">
      <nav class="site-nav site-nav-left">
        <a href="/events" class:list={["site-nav-link", { active: currentPath.startsWith("/events") || currentPath.startsWith("/potlucks") }]}>Events</a>
        <a href="/groups" class:list={["site-nav-link", { active: currentPath.startsWith("/groups") }]}>Groups</a>
      </nav>

      <a href="/" class="site-logo" aria-label="Denver Social home">
        <img src="/logo-light.svg" alt="Denver Social" class="site-logo-img" />
      </a>

      <nav class="site-nav site-nav-right">
        <a href="/about" class:list={["site-nav-link", { active: currentPath.startsWith("/about") }]}>About</a>
        <a href="/help"  class:list={["site-nav-link", { active: currentPath.startsWith("/help") }]}>Help</a>
        {isAdmin && (
          <a href="/admin/dashboard" class:list={["site-nav-link site-nav-admin", { active: currentPath.startsWith("/admin") }]}>⚙ Admin</a>
        )}
      </nav>

      <div class="site-auth">
        {user ? (
          <>
            <a href="/profile" class="site-user">
              <span class="site-user-name">{redditName ? `u/${redditName}` : 'Profile'}</span>
              {typeof user.karma === 'number' && <span class="site-user-karma">{user.karma} karma</span>}
            </a>
            <a href="/api/logout" class="site-logout">Sign out</a>
          </>
        ) : (
          <a href="/login" class="site-cta">Sign in</a>
        )}
      </div>
    </div>
  </header>

  <slot />

  <!-- Site footer -->
  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="footer-col footer-brand-col">
        <a href="/" class="footer-brand">
          <span class="footer-brand-icon" aria-hidden="true">🌆</span>
          <span class="footer-brand-name">Denver <span>Social</span></span>
        </a>
        <p class="footer-tagline">No ads, no algorithms. Just locals meeting locals.</p>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Explore</div>
        <a href="/events">Events</a>
        <a href="/help">Help</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">About</div>
        <a href="/about">About</a>
        <a href="/conduct">Safety & terms</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Stay in touch</div>
        <a href="/contact">Contact us</a>
        <a href="/login">Sign in</a>
        {isAdmin && <a href="/admin/dashboard">Admin dashboard</a>}
      </div>
    </div>
    <div class="site-footer-bottom">
      <span>© {new Date().getFullYear()} Denver Social</span>
      <span class="footer-dot">·</span>
      <span>Made in Denver, CO 🏔</span>
    </div>
  </footer>

  <!-- Mobile bottom nav -->
  <nav class="mob-nav">
    <a href="/"        class:list={["mob-link", { active: currentPath === "/" }]}>
      <span class="mob-icon">🏠</span><span class="mob-label">Home</span>
    </a>
    <a href="/events"  class:list={["mob-link", { active: currentPath.startsWith("/events") || currentPath.startsWith("/potlucks") }]}>
      <span class="mob-icon">📅</span><span class="mob-label">Events</span>
    </a>
    <a href="/about" class:list={["mob-link", { active: currentPath.startsWith("/about") }]}>
      <span class="mob-icon">ℹ️</span><span class="mob-label">About</span>
    </a>
    <a href="/me"    class:list={["mob-link", { active: currentPath === "/me" || currentPath === "/profile" }]}>
      <span class="mob-icon">👤</span><span class="mob-label">Me</span>
    </a>
    {isAdmin && (
      <a href="/admin/dashboard" class:list={["mob-link", { active: currentPath.startsWith("/admin") }]}>
        <span class="mob-icon">⚙</span><span class="mob-label">Admin</span>
      </a>
    )}
  </nav>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* CLAUDE.md design tokens — Clean & Crisp light theme */
  :root {
    /* Surface */
    --bg: #FFFFFF;
    --surface: #F8F9FB;
    --surface-hover: #F0F2F5;
    --border: #E5E7EB;
    --border-hover: #D1D5DB;

    /* Text */
    --text: #111827;
    --text-sec: #6B7280;
    --text-faint: #9CA3AF;

    /* Accents */
    --accent: #0EA5E9;       /* sky blue primary */
    --accent-dim: rgba(14, 165, 233, 0.10);
    --accent-glow: rgba(14, 165, 233, 0.22);
    --accent2: #10B981;      /* emerald green secondary */
    --accent2-dim: rgba(16, 185, 129, 0.10);
    --mint: #10B981;         /* alias */

    /* CTA */
    --cta-bg: #0EA5E9;
    --cta-text: #FFFFFF;

    /* Tags */
    --tag-bg: #E0F2FE;       /* sky-100 */
    --tag-text: #0369A1;     /* sky-700 */
    --tag-bg2: #D1FAE5;      /* emerald-100 */
    --tag-text2: #047857;    /* emerald-700 */
    --tag-bg3: #FEF3C7;      /* amber-100 */
    --tag-text3: #92400E;    /* amber-800 */

    /* Status */
    --green: #10B981;
    --green-dim: rgba(16, 185, 129, 0.10);
    --red: #DC2626;
    --red-dim: rgba(220, 38, 38, 0.10);
    --yellow: #D97706;
    --yellow-dim: rgba(217, 119, 6, 0.10);

    /* Type */
    --font: 'Inter', system-ui, sans-serif;
    --font-display: 'Outfit', system-ui, sans-serif;

    /* Shape */
    --radius: 14px;
    --radius-lg: 20px;
    --radius-pill: 50px;

    /* Shadow */
    --card-shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --card-shadow-lg: 0 4px 16px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);

    /* 4px spacing scale */
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;
    --space-6: 32px;
    --space-7: 48px;
    --space-8: 64px;
    --space-9: 96px;
  }

  html { font-family: var(--font); background: var(--bg); color: var(--text); scroll-behavior: smooth; }
  body { min-height: 100vh; padding-bottom: 72px; -webkit-font-smoothing: antialiased; -webkit-overflow-scrolling: touch; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  button { font-family: var(--font); }
  h1, h2, h3 { font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; color: var(--text); }

  /* ── Site Header — dark slate, centered logo, nav split L/R ── */
  .site-header {
    position: sticky; top: 0; z-index: 200;
    background: rgba(15, 23, 42, 0.94); /* slate-900 */
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    height: 72px; display: flex; align-items: center;
  }
  .site-header-inner {
    width: 100%; max-width: 1200px; margin: 0 auto;
    padding: 0 var(--space-5);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
  }

  .site-nav { display: flex; gap: var(--space-1); align-items: center; }
  .site-nav-left { justify-self: end; }
  .site-nav-right { justify-self: start; }
  .site-nav-link {
    font-size: 14px; font-weight: 500;
    color: rgba(255,255,255,0.72);
    padding: 8px 14px; border-radius: 999px;
    transition: color 0.15s, background 0.15s; text-decoration: none;
    white-space: nowrap;
  }
  .site-nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }
  .site-nav-link:active { background: rgba(255,255,255,0.10); }
  .site-nav-link.active { color: var(--accent); background: rgba(14, 165, 233, 0.14); }
  .site-nav-admin {
    color: #c4b5fd; background: rgba(124,58,237,0.18);
    border: 1px solid rgba(124,58,237,0.35);
  }
  .site-nav-admin:hover { color: #fff; background: rgba(124,58,237,0.30); }

  .site-logo {
    display: inline-flex; align-items: center; gap: var(--space-2);
    text-decoration: none; flex-shrink: 0;
    justify-self: center;
    transition: opacity 0.15s, transform 0.15s;
  }
  .site-logo:hover { opacity: 0.92; transform: translateY(-1px); }
  .site-logo:active { opacity: 0.8; transform: none; }
  .site-logo-img {
    height: 44px; width: auto;
    display: block;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.35));
  }

  .site-auth { display: flex; align-items: center; gap: var(--space-2); justify-self: end; }
  .site-user {
    display: flex; flex-direction: column; align-items: flex-end;
    text-decoration: none; padding: 6px 12px; border-radius: 10px;
    transition: background 0.15s;
  }
  .site-user:hover { background: rgba(255,255,255,0.06); }
  .site-user-name { font-size: 13px; font-weight: 600; color: #fff; }
  .site-user-karma { font-size: 11px; color: var(--accent); font-weight: 600; }
  .site-logout {
    font-size: 13px; color: rgba(255,255,255,0.55);
    padding: 6px 10px; border-radius: 10px;
    transition: color 0.15s;
  }
  .site-logout:hover { color: #fff; }
  .site-cta {
    font-size: 14px; font-weight: 600;
    background: var(--cta-bg); color: var(--cta-text);
    padding: 10px 20px; border-radius: var(--radius-pill);
    transition: all 0.15s;
    white-space: nowrap;
    box-shadow: 0 1px 2px rgba(14,165,233,0.30);
  }
  .site-cta:hover { box-shadow: 0 4px 14px rgba(14,165,233,0.50); transform: translateY(-1px); }
  .site-cta:active { transform: translateY(0); }

  @media(max-width: 760px) {
    .site-nav { display: none; }
    .site-header-inner { grid-template-columns: 1fr auto 1fr; gap: var(--space-3); }
    .site-logo { grid-column: 2 / 3; }
    .site-auth { grid-column: 3 / 4; }
    .site-logo-img { height: 38px; }
  }
  @media(max-width: 500px) {
    .site-user-karma { display: none; }
    .site-cta { font-size: 13px; padding: 9px 16px; }
    .site-header-inner { padding: 0 var(--space-4); }
  }

  /* ── Mobile bottom nav ── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    background: rgba(255,255,255,0.96); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-around; align-items: center;
    padding: 6px 0 max(6px, env(safe-area-inset-bottom));
    height: 60px;
  }
  .mob-link {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none; padding: 4px 10px;
    color: var(--text-faint); transition: color 0.15s;
    -webkit-tap-highlight-color: transparent;
    min-width: 48px;
  }
  .mob-link.active { color: var(--accent); }
  .mob-icon { font-size: 22px; line-height: 1; }
  .mob-label { font-size: 10px; font-weight: 600; letter-spacing: 0.2px; }
  @media(min-width: 701px) { .mob-nav { display: none; } body { padding-bottom: 0; } }

  /* ── Shared components ── */
  .card {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: var(--space-5);
    box-shadow: var(--card-shadow);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .card:hover { box-shadow: var(--card-shadow-lg); border-color: var(--border-hover); }
  .card:active { transform: translateY(1px); }

  .btn-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 12px 24px; border-radius: var(--radius-pill);
    font-size: 15px; font-weight: 600;
    background: var(--cta-bg); color: var(--cta-text); border: none;
    cursor: pointer; text-decoration: none;
    box-shadow: 0 1px 3px rgba(14,165,233,0.25);
    transition: all 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .btn-cta:hover { box-shadow: 0 6px 20px rgba(14,165,233,0.35); transform: translateY(-1px); }
  .btn-cta:active { transform: translateY(0); box-shadow: 0 1px 3px rgba(14,165,233,0.25); }

  .btn-sec {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 12px 22px; border-radius: var(--radius-pill);
    font-size: 15px; font-weight: 600;
    background: var(--bg); color: var(--text); border: 1px solid var(--border);
    cursor: pointer; text-decoration: none; transition: all 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .btn-sec:hover { border-color: var(--border-hover); background: var(--surface); }
  .btn-sec:active { background: var(--surface-hover); }

  .input {
    width: 100%; padding: 12px 14px;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; font-size: 14px; color: var(--text);
    font-family: var(--font); outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    -webkit-appearance: none; appearance: none;
  }
  .input::placeholder { color: var(--text-faint); }
  .input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }

  /* Tags */
  .tag { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 999px; display: inline-flex; align-items: center; }
  .tag-blue   { background: var(--tag-bg);  color: var(--tag-text);  }
  .tag-green  { background: var(--tag-bg2); color: var(--tag-text2); }
  .tag-yellow { background: var(--tag-bg3); color: var(--tag-text3); }
  .tag-purple { background: var(--tag-bg); color: var(--tag-text); }     /* legacy alias → blue */
  .tag-orange { background: var(--tag-bg3); color: var(--tag-text3); }  /* legacy alias → yellow */
  .tag-red    { background: var(--red-dim); color: var(--red); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--border-hover); }
  ::selection { background: var(--accent-dim); color: var(--accent); }

  /* Footer */
  .site-footer {
    margin-top: var(--space-8);
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: var(--space-7) var(--space-5) var(--space-5);
    margin-bottom: 72px; /* room for mobile bottom nav */
  }
  .site-footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; gap: var(--space-6);
    grid-template-columns: 2fr 1fr 1fr 1fr;
  }
  .footer-col { display: flex; flex-direction: column; gap: var(--space-2); }
  .footer-col-title { font-size: 11px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: var(--space-1); }
  .footer-col a { font-size: 14px; color: var(--text-sec); transition: color 0.15s; }
  .footer-col a:hover { color: var(--accent); }

  .footer-brand { display: inline-flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-2); }
  .footer-brand-icon { font-size: 22px; }
  .footer-brand-name { font-family: var(--font-display); font-size: 18px; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
  .footer-brand-name span { color: var(--accent); }
  .footer-tagline { font-size: 13px; color: var(--text-sec); line-height: 1.55; max-width: 280px; }

  .site-footer-bottom {
    max-width: 1100px; margin: var(--space-6) auto 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
    display: flex; align-items: center; gap: var(--space-2);
    font-size: 12px; color: var(--text-faint);
    flex-wrap: wrap;
  }
  .footer-dot { color: var(--border-hover); }

  @media(min-width: 701px) {
    .site-footer { margin-bottom: 0; }
  }
  @media(max-width: 700px) {
    .site-footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand-col { grid-column: 1 / -1; }
  }
  @media(max-width: 420px) {
    .site-footer-inner { grid-template-columns: 1fr; }
    .footer-brand-col { grid-column: auto; }
  }
</style>
