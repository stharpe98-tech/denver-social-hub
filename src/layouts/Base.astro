---
const { title = "Denver Social", description = "Real small-group events across the Denver metro.", theme = "dark" } = Astro.props;

let user: any = null;
const cookie = Astro.cookies.get("dsn_user")?.value;
if (cookie) { try { user = JSON.parse(cookie); } catch {} }

const isAdmin = user?.email === "stharpe98@gmail.com";
const currentPath = Astro.url.pathname;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Denver Social</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
</head>
<body class:list={[`theme-${theme}`]}>
  <nav class="nav">
    <a href="/" class="nav-logo">Denver <span>Social</span></a>

    <div class="nav-links">
      <a href="/events"   class:list={["nav-link", { active: currentPath.startsWith("/events") && !currentPath.startsWith("/events/new") }]}>Events</a>
      <a href="/discover" class:list={["nav-link", { active: currentPath.startsWith("/discover") }]}>Discover</a>
      <a href="/members"  class:list={["nav-link", { active: currentPath.startsWith("/members")  }]}>The Crew</a>
      <a href="/about"    class:list={["nav-link", { active: currentPath.startsWith("/about")    }]}>About</a>
    </div>

    <div class="nav-auth">
      {user ? (
        <>
          <a href="/profile" class="nav-profile">My Profile</a>
          <a href="/api/logout" class="nav-logout">Sign Out</a>
        </>
      ) : (
        <a href="/login" class="nav-cta">Join Free</a>
      )}
    </div>
  </nav>

  <slot />

  <div class="mob-nav">
    <div class="mob-nav-inner">
      <a href="/"        class:list={[{ active: currentPath === "/" }]}><span>🏠</span>Home</a>
      <a href="/events"  class:list={[{ active: currentPath.startsWith("/events") }]}><span>📅</span>Events</a>
      <a href="/discover" class:list={[{ active: currentPath.startsWith("/discover") }]}><span>🔍</span>Explore</a>
      <a href="/members" class:list={[{ active: currentPath.startsWith("/members") }]}><span>👥</span>Crew</a>
      <a href="/about"   class:list={[{ active: currentPath.startsWith("/about") }]}><span>💬</span>About</a>
      {isAdmin && <a href="/admin" class:list={[{ active: currentPath.startsWith("/admin") }]}><span>⚙️</span>Admin</a>}
    </div>
  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #05070d;
    --bg-raised: rgba(255,255,255,.035);
    --bg-raised-hover: rgba(255,255,255,.055);
    --border: rgba(255,255,255,.07);
    --border-hover: rgba(255,255,255,.14);
    --text: #e8ecf4;
    --text-muted: #6b7a8e;
    --text-faint: #3d4654;
    --coral: #F05A28;
    --coral-dim: rgba(240,90,40,.1);
    --coral-2: #FF8A65;
    --green: #4ade80;
    --green-dim: rgba(74,222,128,.1);
    --blue: #3b82f6;
    --blue-dim: rgba(59,130,246,.1);
    --purple: #a855f7;
    --purple-dim: rgba(168,85,247,.12);
    --pink: #ec4899;
    --pink-dim: rgba(236,72,153,.12);
    --yellow: #fbbf24;
    --yellow-dim: rgba(251,191,36,.12);
    --gradient-party: linear-gradient(135deg, #F05A28 0%, #ec4899 50%, #a855f7 100%);
    --gradient-sunset: linear-gradient(135deg, #F05A28 0%, #fbbf24 100%);
    --gradient-dusk:   linear-gradient(135deg, #a855f7 0%, #3b82f6 100%);
    --wash-warm: radial-gradient(ellipse at 50% 100%, rgba(240,90,40,.12), transparent 60%);
    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'DM Sans', -apple-system, sans-serif;
    --radius: 14px;
    --radius-lg: 20px;
    --radius-xl: 28px;
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;
    --space-6: 32px;
    --space-7: 48px;
    --space-8: 64px;
    --space-9: 96px;

    /* ── Cream palette (opt-in via <Base theme="cream">) ── */
    --cream: #FFF8F1;
    --cream-raised: #FFFFFF;
    --cream-sunk: #FBEFE1;
    --ink: #1A1220;
    --ink-2: #4A3D50;
    --ink-faint: #8A7D92;
    --sky: #BAE6FD;
    --sky-deep: #7DD3FC;
    --border-cream: rgba(26,18,32,.08);
    --border-cream-hover: rgba(26,18,32,.16);

    /* ── Time-of-day gradients ── */
    --tod-morning: linear-gradient(135deg, #FFD4B8 0%, #FFE8D1 45%, #BAE6FD 100%);
    --tod-midday:  linear-gradient(135deg, #BAE6FD 0%, #E0F2FE 50%, #FEF9C3 100%);
    --tod-dusk:    linear-gradient(135deg, #F05A28 0%, #ec4899 50%, #a855f7 100%);
    --tod-night:   radial-gradient(ellipse at 30% 20%, #7c3aed 0%, transparent 55%),
                   radial-gradient(ellipse at 80% 80%, #ec4899 0%, transparent 50%),
                   linear-gradient(135deg, #1a0b2e 0%, #0b0618 100%);

    /* ── Theme-switchable vars (default = dark) ── */
    --nav-bg: rgba(5,7,13,.88);
    --nav-border: var(--border);
  }

  /* ── Cream theme overrides ── */
  body.theme-cream {
    --bg: var(--cream);
    --bg-raised: var(--cream-raised);
    --bg-raised-hover: #FFFFFF;
    --text: var(--ink);
    --text-muted: var(--ink-2);
    --text-faint: var(--ink-faint);
    --border: var(--border-cream);
    --border-hover: var(--border-cream-hover);
    --nav-bg: rgba(255,248,241,.82);
    --nav-border: rgba(26,18,32,.06);
    background:
      radial-gradient(ellipse 60% 40% at 88% 8%, rgba(240,90,40,.12), transparent 60%),
      radial-gradient(ellipse 55% 45% at 8% 92%, rgba(186,230,253,.28), transparent 60%),
      radial-gradient(ellipse 40% 30% at 95% 60%, rgba(236,72,153,.06), transparent 60%),
      var(--cream);
    background-attachment: fixed;
  }
  body.theme-cream::before {
    content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
    opacity: .35; mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180' viewBox='0 0 180 180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.4 0 0 0 0 0.3 0 0 0 0 0.3 0 0 0 0.25 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }
  body.theme-cream > * { position: relative; z-index: 1; }

  html { font-family: var(--sans); background: var(--bg); color: var(--text); }
  body { min-height: 100vh; padding-bottom: 80px; -webkit-font-smoothing: antialiased; }
  a { color: inherit; }

  /* ── Nav ── */
  .nav {
    padding: 0 32px; height: 56px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--nav-border);
    position: sticky; top: 0; z-index: 100;
    background: var(--nav-bg); backdrop-filter: blur(24px) saturate(1.4);
  }
  .nav-logo {
    font-family: var(--serif); font-size: 19px; color: var(--text); text-decoration: none;
    letter-spacing: -0.3px;
  }
  body.theme-dark .nav-logo { color: #fff; }
  .nav-logo span { color: var(--coral); font-style: italic; }
  body.theme-dark .nav-logo span { color: var(--green); }

  .nav-links {
    display: flex; gap: 6px; align-items: center;
    position: absolute; left: 50%; transform: translateX(-50%);
  }
  .nav-link {
    font-size: 13px; font-weight: 500; text-decoration: none; color: var(--text-muted);
    padding: 6px 14px; border-radius: 8px; transition: all .2s;
  }
  .nav-link:hover { color: var(--text); background: rgba(255,255,255,.04); }
  .nav-link.active { color: #fff; background: rgba(255,255,255,.07); }
  @media (max-width: 900px) { .nav-links { display: none; } .nav { padding: 0 20px; } }

  .nav-auth { display: flex; gap: 8px; align-items: center; }
  .nav-auth a { font-size: 12px; font-weight: 600; text-decoration: none; padding: 7px 16px; border-radius: 50px; transition: all .2s; }
  .nav-profile { color: var(--text); border: 1px solid var(--border); }
  .nav-profile:hover { border-color: var(--border-hover); }
  .nav-logout { color: var(--text-muted); }
  .nav-logout:hover { color: #f87171; }
  .nav-cta { background: var(--coral); color: #fff; box-shadow: 0 6px 16px rgba(240,90,40,.22); }
  .nav-cta:hover { background: #d94d1f; transform: translateY(-1px); box-shadow: 0 10px 22px rgba(240,90,40,.32); }

  /* ── Mobile nav ── */
  .mob-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: var(--nav-bg); backdrop-filter: blur(24px);
    border-top: 1px solid var(--nav-border);
    padding: 8px 0 max(8px, env(safe-area-inset-bottom));
  }
  .mob-nav-inner {
    display: flex; justify-content: space-around; align-items: center;
    max-width: 540px; margin: 0 auto; padding: 0 4px;
  }
  .mob-nav a {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none; padding: 6px 10px; font-size: 10px;
    color: var(--text-faint); font-weight: 600; border-radius: 10px;
    transition: all .2s;
  }
  .mob-nav a span { font-size: 20px; }
  .mob-nav a.active { color: var(--coral); background: var(--coral-dim); }
  body.theme-dark .mob-nav a.active { color: #fff; }
  .mob-nav a.active span { filter: none; }
  @media (min-width: 901px) { .mob-nav { display: none; } body { padding-bottom: 0; } }

  /* ── Shared components ── */
  .card {
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px;
    transition: border-color .2s;
  }
  .card:hover { border-color: var(--border-hover); }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 13px 24px; border-radius: 12px; font-size: 14px; font-weight: 700;
    cursor: pointer; font-family: var(--sans); text-decoration: none; border: none;
    transition: all .2s;
  }
  .btn-primary { background: var(--coral); color: #fff; }
  .btn-primary:hover { background: #d94d1f; transform: translateY(-1px); }
  .btn-ghost { background: var(--bg-raised); color: var(--text-muted); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }
  .input {
    width: 100%; padding: 13px 16px;
    background: rgba(255,255,255,.04); border: 1px solid var(--border);
    border-radius: 12px; font-size: 14px; color: var(--text); font-family: var(--sans);
    transition: border-color .2s;
  }
  .input::placeholder { color: var(--text-faint); }
  .input:focus { border-color: var(--coral); outline: none; }
  .chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 16px; background: var(--bg-raised); border: 1.5px solid var(--border);
    border-radius: var(--radius); font-size: 13px; color: var(--text);
    cursor: pointer; transition: all .2s;
  }
  .chip:hover { border-color: var(--border-hover); }
  .chip.selected { border-color: var(--coral); background: var(--coral-dim); color: var(--coral); }
  .muted { color: var(--text-muted); }
  select, textarea { color: var(--text); }

  /* ══════════════════════════════════════════════════════════════
     Shared components (carry design language across pages)
     ══════════════════════════════════════════════════════════════ */

  /* ── Party CTA — signature gradient pill ── */
  .btn-party {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-6); color: #fff;
    border-radius: 999px; font-size: 15px; font-weight: 700; letter-spacing: .2px;
    background: var(--gradient-party);
    background-size: 200% 100%; background-position: 0% 50%;
    box-shadow: 0 10px 28px rgba(240,90,40,.35), 0 0 0 1px rgba(255,255,255,.06) inset;
    border: none; cursor: pointer; text-decoration: none;
    font-family: var(--sans);
    transition: transform .2s cubic-bezier(.22,1,.36,1), box-shadow .3s, background-position .6s;
  }
  .btn-party:hover { transform: translateY(-2px) scale(1.02); background-position: 100% 50%; box-shadow: 0 16px 40px rgba(236,72,153,.45); }
  .btn-party:active { transform: translateY(0) scale(.99); }
  .btn-party-lg { padding: var(--space-4) var(--space-7); font-size: 16px; }

  .btn-ghost-lg {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--bg-raised); border: 1px solid var(--border);
    color: var(--text); border-radius: 999px; font-size: 15px; font-weight: 600;
    text-decoration: none; transition: all .2s;
  }
  .btn-ghost-lg:hover { background: var(--bg-raised-hover); border-color: var(--border-hover); transform: translateY(-1px); }
  .btn-ghost-lg:active { transform: translateY(0); }

  /* ── Floating sticker emojis ── */
  .sticker {
    position: absolute; font-size: 32px; line-height: 1;
    animation: bob 4s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(240,90,40,.25));
    pointer-events: none; user-select: none;
  }
  .sticker.s-delay-1 { animation-delay: .6s; }
  .sticker.s-delay-2 { animation-delay: 1.2s; }
  .sticker.s-delay-3 { animation-delay: 1.8s; }
  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(-12px) rotate(4deg); }
  }

  /* ── Category pill scroller (Meetup-style) ── */
  .categories-scroll {
    display: flex; gap: var(--space-3);
    padding: var(--space-2) var(--space-6) var(--space-5);
    overflow-x: auto; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .categories-scroll::-webkit-scrollbar { display: none; }
  .cat-pill {
    scroll-snap-align: start; flex: 0 0 auto;
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-5) var(--space-3) var(--space-3);
    background: color-mix(in srgb, var(--tint) 14%, var(--bg-raised));
    border: 1.5px solid color-mix(in srgb, var(--tint) 32%, transparent);
    border-radius: 999px; text-decoration: none;
    transition: transform .25s cubic-bezier(.22,1,.36,1), background .25s, border-color .25s;
  }
  .cat-pill:hover {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--tint) 22%, var(--bg-raised));
    border-color: color-mix(in srgb, var(--tint) 55%, transparent);
  }
  .cat-pill.active {
    background: color-mix(in srgb, var(--tint) 28%, var(--bg-raised));
    border-color: color-mix(in srgb, var(--tint) 70%, transparent);
  }
  .cat-pill:active { transform: translateY(0); }
  .cat-emoji {
    font-size: 24px; line-height: 1;
    width: 44px; height: 44px; border-radius: 50%;
    background: color-mix(in srgb, var(--tint) 28%, var(--bg-raised));
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .cat-text { display: flex; flex-direction: column; line-height: 1.2; }
  .cat-text strong { font-size: 14px; color: var(--text); font-weight: 700; }
  .cat-text small { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  /* ── Time-of-day event card ── */
  .tod-card {
    position: relative;
    display: grid; grid-template-columns: auto 1fr auto; gap: var(--space-4); align-items: center;
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg); text-decoration: none;
    color: var(--ink); overflow: hidden;
    box-shadow: 0 12px 32px rgba(240,90,40,.10);
    transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
    border: 1.5px solid transparent;
  }
  .tod-card::before {
    content: ''; position: absolute; inset: 0; z-index: 0;
    background: var(--tod-dusk); opacity: .18;
  }
  .tod-card[data-tod="morning"]::before { background: var(--tod-morning); opacity: .55; }
  .tod-card[data-tod="midday"]::before  { background: var(--tod-midday);  opacity: .55; }
  .tod-card[data-tod="dusk"]::before    { background: var(--tod-dusk);    opacity: .22; }
  .tod-card[data-tod="night"]::before   { background: var(--tod-night);   opacity: 1; }
  .tod-card > * { position: relative; z-index: 1; }
  .tod-card:hover { transform: translateY(-3px); box-shadow: 0 20px 48px rgba(236,72,153,.18); }

  .tod-card[data-tod="night"] { color: #fff; border-color: rgba(255,255,255,.08); box-shadow: 0 12px 32px rgba(124,58,237,.3); }
  .tod-card[data-tod="night"] .tod-meta,
  .tod-card[data-tod="night"] .tod-hype-count { color: rgba(255,255,255,.75); }

  .tod-date {
    text-align: center; padding: var(--space-2) var(--space-3); min-width: 60px;
    background: rgba(255,255,255,.7); border-radius: var(--radius);
    backdrop-filter: blur(8px);
  }
  .tod-card[data-tod="night"] .tod-date { background: rgba(255,255,255,.12); }
  .tod-month { display: block; font-size: 10px; font-weight: 800; color: var(--coral); text-transform: uppercase; letter-spacing: .1em; }
  .tod-card[data-tod="night"] .tod-month { color: #fbbf24; }
  .tod-day { display: block; font-family: var(--serif); font-size: 24px; color: var(--ink); line-height: 1.05; }
  .tod-card[data-tod="night"] .tod-day { color: #fff; }

  .tod-body { min-width: 0; }
  .tod-type-row { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-1); flex-wrap: wrap; }
  .tod-type-emoji { font-size: 14px; }
  .tod-type-label {
    font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .12em;
    color: var(--ink-2);
  }
  .tod-card[data-tod="night"] .tod-type-label { color: rgba(255,255,255,.7); }
  .tod-featured {
    font-size: 9px; font-weight: 800; padding: 2px var(--space-2); border-radius: 999px;
    background: var(--gradient-sunset); color: #fff; letter-spacing: .08em;
  }
  .tod-title { font-size: 16px; font-weight: 700; margin-bottom: var(--space-1); letter-spacing: -.2px; line-height: 1.2; }
  .tod-meta { font-size: 12px; color: var(--ink-2); }

  .tod-right { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-2); flex-shrink: 0; }
  .tod-hype {
    display: inline-flex; align-items: center; gap: var(--space-1);
    padding: var(--space-1) var(--space-3); border-radius: 999px;
    background: rgba(255,255,255,.7); backdrop-filter: blur(8px);
    font-size: 12px; font-weight: 700; color: var(--coral);
    border: none; cursor: pointer;
    transition: transform .2s, background .2s;
  }
  .tod-card[data-tod="night"] .tod-hype { background: rgba(255,255,255,.15); color: #fbbf24; }
  .tod-hype:hover { transform: scale(1.08); background: #fff; }
  .tod-card[data-tod="night"] .tod-hype:hover { background: rgba(255,255,255,.25); }
  .tod-hype.hyped { background: var(--gradient-party); color: #fff; }
  .tod-hype-icon { font-size: 14px; }

  .tod-price {
    font-size: 12px; font-weight: 700; color: var(--ink-2);
  }
  .tod-card[data-tod="night"] .tod-price { color: rgba(255,255,255,.85); }
  .tod-price.free { color: #059669; }
  .tod-card[data-tod="night"] .tod-price.free { color: #4ade80; }

  /* ── Fade-up scroll animation ── */
  .fade-up { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s cubic-bezier(.22,1,.36,1); }
  .fade-up.in { opacity: 1; transform: translateY(0); }

  /* ── Serif italic emphasis helper ── */
  .serif-em {
    font-family: var(--serif); font-style: italic;
    background: var(--gradient-party);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }

  @media (max-width: 640px) {
    .tod-card { grid-template-columns: auto 1fr; gap: var(--space-3); padding: var(--space-3) var(--space-4); }
    .tod-right { grid-column: 1 / -1; flex-direction: row; justify-content: space-between; align-items: center; }
    .categories-scroll { padding: var(--space-2) var(--space-4) var(--space-4); }
  }
</style>
