<script is:inline>
  (function() {
    var tour = document.getElementById('welcome-tour');
    if (!tour) return;
    try {
      if (localStorage.getItem('dsn_welcome_seen')) return;
    } catch (e) {}
    // Show after a brief delay so the page settles first
    setTimeout(function() { tour.removeAttribute('hidden'); }, 500);

    var slides = tour.querySelectorAll('.wt-slide');
    var footer = document.getElementById('wt-footer');
    var prevBtn = document.getElementById('wt-prev');
    var nextBtn = document.getElementById('wt-next');
    var closeBtn = document.getElementById('wt-close');
    var dots = tour.querySelectorAll('.wt-dot');
    var step = 0;
    var maxStep = slides.length - 1;

    function dismiss() {
      try { localStorage.setItem('dsn_welcome_seen', '1'); } catch (e) {}
      // Cookie is the source of truth — survives localStorage clears,
      // Safari private mode, etc. 1 year, root path.
      try {
        document.cookie = 'dsn_tour_seen=1; Path=/; Max-Age=31536000; SameSite=Lax';
      } catch (e) {}
      tour.setAttribute('hidden', '');
    }

    function show(n) {
      step = Math.max(0, Math.min(maxStep, n));
      slides.forEach(function(s, i) {
        if (i === step) s.removeAttribute('hidden');
        else s.setAttribute('hidden', '');
      });
      if (step >= 1 && step <= 5) {
        footer.removeAttribute('hidden');
        dots.forEach(function(d, i) {
          d.classList.toggle('active', i === step - 1);
        });
        prevBtn.disabled = step === 1;
        nextBtn.textContent = step === maxStep ? 'Done' : 'Next →';
      } else {
        footer.setAttribute('hidden', '');
      }
    }

    tour.addEventListener('click', function(e) {
      // Backdrop click closes
      if (e.target === tour) { dismiss(); return; }
      // Walk up to find the nearest [data-action] — tap targets on
      // mobile can land on child spans inside a button
      var el = e.target;
      while (el && el !== tour) {
        var action = el.getAttribute && el.getAttribute('data-action');
        if (action) {
          if (action === 'start') show(1);
          else if (action === 'skip') dismiss();
          else if (action === 'signin') {
            dismiss();
            window.location.href = '/login';
          }
          else if (action === 'prev') show(step - 1);
          else if (action === 'next') {
            if (step === maxStep) dismiss();
            else show(step + 1);
          }
          return;
        }
        el = el.parentNode;
      }
    });
    closeBtn.addEventListener('click', dismiss);
    document.addEventListener('keydown', function(e) {
      if (tour.hasAttribute('hidden')) return;
      if (e.key === 'Escape') dismiss();
      else if (e.key === 'ArrowRight' && step >= 1 && step < maxStep) show(step + 1);
      else if (e.key === 'ArrowLeft' && step > 1) show(step - 1);
    });
  })();
</script>
